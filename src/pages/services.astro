---
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.worshipmetrics.com";
const SITE_URL = "https://worshipmetrics.com";
const R2 = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
const HERO_IMAGE = `${R2}/homepage/Team%20Collaboration%20hero.jpg`;
const PLAN_IMAGE = `${R2}/homepage/Invite%20Team%20Member.jpg`;
const RUN_IMAGE = `${R2}/homepage/Church%20Viewer.jpg`;
const TEAM_IMAGE = `${R2}/Tech%20Manager/WorshipMetrics%20Tech%20Manager%20Web-UI%20Panels.jpg`;

const views = [
  { title: "Plan view", body: "Build the service order, duplicate forward from last week, and keep every item in one timeline your team can understand." },
  { title: "Production view", body: "See every role, every timing cue, and every service item in the same operating picture instead of a stack of disconnected tools." },
  { title: "Run view", body: "Move through Sunday live with confidence, with volunteers following the same order the team planned earlier in the week." },
];

const planningBullets = [
  "Unlimited service plans and templates on Free Forever",
  "A planning layer pastors, volunteers, and the booth can all understand",
  "Duplicate-forward workflows for the Sundays that should feel familiar",
  "A shared plan that is useful before you ever turn on automation",
];

const volunteerBullets = [
  "Capability matching so the right people serve in the right positions",
  "Availability, blackouts, and assignment visibility in one workflow",
  "Faster replacement when somebody drops out late in the week",
  "A clean handoff into role-specific control panels for live Sunday",
];

const automationBullets = [
  "Timeline-synced show automation keeps the room in step",
  "Volunteer control panels run on any tablet or phone with only the controls that role needs",
  "Natural-language cue authoring helps teams build advanced production moments faster",
  "Automated macros and cue firing reduce how much the booth has to remember live",
];

const serviceRows = [
  ["Service Planning", "Included", "Included", "Included"],
  ["Volunteer Management", "Included", "Included", "Included"],
  ["Run mode", "Included", "Included", "Included"],
  ["Production automation engine", "No", "No", "Included"],
  ["Volunteer control panels", "No", "No", "Included"],
  ["Natural-language cue authoring", "No", "No", "Included"],
  ["Production intercom", "No", "No", "Included"],
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "WorshipMetrics Services",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web, iOS, Android",
  url: `${SITE_URL}/services`,
  image: HERO_IMAGE,
  description: "Plan your Sunday, share the work across your whole team, and grow into production automation when your ministry is ready.",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
    url: `${SITE_URL}/pricing`,
  },
};
---

<Layout
  title="Services"
  socialTitle="Worship Metrics Services"
  description="Plan your Sunday, share the work across your whole team, and grow into production automation when your ministry is ready."
  canonical="/services"
  ogImage={HERO_IMAGE}
  structuredData={structuredData}
>
  <Fragment slot="head">
    <link rel="preload" as="image" href={HERO_IMAGE} />
  </Fragment>

  <section class="bg-gradient-to-b from-indigo-50 via-white to-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)]">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Services</p>
        <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
          Plan the service. Share the work. Make Sunday easier.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-600 sm:text-xl">
          Services is the workflow that helps churches stop running Sunday out of scattered docs, memory, and group texts. Build the plan, assign the team, run the room, and invite more people into meaningful roles.
        </p>
        <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:flex-wrap sm:items-center">
          <a href={`${APP_URL}/sign-up`} class="btn-primary" data-wm-track="cta_click" data-wm-track-label="services_hero_get_started_free" data-wm-track-location="services_hero">Get started free</a>
          <a href="/pricing" class="btn-outline" data-wm-track="cta_click" data-wm-track-label="services_hero_see_pricing" data-wm-track-location="services_hero">See pricing</a>
          <a href="/av-club" class="btn-outline">Start an AV Club</a>
        </div>
        <p class="mt-4 text-sm text-slate-500">Free Forever gets the whole team into the workflow before you pay.</p>
      </div>

      <div class="overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-[0_24px_60px_rgba(15,23,42,0.12)]">
        <img src={HERO_IMAGE} alt="Services planning and team coordination view in WorshipMetrics" loading="eager" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">The three views</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">One mental model from planning to production.</h2>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {views.map(({ title, body }) => (
          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-8 shadow-sm">
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-indigo-600">{title}</p>
            <p class="mt-4 text-sm leading-relaxed text-slate-600 sm:text-base">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-2">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Plan with your team</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Give everybody the same plan before Sunday starts.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          Services is built around the reality that most churches repeat rhythms. Copy forward what worked, make the real changes, and give every person the same picture of what Sunday will require.
        </p>
        <ul class="mt-8 space-y-3">
          {planningBullets.map((item) => (
            <li class="flex items-start gap-3 text-sm text-slate-700 sm:text-base"><span class="mt-2 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-indigo-500"></span><span>{item}</span></li>
          ))}
        </ul>
      </div>
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src={PLAN_IMAGE} alt="Planning and assignment workflow in WorshipMetrics" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src={TEAM_IMAGE} alt="Volunteer control panels in WorshipMetrics" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Share the work</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Every volunteer gets a role. Every role gets the right panel.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          This is how churches stop asking one person to do everything. Services gives staff and volunteers clearer assignments, and the paid production engine gives each role a simpler live surface to work from.
        </p>
        <ul class="mt-8 space-y-3">
          {volunteerBullets.map((item) => (
            <li class="flex items-start gap-3 text-sm text-slate-700 sm:text-base"><span class="mt-2 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-indigo-500"></span><span>{item}</span></li>
          ))}
        </ul>
        <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
          <a href="/volunteers" class="btn-outline">See Volunteers</a>
          <a href="/av-club" class="btn-outline">This is how you build an AV Club</a>
          <a href="/av-team" class="btn-outline">See the seven role panels</a>
        </div>
      </div>
    </div>
  </section>

  <section id="automate" class="bg-slate-950 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl rounded-[2rem] border border-white/10 bg-white/5 p-8 shadow-2xl sm:p-12">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.95fr)]">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-300">Automate your Sunday</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">The paid tier turns the plan into a real production engine.</h2>
          <p class="mt-4 text-base leading-relaxed text-slate-300 sm:text-lg">
            When your church is ready, Pro stops being just a planning upgrade. It becomes the automation layer that helps cues fire on time, volunteers stay in sync, and the room run with less pressure on one operator.
          </p>
          <ul class="mt-8 space-y-3">
            {automationBullets.map((item) => (
              <li class="flex items-start gap-3 text-sm text-slate-200 sm:text-base"><span class="mt-2 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-indigo-400"></span><span>{item}</span></li>
            ))}
          </ul>
        </div>
        <div class="rounded-3xl border border-white/10 bg-slate-900/70 p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-slate-300">What changes when you automate</p>
          <div class="mt-6 space-y-4">
            {[
              "The service plan becomes an execution-ready rundown instead of a reference document.",
              "Automated show control sequences fire on cue so cameras, graphics, lighting, and switcher moves stay aligned.",
              "Every volunteer gets a dedicated control panel on any tablet, with exactly the buttons they need and nothing more.",
              "The booth spends less energy translating the plan and more energy serving the room well.",
            ].map((item) => (
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-sm leading-relaxed text-slate-200">{item}</div>
            ))}
          </div>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/pricing" class="btn-primary">See Pro pricing</a>
            <a href="/kb" class="btn-outline" style="border-color:rgba(255,255,255,0.16);color:#fff;">Technical setup guides</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-2">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Run Sunday live</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">A run-of-show that still works on Free Forever.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          The free workflow is not a teaser. It is a real way to get your team organized now. Then, when the ministry is ready for deeper live execution, the same workflow grows with you.
        </p>
        <div class="mt-8"><a href="/pricing" class="btn-primary">Compare plans</a></div>
      </div>
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src={RUN_IMAGE} alt="Live production and service execution view in WorshipMetrics" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Free Forever vs Pro</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Start with the whole team. Upgrade when the room is ready.</h2>
      </div>
      <div class="mt-10 overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <table class="w-full text-sm">
          <thead class="bg-slate-50 text-left">
            <tr>
              <th class="px-6 py-4 font-semibold text-slate-700">Services capability</th>
              <th class="px-6 py-4 font-semibold text-slate-700">Free Forever</th>
              <th class="px-6 py-4 font-semibold text-slate-700">Starter</th>
              <th class="px-6 py-4 font-semibold text-slate-700">Pro</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 bg-white">
            {serviceRows.map(([feature, free, starter, pro]) => (
              <tr>
                <td class="px-6 py-4 font-semibold text-slate-900">{feature}</td>
                <td class="px-6 py-4 text-slate-600">{free}</td>
                <td class="px-6 py-4 text-slate-600">{starter}</td>
                <td class="px-6 py-4 text-slate-600">{pro}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Start with the plan your team can actually use.</h2>
      <p class="mx-auto mt-4 max-w-3xl text-base leading-relaxed text-slate-600 sm:text-lg">
        Install Worship Metrics, invite the team, and build a service workflow that works before the room fills up. Then use it to grow an AV Club that can carry more of Sunday together.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row sm:flex-wrap">
        <a href={`${APP_URL}/sign-up`} class="btn-primary" data-wm-track="cta_click" data-wm-track-label="services_footer_get_started_free" data-wm-track-location="services_footer_cta">Get started free</a>
        <a href="/discovery-call" class="btn-outline" data-wm-track="cta_click" data-wm-track-label="services_footer_book_call" data-wm-track-location="services_footer_cta">Book a demo</a>
        <a href="/av-club" class="btn-outline">Start an AV Club</a>
      </div>
    </div>
  </section>
</Layout>
