---
import Layout from "../../layouts/Layout.astro";

const R2 = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
---

<Layout
  title="Church Community Platform"
  description="Launch a Discord-based digital campus for your church — with automations, YouTube chat sync, and guided onboarding."
  canonical="/solutions/church-community-platform"
>
  <!-- Hero -->
  <section class="bg-white px-6 py-20 sm:py-28">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-indigo-600">
        Church Community Platform
      </p>
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
        Build a digital home your congregation will actually use.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-600 sm:text-xl">
        We set up a Discord-based community platform for your church — with prayer channels,
        ministry spaces, YouTube chat sync, announcements, and member onboarding. All connected,
        all week long.
      </p>
      <div class="mt-8">
        <a
          href="/discovery-call"
          class="rounded-lg bg-indigo-600 px-7 py-3 text-base font-semibold text-white shadow-sm hover:bg-indigo-700 transition"
        >
          Book a discovery call
        </a>
      </div>
    </div>
  </section>

  <!-- Community visuals -->
  <section class="bg-slate-50 px-6 pb-8 sm:pb-12">
    <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img
          src={`${R2}/homepage/WorshipMetrics%20Discord%20Setup.jpg`}
          alt="WorshipMetrics Discord community setup"
          loading="lazy"
          decoding="async"
          class="aspect-[16/10] w-full object-cover"
        />
      </div>
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img
          src={`${R2}/homepage/Discord%20for%20Worship.jpg`}
          alt="Discord community for worship ministry"
          loading="lazy"
          decoding="async"
          class="aspect-[16/10] w-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- Why Discord -->
  <section class="bg-slate-50 px-6 py-20">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-center text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl mb-12">
        One digital home for your whole congregation.
      </h2>
      <div class="grid gap-8 sm:grid-cols-3">
        <div class="rounded-2xl bg-white p-8 shadow-sm border border-slate-100">
          <h3 class="text-lg font-bold text-slate-900 mb-3">Already where your people are</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Discord is free, works on every device, and is already understood by younger members.
            Your church gets a familiar platform with ministry-specific structure.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-8 shadow-sm border border-slate-100">
          <h3 class="text-lg font-bold text-slate-900 mb-3">More than announcements</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Prayer channels, small group spaces, volunteer coordination, new member onboarding, and
            live Sunday conversation — all in one place.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-8 shadow-sm border border-slate-100">
          <h3 class="text-lg font-bold text-slate-900 mb-3">WorshipMetrics handles the setup</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            We configure the server, build the automations, sync your YouTube chat, and connect
            your website. You get the ministry value without the technical lift.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing tiers -->
  <section class="bg-white px-6 py-20">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-center text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl mb-12">
        Choose your platform tier.
      </h2>
      <div class="grid gap-8 sm:grid-cols-3">
        <!-- Starter -->
        <div class="rounded-2xl border border-slate-200 p-8 flex flex-col">
          <p class="text-sm font-semibold uppercase tracking-widest text-slate-500 mb-2">Starter</p>
          <p class="text-4xl font-extrabold text-slate-900 mb-1">$299</p>
          <p class="text-sm text-slate-500 mb-6">one-time</p>
          <ul class="space-y-3 text-sm text-slate-700 flex-1">
            <li class="flex items-start gap-2">
              <span class="text-indigo-600 font-bold mt-0.5">&#10003;</span>
              Discord server template
            </li>
            <li class="flex items-start gap-2">
              <span class="text-indigo-600 font-bold mt-0.5">&#10003;</span>
              Basic roles and channels
            </li>
            <li class="flex items-start gap-2">
              <span class="text-indigo-600 font-bold mt-0.5">&#10003;</span>
              Welcome bot
            </li>
            <li class="flex items-start gap-2">
              <span class="text-indigo-600 font-bold mt-0.5">&#10003;</span>
              30-day email support
            </li>
          </ul>
          <a
            href="/discovery-call"
            class="mt-8 block rounded-lg border border-indigo-600 px-5 py-2.5 text-center text-sm font-semibold text-indigo-600 hover:bg-indigo-50 transition"
          >
            Get started
          </a>
        </div>

        <!-- Connected -->
        <div class="rounded-2xl border border-slate-200 p-8 flex flex-col">
          <p class="text-sm font-semibold uppercase tracking-widest text-slate-500 mb-2">Connected</p>
          <p class="text-4xl font-extrabold text-slate-900 mb-1">$599</p>
          <p class="text-sm text-slate-500 mb-6">one-time</p>
          <ul class="space-y-3 text-sm text-slate-700 flex-1">
            <li class="flex items-start gap-2">
              <span class="text-indigo-600 font-bold mt-0.5">&#10003;</span>
              Everything in Starter
            </li>
            <li class="flex items-start gap-2">
              <span class="text-indigo-600 font-bold mt-0.5">&#10003;</span>
              Website contact widget
            </li>
            <li class="flex items-start gap-2">
              <span class="text-indigo-600 font-bold mt-0.5">&#10003;</span>
              YouTube live chat mirror
            </li>
            <li class="flex items-start gap-2">
              <span class="text-indigo-600 font-bold mt-0.5">&#10003;</span>
              Custom branding
            </li>
          </ul>
          <a
            href="/discovery-call"
            class="mt-8 block rounded-lg border border-indigo-600 px-5 py-2.5 text-center text-sm font-semibold text-indigo-600 hover:bg-indigo-50 transition"
          >
            Get started
          </a>
        </div>

        <!-- Full Platform -->
        <div class="rounded-2xl border-2 border-indigo-600 bg-indigo-50 p-8 flex flex-col relative">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-indigo-600 px-4 py-1 text-xs font-bold text-white whitespace-nowrap">
            Most comprehensive
          </span>
          <p class="text-sm font-semibold uppercase tracking-widest text-indigo-600 mb-2">Full Platform</p>
          <p class="text-4xl font-extrabold text-slate-900 mb-1">$999</p>
          <p class="text-sm text-slate-500 mb-6">one-time</p>
          <ul class="space-y-3 text-sm text-slate-700 flex-1">
            <li class="flex items-start gap-2">
              <span class="text-indigo-600 font-bold mt-0.5">&#10003;</span>
              Everything in Connected
            </li>
            <li class="flex items-start gap-2">
              <span class="text-indigo-600 font-bold mt-0.5">&#10003;</span>
              WorshipMetrics dashboard integration
            </li>
            <li class="flex items-start gap-2">
              <span class="text-indigo-600 font-bold mt-0.5">&#10003;</span>
              Monthly automated reports
            </li>
            <li class="flex items-start gap-2">
              <span class="text-indigo-600 font-bold mt-0.5">&#10003;</span>
              90-day support
            </li>
            <li class="flex items-start gap-2">
              <span class="text-indigo-600 font-bold mt-0.5">&#10003;</span>
              1-hour staff training Zoom
            </li>
          </ul>
          <a
            href="/discovery-call"
            class="mt-8 block rounded-lg bg-indigo-600 px-5 py-2.5 text-center text-sm font-semibold text-white hover:bg-indigo-700 transition"
          >
            Get started
          </a>
        </div>
      </div>

      <!-- CTA below tiers -->
      <p class="mt-12 text-center text-slate-600">
        Not sure which tier fits your church?{" "}
        <a href="/discovery-call" class="font-semibold text-indigo-600 hover:text-indigo-700">
          Book a discovery call to design your platform &rarr;
        </a>
      </p>
    </div>
  </section>
</Layout>
