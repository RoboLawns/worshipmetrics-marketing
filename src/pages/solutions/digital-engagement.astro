---
import Layout from "../../layouts/Layout.astro";

const R2 = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
---

<Layout
  title="Church Digital Engagement Platform for Online Visitors"
  description="Welcome online church visitors, route prayer requests, and turn digital engagement into real pastoral follow-up with WorshipMetrics."
  canonical="/solutions/digital-engagement"
>
  <!-- Hero -->
  <section class="bg-white px-6 py-20 sm:py-28">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-indigo-600">
        Digital Engagement
      </p>
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
        Turn your online audience from unknown into known.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-600 sm:text-xl">
        Most churches have an online presence. Fewer have a system for turning anonymous attention
        into real pastoral relationships. WorshipMetrics helps bridge that gap.
      </p>
    </div>
  </section>

  <!-- Visual proof -->
  <section class="bg-white px-6 pb-8 sm:pb-12">
    <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)]">
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img
          src={`${R2}/homepage/Online%20Attendance%20Older%20Woman.jpg`}
          alt="Online church engagement through WorshipMetrics"
          loading="lazy"
          decoding="async"
          class="aspect-[16/10] w-full object-cover"
        />
      </div>
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img
          src={`${R2}/homepage/Worship%20Metrics%20is%20Easy.jpg`}
          alt="WorshipMetrics digital engagement workflow"
          loading="lazy"
          decoding="async"
          class="aspect-[16/10] w-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- Why it matters -->
  <section class="bg-slate-50 px-6 py-20">
    <div class="mx-auto max-w-5xl">
      <div class="grid gap-8 sm:grid-cols-3">
        <div class="rounded-2xl bg-white p-8 shadow-sm border border-slate-100">
          <h3 class="text-lg font-bold text-slate-900 mb-3">Online visitors deserve follow-up too</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            A livestream viewer, a website visitor, or someone who left a prayer request in chat
            — they are part of your congregation and deserve the same care.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-8 shadow-sm border border-slate-100">
          <h3 class="text-lg font-bold text-slate-900 mb-3">Prayer requests shouldn't disappear</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Digital requests, comments, and first-time conversations get routed to the right person
            instead of disappearing into inboxes.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-8 shadow-sm border border-slate-100">
          <h3 class="text-lg font-bold text-slate-900 mb-3">Know who engaged, not just how many</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            See which online interactions converted to real visitor records, prayer responses, and
            pastoral follow-up.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What it includes -->
  <section class="bg-white px-6 py-20">
    <div class="mx-auto max-w-4xl">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl mb-12 text-center">
        What it includes
      </h2>
      <div class="grid gap-6 sm:grid-cols-2">
        <div class="flex gap-4 rounded-2xl border border-slate-200 p-6">
          <div class="mt-1 flex-shrink-0 h-6 w-6 rounded-full bg-indigo-100 flex items-center justify-center">
            <span class="text-indigo-600 text-xs font-bold">1</span>
          </div>
          <div>
            <h3 class="text-base font-bold text-slate-900 mb-1">Website chat response</h3>
            <p class="text-slate-600 text-sm leading-relaxed">
              Warm visitor conversations, connect-card pathways, and prayer request handling.
            </p>
          </div>
        </div>
        <div class="flex gap-4 rounded-2xl border border-slate-200 p-6">
          <div class="mt-1 flex-shrink-0 h-6 w-6 rounded-full bg-indigo-100 flex items-center justify-center">
            <span class="text-indigo-600 text-xs font-bold">2</span>
          </div>
          <div>
            <h3 class="text-base font-bold text-slate-900 mb-1">Livestream viewer engagement</h3>
            <p class="text-slate-600 text-sm leading-relaxed">
              Help your online audience feel seen with response workflows for comments, questions,
              and next steps.
            </p>
          </div>
        </div>
        <div class="flex gap-4 rounded-2xl border border-slate-200 p-6">
          <div class="mt-1 flex-shrink-0 h-6 w-6 rounded-full bg-indigo-100 flex items-center justify-center">
            <span class="text-indigo-600 text-xs font-bold">3</span>
          </div>
          <div>
            <h3 class="text-base font-bold text-slate-900 mb-1">Prayer request routing</h3>
            <p class="text-slate-600 text-sm leading-relaxed">
              Receive, triage, and route requests so every concern lands with the right person on
              your team.
            </p>
          </div>
        </div>
        <div class="flex gap-4 rounded-2xl border border-slate-200 p-6">
          <div class="mt-1 flex-shrink-0 h-6 w-6 rounded-full bg-indigo-100 flex items-center justify-center">
            <span class="text-indigo-600 text-xs font-bold">4</span>
          </div>
          <div>
            <h3 class="text-base font-bold text-slate-900 mb-1">
              Social monitoring
              <span class="ml-2 inline-block rounded-full bg-indigo-100 px-2 py-0.5 text-xs font-medium text-indigo-700">Established</span>
            </h3>
            <p class="text-slate-600 text-sm leading-relaxed">
              Watch the channels your community uses to reach out, and respond with context.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Embed widget -->
  <section class="bg-slate-50 px-6 py-20">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl mb-4 text-center">
        Add an outreach widget to your website in one line of code.
      </h2>
      <p class="text-center text-slate-600 mb-8">
        Place a prayer request widget, connect card, or chat prompt directly on your church
        website. Visitor submissions create real people records in WorshipMetrics automatically.
      </p>
      <div class="rounded-xl bg-slate-900 p-6 overflow-x-auto">
        <code class="text-sm text-emerald-400 font-mono whitespace-nowrap">
          &lt;script async src="https://worshipmetrics.com/api/public/outreach/YOUR_CHURCH/YOUR_WIDGET/embed.js"&gt;&lt;/script&gt;
        </code>
      </div>
    </div>
  </section>

  <!-- Plans -->
  <section class="bg-white px-6 py-20">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl mb-8">
        Included on paid plans.
      </h2>
      <div class="grid gap-6 sm:grid-cols-2 text-left mb-10">
        <div class="rounded-2xl border border-slate-200 p-8">
          <p class="text-sm font-semibold uppercase tracking-widest text-indigo-600 mb-2">Essentials</p>
          <p class="text-3xl font-extrabold text-slate-900 mb-1">$19.99<span class="text-base font-normal text-slate-500">/month</span></p>
          <p class="mt-4 text-slate-700 text-sm">Outreach tools included</p>
        </div>
        <div class="rounded-2xl border border-indigo-200 bg-indigo-50 p-8">
          <p class="text-sm font-semibold uppercase tracking-widest text-indigo-600 mb-2">Established</p>
          <p class="text-3xl font-extrabold text-slate-900 mb-1">$49.99<span class="text-base font-normal text-slate-500">/month</span></p>
          <p class="mt-4 text-slate-700 text-sm">Outreach tools + social monitoring</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Related guides -->
  <section class="bg-slate-50 px-6 py-16">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">Related church growth guides</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {[
          {
            href: "/church-visitor-follow-up-software",
            title: "Church visitor follow-up software",
            body: "See how online and in-person guest follow-up can run from the same system.",
          },
          {
            href: "/church-guest-follow-up-system",
            title: "Church guest follow-up system",
            body: "See the process-focused guide for building a repeatable guest response workflow.",
          },
          {
            href: "/church-attendance-tracking-software",
            title: "Church attendance tracking software",
            body: "Connect online audience reporting with in-person attendance and weekly ministry review.",
          },
          {
            href: "/church-livestream-analytics",
            title: "Church livestream analytics",
            body: "See how churches review live viewers, replay reach, and online audience signals.",
          },
          {
            href: "/church-digital-signage-software",
            title: "Church digital signage software",
            body: "Support your digital front door with clearer in-building communication and signage workflows.",
          },
        ].map(({ href, title, body }) => (
          <a href={href} class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:bg-indigo-50/20">
            <h3 class="text-lg font-semibold text-slate-900">{title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{body}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-indigo-600">Read guide →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-indigo-600 px-6 py-20">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Build an outreach system your team can sustain.
      </h2>
      <p class="mt-4 text-lg text-indigo-100">
        Turn online attention into pastoral relationships.
      </p>
      <div class="mt-8">
        <a
          href="/outreach-services"
          class="rounded-lg bg-white px-8 py-3 text-base font-semibold text-indigo-600 shadow-sm hover:bg-indigo-50 transition"
        >
          Learn about Outreach Services &rarr;
        </a>
      </div>
    </div>
  </section>
</Layout>
