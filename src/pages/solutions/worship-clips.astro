---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Worship Clips"
  description="Turn your sermon into social content automatically. Clips for Instagram, YouTube Shorts, TikTok, and Facebook — no video editing required."
  canonical="/solutions/worship-clips"
>
  <!-- Hero -->
  <section class="bg-white px-6 py-20 sm:py-28">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-indigo-600">
        Worship Clips
      </p>
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
        Your message doesn't end when the service does.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-600 sm:text-xl">
        WorshipMetrics automatically turns your livestream into mobile-ready clips for Instagram,
        YouTube Shorts, TikTok, and Facebook — without video editing software.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="https://app.worshipmetrics.com/sign-up"
          class="rounded-lg bg-indigo-600 px-7 py-3 text-base font-semibold text-white shadow-sm hover:bg-indigo-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition"
        >
          Start for free
        </a>
        <a href="/pricing" class="text-base font-semibold text-indigo-600 hover:text-indigo-700">
          See pricing &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-y border-slate-200 bg-slate-50 px-6 py-12">
    <div class="mx-auto max-w-4xl">
      <dl class="grid grid-cols-1 gap-8 sm:grid-cols-3 text-center">
        <div>
          <dt class="text-4xl font-extrabold text-indigo-600">52 clips/year</dt>
          <dd class="mt-2 text-sm font-medium text-slate-600">on the Essentials plan</dd>
        </div>
        <div>
          <dt class="text-4xl font-extrabold text-indigo-600">Unlimited clips</dt>
          <dd class="mt-2 text-sm font-medium text-slate-600">on Established</dd>
        </div>
        <div>
          <dt class="text-4xl font-extrabold text-indigo-600">3 formats</dt>
          <dd class="mt-2 text-sm font-medium text-slate-600">vertical, square, and horizontal</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- How it works -->
  <section class="px-6 py-20 bg-white">
    <div class="mx-auto max-w-4xl">
      <h2 class="text-center text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl mb-12">
        How it works
      </h2>
      <ol class="relative border-l border-indigo-200 space-y-10 ml-4">
        <li class="pl-8">
          <span class="absolute -left-4 flex h-8 w-8 items-center justify-center rounded-full bg-indigo-600 text-white text-sm font-bold">1</span>
          <h3 class="text-xl font-bold text-slate-900">Your service streams or records</h3>
          <p class="mt-2 text-slate-600">
            Connect your YouTube livestream or upload a video file. No special equipment required.
          </p>
        </li>
        <li class="pl-8">
          <span class="absolute -left-4 flex h-8 w-8 items-center justify-center rounded-full bg-indigo-600 text-white text-sm font-bold">2</span>
          <h3 class="text-xl font-bold text-slate-900">Clips are created for you</h3>
          <p class="mt-2 text-slate-600">
            Sermons, scripture readings, and worship moments are identified and formatted for every
            major social platform.
          </p>
        </li>
        <li class="pl-8">
          <span class="absolute -left-4 flex h-8 w-8 items-center justify-center rounded-full bg-indigo-600 text-white text-sm font-bold">3</span>
          <h3 class="text-xl font-bold text-slate-900">Publish and reach more people</h3>
          <p class="mt-2 text-slate-600">
            Clips go out to Instagram Reels, YouTube Shorts, TikTok, and Facebook. People who
            weren't in the room see what they missed.
          </p>
        </li>
      </ol>
    </div>
  </section>

  <!-- Why it matters -->
  <section class="bg-slate-50 px-6 py-20">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-center text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl mb-12">
        Reach the people who weren't in the room.
      </h2>
      <div class="grid gap-8 sm:grid-cols-3">
        <div class="rounded-2xl bg-white p-8 shadow-sm border border-slate-100">
          <h3 class="text-lg font-bold text-slate-900 mb-3">Social-first formats</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Every clip is formatted for Reels, Shorts, and TikTok automatically. Vertical and
            horizontal, ready to post.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-8 shadow-sm border border-slate-100">
          <h3 class="text-lg font-bold text-slate-900 mb-3">No video editor needed</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            A single volunteer can run the full workflow in under an hour. No Final Cut, no
            Premiere.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-8 shadow-sm border border-slate-100">
          <h3 class="text-lg font-bold text-slate-900 mb-3">Extend your weekly reach</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Your Sunday message becomes content that works all week. People discover your church
            through a clip they never would have searched for.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Plans -->
  <section class="bg-white px-6 py-20">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl mb-10">
        Included on paid plans.
      </h2>
      <div class="grid gap-6 sm:grid-cols-2 text-left mb-10">
        <div class="rounded-2xl border border-slate-200 p-8">
          <p class="text-sm font-semibold uppercase tracking-widest text-indigo-600 mb-2">Essentials</p>
          <p class="text-3xl font-extrabold text-slate-900 mb-1">$19.99<span class="text-base font-normal text-slate-500">/month</span></p>
          <p class="mt-4 text-slate-700 font-medium">1 clip/week — 52 clips/year</p>
        </div>
        <div class="rounded-2xl border border-indigo-200 bg-indigo-50 p-8">
          <p class="text-sm font-semibold uppercase tracking-widest text-indigo-600 mb-2">Established</p>
          <p class="text-3xl font-extrabold text-slate-900 mb-1">$49.99<span class="text-base font-normal text-slate-500">/month</span></p>
          <p class="mt-4 text-slate-700 font-medium">Unlimited clips</p>
        </div>
      </div>
      <a href="/pricing" class="text-base font-semibold text-indigo-600 hover:text-indigo-700">
        See all pricing &rarr;
      </a>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-indigo-600 px-6 py-20">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Turn this Sunday's service into content.
      </h2>
      <p class="mt-4 text-lg text-indigo-100">No video editing. No extra equipment. Just your message, reaching further.</p>
      <div class="mt-8">
        <a
          href="https://app.worshipmetrics.com/sign-up"
          class="rounded-lg bg-white px-8 py-3 text-base font-semibold text-indigo-600 shadow-sm hover:bg-indigo-50 transition"
        >
          Start for free
        </a>
      </div>
    </div>
  </section>
</Layout>
