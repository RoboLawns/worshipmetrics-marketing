---
import Layout from "../layouts/Layout.astro";

const SITE_URL = "https://worshipmetrics.com";
const OG_IMAGE = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main/homepage/new%20images/Church%20Digital%20Signage.jpg";
const faqItems = [
  {
    question: "What is church digital signage software?",
    answer: "Church digital signage software helps churches manage lobby screens, welcome slides, countdowns, event announcements, and other in-building displays from one central system.",
  },
  {
    question: "Can WorshipMetrics manage church lobby screens remotely?",
    answer: "Yes. WorshipMetrics lets churches manage digital signage remotely so staff can update screens without walking back to a dedicated computer in the building.",
  },
  {
    question: "Does church digital signage require special hardware?",
    answer: "WorshipMetrics signage is designed to work with displays churches already have, and the Hub can be used when churches want a more connected hardware workflow.",
  },
  {
    question: "Is digital signage included with WorshipMetrics?",
    answer: "WorshipMetrics includes digital signage as part of the broader platform strategy, with more expansive signage use available on paid plans.",
  },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "WorshipMetrics Church Digital Signage Software",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: `${SITE_URL}/church-digital-signage-software`,
    image: OG_IMAGE,
    description: "Church digital signage software for welcome screens, lobby announcements, countdowns, and remote display management.",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
      availability: "https://schema.org/InStock",
      url: `${SITE_URL}/pricing`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map(({ question, answer }) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: { "@type": "Answer", text: answer },
    })),
  },
];
---

<Layout
  title="Church Digital Signage Software"
  description="Church digital signage software for welcome screens, lobby announcements, countdowns, and remote display management."
  canonical="/church-digital-signage-software"
  ogImage={OG_IMAGE}
  structuredData={structuredData}
>
  <section class="bg-gradient-to-b from-indigo-50 to-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Church digital signage software</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">Church digital signage software for welcome screens, lobbies, and in-building communication.</h1>
      <p class="mt-6 text-lg text-slate-600 sm:text-xl">Update church screens from anywhere, keep announcements current, and make your in-building communication easier to manage every week.</p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/platform/operations" class="rounded-xl bg-indigo-600 px-8 py-3 text-base font-semibold text-white shadow transition hover:bg-indigo-700">See operations workflows</a>
        <a href="/appliance" class="rounded-xl border border-slate-300 px-8 py-3 text-base font-semibold text-slate-700 transition hover:border-indigo-400 hover:text-indigo-600">See the Hub</a>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 pb-8 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)]">
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src={OG_IMAGE} alt="Church digital signage software in WorshipMetrics" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src="https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main/homepage/Team%20Collaboration%20hero.jpg" alt="Managing church signage and team workflows" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl grid gap-6 md:grid-cols-3">
      {[
        ["Update screens remotely", "Change welcome slides, announcements, and countdowns without sending someone back to a building computer."],
        ["Use screens you already own", "Churches often do not need a complicated signage stack just to keep lobby communication fresh and accurate."],
        ["Keep communication current", "When it is easy to update screens, your congregation actually sees useful next steps, events, and announcements."],
      ].map(([title, body]) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900">{title}</h2>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">{body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-center text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">How WorshipMetrics approaches church digital signage</h2>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {[
          ["Create", "Prepare the announcements, welcome messages, or slides your church needs this week."],
          ["Publish", "Push updates to your displays from a central place instead of maintaining disconnected signage machines."],
          ["Manage", "Keep signage connected to the rest of your worship, operations, and communication workflows."],
        ].map(([title, body]) => (
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-8">
            <h3 class="text-xl font-bold text-slate-900">{title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center text-2xl font-bold text-slate-900 sm:text-3xl">Related pages</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {[
          { href: "/platform/operations", title: "Operations workflows", body: "See how signage fits into the broader church operations and team workflow." },
          { href: "/appliance", title: "WorshipMetrics Hub", body: "See the connected hardware option for churches that want signage plus automation and AV workflows." },
          { href: "/pricing", title: "Pricing", body: "Compare plans and see where digital signage fits across software and hardware options." },
        ].map(({ href, title, body }) => (
          <a href={href} class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:bg-indigo-50/20">
            <h3 class="text-lg font-semibold text-slate-900">{title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{body}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-indigo-600">Explore →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">FAQ</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Questions churches ask about digital signage software</h2>
      </div>
      <div class="mt-8 space-y-4">
        {faqItems.map(({ question, answer }) => (
          <details class="rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-sm">
            <summary class="cursor-pointer list-none text-lg font-semibold text-slate-900">{question}</summary>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-indigo-600 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-white">Make church signage easier to manage every week.</h2>
      <p class="mt-4 text-indigo-200">We can show you how digital signage fits with your existing displays, team workflow, and WorshipMetrics setup.</p>
      <a href="/discovery-call" class="mt-8 inline-block rounded-xl bg-white px-8 py-3 text-base font-semibold text-indigo-700 shadow transition hover:bg-indigo-50">Book a discovery call</a>
    </div>
  </section>
</Layout>
