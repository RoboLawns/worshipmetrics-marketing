---
import Layout from "../layouts/Layout.astro";

const R2 = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
---

<Layout
  title="AV Operations Platform for Churches"
  description="Not ChMS. Not generic AV software. WorshipMetrics is the church AV operations platform for monitoring, production control, camera-based attendance, and booth workflows."
  canonical="/platform"
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-indigo-50 to-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-indigo-600">Features</p>
        <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">The AV operations platform for churches.</h1>
        <p class="mt-4 text-lg text-slate-600">
          Not a ChMS. Not a streaming app. The system that keeps the booth working, the stream up, the cameras counting, and the weekly content workflow moving for church AV teams.
        </p>
    </div>

    <!-- 3 pillars -->
    <div class="mx-auto mt-12 grid max-w-4xl gap-6 sm:grid-cols-3">
      {[
        {
          icon: "M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 8.25h3m-3 3.75h3m-3 3.75h3",
          heading: "Built for the booth",
          body: "Church AV workflows, church AV vocabulary, and church production realities.",
        },
        {
          icon: "M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z",
          heading: "Built for volunteers",
          body: "Simple enough for Sunday volunteers, useful enough for full-time tech staff.",
        },
        {
          icon: "M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z",
          heading: "Runs the weekly rhythm",
          body: "Monitoring, production, attendance, signage, and reporting in one system.",
        },
      ].map(({ icon, heading, body }) => (
        <div class="rounded-2xl border border-slate-100 bg-white p-6 text-center shadow-sm">
          <div class="mx-auto mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-50 text-indigo-600">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
            </svg>
          </div>
          <h3 class="font-semibold text-slate-900">{heading}</h3>
          <p class="mt-1 text-sm text-slate-500">{body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Platform walkthrough -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto mb-10 max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Platform walkthrough</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
          See the workflow your team actually uses.
        </h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-2">
        {[
          {
            title: "Attendance that matches the room",
            body: "Volunteers count inside a familiar seat template instead of starting from scratch every week.",
            href: "/platform/attendance",
            src: `${R2}/tablet/New%20Seat%20Counting%20Layout.jpg`,
            alt: "WorshipMetrics seat counting layout",
          },
          {
            title: "Tech Manager for the booth",
            body: "Map devices, watch OBS health, and give Luminos the context it needs to troubleshoot with specificity.",
            href: "/tech-manager",
            src: `${R2}/homepage/1%20Worship%20Technology%20Assistance.jpg`,
            alt: "WorshipMetrics Tech Manager workflow",
          },
          {
            title: "Role-based team workflows",
            body: "Give volunteers and staff the right screens for the role they serve in this week.",
            href: "/platform/operations",
            src: `${R2}/tablet/Team%20Collaboration.jpg`,
            alt: "Team collaboration inside WorshipMetrics",
          },
          {
            title: "Luminos for weekly AV review",
            body: "See what changed this week, what broke, and what needs attention before the next service.",
            href: "/luminos-ai-assistant",
            src: `${R2}/Luminos/Luminos%20Profile.jpg`,
            alt: "Luminos profile illustration",
          },
        ].map(({ title, body, href, src, alt }) => (
          <a href={href} class="group overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm transition hover:border-indigo-300 hover:shadow-md">
            <img src={src} alt={alt} loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
            <div class="p-6">
              <h3 class="text-lg font-semibold text-slate-900 group-hover:text-indigo-700">{title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">{body}</p>
              <span class="mt-4 inline-block text-sm font-semibold text-indigo-600 group-hover:underline">Learn more →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Popular guides -->
  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Popular guides</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Explore the specific workflows churches compare most.</h2>
      </div>
      <div class="mt-8 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {[
          { href: "/church-attendance-tracking-software", title: "Attendance tracking software", body: "A focused guide to church attendance workflows, volunteer counting, and online reporting." },
          { href: "/av-monitoring-for-houses-of-worship", title: "AV monitoring for churches", body: "A focused guide to stream health, alerts, and what the booth needs before anyone notices a problem." },
          { href: "/tech-manager", title: "Tech Manager", body: "How device discovery, system documentation, and desktop monitoring fit into the stack." },
          { href: "/church-check-in-tablet", title: "Church check-in tablet", body: "A dedicated guide to tablet-based check-in, attendance, and guest workflows." },
          { href: "/church-digital-signage-software", title: "Digital signage software", body: "How churches manage lobby displays and signage with less friction." },
        ].map(({ href, title, body }) => (
          <a href={href} class="rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-sm transition hover:border-indigo-300 hover:bg-white">
            <h3 class="text-lg font-semibold text-slate-900">{title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{body}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-indigo-600">Read guide →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Feature nav cards -->
  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <h2 class="mb-10 text-center text-2xl font-bold text-slate-900">Everything the platform includes</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {[
          {
            title: "Attendance",
            href: "/platform/attendance",
            desc: "Count in-room and online together. Templates, Auto-Count, and trend reports.",
            icon: "M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z",
          },
          {
            title: "Tech Manager",
            href: "/tech-manager",
            desc: "Desktop monitoring, device discovery, and system documentation for the AV booth.",
            icon: "M3 5.25A2.25 2.25 0 015.25 3h13.5A2.25 2.25 0 0121 5.25v9A2.25 2.25 0 0118.75 16.5H13.5l-2.25 3-2.25-3H5.25A2.25 2.25 0 013 14.25v-9z",
          },
          {
            title: "Operations",
            href: "/platform/operations",
            desc: "Volunteer roles, permissions, devices, and multi-campus tools.",
            icon: "M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z M15 12a3 3 0 11-6 0 3 3 0 016 0z",
          },
          {
            title: "Luminos AI",
            href: "/luminos-ai-assistant",
            desc: "Weekly ministry summaries in plain English. Role-aware. Action-confirmed.",
            icon: "M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z",
          },
          {
            title: "Worship Clips",
            href: "/solutions/worship-clips",
            desc: "Turn services into mobile-ready clips without video editing software.",
            icon: "M3.375 19.5h17.25m-17.25 0a1.125 1.125 0 01-1.125-1.125M3.375 19.5h7.5c.621 0 1.125-.504 1.125-1.125m-9.75 0V5.625m0 12.75v-1.5c0-.621.504-1.125 1.125-1.125m18.375 2.625V5.625m0 12.75c0 .621-.504 1.125-1.125 1.125m1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125m0 3.75h-7.5A1.125 1.125 0 0112 18.375m9.75-12.75c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125m19.5 0v1.5c0 .621-.504 1.125-1.125 1.125M2.25 5.625v1.5c0 .621.504 1.125 1.125 1.125m0 0h17.25m-17.25 0h7.5c.621 0 1.125.504 1.125 1.125M3.375 8.25c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125m17.25-3.75h-7.5c-.621 0-1.125.504-1.125 1.125m8.625-1.125c.621 0 1.125.504 1.125 1.125v1.5c0 .621-.504 1.125-1.125 1.125m-17.25 0h7.5m-7.5 0c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125M12 10.875v-1.5m0 1.5c0 .621-.504 1.125-1.125 1.125M12 10.875c0 .621.504 1.125 1.125 1.125m-2.25 0c0 .621-.504 1.125-1.125 1.125m0 1.5V14.25m0-2.625c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125M9.75 14.25h1.5m4.875-9.375c0 .621-.504 1.125-1.125 1.125M15 5.625c0 .621.504 1.125 1.125 1.125m-2.25 0c.621 0 1.125.504 1.125 1.125",
          },
          {
            title: "Digital Signage",
            href: "/signage-display",
            desc: "Keep lobby displays updated without adding another disconnected tool.",
            icon: "M2.25 6.75A2.25 2.25 0 014.5 4.5h15A2.25 2.25 0 0121.75 6.75v9A2.25 2.25 0 0119.5 18h-15a2.25 2.25 0 01-2.25-2.25v-9zM9 21h6",
          },
        ].map(({ title, href, desc, icon }) => (
          <a
            href={href}
            class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:shadow-md"
          >
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-50 text-indigo-600 transition group-hover:bg-indigo-600 group-hover:text-white">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
              </svg>
            </div>
            <h3 class="font-semibold text-slate-900 group-hover:text-indigo-700">{title}</h3>
            <p class="mt-1 flex-1 text-sm text-slate-500">{desc}</p>
            <span class="mt-4 text-sm font-semibold text-indigo-600 group-hover:underline">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How the platform works -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <h2 class="mb-10 text-center text-2xl font-bold text-slate-900 sm:text-3xl">How the platform works</h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          {
            step: "01",
            heading: "Monitor the system before service starts",
            body: "Check stream health, devices, cameras, and alerts before the room fills up.",
          },
          {
            step: "02",
            heading: "Run the service from one booth workflow",
            body: "Attendance, PTZ control, OBS and vMix workflows, and signage stay in the same operating system.",
          },
          {
            step: "03",
            heading: "Review what changed before next Sunday",
            body: "Luminos and Tech Manager help the booth spot trends, failures, and follow-up tasks faster.",
          },
        ].map(({ step, heading, body }) => (
          <div class="flex flex-col">
            <span class="text-5xl font-extrabold text-indigo-100 leading-none">{step}</span>
            <h3 class="mt-3 text-lg font-semibold text-slate-900">{heading}</h3>
            <p class="mt-2 text-sm text-slate-500 leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <section class="bg-slate-900 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-white">See how it fits your weekly workflow.</h2>
      <a
        href="/discovery-call"
        class="mt-8 inline-block rounded-xl bg-indigo-600 px-8 py-3 text-base font-semibold text-white shadow transition hover:bg-indigo-500"
      >
        Book a discovery call
      </a>
    </div>
  </section>
</Layout>
