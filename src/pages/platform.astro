---
import Layout from "../layouts/Layout.astro";

const R2 = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";

const platformCards = [
  {
    title: "Services",
    href: "/services",
    desc: "Plan the service, assign the team, and run Sunday from one connected workflow.",
    src: `${R2}/homepage/Team%20Collaboration%20hero.jpg`,
  },
  {
    title: "Volunteers",
    href: "/volunteers",
    desc: "Capabilities, scheduling, communications, and replacement workflows for real church teams.",
    src: `${R2}/homepage/new%20images/Worship%20Volunteers%20Working%20Together.jpg`,
  },
  {
    title: "Tech Manager",
    href: "/tech-manager",
    desc: "The desktop app that powers the booth with monitoring, mapping, and system context.",
    src: `${R2}/homepage/1%20Worship%20Technology%20Assistance.jpg`,
  },
  {
    title: "Worship Clips",
    href: "/solutions/worship-clips",
    desc: "Turn Sunday into clips your team can publish without an extra editing sprint.",
    src: `${R2}/homepage/Worship%20Clips%20Hero%202.jpg`,
  },
  {
    title: "Attendance",
    href: "/platform/attendance",
    desc: "Count in-room and online together with volunteer-friendly and camera-assisted workflows.",
    src: `${R2}/tablet/New%20Seat%20Counting%20Layout.jpg`,
  },
  {
    title: "Digital Signage",
    href: "/signage-display",
    desc: "Keep screens current from one system instead of one more disconnected tool.",
    src: `${R2}/homepage/new%20images/Worship%20Digital%20Signage%20System.jpg`,
  },
  {
    title: "Luminos AI",
    href: "/luminos-ai-assistant",
    desc: "Use real system context to understand what changed, what broke, and what needs attention.",
    src: `${R2}/Luminos/Luminos%20Profile.jpg`,
  },
];
---

<Layout
  title="Platform Overview"
  description="See how Services, Volunteers, Tech Manager, Worship Clips, Attendance, Digital Signage, and Luminos fit together inside WorshipMetrics."
  canonical="/platform"
>
  <section class="bg-gradient-to-b from-indigo-50 to-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Platform overview</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">Everything Worship Metrics does, in one connected story.</h1>
      <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-slate-600 sm:text-xl">
        Worship Metrics is no longer one booth app with a few extras around it. It is the operating system for your Sunday: planning, volunteers, production, clips, reporting, and the hardware that supports the workflow.
      </p>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {platformCards.map(({ title, href, desc, src }) => (
          <a href={href} class="group overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-sm transition hover:border-indigo-300 hover:shadow-md">
            <img src={src} alt={title} loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
            <div class="p-6">
              <h2 class="text-xl font-semibold text-slate-900 group-hover:text-indigo-700">{title}</h2>
              <p class="mt-3 text-sm leading-relaxed text-slate-600">{desc}</p>
              <span class="mt-4 inline-block text-sm font-semibold text-indigo-600">Explore →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">How the pieces fit</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Free gets your church organized. Paid adds deeper execution.</h2>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {[
          {
            heading: "Start with the shared workflow",
            body: "Services, Volunteers, Attendance, and Signage give the team a connected baseline before you ever ask the church to buy a deeper tier.",
          },
          {
            heading: "Add booth intelligence",
            body: "Tech Manager and Luminos bring the booth, the system map, and real diagnostics into the same operating picture.",
          },
          {
            heading: "Grow into automation",
            body: "Paid tiers add the execution layer, deeper monitoring, cloud workflows, and the production capabilities that justify the upgrade, including the Central Control-powered automation story.",
          },
        ].map(({ heading, body }) => (
          <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
            <h3 class="text-xl font-semibold text-slate-900">{heading}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">See the platform in the order your church will experience it.</h2>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row sm:flex-wrap">
        <a href="/services" class="btn-primary">Start with Services</a>
        <a href="/pricing" class="btn-outline">Compare plans</a>
        <a href="/why-worship-metrics" class="btn-outline">Why Worship Metrics</a>
      </div>
    </div>
  </section>
</Layout>
