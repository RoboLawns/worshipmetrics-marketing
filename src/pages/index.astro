---
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.worshipmetrics.com";
const R2      = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
---

<Layout
  title="Church Attendance & Community Platform"
  description="WorshipMetrics helps your church track attendance, follow up with visitors, and engage your online audience — all in one weekly workflow your volunteers can actually run."
  canonical="/"
>
<style>
  /* ── Hero ── */
  .hero {
    position: relative; overflow: hidden;
    padding: 6rem 1.5rem 5rem;
    text-align: center;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(900px circle at 20% 0%,  rgba(107,140,255,0.18), transparent 55%),
      radial-gradient(700px circle at 80% 10%,  rgba(46,204,143,0.10),  transparent 55%);
    pointer-events: none;
  }
  .hero-inner { position: relative; max-width: 56rem; margin: 0 auto; }
  .pill {
    display: inline-block;
    background: rgba(107,140,255,0.12);
    border: 1px solid rgba(107,140,255,0.28);
    color: #9ab0ff;
    font-size: 0.7rem; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.3rem 0.9rem; border-radius: 999px; margin-bottom: 1.25rem;
  }
  h1 {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 800; line-height: 1.1; letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }
  .hero-sub {
    font-size: 1.1rem; color: #8a96b3; max-width: 38rem; margin: 0 auto 2rem; line-height: 1.7;
  }
  .hero-ctas { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; }
  .hero-fine { margin-top: 1rem; font-size: 0.8rem; color: #8a96b3; }
  .trust-pills {
    display: flex; flex-wrap: wrap; justify-content: center; gap: 0.5rem; margin-top: 2.5rem;
  }
  .trust-pill {
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 999px; padding: 0.3rem 0.9rem;
    font-size: 0.78rem; color: #8a96b3;
  }

  /* ── Hero image ── */
  .hero-img-wrap {
    position: relative; max-width: 64rem; margin: 3.5rem auto 0;
    border-radius: 1rem; overflow: hidden;
    border: 1px solid rgba(107,140,255,0.18);
    box-shadow: 0 32px 80px rgba(0,0,0,0.55), 0 0 0 1px rgba(107,140,255,0.1);
  }
  .hero-img-wrap img { display: block; width: 100%; height: auto; }

  /* ── Sections ── */
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 72rem; margin: 0 auto; }
  .section-alt { background: rgba(255,255,255,0.02); }

  .section-eyebrow { text-align: center; margin-bottom: 0.5rem; }
  .section-title {
    font-size: clamp(1.6rem, 3vw, 2.25rem); font-weight: 700;
    text-align: center; margin-bottom: 0.75rem;
  }
  .section-sub { text-align: center; color: #8a96b3; font-size: 1rem; margin-bottom: 3rem; }

  /* ── 3-col feature cards ── */
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  @media (max-width: 900px) { .grid-3 { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .grid-3 { grid-template-columns: 1fr; } }

  /* ── How it works ── */
  .steps { display: flex; flex-direction: column; gap: 2rem; max-width: 42rem; margin: 0 auto; }
  .step { display: flex; gap: 1.25rem; align-items: flex-start; }
  .step-num {
    flex-shrink: 0; width: 2.5rem; height: 2.5rem;
    background: var(--primary); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 0.95rem; color: #fff;
    box-shadow: 0 0 20px rgba(107,140,255,0.5);
  }
  .step-body h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.25rem; }
  .step-body p  { color: #8a96b3; font-size: 0.9rem; line-height: 1.65; }

  /* ── Split sections ── */
  .split { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
  @media (max-width: 768px) { .split { grid-template-columns: 1fr; } }
  .split-img {
    border-radius: 0.875rem; overflow: hidden;
    border: 1px solid rgba(107,140,255,0.16);
    box-shadow: 0 16px 48px rgba(0,0,0,0.45);
  }
  .split-img img { display: block; width: 100%; height: auto; }
  .split-content h2 { font-size: 1.75rem; font-weight: 700; margin-bottom: 0.75rem; line-height: 1.25; }
  .split-content p  { color: #8a96b3; line-height: 1.7; margin-bottom: 1.25rem; }
  .split-bullets { list-style: none; padding: 0; margin: 0 0 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .split-bullets li { display: flex; align-items: center; gap: 0.6rem; font-size: 0.9rem; color: #c4ceee; }
  .split-bullets li::before { content: ''; flex-shrink: 0; width: 6px; height: 6px; border-radius: 50%; background: var(--primary); }

  /* ── Video ── */
  .video-wrap {
    position: relative; padding-bottom: 56.25%; height: 0;
    border-radius: 0.875rem; overflow: hidden;
    border: 1px solid rgba(107,140,255,0.16);
    box-shadow: 0 16px 48px rgba(0,0,0,0.5);
    margin-top: 2.5rem;
  }
  .video-wrap iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }

  /* ── Testimonials ── */
  .grid-3-auto { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.25rem; }
  .testimonial-card {
    background: var(--bg-card); border: 1px solid rgba(107,140,255,0.14);
    border-radius: 1rem; padding: 1.5rem;
  }
  .testimonial-card blockquote { color: #c4ceee; line-height: 1.7; font-size: 0.9rem; }
  .testimonial-card figcaption { margin-top: 1rem; font-size: 0.78rem; color: #8a96b3; }

  /* ── Bottom CTA ── */
  .cta-band {
    text-align: center; padding: 5rem 1.5rem;
    background:
      radial-gradient(800px circle at 50% 100%, rgba(107,140,255,0.14), transparent 60%);
    border-top: 1px solid rgba(107,140,255,0.12);
  }
  .cta-band h2 { font-size: 2rem; font-weight: 700; margin-bottom: 0.75rem; }
  .cta-band p  { color: #8a96b3; margin-bottom: 2rem; }
  .cta-band .btns { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; }
</style>

<!-- ═══════════════════════════════ HERO ═══════════════════════════════ -->
<section class="hero">
  <div class="hero-inner">
    <span class="pill">Built for churches</span>
    <h1>
      Know who's in the room.<br/>
      <span class="title-gradient">Reach who isn't.</span>
    </h1>
    <p class="hero-sub">
      WorshipMetrics helps your church track attendance, follow up with visitors, and engage your
      online audience — all in one weekly workflow your volunteers can actually run.
    </p>
    <div class="hero-ctas">
      <a href="/discovery-call" class="btn-primary">Book a free discovery call</a>
      <a href={`${APP_URL}/sign-up`} class="btn-outline">Start for free</a>
    </div>
    <p class="hero-fine">No credit card required. Free plan available.</p>
    <div class="trust-pills">
      {["Works on any device", "Built for volunteers", "1–3 min per service", "In-room + online together"].map(p => (
        <span class="trust-pill">{p}</span>
      ))}
    </div>
  </div>

  <!-- Hero image — real dashboard screenshot -->
  <div class="hero-img-wrap" style="max-width:64rem;margin-top:3.5rem;">
    <img
      src={`${R2}/tablet/Worship Metrics Dashboard.jpg`}
      alt="WorshipMetrics dashboard showing attendance trends and people records"
      loading="eager"
      width="1280" height="720"
    />
  </div>
</section>

<!-- ═══════════════════════════ WHAT IT DOES ══════════════════════════ -->
<section class="section section-alt">
  <div class="section-inner">
    <p class="eyebrow section-eyebrow">The platform</p>
    <h2 class="section-title">One workflow. Every Sunday.</h2>
    <p class="section-sub">From counting the room to following up on Monday morning.</p>

    <div class="grid-3">
      {[
        { title: "Track attendance", body: "Count in-person and online together. Seat templates, Auto-Count, and quick manual entry — whatever fits your Sunday.", href: "/platform/attendance" },
        { title: "Follow up faster", body: "Know who is new, who is missing, and who needs a pastoral check-in. Attendance becomes action, not just a number.", href: "/platform/people" },
        { title: "Reach online visitors", body: "Turn anonymous livestream viewers and website visitors into known people your team can actually follow up with.", href: "/solutions/digital-engagement" },
      ].map(({ title, body, href }) => (
        <a href={href} class="card" style="padding:1.75rem;text-decoration:none;display:block;">
          <h3 style="font-size:1rem;font-weight:600;margin-bottom:0.5rem;">{title}</h3>
          <p style="color:#8a96b3;font-size:0.875rem;line-height:1.65;margin-bottom:0.75rem;">{body}</p>
          <span style="font-size:0.8rem;color:var(--primary);font-weight:600;">Learn more →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ════════════════════════════ SEAT COUNTING ════════════════════════ -->
<section class="section">
  <div class="section-inner">
    <div class="split">
      <div class="split-img">
        <img
          src={`${R2}/homepage/3 Worship Metrics Attendance Tracking.jpg`}
          alt="Worship Metrics seat counting layout on a tablet"
          loading="lazy" width="800" height="530"
        />
      </div>
      <div class="split-content">
        <p class="eyebrow" style="margin-bottom:0.5rem;">Attendance tracking</p>
        <h2>Count the room in 1–3 minutes every Sunday.</h2>
        <p>Build your sanctuary layout once. Volunteers confirm what changed — they're not recounting from zero. Auto-Count handles the hectic Sundays.</p>
        <ul class="split-bullets">
          <li>Seat templates built for real church spaces</li>
          <li>Auto-Count from a quick photo when time is tight</li>
          <li>In-person and livestream combined in one total</li>
          <li>Attendance patterns tied to real people records</li>
        </ul>
        <a href="/platform/attendance" class="btn-primary">See how it works</a>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════ VISITOR CAPTURE ═══════════════════════ -->
<section class="section section-alt">
  <div class="section-inner">
    <div class="split">
      <div class="split-content">
        <p class="eyebrow" style="margin-bottom:0.5rem;">People & follow-up</p>
        <h2>Turn guests into known people before they leave the parking lot.</h2>
        <p>Scan welcome cards with any phone camera. QR check-in for digital-first guests. All paths create the same usable people record your team can follow up from Monday morning.</p>
        <ul class="split-bullets">
          <li>Welcome card scanning with computer vision</li>
          <li>QR code self-check-in for phone-first guests</li>
          <li>Prayer requests routed to the right person</li>
          <li>Absence alerts before weeks become months</li>
        </ul>
        <a href="/platform/people" class="btn-primary">See people tools</a>
      </div>
      <div class="split-img">
        <img
          src={`${R2}/homepage/Worship Metrics is Easy.jpg`}
          alt="Church team using WorshipMetrics for visitor follow-up"
          loading="lazy" width="800" height="530"
        />
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════ VIDEO ════════════════════════════ -->
<section class="section">
  <div class="section-inner" style="max-width:56rem;">
    <p class="eyebrow section-eyebrow">See it in action</p>
    <h2 class="section-title">A quick look at WorshipMetrics</h2>
    <div class="video-wrap">
      <iframe
        src="https://www.youtube-nocookie.com/embed/TUTc5Q3NliM?rel=0&modestbranding=1&playsinline=1"
        title="WorshipMetrics walkthrough"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
  </div>
</section>

<!-- ══════════════════════════ WORSHIP CLIPS ═════════════════════════ -->
<section class="section section-alt">
  <div class="section-inner">
    <div class="split">
      <div class="split-img">
        <img
          src={`${R2}/homepage/WorshipClips Hero.jpg`}
          alt="Worship Clips turning a sermon into social content"
          loading="lazy" width="800" height="530"
        />
      </div>
      <div class="split-content">
        <p class="eyebrow" style="margin-bottom:0.5rem;">Worship Clips</p>
        <h2>Your message doesn't end when the service does.</h2>
        <p>WorshipMetrics automatically turns your livestream into ready-to-post social content — Reels, Shorts, TikTok, Facebook. No video editing software. One volunteer. Under an hour.</p>
        <ul class="split-bullets">
          <li>52 clips/year on Essentials. Unlimited on Established.</li>
          <li>Vertical, square, and horizontal formats auto-generated</li>
          <li>Reach people who weren't in the room</li>
        </ul>
        <a href="/solutions/worship-clips" class="btn-primary">See Worship Clips</a>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════ COMMUNITY PLATFORM ════════════════════════ -->
<section class="section">
  <div class="section-inner">
    <div class="split">
      <div class="split-content">
        <p class="eyebrow" style="margin-bottom:0.5rem;">Community Platform</p>
        <h2>Build a digital home your congregation will actually use.</h2>
        <p>We set up a Discord-based community platform for your church — prayer channels, small group spaces, YouTube chat sync, announcements, and member onboarding. All week long, not just Sunday.</p>
        <ul class="split-bullets">
          <li>Discord setup, automations, and YouTube chat sync</li>
          <li>Ministry-specific channels your team designs</li>
          <li>One-time setup fee — we handle the technical lift</li>
        </ul>
        <a href="/solutions/church-community-platform" class="btn-primary">See community platform</a>
      </div>
      <div class="split-img">
        <img
          src={`${R2}/homepage/WorshipMetrics Discord Setup.jpg`}
          alt="WorshipMetrics Discord community platform setup"
          loading="lazy" width="800" height="530"
        />
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════ LUMINOS AI ════════════════════════════ -->
<section class="section section-alt">
  <div class="section-inner">
    <div class="split">
      <div class="split-img">
        <img
          src={`${R2}/homepage/Luminos.jpg`}
          alt="Luminos AI assistant summarizing weekly ministry data"
          loading="lazy" width="800" height="530"
        />
      </div>
      <div class="split-content">
        <p class="eyebrow" style="margin-bottom:0.5rem;">Luminos AI</p>
        <h2>Walk into Monday knowing what matters most.</h2>
        <p>Luminos lives inside your WorshipMetrics dashboard and answers the questions your team already asks every Monday — in plain English, without digging through reports.</p>
        <ul class="split-bullets">
          <li>"Who has missed multiple services and may need a check-in?"</li>
          <li>"Which guests still need a response from this week?"</li>
          <li>"Give me a summary before Monday staff meeting."</li>
        </ul>
        <a href="/luminos-ai-assistant" class="btn-primary">See Luminos</a>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════ HOW IT WORKS ═════════════════════════ -->
<section class="section">
  <div class="section-inner">
    <p class="eyebrow section-eyebrow">The weekly rhythm</p>
    <h2 class="section-title">Simple enough to repeat every Sunday.</h2>
    <p class="section-sub">A three-step loop your whole team can run without any training overhead.</p>
    <ol class="steps">
      {[
        { n:"1", t:"Count",      b:"Volunteers use a seat template or Auto-Count to log attendance in 1–3 minutes during or after service." },
        { n:"2", t:"Capture",    b:"New visitors, prayer requests, and online interactions get attached to real people records automatically." },
        { n:"3", t:"Follow up",  b:"Leadership gets a clear Monday summary: who's new, who's missing, what needs pastoral attention this week." },
      ].map(({ n, t, b }) => (
        <li class="step">
          <span class="step-num">{n}</span>
          <div class="step-body">
            <h3>{t}</h3>
            <p>{b}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<!-- ══════════════════════════ TESTIMONIALS ══════════════════════════ -->
<section class="section section-alt">
  <div class="section-inner">
    <p class="eyebrow section-eyebrow">What churches are saying</p>
    <h2 class="section-title">Real results from real ministry teams.</h2>
    <div class="grid-3-auto" style="margin-top:2.5rem;">
      {[
        { quote: "Before WorshipMetrics, we had no idea who was watching our stream. Now we have a follow-up system running within 24 hours of every service.", attr: "Executive Pastor, mid-size church, Southeast U.S." },
        { quote: "The consulting piece made the difference. We had the technology — we just didn't know how to use it pastorally.", attr: "Lead Pastor, growing church, Midwest" },
        { quote: "Our YouTube chat used to go unmonitored every Sunday. Now someone is in there welcoming viewers and routing prayer requests in real time.", attr: "Communications Director, large church, Texas" },
      ].map(({ quote, attr }) => (
        <figure class="testimonial-card">
          <div style="color:#6b8cff;font-size:1.5rem;margin-bottom:0.5rem;">⭐</div>
          <blockquote>"{quote}"</blockquote>
          <figcaption>— {attr}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════════════ HARDWARE ROW ═════════════════════════ -->
<section class="section">
  <div class="section-inner">
    <p class="eyebrow section-eyebrow">Hardware</p>
    <h2 class="section-title">Purpose-built devices for churches.</h2>
    <p class="section-sub">Optional hardware that connects directly to the same WorshipMetrics dashboard.</p>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-top:2.5rem;">
      {[{
        img: `${R2}/tablet/Worship Metrics Appliance Small.jpg`,
        name: "WorshipMetrics Hub",
        price: "$499 one-time",
        desc: "Automatic attendance, cloud-managed digital signage, remote PTZ camera control, and live production — from one device. No subscriptions.",
        href: "/appliance",
      },{
        img: `${R2}/tablet/New Worship Metrics Tablet Hero.jpg`,
        name: "WorshipMetrics Tablet",
        price: "From $349",
        desc: "A dedicated volunteer workflow for check-in, attendance, and guest capture. Includes a free Essentials plan. Sets up in 60 seconds.",
        href: "/tablet",
      }].map(({ img, name, price, desc, href }) => (
        <a href={href} class="card" style="text-decoration:none;display:block;overflow:hidden;">
          <div style="height:200px;overflow:hidden;">
            <img src={img} alt={name} loading="lazy" width="600" height="400"
              style="width:100%;height:100%;object-fit:cover;" />
          </div>
          <div style="padding:1.5rem;">
            <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:0.5rem;">
              <h3 style="font-size:1rem;font-weight:600;">{name}</h3>
              <span style="font-size:0.8rem;color:var(--primary);font-weight:600;">{price}</span>
            </div>
            <p style="color:#8a96b3;font-size:0.85rem;line-height:1.6;margin-bottom:0.75rem;">{desc}</p>
            <span style="font-size:0.8rem;color:var(--primary);font-weight:600;">See details →</span>
          </div>
        </a>
      ))}
    </div>
    <p style="text-align:center;margin-top:1.25rem;">
      <a href="/hardware" style="font-size:0.85rem;color:var(--primary);font-weight:600;">Compare Hub vs. Tablet →</a>
    </p>
  </div>
</section>

<!-- ════════════════════════════ BOTTOM CTA ══════════════════════════ -->
<div class="cta-band">
  <p class="eyebrow" style="margin-bottom:0.5rem;">Start this Sunday</p>
  <h2>Know your congregation. Care for it well.</h2>
  <p>Join churches using WorshipMetrics to track attendance, follow up with visitors, and reach people online.</p>
  <div class="btns">
    <a href={`${APP_URL}/sign-up`} class="btn-primary">Get started free</a>
    <a href="/discovery-call" class="btn-outline">Book a discovery call</a>
  </div>
</div>

</Layout>
