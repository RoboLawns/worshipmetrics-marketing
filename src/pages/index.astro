---
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.worshipmetrics.com";
const R2      = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
---

<Layout
  title="Church Attendance & Community Platform"
  description="WorshipMetrics helps your church track attendance, follow up with visitors, and engage your online audience — all in one weekly workflow your volunteers can actually run."
  canonical="/"
>
<style>
  /* ── Shared section rhythm ────────────────────── */
  .section     { padding: 5rem 1.5rem; }
  .section-alt { background: var(--bg-soft); }
  .inner       { max-width: 72rem; margin: 0 auto; }
  .inner-sm    { max-width: 48rem; margin: 0 auto; }

  .section-eyebrow { text-align: center; margin-bottom: 0.4rem; }
  .section-title   {
    font-size: clamp(1.65rem, 3vw, 2.4rem);
    font-weight: 800; text-align: center;
    color: var(--text); margin-bottom: 0.75rem; line-height: 1.15;
  }
  .section-sub { text-align: center; color: var(--text-muted); font-size: 1rem; max-width: 40rem; margin: 0 auto 3rem; line-height: 1.7; }

  /* ── Hero ─────────────────────────────────────── */
  .hero {
    padding: 5.5rem 1.5rem 4rem;
    text-align: center;
    background: linear-gradient(180deg, #eef1fd 0%, #ffffff 100%);
    border-bottom: 1px solid var(--border);
  }
  .hero-pill {
    display: inline-flex; align-items: center; gap: 0.4rem;
    background: #fff; border: 1.5px solid var(--primary-border);
    color: var(--primary); border-radius: 999px;
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    padding: 0.3rem 0.9rem; margin-bottom: 1.5rem;
    box-shadow: 0 2px 8px rgba(67,97,238,0.1);
  }
  .hero h1 {
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    font-weight: 800; line-height: 1.1; letter-spacing: -0.025em;
    color: var(--text); margin-bottom: 1.25rem;
  }
  .hero h1 span { color: var(--primary); }
  .hero-sub {
    font-size: 1.125rem; color: var(--text-soft);
    max-width: 38rem; margin: 0 auto 2.25rem; line-height: 1.72;
  }
  .hero-ctas { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; }
  .hero-fine { margin-top: 0.9rem; font-size: 0.8rem; color: var(--text-muted); }

  .trust-row {
    display: flex; flex-wrap: wrap; justify-content: center; gap: 0.6rem;
    margin-top: 2.75rem;
  }
  .trust-chip {
    display: flex; align-items: center; gap: 0.4rem;
    background: #fff; border: 1px solid var(--border);
    border-radius: 999px; padding: 0.3rem 0.85rem;
    font-size: 0.8rem; color: var(--text-soft); font-weight: 500;
    box-shadow: 0 1px 4px rgba(15,26,46,0.06);
  }
  .trust-chip svg { color: var(--primary); flex-shrink: 0; }

  /* Hero screenshot */
  .hero-img {
    max-width: 62rem; margin: 3.5rem auto 0;
    border-radius: 1rem; overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 24px 64px rgba(15,26,46,0.12), 0 4px 16px rgba(67,97,238,0.08);
  }
  .hero-img img { display: block; width: 100%; height: auto; }

  /* ── 3-col grid ───────────────────────────────── */
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  @media (max-width: 900px) { .grid-3 { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .grid-3 { grid-template-columns: 1fr; } }

  .feature-card {
    background: #fff; border: 1.5px solid var(--border);
    border-radius: var(--radius-card); padding: 1.75rem;
    text-decoration: none; display: block;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .feature-card:hover {
    border-color: var(--primary-border);
    box-shadow: 0 8px 28px rgba(67,97,238,0.09);
    transform: translateY(-2px);
  }
  .feature-icon {
    width: 2.6rem; height: 2.6rem; border-radius: 0.625rem;
    background: var(--primary-light); display: flex; align-items: center; justify-content: center;
    margin-bottom: 0.9rem;
  }
  .feature-icon svg { width: 1.2rem; height: 1.2rem; color: var(--primary); }
  .feature-card h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 0.4rem; }
  .feature-card p  { font-size: 0.875rem; color: var(--text-soft); line-height: 1.65; margin-bottom: 0.75rem; }
  .feature-card .arrow { font-size: 0.8rem; font-weight: 700; color: var(--primary); }

  /* ── Split sections ───────────────────────────── */
  .split { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .split { grid-template-columns: 1fr; gap: 2.5rem; } }
  .split-img {
    border-radius: 0.875rem; overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 12px 40px rgba(15,26,46,0.1);
  }
  .split-img img { display: block; width: 100%; height: auto; }
  .split-text h2 {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 800; color: var(--text);
    line-height: 1.2; margin-bottom: 0.75rem;
  }
  .split-text p   { color: var(--text-soft); line-height: 1.75; margin-bottom: 1.25rem; font-size: 0.95rem; }
  .bullets { list-style: none; padding: 0; margin: 0 0 1.5rem; display: flex; flex-direction: column; gap: 0.55rem; }
  .bullets li {
    display: flex; align-items: flex-start; gap: 0.65rem;
    font-size: 0.9rem; color: var(--text-soft);
  }
  .bullets li::before {
    content: ''; flex-shrink: 0;
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--primary); margin-top: 0.5rem;
  }

  /* ── Steps ────────────────────────────────────── */
  .steps { display: flex; flex-direction: column; gap: 1.75rem; max-width: 40rem; margin: 0 auto; }
  .step  { display: flex; gap: 1.25rem; align-items: flex-start; }
  .step-num {
    flex-shrink: 0; width: 2.5rem; height: 2.5rem;
    background: var(--primary); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 0.9rem; color: #fff;
    box-shadow: 0 4px 12px rgba(67,97,238,0.3);
  }
  .step-body h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 0.2rem; }
  .step-body p  { font-size: 0.875rem; color: var(--text-soft); line-height: 1.65; }

  /* ── Testimonials ─────────────────────────────── */
  .testimonial-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.25rem; }
  .testimonial {
    background: #fff; border: 1.5px solid var(--border);
    border-radius: var(--radius-card); padding: 1.5rem;
  }
  .testimonial-stars { color: var(--accent); font-size: 0.875rem; margin-bottom: 0.75rem; letter-spacing: 0.05em; }
  .testimonial blockquote { font-size: 0.9rem; color: var(--text-soft); line-height: 1.7; font-style: italic; }
  .testimonial figcaption { margin-top: 1rem; font-size: 0.78rem; color: var(--text-muted); font-weight: 600; font-style: normal; }

  /* ── Video ────────────────────────────────────── */
  .video-wrap {
    position: relative; padding-bottom: 56.25%; height: 0;
    border-radius: 0.875rem; overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 12px 40px rgba(15,26,46,0.1);
    margin-top: 2.5rem;
  }
  .video-wrap iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }

  /* ── Hardware cards ───────────────────────────── */
  .hw-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 2.5rem; }
  @media (max-width: 600px) { .hw-grid { grid-template-columns: 1fr; } }
  .hw-card {
    background: #fff; border: 1.5px solid var(--border);
    border-radius: var(--radius-card); overflow: hidden;
    text-decoration: none; display: block;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .hw-card:hover { border-color: var(--primary-border); box-shadow: 0 8px 28px rgba(67,97,238,0.1); transform: translateY(-2px); }
  .hw-card img   { display: block; width: 100%; height: 200px; object-fit: cover; }
  .hw-card-body  { padding: 1.4rem; }
  .hw-name  { font-size: 1rem; font-weight: 700; color: var(--text); }
  .hw-price { font-size: 0.82rem; font-weight: 700; color: var(--primary); }
  .hw-desc  { font-size: 0.85rem; color: var(--text-soft); line-height: 1.6; margin: 0.4rem 0 0.75rem; }

  /* ── CTA banner ───────────────────────────────── */
  .cta-band {
    background: var(--primary);
    padding: 5rem 1.5rem;
    text-align: center;
  }
  .cta-band h2 { font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 800; color: #fff; margin-bottom: 0.75rem; }
  .cta-band p  { color: rgba(255,255,255,0.8); font-size: 1rem; margin-bottom: 2rem; }
  .cta-band .btns { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; }
  .btn-white  {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.7rem 1.6rem; border-radius: var(--radius-btn);
    background: #fff; color: var(--primary);
    font-weight: 700; font-size: 0.9rem; text-decoration: none;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
    transition: box-shadow 0.15s, transform 0.15s;
  }
  .btn-white:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.2); transform: translateY(-1px); }
  .btn-white-outline {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.7rem 1.6rem; border-radius: var(--radius-btn);
    border: 2px solid rgba(255,255,255,0.5);
    color: #fff; background: transparent;
    font-weight: 700; font-size: 0.9rem; text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .btn-white-outline:hover { background: rgba(255,255,255,0.12); border-color: #fff; }
</style>

<!-- ═══════════════════════════════ HERO ════════════════════════════ -->
<section class="hero">
  <div class="inner-sm">
    <div class="hero-pill">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2"/><circle cx="12" cy="12" r="10"/></svg>
      Built for churches
    </div>
    <h1>Know who's in the room.<br/><span>Reach who isn't.</span></h1>
    <p class="hero-sub">
      WorshipMetrics helps your church track attendance, follow up with visitors, and engage
      your online audience — in one simple weekly workflow your volunteers can actually run.
    </p>
    <div class="hero-ctas">
      <a href="/discovery-call" class="btn-primary">Book a free discovery call</a>
      <a href={`${APP_URL}/sign-up`} class="btn-outline">Start for free</a>
    </div>
    <p class="hero-fine">No credit card required. Free plan available.</p>

    <div class="trust-row">
      {[
        { icon: "📱", text: "Works on any device" },
        { icon: "🙋", text: "Built for volunteers" },
        { icon: "⏱️", text: "1–3 min per service" },
        { icon: "🌐", text: "In-person + online together" },
      ].map(({ icon, text }) => (
        <span class="trust-chip">{icon} {text}</span>
      ))}
    </div>
  </div>

  <div class="hero-img">
    <img
      src={`${R2}/tablet/Worship Metrics Dashboard.jpg`}
      alt="WorshipMetrics dashboard showing attendance and people records"
      loading="eager" width="1280" height="720"
    />
  </div>
</section>

<!-- ═══════════════════════ WHAT IT DOES ══════════════════════════════ -->
<section class="section">
  <div class="inner">
    <p class="eyebrow section-eyebrow">The platform</p>
    <h2 class="section-title">One workflow. Every Sunday.</h2>
    <p class="section-sub">From counting the room to following up on Monday morning — all connected.</p>

    <div class="grid-3">
      {[
        {
          href: "/platform/attendance",
          title: "Track attendance",
          body: "Count in-person and online together. Seat templates, Auto-Count, and quick manual entry — whatever fits your Sunday.",
          icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/>`,
        },
        {
          href: "/platform/people",
          title: "Follow up faster",
          body: "Know who is new, who is missing, and who needs a pastoral check-in. Attendance becomes action, not just a number.",
          icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>`,
        },
        {
          href: "/solutions/digital-engagement",
          title: "Reach online visitors",
          body: "Turn anonymous livestream viewers and website visitors into known people your team can actually follow up with.",
          icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/>`,
        },
      ].map(({ href, title, body, icon }) => (
        <a href={href} class="feature-card">
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true" set:html={icon}/>
          </div>
          <h3>{title}</h3>
          <p>{body}</p>
          <span class="arrow">Learn more →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════════ SEAT COUNTING ════════════════════════════ -->
<section class="section section-alt">
  <div class="inner">
    <div class="split">
      <div class="split-img">
        <img
          src={`${R2}/homepage/3 Worship Metrics Attendance Tracking.jpg`}
          alt="Seat counting layout on a WorshipMetrics tablet"
          loading="lazy" width="800" height="540"
        />
      </div>
      <div class="split-text">
        <p class="eyebrow" style="margin-bottom:0.5rem;">Attendance tracking</p>
        <h2>Count the room in 1–3 minutes, every Sunday.</h2>
        <p>Build your sanctuary layout once. Volunteers confirm what changed each week — they're not recounting from zero. Auto-Count handles the hectic Sundays when there's no time to spare.</p>
        <ul class="bullets">
          <li>Seat templates built for real church spaces</li>
          <li>Auto-Count from a quick photo when time is tight</li>
          <li>In-person and livestream in one combined total</li>
          <li>Attendance patterns tied to real people records</li>
        </ul>
        <a href="/platform/attendance" class="btn-primary">See how it works</a>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════ VISITOR CAPTURE ══════════════════════════ -->
<section class="section">
  <div class="inner">
    <div class="split">
      <div class="split-text">
        <p class="eyebrow" style="margin-bottom:0.5rem;">People & follow-up</p>
        <h2>Turn guests into known people before they leave the parking lot.</h2>
        <p>Scan welcome cards with any phone camera. QR check-in for digital-first guests. Either way, a real people record is created instantly — with enough context for your team to follow up well.</p>
        <ul class="bullets">
          <li>Welcome card scanning with computer vision</li>
          <li>QR code self-check-in for phone-first guests</li>
          <li>Prayer requests routed to the right person</li>
          <li>Absence alerts before weeks become months</li>
        </ul>
        <a href="/platform/people" class="btn-primary">See people tools</a>
      </div>
      <div class="split-img">
        <img
          src={`${R2}/homepage/Worship Metrics is Easy.jpg`}
          alt="Church team using WorshipMetrics for visitor follow-up"
          loading="lazy" width="800" height="540"
        />
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════ VIDEO ═══════════════════════════════ -->
<section class="section section-alt">
  <div class="inner-sm">
    <p class="eyebrow section-eyebrow">See it in action</p>
    <h2 class="section-title">A quick look at WorshipMetrics</h2>
    <div class="video-wrap">
      <iframe
        src="https://www.youtube-nocookie.com/embed/TUTc5Q3NliM?rel=0&modestbranding=1&playsinline=1"
        title="WorshipMetrics walkthrough"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen loading="lazy"
      ></iframe>
    </div>
  </div>
</section>

<!-- ════════════════════════ WORSHIP CLIPS ══════════════════════════ -->
<section class="section">
  <div class="inner">
    <div class="split">
      <div class="split-img">
        <img
          src={`${R2}/homepage/WorshipClips Hero.jpg`}
          alt="Worship Clips converting a sermon into social media content"
          loading="lazy" width="800" height="540"
        />
      </div>
      <div class="split-text">
        <p class="eyebrow" style="margin-bottom:0.5rem;">Worship Clips</p>
        <h2>Your message doesn't end when the service does.</h2>
        <p>WorshipMetrics automatically turns your livestream into ready-to-post clips for Instagram, YouTube Shorts, TikTok, and Facebook. No video editing software. One volunteer. Under an hour.</p>
        <ul class="bullets">
          <li>52 clips/year on Essentials · Unlimited on Established</li>
          <li>Vertical, square, and horizontal formats created automatically</li>
          <li>Reach people who weren't in the room on Sunday</li>
        </ul>
        <a href="/solutions/worship-clips" class="btn-primary">See Worship Clips</a>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════ COMMUNITY PLATFORM ════════════════════ -->
<section class="section section-alt">
  <div class="inner">
    <div class="split">
      <div class="split-text">
        <p class="eyebrow" style="margin-bottom:0.5rem;">Community Platform</p>
        <h2>Build a digital home your congregation will actually use.</h2>
        <p>We set up a Discord-based community platform for your church — prayer channels, small group spaces, YouTube chat sync, announcements, and member onboarding. All week long, not just Sunday.</p>
        <ul class="bullets">
          <li>Discord setup, automations, and YouTube chat sync</li>
          <li>Ministry-specific channels your team designs</li>
          <li>One-time setup fee — we handle the technical lift</li>
        </ul>
        <a href="/solutions/church-community-platform" class="btn-primary">See community platform</a>
      </div>
      <div class="split-img">
        <img
          src={`${R2}/homepage/WorshipMetrics Discord Setup.jpg`}
          alt="WorshipMetrics Discord community platform"
          loading="lazy" width="800" height="540"
        />
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════ HOW IT WORKS ════════════════════════ -->
<section class="section">
  <div class="inner">
    <p class="eyebrow section-eyebrow">The weekly rhythm</p>
    <h2 class="section-title">Simple enough to repeat every Sunday.</h2>
    <p class="section-sub">A three-step loop your whole team can run without any training overhead.</p>
    <ol class="steps">
      {[
        { n:"1", t:"Count",     b:"Volunteers use a seat template or Auto-Count to log attendance in 1–3 minutes during or after service." },
        { n:"2", t:"Capture",   b:"New visitors, prayer requests, and online interactions get attached to real people records automatically." },
        { n:"3", t:"Follow up", b:"Leadership gets a clear Monday summary: who's new, who's missing, what needs pastoral attention this week." },
      ].map(({ n, t, b }) => (
        <li class="step">
          <span class="step-num">{n}</span>
          <div class="step-body"><h3>{t}</h3><p>{b}</p></div>
        </li>
      ))}
    </ol>
  </div>
</section>

<!-- ════════════════════════ TESTIMONIALS ═══════════════════════════ -->
<section class="section section-alt">
  <div class="inner">
    <p class="eyebrow section-eyebrow">What churches are saying</p>
    <h2 class="section-title">Real results from real ministry teams.</h2>
    <div class="testimonial-grid" style="margin-top:2.5rem;">
      {[
        { q: "Before WorshipMetrics, we had no idea who was watching our stream. Now we have a follow-up system running within 24 hours of every service.", a: "Executive Pastor, mid-size church, Southeast U.S." },
        { q: "The consulting piece made the difference. We had the technology — we just didn't know how to use it pastorally.", a: "Lead Pastor, growing church, Midwest" },
        { q: "Our YouTube chat used to go unmonitored every Sunday. Now someone is in there welcoming viewers and routing prayer requests in real time.", a: "Communications Director, large church, Texas" },
      ].map(({ q, a }) => (
        <figure class="testimonial">
          <div class="testimonial-stars">★★★★★</div>
          <blockquote>"{q}"</blockquote>
          <figcaption>— {a}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════════ HARDWARE ROW ═══════════════════════════ -->
<section class="section">
  <div class="inner">
    <p class="eyebrow section-eyebrow">Hardware</p>
    <h2 class="section-title">Purpose-built devices for churches.</h2>
