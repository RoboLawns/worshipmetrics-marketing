---
import Layout from "../layouts/Layout.astro";
import IntegrationsBand from "../components/integrations/IntegrationsBand.astro";

const SITE_URL = "https://worshipmetrics.com";
const R2 = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
const HERO_IMAGE = `${R2}/homepage/new%20images/Worship%20Volunteers%20Working%20Together.jpg`;
const SERVICES_IMAGE = `${R2}/homepage/Team%20Collaboration%20hero.jpg`;
const STREAM_HEALTH_IMAGE = `${R2}/homepage/new%20images/Stream%20Health.jpg`;
const VOLUNTEER_PANEL_IMAGE = `${R2}/Tech%20Manager/WorshipMetrics%20Tech%20Manager%20Web-UI%20Panels.jpg`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "WorshipMetrics",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web, Windows, Mac, iOS, Android",
  url: SITE_URL,
  image: HERO_IMAGE,
  description: "WorshipMetrics helps churches run Sunday well, build a real team behind the booth, and extend the message to everyone Sunday could not reach in person.",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
    url: `${SITE_URL}/pricing`,
  },
};
---

<Layout
  title="Move Those in the Room. Reach Who Isn't"
  socialTitle="WorshipMetrics | Move Those in the Room. Reach Who Isn't"
  description="Worship Metrics gives churches the tools to run Sunday well, build a real team behind the booth, and extend the message to everyone Sunday couldn't reach in person."
  canonical="/"
  ogImage={HERO_IMAGE}
  structuredData={structuredData}
>
  <Fragment slot="head">
    <link rel="preload" as="image" href={HERO_IMAGE} />
  </Fragment>

  <section class="bg-gradient-to-b from-indigo-50 via-white to-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)]">
      <div>
        <p class="inline-flex rounded-full border border-slate-200 bg-slate-50 px-4 py-1 text-[11px] font-medium uppercase tracking-[0.18em] text-slate-500 shadow-sm">
          Free forever. No credit card required.
        </p>
        <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
          Move those in the room. Reach who isn't.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-600 sm:text-xl">
          Worship Metrics gives churches the tools to run Sunday well, build a real team behind the booth, and extend the message to everyone Sunday couldn't reach in person.
        </p>
        <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
          <a href="/platform" class="btn-primary" data-wm-track="cta_click" data-wm-track-label="home_hero_see_how_it_works" data-wm-track-location="home_hero">See how it works</a>
          <a href="/discovery-call" class="btn-outline" data-wm-track="cta_click" data-wm-track-label="home_hero_talk_team" data-wm-track-location="home_hero">Talk with our team</a>
        </div>
      </div>

      <div class="overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-[0_24px_60px_rgba(15,23,42,0.12)]">
        <img src={HERO_IMAGE} alt="Church volunteers working together with WorshipMetrics" loading="eager" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-2">
      <div class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-8 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Reach</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Reach further than your sanctuary.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          Livestream that actually works. Sermon clips ready to publish before the parking lot empties. Digital signage that updates from a phone. Every Sunday becomes content that finds the people who weren't there.
        </p>
      </div>
      <div class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-8 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Team</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Build the team that makes it possible.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          Role-based control panels for every job in the booth. Volunteer scheduling that doesn't depend on one exhausted coordinator. Training-friendly workflows so a teenager can run a camera with confidence. One person can't carry Sunday, and shouldn't have to.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-2">
      <div class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Tech Manager</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">The desktop app that powers the booth.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          Map your system, monitor your stream, control your cameras, and turn every Sunday into ready-to-publish clips without leaving the room.
        </p>
        <p class="mt-5 inline-flex rounded-full bg-indigo-50 px-3 py-1 text-sm font-semibold text-indigo-700">
          Worship Clips is included free.
        </p>
        <div class="mt-8">
          <a href="/tech-manager" class="btn-primary">See Tech Manager →</a>
        </div>
      </div>
      <div class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Platform</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">The Worship Metrics Platform</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          The cloud platform behind the ministry. Plan the service, share the load with your team, count attendance in-room and online, and walk into Monday already knowing who needs follow-up.
        </p>
        <div class="mt-8">
          <a href="/platform" class="btn-primary">See the Platform →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">How it works</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Plan. Run. Know.</h2>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {[
          {
            title: "Plan",
            body: "Build the service in a format pastors, volunteers, and the booth can all understand.",
            href: "/services",
          },
          {
            title: "Run",
            body: "Keep the room steady with booth tools, role panels, and a clearer live workflow.",
            href: "/tech-manager",
          },
          {
            title: "Know",
            body: "Walk into Monday with clearer attendance, healthier follow-up, and better visibility into what really happened.",
            href: "/platform/attendance",
          },
        ].map(({ title, body, href }, index) => (
          <a href={href} class="rounded-3xl border border-slate-200 bg-slate-50 p-8 shadow-sm transition hover:border-indigo-300 hover:bg-white hover:shadow-md">
            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-indigo-600 text-sm font-bold text-white">{index + 1}</span>
            <h3 class="mt-5 text-xl font-bold text-slate-900">{title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{body}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[minmax(0,0.98fr)_minmax(0,1.02fr)]">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Prove your AV is serving the mission</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Most AV vendors lead with a quote. We lead with a question.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          Is what you already have actually serving the mission? Our pilot helps you answer that, with real data on attendance, engagement, and system health. When the time comes to upgrade equipment or plan an install, you'll have the metrics to justify it.
        </p>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          And we'll be ready to help with that too, on your timeline, not ours.
        </p>
        <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
          <a href="/pilot-program" class="btn-primary">Start your pilot</a>
          <a href="/your-av-partner" class="btn-outline">See AV Partner services</a>
        </div>
      </div>
      <div class="overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-sm">
        <img src={STREAM_HEALTH_IMAGE} alt="Stream health dashboard in WorshipMetrics" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[minmax(0,0.98fr)_minmax(0,1.02fr)]">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Build a ministry, not just a production team</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Your AV booth could be where new volunteers find their place.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          Churches need volunteers. Youth ministries need meaningful next steps for students who are ready for real responsibility. Worship Metrics brings those two needs together.
        </p>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          With role-based interfaces, simpler control panels, and training-friendly workflows, you can invite more people into Sunday without throwing them into the deep end. That is how an AV Club becomes a ministry, not just a staffing fix.
        </p>
        <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
          <a href="/av-club" class="btn-primary">Start a Church AV Club</a>
          <a href="/volunteers" class="btn-outline">See the volunteer workflow</a>
        </div>
      </div>
      <div class="overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-sm">
        <img src={VOLUNTEER_PANEL_IMAGE} alt="Volunteer-friendly control panels in WorshipMetrics" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Services</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Plan the service. Share the work. Make Sunday easier.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          Services is where the whole church gets on the same page. It gives staff, volunteers, and the booth one service workflow instead of a pile of disconnected notes and texts.
        </p>
        <ul class="mt-8 space-y-3 text-sm text-slate-700 sm:text-base">
          {[
            "Free Forever gets the whole team into the same service plan",
            "Paid tiers add the production engine that makes live Sunday smoother",
            "Every role becomes easier to share with new volunteers and younger team members",
          ].map((item) => (
            <li class="flex items-start gap-3"><span class="mt-2 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-indigo-500"></span><span>{item}</span></li>
          ))}
        </ul>
        <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
          <a href="/services" class="btn-primary">See Services</a>
          <a href="/pricing" class="btn-outline">See pricing</a>
        </div>
      </div>
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src={SERVICES_IMAGE} alt="Services workflow in WorshipMetrics" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>
  </section>

  <IntegrationsBand />

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl rounded-[2rem] border border-slate-200 bg-slate-50 p-10 text-center shadow-sm sm:p-12">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Not sure where to start?</h2>
      <p class="mx-auto mt-4 max-w-3xl text-base leading-relaxed text-slate-600 sm:text-lg">
        Talk with our team for 30 minutes. We'll listen first, recommend second.
      </p>
      <div class="mt-8">
        <a href="/discovery-call" class="btn-primary">Book a call →</a>
      </div>
    </div>
  </section>
</Layout>
