---
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.worshipmetrics.com";
const R2      = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
const R2NEW   = `${R2}/homepage/new%20images`;
---

<Layout
  title="The Church Technology Partner"
  description="WorshipMetrics is your church's technology partner — from automatic attendance and AV monitoring to livestream health, digital signage, volunteer tools, and online reach. Built by worship leaders, for worship leaders."
  canonical="/"
>
<style>
  /* ── Shared rhythm ─────────────────────────────────── */
  .section      { padding: 5rem 1.5rem; }
  .section-alt  { background: var(--bg-soft); }
  .inner        { max-width: 72rem; margin: 0 auto; }
  .inner-md     { max-width: 56rem; margin: 0 auto; }
  .inner-sm     { max-width: 44rem; margin: 0 auto; }

  .eyebrow-center { text-align: center; margin-bottom: 0.4rem; }
  .h2-center {
    font-size: clamp(1.7rem, 3vw, 2.5rem); font-weight: 800;
    color: var(--text); text-align: center; line-height: 1.15; margin-bottom: 0.75rem;
  }
  .sub-center {
    text-align: center; color: var(--text-muted); font-size: 1rem;
    max-width: 42rem; margin: 0 auto 3rem; line-height: 1.72;
  }

  /* ── HERO ──────────────────────────────────────────── */
  .hero {
    padding: 5.5rem 1.5rem 0;
    text-align: center;
    background: linear-gradient(175deg, #eef1fd 0%, #ffffff 60%);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 0.4rem;
    background: #fff; border: 1.5px solid var(--primary-border);
    color: var(--primary); border-radius: 999px;
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.28rem 0.9rem; margin-bottom: 1.5rem;
    box-shadow: 0 2px 8px rgba(67,97,238,0.1);
  }
  .hero h1 {
    font-size: clamp(2.4rem, 5.5vw, 4.25rem); font-weight: 800;
    line-height: 1.08; letter-spacing: -0.03em; color: var(--text);
    margin-bottom: 1.25rem;
  }
  .hero h1 em { font-style: normal; color: var(--primary); }
  .hero-sub {
    font-size: 1.1rem; color: var(--text-soft); max-width: 42rem;
    margin: 0 auto 2.25rem; line-height: 1.75;
  }
  .hero-ctas { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; margin-bottom: 0.9rem; }
  .hero-fine  { font-size: 0.8rem; color: var(--text-muted); margin-bottom: 3rem; }

  .hero-img-wrap {
    max-width: 64rem; margin: 0 auto;
    border-radius: 1rem 1rem 0 0; overflow: hidden;
    border: 1px solid var(--border); border-bottom: none;
    box-shadow: 0 -4px 40px rgba(67,97,238,0.06), 0 24px 64px rgba(15,26,46,0.1);
  }
  .hero-img-wrap img { display: block; width: 100%; height: auto; }

  .social-proof-bar {
    background: #0f1a2e; color: rgba(255,255,255,0.86);
    text-align: center; padding: 0.95rem 1.5rem;
    font-size: 0.85rem; font-weight: 700; letter-spacing: 0.02em;
  }

  /* ── PAIN → PROMISE ────────────────────────────────── */
  .pain-grid {
    display: grid; grid-template-columns: repeat(2,1fr); gap: 1.5rem;
  }
  @media (max-width: 860px) { .pain-grid { grid-template-columns: 1fr; max-width: 36rem; margin: 0 auto; } }

  .pain-card {
    border: 1.5px solid var(--border); border-radius: var(--radius-card);
    background: #fff; padding: 1.75rem; position: relative; overflow: hidden;
    transition: box-shadow 0.2s, border-color 0.2s, transform 0.2s;
  }
  .pain-card:hover { border-color: var(--primary-border); box-shadow: 0 8px 28px rgba(67,97,238,0.09); transform: translateY(-2px); }
  .pain-before {
    font-size: 0.75rem; font-weight: 700; color: #dc2626;
    letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.5rem;
    display: flex; align-items: center; gap: 0.35rem;
  }
  .pain-before::before { content: '✕'; font-size: 0.7rem; }
  .pain-after {
    font-size: 0.75rem; font-weight: 700; color: #16a34a;
    letter-spacing: 0.08em; text-transform: uppercase; margin: 1rem 0 0.5rem;
    display: flex; align-items: center; gap: 0.35rem;
  }
  .pain-after::before { content: '✓'; font-size: 0.7rem; }
  .pain-problem { font-size: 0.925rem; color: var(--text-soft); line-height: 1.6; font-style: italic; }
  .pain-solution { font-size: 0.925rem; color: var(--text); font-weight: 600; line-height: 1.6; }
  .pain-icon {
    width: 2.75rem; height: 2.75rem; border-radius: 0.625rem;
    background: var(--primary-light); display: flex; align-items: center; justify-content: center;
    margin-bottom: 1rem;
  }
  .pain-icon svg { width: 1.3rem; height: 1.3rem; color: var(--primary); }

  /* ── ECOSYSTEM GRID ────────────────────────────────── */
  .eco-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 2.5rem;
  }
  @media (max-width: 900px) { .eco-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .eco-grid { grid-template-columns: 1fr; } }

  .eco-card {
    background: #fff; border: 1.5px solid var(--border);
    border-radius: var(--radius-card); padding: 1.5rem;
    text-decoration: none; display: flex; flex-direction: column; gap: 0.5rem;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .eco-card:hover { border-color: var(--primary-border); box-shadow: 0 8px 28px rgba(67,97,238,0.09); transform: translateY(-2px); }
  .eco-label {
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--text-muted);
  }
  .eco-title { font-size: 1rem; font-weight: 700; color: var(--text); }
  .eco-desc  { font-size: 0.825rem; color: var(--text-soft); line-height: 1.6; flex: 1; }
  .eco-link  { font-size: 0.8rem; font-weight: 700; color: var(--primary); margin-top: 0.25rem; }
  .eco-badge {
    display: inline-block; font-size: 0.65rem; font-weight: 700;
    padding: 0.2rem 0.55rem; border-radius: 999px;
    background: #dcfce7; color: #15803d; align-self: flex-start;
  }

  /* ── SPLIT SECTION ─────────────────────────────────── */
  .split { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  @media (max-width: 768px) { .split { grid-template-columns: 1fr; gap: 2.5rem; } }
  .split-img {
    border-radius: 0.875rem; overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 12px 40px rgba(15,26,46,0.09);
  }
  .split-img img { display: block; width: 100%; height: auto; }
  .split-text h2 {
    font-size: clamp(1.5rem, 2.5vw, 2rem); font-weight: 800;
    color: var(--text); line-height: 1.2; margin-bottom: 0.75rem;
  }
  .split-text p   { color: var(--text-soft); line-height: 1.77; margin-bottom: 1.25rem; font-size: 0.95rem; }
  .bullets { list-style: none; padding: 0; margin: 0 0 1.5rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .bullets li {
    display: flex; align-items: flex-start; gap: 0.65rem;
    font-size: 0.9rem; color: var(--text-soft);
  }
  .bullets li::before {
    content: ''; flex-shrink: 0; width: 6px; height: 6px;
    border-radius: 50%; background: var(--primary); margin-top: 0.5rem;
  }

  /* ── AV / SIGNAGE highlight band ───────────────────── */
  .highlight-band {
    background: var(--primary); border-radius: 1.25rem;
    padding: 2.5rem; display: flex; align-items: center; gap: 2rem;
    margin-bottom: 1.5rem;
  }
  @media (max-width: 640px) { .highlight-band { flex-direction: column; text-align: center; } }
  .highlight-band-icon {
    flex-shrink: 0; width: 3.5rem; height: 3.5rem;
    background: rgba(255,255,255,0.15); border-radius: 0.875rem;
    display: flex; align-items: center; justify-content: center;
  }
  .highlight-band-icon svg { width: 1.75rem; height: 1.75rem; color: #fff; }
  .highlight-band h3 { font-size: 1.1rem; font-weight: 800; color: #fff; margin-bottom: 0.35rem; }
  .highlight-band p  { font-size: 0.875rem; color: rgba(255,255,255,0.8); line-height: 1.65; margin: 0; }

  /* ── VOLUNTEER ROLES ───────────────────────────────── */
  .roles-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1rem; margin-top: 2.5rem; }
  @media (max-width: 900px) { .roles-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) { .roles-grid { grid-template-columns: 1fr; } }

  .role-card {
    background: #fff; border: 1.5px solid var(--border);
    border-radius: var(--radius-card); padding: 1.4rem;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .role-card:hover { border-color: var(--primary-border); box-shadow: 0 8px 24px rgba(67,97,238,0.08); transform: translateY(-2px); }
  .role-emoji { font-size: 1.75rem; margin-bottom: 0.75rem; }
  .role-name { font-size: 0.875rem; font-weight: 800; color: var(--text); margin-bottom: 0.2rem; }
  .role-job  { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--primary); margin-bottom: 0.5rem; }
  .role-desc { font-size: 0.825rem; color: var(--text-soft); line-height: 1.6; }

  /* ── ORIGIN / MISSION ──────────────────────────────── */
  .mission-band {
    background: var(--text); border-radius: 1.5rem;
    padding: 3.5rem; text-align: center;
  }
  .mission-band h2 { font-size: clamp(1.6rem, 2.5vw, 2.2rem); font-weight: 800; color: #fff; margin-bottom: 0.75rem; line-height: 1.2; }
  .mission-band p  { color: rgba(255,255,255,0.7); font-size: 1rem; line-height: 1.75; max-width: 42rem; margin: 0 auto 2rem; }
  .founders { display: flex; justify-content: center; gap: 2rem; flex-wrap: wrap; margin-bottom: 2rem; }
  .founder  {
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    width: 9rem;
  }
  .founder-avatar {
    width: 5rem; height: 5rem; border-radius: 50%;
    background: rgba(255,255,255,0.12); border: 2px solid rgba(255,255,255,0.2);
    overflow: hidden; display: flex; align-items: center; justify-content: center;
    color: rgba(255,255,255,0.4); font-size: 1.5rem;
  }
  .founder-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .founder-name  { font-size: 0.875rem; font-weight: 700; color: #fff; }
  .founder-title { font-size: 0.75rem; color: rgba(255,255,255,0.55); text-align: center; }

  /* ── LUMINOS BAND ──────────────────────────────────── */
  .luminos-band {
    background: linear-gradient(135deg, #f0f3fb 0%, #e8ecff 100%);
    border: 1.5px solid var(--primary-border); border-radius: 1.25rem;
    padding: 2.5rem; display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: center;
  }
  @media (max-width: 640px) { .luminos-band { grid-template-columns: 1fr; } }
  .luminos-tag { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--primary); margin-bottom: 0.5rem; }
  .luminos-band h3 { font-size: 1.4rem; font-weight: 800; color: var(--text); margin-bottom: 0.6rem; line-height: 1.2; }
  .luminos-band p  { font-size: 0.9rem; color: var(--text-soft); line-height: 1.7; margin-bottom: 1.25rem; }
  .luminos-prompts { display: flex; flex-direction: column; gap: 0.5rem; }
  .luminos-prompt {
    background: #fff; border: 1px solid var(--border);
    border-radius: 0.625rem; padding: 0.65rem 0.9rem;
    font-size: 0.825rem; color: var(--text-soft); font-style: italic;
  }
  .luminos-prompt span { font-style: normal; font-weight: 700; color: var(--primary); }

  /* ── STEPS ─────────────────────────────────────────── */
  .steps { display: flex; flex-direction: column; gap: 1.75rem; max-width: 40rem; margin: 0 auto; }
  .step  { display: flex; gap: 1.25rem; align-items: flex-start; }
  .step-num {
    flex-shrink: 0; width: 2.5rem; height: 2.5rem; border-radius: 50%;
    background: var(--primary); display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 0.9rem; color: #fff;
    box-shadow: 0 4px 12px rgba(67,97,238,0.3);
  }
  .step-body h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 0.2rem; }
  .step-body p  { font-size: 0.875rem; color: var(--text-soft); line-height: 1.65; }

  /* ── CTA BAND ──────────────────────────────────────── */
  .cta-band { background: var(--primary); padding: 5.5rem 1.5rem; text-align: center; }
  .cta-band h2 { font-size: clamp(1.9rem, 3.5vw, 2.75rem); font-weight: 800; color: #fff; margin-bottom: 0.75rem; line-height: 1.15; }
  .cta-band p  { color: rgba(255,255,255,0.8); font-size: 1.05rem; margin-bottom: 2.25rem; max-width: 36rem; margin-left: auto; margin-right: auto; }
  .cta-btns { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; margin-bottom: 1.25rem; }
  .btn-white {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.75rem 1.75rem; border-radius: var(--radius-btn);
    background: #fff; color: var(--primary); font-weight: 700; font-size: 0.9rem;
    text-decoration: none; box-shadow: 0 4px 16px rgba(0,0,0,0.15);
    transition: box-shadow 0.15s, transform 0.15s;
  }
  .btn-white:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.2); transform: translateY(-1px); }
  .btn-ghost-white {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.75rem 1.75rem; border-radius: var(--radius-btn);
    border: 2px solid rgba(255,255,255,0.45); color: #fff; background: transparent;
    font-weight: 700; font-size: 0.9rem; text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .btn-ghost-white:hover { background: rgba(255,255,255,0.12); border-color: #fff; }
  .cta-note { font-size: 0.82rem; color: rgba(255,255,255,0.55); }
</style>

<!-- ═══════════════════════════════════════════════════
     HERO
════════════════════════════════════════════════════ -->
<section class="hero">
  <div class="inner-sm">
    <div class="hero-badge">
      The complete church technology platform
    </div>
    <h1>
      Know who's in the room.<br/>
      <em>Reach who isn't.</em>
    </h1>
    <p class="hero-sub">
      The complete church technology platform — automatic attendance, free digital signage,
      AV monitoring, and tools that connect your congregation all week long.
    </p>
    <div class="hero-ctas">
      <a href={`${APP_URL}/sign-up`} class="btn-primary">Start free — no credit card</a>
      <a href="/appliance" class="btn-outline">See the Hub</a>
    </div>
    <p class="hero-fine">Free forever. Upgrade when you're ready.</p>
  </div>

  <div class="hero-img-wrap">
    <img
      src={`${R2}/homepage/WorshipMetrics%20Hero%20New.jpg`}
      alt="WorshipMetrics — the church technology partner"
      loading="eager" width="1280" height="720"
    />
  </div>
</section>

<section class="social-proof-bar">
  Trusted by churches of every size — from 50 seats to 5,000.
</section>

<!-- ═══════════════════════════════════════════════════
     PAIN → PROMISE
════════════════════════════════════════════════════ -->
<section class="section">
  <div class="inner">
    <p class="eyebrow eyebrow-center">The challenge</p>
    <h2 class="h2-center">Every church is doing technology.<br/>Most are doing it alone.</h2>
    <p class="sub-center">We built WorshipMetrics because we lived these problems firsthand.</p>

    <div class="pain-grid">
      {[
        {
          icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z"/>`,
          before: "You're counting on paper",
          problem: "Someone tallies attendance on a notepad. It maybe gets entered into a spreadsheet. Maybe.",
          after: "What WorshipMetrics does",
          solution: "Auto-Count does the heavy lifting. Luminos AI turns numbers into pastoral insight before Monday morning.",
        },
        {
          icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/>`,
          before: "Your stream goes down unnoticed",
          problem: "Twelve minutes in someone texts you. Half your online congregation already gave up.",
          after: "What WorshipMetrics does",
          solution: "Real-time AV monitoring alerts your team the moment something goes wrong — before anyone else knows.",
        },
        {
          icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/>`,
          before: "Online viewers are invisible",
          problem: "You get a view count. You have no idea who they are, whether they came back, or how to reach them.",
          after: "What WorshipMetrics does",
          solution: "Digital engagement tools capture online visitors, route prayer requests, and turn viewership into relationships.",
        },
        {
          icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 4.5A2.25 2.25 0 014.5 2.25h15A2.25 2.25 0 0121.75 4.5v11.25A2.25 2.25 0 0119.5 18h-6l-3.75 3.75V18h-5.25A2.25 2.25 0 012.25 15.75V4.5z"/>`,
          before: "Your lobby screen hasn't been updated in weeks",
          problem: "Someone has to walk to a computer in the building, open a file, and remember the password.",
          after: "What WorshipMetrics does",
          solution: "Free digital signage. Update every screen in your church from your phone, from anywhere, right now.",
        },
      ].map(({ icon, before, problem, after, solution }) => (
        <div class="pain-card">
          <div class="pain-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true" set:html={icon}/>
          </div>
          <div class="pain-before">{before}</div>
          <p class="pain-problem">"{problem}"</p>
          <div class="pain-after">{after}</div>
          <p class="pain-solution">{solution}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     DIGITAL SIGNAGE — FREE
════════════════════════════════════════════════════ -->
<section class="section section-alt">
  <div class="inner">
    <div class="split">
      <div class="split-img">
        <img
          src={`${R2NEW}/Church%20Digital%20Signage.jpg`}
          alt="Church digital signage display showing announcements"
          loading="lazy" width="800" height="540"
        />
      </div>
      <div class="split-text">
        <p class="eyebrow" style="margin-bottom:0.5rem;">Digital signage</p>
        <h2>Free digital signage.<br/>Because we believe in the mission.</h2>
        <p>Update every screen in your church from your phone — announcements, countdowns, event slides, welcome messages. Cloud-managed, instantly updated, and completely free on every plan.</p>
        <p style="font-size:0.875rem;color:var(--text-muted);font-style:italic;">We give signage away because we believe churches shouldn't pay to keep their congregation informed. Point any smart TV at a URL and it's live in under a minute.</p>
        <ul class="bullets">
          <li>Works with TVs you already own</li>
          <li>Unlimited screens on paid plans — 1 screen free forever</li>
          <li>No hardware required. No monthly fees. Ever.</li>
          <li>Push updates from your phone mid-service</li>
        </ul>
        <a href={`${APP_URL}/sign-up`} class="btn-primary">Start free — get your signage URL</a>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     HUB
════════════════════════════════════════════════════ -->
<section class="section">
  <div class="inner">
    <div class="split">
      <div class="split-text">
        <p class="eyebrow" style="margin-bottom:0.5rem;">Introducing the Worship Metrics Hub</p>
        <h2>One device. Your entire church, connected.</h2>
        <p>The Hub is a cloud-connected appliance that plugs into your existing setup and runs your entire Established plan automatically — no computer, no configuration, no volunteer overhead.</p>
        <ul class="bullets">
          <li>Fully automatic attendance — your camera counts your congregation every week</li>
          <li>AV health monitoring — stream, audio, video, and display status in real time</li>
          <li>Remote PTZ camera control — pan, tilt, zoom from anywhere in the world</li>
          <li>Remote OBS and vMix control — run a great service without being in the building</li>
          <li>Auto video upload — sermon clips in the cloud before the last car leaves the parking lot</li>
          <li>Digital signage — lobby displays managed from your phone</li>
        </ul>
        <p style="font-size:0.85rem;color:var(--text-muted);margin-bottom:1rem;">No subscription required. One-time purchase. Plug it in and it works.</p>
        <div style="display:flex;flex-wrap:wrap;gap:0.75rem;">
          <a href="/appliance" class="btn-primary">See the Hub — $499</a>
          <a href="/pricing" class="btn-outline">Compare plans</a>
        </div>
      </div>
      <div class="split-img">
        <img
          src={`${R2NEW}/Stream%20Health.jpg`}
          alt="WorshipMetrics AV monitoring and stream health dashboard"
          loading="lazy" width="800" height="540"
        />
      </div>
    </div>
