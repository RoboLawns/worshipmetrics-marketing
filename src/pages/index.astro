---
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.worshipmetrics.com";
---

<Layout
  title="Church Attendance & Community Platform"
  description="WorshipMetrics gives churches effortless attendance tracking, member management, and community engagement tools — all in one place."
  canonical="/"
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-indigo-50 via-white to-slate-50 px-4 py-24 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <span class="inline-block rounded-full bg-indigo-100 px-4 py-1 text-xs font-semibold uppercase tracking-widest text-indigo-700">
        Built for churches
      </span>
      <h1 class="mt-6 text-4xl font-extrabold leading-tight tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
        Know your congregation.<br />
        <span class="text-indigo-600">Grow your community.</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-600">
        WorshipMetrics makes it simple to track attendance, understand your members, and
        stay connected — without the spreadsheets or complexity.
      </p>
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={`${APP_URL}/sign-up`}
          class="w-full rounded-xl bg-indigo-600 px-8 py-3.5 text-base font-semibold text-white shadow-md transition hover:bg-indigo-700 sm:w-auto"
        >
          Get started free
        </a>
        <a
          href="/features"
          class="w-full rounded-xl border border-slate-300 bg-white px-8 py-3.5 text-base font-semibold text-slate-700 transition hover:border-indigo-400 hover:text-indigo-600 sm:w-auto"
        >
          See all features →
        </a>
      </div>
      <p class="mt-4 text-sm text-slate-400">No credit card required. Free trial available.</p>
    </div>

    <!-- Decorative background blobs -->
    <div class="pointer-events-none absolute -top-32 -right-32 h-96 w-96 rounded-full bg-indigo-200 opacity-20 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-violet-300 opacity-20 blur-3xl"></div>
  </section>

  <!-- Social proof bar -->
  <section class="border-y border-slate-100 bg-white px-4 py-6 sm:px-6 lg:px-8">
    <p class="text-center text-sm font-medium text-slate-400">
      Trusted by churches across the country
    </p>
  </section>

  <!-- Feature highlights -->
  <section class="px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="text-center">
        <h2 class="text-3xl font-bold text-slate-900">Everything your church needs</h2>
        <p class="mt-3 text-slate-500">Powerful features without the enterprise price tag.</p>
      </div>

      <div class="mt-14 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {[
          {
            icon: "📊",
            title: "Attendance Tracking",
            body: "Record head counts in seconds with one-tap entry, auto-scheduling, and historical trend reports.",
          },
          {
            icon: "👥",
            title: "Member Management",
            body: "Maintain a rich directory with roles, birthdays, contact info, and custom groups.",
          },
          {
            icon: "📱",
            title: "Mobile Ready",
            body: "Works on any device — phone, tablet, or desktop. No app install required.",
          },
          {
            icon: "📈",
            title: "Analytics & Insights",
            body: "Spot growth trends, track first-time visitors, and export reports for leadership.",
          },
          {
            icon: "🔔",
            title: "Celebrations & Alerts",
            body: "Automated birthday and anniversary reminders so no milestone slips through.",
          },
          {
            icon: "🔒",
            title: "Secure & Private",
            body: "Role-based access control keeps sensitive member data in the right hands.",
          },
        ].map(({ icon, title, body }) => (
          <div class="rounded-2xl border border-slate-100 bg-slate-50 p-6 shadow-sm">
            <div class="mb-4 text-3xl">{icon}</div>
            <h3 class="font-semibold text-slate-900">{title}</h3>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">{body}</p>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center">
        <a href="/features" class="text-sm font-semibold text-indigo-600 hover:text-indigo-800">
          See the full feature list →
        </a>
      </div>
    </div>
  </section>

  <!-- CTA banner -->
  <section class="bg-indigo-600 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold text-white">Ready to get started?</h2>
      <p class="mt-4 text-indigo-200">
        Join churches already using WorshipMetrics to know and grow their congregations.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={`${APP_URL}/sign-up`}
          class="rounded-xl bg-white px-8 py-3 text-base font-semibold text-indigo-700 shadow transition hover:bg-indigo-50"
        >
          Create your free account
        </a>
        <a
          href={`${APP_URL}/sign-in`}
          class="rounded-xl border border-indigo-400 px-8 py-3 text-base font-semibold text-white transition hover:bg-indigo-700"
        >
          Sign in
        </a>
      </div>
    </div>
  </section>
</Layout>
