---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Pilot Program Request Received"
  description="Your pilot program request has been received. We'll reach out within 1–2 business days."
  canonical="/pilot-program/thank-you"
  robots="noindex,follow"
>
  <section class="bg-white px-6 py-24 sm:py-32">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-indigo-600">Thank you</p>
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
        Your pilot request has been received.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-600 sm:text-xl">
        We&apos;ll reach out within 1–2 business days to schedule a quick call and learn more about your congregation.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/discovery-call" class="rounded-xl bg-indigo-600 px-8 py-3 text-base font-semibold text-white shadow transition hover:bg-indigo-700">
          Book a call now instead
        </a>
        <a href="/" class="rounded-xl border border-slate-300 px-8 py-3 text-base font-semibold text-slate-700 transition hover:border-indigo-400 hover:text-indigo-600">
          Return to homepage
        </a>
      </div>
    </div>
  </section>
</Layout>
