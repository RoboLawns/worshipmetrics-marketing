---
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.worshipmetrics.com";
const SITE_URL = "https://worshipmetrics.com";
const R2 = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
const HERO_IMAGE = `${R2}/homepage/Worship%20Metrics%20Team%20Collaboration.jpg`;
const CHAT_IMAGE = `${R2}/homepage/Team%20Chat%20with%20Members.jpg`;

const features = [
  {
    title: "Real-time booth communication",
    body: "Chat flows alongside your service workflow so the team stays in sync without switching apps. Operators, directors, and volunteers all see the same conversation.",
  },
  {
    title: "Role-based channels",
    body: "Production, audio, lighting, and welcome teams each get their own space. Conversations stay relevant and nobody gets flooded with messages they don't need.",
  },
  {
    title: "Production intercom",
    body: "When Pro is active, chat becomes an intercom layer that travels with the live service. Cue confirmations, timing checks, and quick fixes happen in the same surface the team is already watching.",
  },
  {
    title: "Ministry-wide messaging",
    body: "Beyond Sunday, chat keeps staff, volunteers, and ministry leads connected during the week. Plan changes, scheduling updates, and prayer requests don't need a separate group text.",
  },
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "WorshipMetrics Team Chat",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web, iOS, Android",
  url: `${SITE_URL}/team-chat`,
  image: HERO_IMAGE,
  description: "Real-time team communication built into the same platform that runs Sunday. Chat flows alongside your service workflow so nobody has to switch apps mid-service.",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
    url: `${SITE_URL}/pricing`,
  },
};
---

<Layout
  title="Team Chat"
  socialTitle="WorshipMetrics Team Chat"
  description="Real-time team communication built into the same platform that runs Sunday. Chat flows alongside your service workflow so nobody has to switch apps mid-service."
  canonical="/team-chat"
  ogImage={HERO_IMAGE}
  structuredData={structuredData}
>
  <Fragment slot="head">
    <link rel="preload" as="image" href={HERO_IMAGE} />
  </Fragment>

  <section class="bg-gradient-to-b from-indigo-50 via-white to-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)]">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Team Chat</p>
        <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
          Communication that lives inside the workflow, not outside it.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-600 sm:text-xl">
          Most church teams run Sunday on a pile of group texts, Discord servers, and hallway conversations. Team Chat brings communication into the same platform that plans the service and runs the room.
        </p>
        <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:flex-wrap sm:items-center">
          <a href={`${APP_URL}/sign-up`} class="btn-primary" data-wm-track="cta_click" data-wm-track-label="team_chat_hero_get_started_free" data-wm-track-location="team_chat_hero">Get started free</a>
          <a href="/services" class="btn-outline">See Services</a>
          <a href="/av-team" class="btn-outline">See the AV Team panels</a>
        </div>
        <p class="mt-4 text-sm text-slate-500">Free Forever includes team chat. No separate tool required.</p>
      </div>

      <div class="overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-[0_24px_60px_rgba(15,23,42,0.12)]">
        <img src={HERO_IMAGE} alt="Team collaboration and chat in WorshipMetrics" loading="eager" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Why it matters</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Communication built for the booth, not the office.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          General-purpose chat tools were designed for desk workers who can look at a screen all day. Church production teams need communication that understands the Sunday cadence and does not ask volunteers to juggle another app.
        </p>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {features.map(({ title, body }) => (
          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-8 shadow-sm">
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-indigo-600">{title}</p>
            <p class="mt-4 text-sm leading-relaxed text-slate-600 sm:text-base">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-2">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Without switching apps</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Chat where the service runs, not somewhere else.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          When a camera feed flickers or a lyric slide is out of order, the fix starts in the booth. With Team Chat inside WorshipMetrics, the conversation happens in the same surface the team is already working from. No app-switching. No missed notifications.
        </p>
        <ul class="mt-8 space-y-3">
          {[
            "Chat lives inside the service workflow, not in a separate browser tab",
            "Production intercom travels with the live run-of-show on Pro",
            "Volunteers only see the channels relevant to their role",
            "Ministry-wide conversations stay available between Sundays",
          ].map((item) => (
            <li class="flex items-start gap-3 text-sm text-slate-700 sm:text-base"><span class="mt-2 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-indigo-500"></span><span>{item}</span></li>
          ))}
        </ul>
        <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
          <a href="/volunteers" class="btn-outline">See Volunteers</a>
          <a href="/services" class="btn-outline">See Services workflow</a>
        </div>
      </div>
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src={CHAT_IMAGE} alt="Team chat and collaboration in WorshipMetrics" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-2">
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src={CHAT_IMAGE} alt="Intercom and live communication in WorshipMetrics" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Production intercom</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">A production intercom that runs on a tablet.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          On Pro, chat becomes a production intercom that carries timing cues, confirmations, and quick adjustments through the live service. Operators, directors, and volunteers communicate without yelling across the booth.
        </p>
        <ul class="mt-8 space-y-3">
          {[
            "Cue confirmations travel with the service timeline",
            "Volunteer control panels include chat for the roles they're assigned",
            "Nobody needs a separate intercom hardware stack",
            "Channels stay organized by production area so messages are actionable",
          ].map((item) => (
            <li class="flex items-start gap-3 text-sm text-slate-700 sm:text-base"><span class="mt-2 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-indigo-500"></span><span>{item}</span></li>
          ))}
        </ul>
        <div class="mt-8">
          <a href="/pricing" class="btn-primary">See Pro pricing</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Built for ministry teams</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Group texts are not a communication strategy.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          When the plan changes on Thursday night or a volunteer drops out on Saturday, the whole team should know without a chain of forwarded messages. Team Chat gives every ministry team a single shared space that stays current.
        </p>
      </div>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { title: "Sunday crew", body: "Everyone serving this Sunday sees the same channel. Updates reach the whole team at once." },
          { title: "Ministry leads", body: "Staff and key volunteers stay connected during the week for planning, changes, and prayer." },
          { title: "AV Club", body: "Youth volunteers and mentors communicate in their own space without mixing with the full team." },
        ].map(({ title, body }) => (
          <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-indigo-600">{title}</p>
            <p class="mt-4 text-sm leading-relaxed text-slate-600 sm:text-base">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Stop running Sunday through text messages.</h2>
      <p class="mx-auto mt-4 max-w-3xl text-base leading-relaxed text-slate-600 sm:text-lg">
        Give your team communication that lives inside the workflow they're already using. Team Chat is included on Free Forever.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row sm:flex-wrap">
        <a href={`${APP_URL}/sign-up`} class="btn-primary" data-wm-track="cta_click" data-wm-track-label="team_chat_footer_get_started_free" data-wm-track-location="team_chat_footer_cta">Get started free</a>
        <a href="/discovery-call" class="btn-outline" data-wm-track="cta_click" data-wm-track-label="team_chat_footer_book_call" data-wm-track-location="team_chat_footer_cta">Book a demo</a>
        <a href="/services" class="btn-outline">See Services</a>
      </div>
    </div>
  </section>
</Layout>
