---
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.worshipmetrics.com";
const SITE_URL = "https://worshipmetrics.com";
const R2 = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
const HERO_IMAGE = `${R2}/homepage/Worship%20Metrics%20Team%20Collaboration.jpg`;
const CHAT_IMAGE = `${R2}/homepage/Team%20Chat%20with%20Members.jpg`;

const features = [
  {
    title: "Private & group messaging",
    body: "Send direct messages to individual team members or create group conversations with the exact people who need to be in the loop. Private, focused, and built for production teams.",
  },
  {
    title: "Public & private channels",
    body: "Create open channels for your whole production team or locked channels for specific roles. Audio gets its own space. Lighting gets its own space. Nobody gets flooded with messages they don&apos;t need.",
  },
  {
    title: "File sharing",
    body: "Share run-of-show docs, lyric sheets, stage plots, and setlists directly in the channel where the team is already talking. No more hunting through email threads or shared drives.",
  },
  {
    title: "Team member profiles",
    body: "Every volunteer and staff member gets a profile tied to their role. Know who is on audio this week, who is running cameras, and who to message when something changes.",
  },
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "WorshipMetrics Team Chat",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web, iOS, Android",
  url: `${SITE_URL}/team-chat`,
  image: HERO_IMAGE,
  description: "A fully featured team collaboration tool built for church production. Private messages, group chats, public and private channels, file sharing — everything your team needs to stay in sync before, during, and after every service.",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
    url: `${SITE_URL}/pricing`,
  },
};
---

<Layout
  title="Team Chat"
  socialTitle="WorshipMetrics Team Chat"
  description="A fully featured team collaboration tool built for church production. Private messages, group chats, public and private channels, file sharing — everything your team needs to stay in sync before, during, and after every service."
  canonical="/team-chat"
  ogImage={HERO_IMAGE}
  structuredData={structuredData}
>
  <Fragment slot="head">
    <link rel="preload" as="image" href={HERO_IMAGE} />
  </Fragment>

  <section class="bg-gradient-to-b from-indigo-50 via-white to-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)]">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Team Chat</p>
        <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
          A fully featured team collaboration tool built for church production.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-600 sm:text-xl">
          Private messages, group chats, public and private channels, and file sharing — all inside the same platform that plans the service and runs the room. Keep your production team in sync before, during, and after every Sunday.
        </p>
        <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:flex-wrap sm:items-center">
          <a href={`${APP_URL}/sign-up`} class="btn-primary" data-wm-track="cta_click" data-wm-track-label="team_chat_hero_get_started_free" data-wm-track-location="team_chat_hero">Sign up free</a>
          <a href="/services" class="btn-outline">See Services</a>
          <a href="/av-team" class="btn-outline">See the AV Team panels</a>
        </div>
        <p class="mt-4 text-sm text-slate-500">Free Forever includes full team chat. No separate tool required.</p>
      </div>

      <div class="overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-[0_24px_60px_rgba(15,23,42,0.12)]">
        <img src={HERO_IMAGE} alt="Team collaboration and chat in WorshipMetrics" loading="eager" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">What's included</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Everything your team needs to collaborate, free forever.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          Most church teams cobble together communication across group texts, Discord servers, and hallway conversations. Team Chat brings private messaging, group collaboration, channels, and file sharing into one place that already knows your service workflow.
        </p>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {features.map(({ title, body }) => (
          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-8 shadow-sm">
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-indigo-600">{title}</p>
            <p class="mt-4 text-sm leading-relaxed text-slate-600 sm:text-base">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-2">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Channels for every team</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Public or private. Every role gets the right space.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          Create public channels where the whole production team can see updates, or private channels for audio, lighting, and camera teams to coordinate without cross-talk. Each channel keeps its conversations focused and every team member knows exactly where to look.
        </p>
        <ul class="mt-8 space-y-3">
          {[
            "Public channels for announcements, service plans, and team-wide updates",
            "Private channels for role-specific coordination without noise",
            "Direct messages for one-on-one communication between team members",
            "Group messages for quick coordination among a few people",
            "File sharing directly in channels — no more digging through email",
          ].map((item) => (
            <li class="flex items-start gap-3 text-sm text-slate-700 sm:text-base"><span class="mt-2 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-indigo-500"></span><span>{item}</span></li>
          ))}
        </ul>
        <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
          <a href="/volunteers" class="btn-outline">See Volunteers</a>
          <a href="/services" class="btn-outline">See Services workflow</a>
        </div>
      </div>
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src={CHAT_IMAGE} alt="Team channels and member chat in WorshipMetrics" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-2">
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src={CHAT_IMAGE} alt="Production intercom and live communication in WorshipMetrics" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Production intercom</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Intercom for live production, available on Pro.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          When Pro is active, chat adds a production intercom layer that travels with the live service. Cue confirmations, timing checks, and quick adjustments happen in the same surface the team is already watching — no separate intercom hardware stack required.
        </p>
        <ul class="mt-8 space-y-3">
          {[
            "Cue confirmations travel with the service timeline",
            "Volunteer control panels include intercom for assigned roles",
            "Operators, directors, and volunteers communicate without yelling across the booth",
            "Channels stay organized by production area so messages are actionable",
          ].map((item) => (
            <li class="flex items-start gap-3 text-sm text-slate-700 sm:text-base"><span class="mt-2 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-indigo-500"></span><span>{item}</span></li>
          ))}
        </ul>
        <div class="mt-8">
          <a href="/pricing" class="btn-primary">See Pro pricing</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Before, during & after</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Stay in sync through the entire week, not just Sunday morning.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          When the plan changes on Thursday night or a volunteer drops out on Saturday, the whole team knows without a chain of forwarded messages. Team Chat keeps every ministry team connected through planning, rehearsals, the live service, and the debrief that follows.
        </p>
      </div>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { title: "Before Sunday", body: "Share service plans, coordinate rehearsals, and confirm assignments. Everyone walks in prepared." },
          { title: "During Sunday", body: "Production intercom keeps the booth in sync. Quick fixes, cue confirmations, and timing checks in real time." },
          { title: "After Sunday", body: "Debrief what worked, share clips, and start planning next week while it&apos;s still fresh." },
        ].map(({ title, body }) => (
          <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-indigo-600">{title}</p>
            <p class="mt-4 text-sm leading-relaxed text-slate-600 sm:text-base">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Stop running Sunday through a pile of text messages.</h2>
      <p class="mx-auto mt-4 max-w-3xl text-base leading-relaxed text-slate-600 sm:text-lg">
        Give your team private messaging, group chats, channels, and file sharing — all inside the workflow they&apos;re already using. Team Chat is included on Free Forever.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row sm:flex-wrap">
        <a href={`${APP_URL}/sign-up`} class="btn-primary" data-wm-track="cta_click" data-wm-track-label="team_chat_footer_get_started_free" data-wm-track-location="team_chat_footer_cta">Sign up free</a>
        <a href="/discovery-call" class="btn-outline" data-wm-track="cta_click" data-wm-track-label="team_chat_footer_book_call" data-wm-track-location="team_chat_footer_cta">Book a demo</a>
        <a href="/services" class="btn-outline">See Services</a>
      </div>
    </div>
  </section>
</Layout>
