---
import Layout from "../layouts/Layout.astro";

const R2 = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
---

<Layout
  title="Luminos AI"
  description="Luminos helps your team review attendance, visitors, follow-up signals, and weekly ministry context in plain English — inside WorshipMetrics."
  canonical="/luminos-ai-assistant"
>
  <!-- Hero -->
  <section class="bg-white px-6 py-20 sm:py-28">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-indigo-600">
        Luminos
      </p>
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
        Walk into Monday knowing what matters most.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-600 sm:text-xl">
        Luminos lives inside WorshipMetrics and helps your team review attendance, notice visitor
        and follow-up signals, and prepare confirmed actions — without digging through multiple
        reports.
      </p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-2 text-sm text-slate-500">
        <span class="rounded-full bg-slate-100 px-3 py-1">Weekly summaries</span>
        <span class="text-slate-300">&middot;</span>
        <span class="rounded-full bg-slate-100 px-3 py-1">Pastoral clarity</span>
        <span class="text-slate-300">&middot;</span>
        <span class="rounded-full bg-slate-100 px-3 py-1">Confirmed actions</span>
      </div>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="https://app.worshipmetrics.com/sign-up"
          class="rounded-lg bg-indigo-600 px-7 py-3 text-base font-semibold text-white shadow-sm hover:bg-indigo-700 transition"
        >
          Start for free
        </a>
        <a href="/discovery-call" class="text-base font-semibold text-indigo-600 hover:text-indigo-700">
          See a demo &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Luminos visual -->
  <section class="bg-slate-50 px-6 pb-8 sm:pb-12">
    <div class="mx-auto max-w-6xl overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
      <div class="grid items-center gap-0 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)]">
        <div class="flex h-full flex-col justify-center bg-slate-950 p-8 sm:p-10">
          <div class="flex items-center gap-4">
            <img
              src={`${R2}/homepage/Luminos.jpg`}
              alt="Luminos AI avatar"
              loading="lazy"
              decoding="async"
              class="h-16 w-16 rounded-2xl object-cover ring-1 ring-white/10"
            />
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-300">Inside your dashboard</p>
              <h2 class="mt-1 text-2xl font-bold text-white sm:text-3xl">Ask ministry questions. Get clear next steps.</h2>
            </div>
          </div>
          <div class="mt-8 space-y-3 text-sm text-slate-300">
            <div class="rounded-2xl bg-white/5 px-4 py-3 ring-1 ring-white/10">"Who has missed multiple services and may need a check-in?"</div>
            <div class="rounded-2xl bg-white/5 px-4 py-3 ring-1 ring-white/10">"Which guests still need a response from this week?"</div>
            <div class="rounded-2xl bg-white/5 px-4 py-3 ring-1 ring-white/10">"Give me a Monday summary I can act on."</div>
          </div>
        </div>
        <img
          src={`${R2}/homepage/Luminos.jpg`}
          alt="Luminos AI interface inside WorshipMetrics"
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- What it does -->
  <section class="bg-slate-50 px-6 py-20">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-center text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl mb-12">
        What Luminos does
      </h2>
      <div class="grid gap-6 sm:grid-cols-2">
        <div class="rounded-2xl bg-white p-8 shadow-sm border border-slate-100">
          <h3 class="text-lg font-bold text-slate-900 mb-3">Ask church questions in plain English</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Attendance, visitors, follow-up signals, and weekly ministry context without digging
            through dashboards.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-8 shadow-sm border border-slate-100">
          <h3 class="text-lg font-bold text-slate-900 mb-3">Respect ministry roles</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Volunteers, staff, and pastors each see the level of detail that fits their
            responsibility.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-8 shadow-sm border border-slate-100">
          <h3 class="text-lg font-bold text-slate-900 mb-3">Draft actions with confirmation</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            When a pastor wants to take action, Luminos drafts it first and waits for confirmation
            before anything runs.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-8 shadow-sm border border-slate-100">
          <h3 class="text-lg font-bold text-slate-900 mb-3">Stays connected to your data</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Works from your actual WorshipMetrics data — not generic church guesses.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sample prompts -->
  <section class="bg-white px-6 py-20">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl mb-8 text-center">
        The kinds of questions Luminos answers.
      </h2>
      <ul class="space-y-3">
        {[
          "What should our pastor know before Monday staff meeting?",
          "Which guests still need a response from this week?",
          "Who has missed multiple services and may need a check-in?",
          "Give me a short summary of attendance, visitors, and follow-up from this week.",
          "What changed this week that deserves our attention first?",
        ].map((prompt) => (
          <li class="flex items-start gap-3 rounded-xl border border-slate-200 px-5 py-4">
            <span class="mt-0.5 text-indigo-500">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z" clip-rule="evenodd" />
              </svg>
            </span>
            <span class="text-slate-700 text-sm">{prompt}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Mock conversation -->
  <section class="bg-slate-50 px-6 py-20">
    <div class="mx-auto max-w-2xl">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl mb-8 text-center">
        See it in action.
      </h2>
      <div class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
        <!-- Chat header -->
        <div class="border-b border-slate-100 bg-slate-50 px-5 py-3 flex items-center gap-2">
          <div class="h-2.5 w-2.5 rounded-full bg-indigo-500"></div>
          <span class="text-sm font-semibold text-slate-700">Luminos</span>
          <span class="ml-auto text-xs text-slate-400">Inside WorshipMetrics</span>
        </div>
        <!-- Messages -->
        <div class="p-6 space-y-6">
          <!-- User -->
          <div class="flex justify-end">
            <div class="max-w-sm rounded-2xl rounded-tr-sm bg-indigo-600 px-4 py-3 text-sm text-white">
              Before staff meeting, give me a short summary of what matters most from this week.
            </div>
          </div>
          <!-- Luminos -->
          <div class="flex justify-start">
            <div class="max-w-prose rounded-2xl rounded-tl-sm bg-slate-100 px-4 py-3 text-sm text-slate-800 leading-relaxed">
              Attendance held steady this week, but three first-time visitor households were
              captured and two regular families have now missed multiple services. Four recent
              guest records still need follow-up, and one prayer request should be reviewed by
              pastoral staff today. Would you like me to break this down by service, pull just
              the guest follow-up items, or prepare a short recap for the team?
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Role access -->
  <section class="bg-white px-6 py-20">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-center text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl mb-4">
        Helpful by design. Careful by default.
      </h2>
      <p class="text-center text-slate-600 mb-12">
        Luminos surfaces different levels of context depending on who's asking.
      </p>
      <div class="grid gap-6 sm:grid-cols-3">
        <div class="rounded-2xl border border-slate-200 p-8">
          <p class="text-sm font-semibold uppercase tracking-widest text-slate-500 mb-3">Volunteer</p>
          <p class="text-slate-700 text-sm leading-relaxed">
            Aggregate ministry visibility. No private records or contact details.
          </p>
        </div>
        <div class="rounded-2xl border border-slate-200 p-8">
          <p class="text-sm font-semibold uppercase tracking-widest text-slate-500 mb-3">Staff / Ministry Leader</p>
          <p class="text-slate-700 text-sm leading-relaxed">
            More member-care context and broader reporting visibility.
          </p>
        </div>
        <div class="rounded-2xl border border-indigo-200 bg-indigo-50 p-8">
          <p class="text-sm font-semibold uppercase tracking-widest text-indigo-600 mb-3">Admin / Pastor</p>
          <p class="text-slate-700 text-sm leading-relaxed">
            Full operational context, action drafting, and confirmation-required admin actions.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Plans -->
  <section class="bg-slate-50 px-6 py-20">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl mb-10">
        Included on paid plans.
      </h2>
      <div class="grid gap-6 sm:grid-cols-2 text-left mb-10">
        <div class="rounded-2xl border border-slate-200 bg-white p-8">
          <p class="text-sm font-semibold uppercase tracking-widest text-indigo-600 mb-2">Essentials</p>
          <p class="text-3xl font-extrabold text-slate-900 mb-1">$19.99<span class="text-base font-normal text-slate-500">/month</span></p>
          <p class="mt-4 text-slate-700 font-medium">90 questions/day</p>
        </div>
        <div class="rounded-2xl border border-indigo-200 bg-indigo-50 p-8">
          <p class="text-sm font-semibold uppercase tracking-widest text-indigo-600 mb-2">Established</p>
          <p class="text-3xl font-extrabold text-slate-900 mb-1">$49.99<span class="text-base font-normal text-slate-500">/month</span></p>
          <p class="mt-4 text-slate-700 font-medium">250 questions/day</p>
        </div>
      </div>
      <a href="/pricing" class="text-base font-semibold text-indigo-600 hover:text-indigo-700">
        See all pricing &rarr;
      </a>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-indigo-600 px-6 py-20">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        See how Luminos works with your church data.
      </h2>
      <p class="mt-4 text-lg text-indigo-100">
        A short call is all it takes to see if it fits your team.
      </p>
      <div class="mt-8">
        <a
          href="/discovery-call"
          class="rounded-lg bg-white px-8 py-3 text-base font-semibold text-indigo-600 shadow-sm hover:bg-indigo-50 transition"
        >
          Book a discovery call
        </a>
      </div>
    </div>
  </section>
</Layout>
