---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProductCTA from '../../../components/kb/ProductCTA.astro';
import BreadcrumbNav from '../../../components/kb/BreadcrumbNav.astro';

const allDevices = await getCollection('devices');
const encoders = allDevices.filter(e => e.data.deviceCategory === 'encoder');
const brands = [...new Set(encoders.map(e => e.data.brand))].sort();
const brandCounts = Object.fromEntries(brands.map(b => [b, encoders.filter(e => e.data.brand === b).length]));
function brandSlug(b: string) {
  return b.toLowerCase().replace(/[\s\/]+/g, '-');
}
---
<BaseLayout title="Hardware Encoder Knowledge Base for Churches" description="Setup guides, stream key configuration, SRT multi-campus setup, and troubleshooting for hardware encoders in church production." canonical="/kb/encoders">
  <section class="border-b border-border bg-bg px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <BreadcrumbNav items={[{ label: 'Knowledge Base', href: '/kb' }, { label: 'Hardware Encoders' }]} />
      <p class="mt-8 text-sm font-semibold uppercase tracking-[0.18em] text-blue-300">Device Documentation</p>
      <h1 class="mt-3 font-display text-5xl text-white">Hardware Encoder Guides</h1>
      <p class="mt-5 max-w-3xl text-lg text-slate-300">Complete documentation for Magewell, Teradek, Epiphan, and every hardware encoder used in church production — setup, stream key configuration, SRT multi-campus routing, and troubleshooting.</p>
    </div>
  </section>
  <section class="bg-[#10151d] px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-300">Browse by Brand</p>
      <h2 class="mt-3 font-display text-4xl text-white">Select your encoder brand</h2>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {brands.map(brand => (
          <a href={`/kb/encoders/${brandSlug(brand)}`} class="group rounded-2xl border border-border bg-surface/80 p-6 shadow transition hover:-translate-y-0.5 hover:border-accent/40">
            <h3 class="font-display text-xl text-white group-hover:text-blue-200">{brand}</h3>
            <p class="mt-2 text-sm text-slate-400">{brandCounts[brand]} article{brandCounts[brand] !== 1 ? 's' : ''}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
  <section class="bg-bg px-6 py-16">
    <div class="mx-auto max-w-5xl"><ProductCTA variant="banner" /></div>
  </section>
</BaseLayout>
