---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProductCTA from '../../../components/kb/ProductCTA.astro';
import BreadcrumbNav from '../../../components/kb/BreadcrumbNav.astro';

const allSoftware = await getCollection('software');
const apps = [...new Set(allSoftware.map(e => e.data.app))].sort();
const appCounts = Object.fromEntries(apps.map(a => [a, allSoftware.filter(e => e.data.app === a).length]));
const appLabels: Record<string, string> = {
  obs: 'OBS Studio', vmix: 'vMix', propresenter: 'ProPresenter',
  easyworship: 'EasyWorship', restream: 'Restream', castr: 'Castr',
  streamlabs: 'Streamlabs', wirecast: 'Wirecast', 'atem-software': 'ATEM Software Control',
};
---
<BaseLayout title="Streaming Software Knowledge Base for Churches" description="Church-specific guides for OBS Studio, vMix, ProPresenter, EasyWorship, and every streaming software used in worship production." canonical="/kb/software">
  <section class="border-b border-border bg-bg px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <BreadcrumbNav items={[{ label: 'Knowledge Base', href: '/kb' }, { label: 'Streaming Software' }]} />
      <p class="mt-8 text-sm font-semibold uppercase tracking-[0.18em] text-blue-300">Software Documentation</p>
      <h1 class="mt-3 font-display text-5xl text-white">Streaming Software Guides</h1>
      <p class="mt-5 max-w-3xl text-lg text-slate-300">Practical guides for every streaming and presentation app used in church production — OBS Studio, vMix, ProPresenter, EasyWorship, and multistreaming platforms.</p>
    </div>
  </section>
  <section class="bg-[#10151d] px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 mt-10">
        {apps.map(app => (
          <a href={`/kb/software/${app}`} class="group rounded-2xl border border-border bg-surface/80 p-6 shadow transition hover:-translate-y-0.5 hover:border-accent/40">
            <h3 class="font-display text-xl text-white group-hover:text-blue-200">{appLabels[app] ?? app}</h3>
            <p class="mt-2 text-sm text-slate-400">{appCounts[app]} article{appCounts[app] !== 1 ? 's' : ''}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
  <section class="bg-bg px-6 py-16">
    <div class="mx-auto max-w-5xl"><ProductCTA variant="banner" /></div>
  </section>
</BaseLayout>
