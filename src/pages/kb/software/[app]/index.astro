---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import BreadcrumbNav from '../../../../components/kb/BreadcrumbNav.astro';
import DifficultyBadge from '../../../../components/kb/DifficultyBadge.astro';
import ProductCTA from '../../../../components/kb/ProductCTA.astro';

export const prerender = true;

const appLabels: Record<string, string> = {
  obs: 'OBS Studio', vmix: 'vMix', propresenter: 'ProPresenter',
  easyworship: 'EasyWorship', restream: 'Restream', castr: 'Castr',
  streamlabs: 'Streamlabs', wirecast: 'Wirecast', 'atem-software': 'ATEM Software Control',
};

export async function getStaticPaths() {
  const allSoftware = await getCollection('software');
  const apps = [...new Set(allSoftware.map(e => e.data.app))];
  return apps.map(app => ({
    params: { app },
    props: { app, articles: allSoftware.filter(e => e.data.app === app).sort((a,b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()) },
  }));
}

const { app, articles } = Astro.props;
const label = appLabels[app] ?? app;
---
<BaseLayout title={`${label} Guides for Church Production`} description={`Church-specific ${label} guides — setup, integration, troubleshooting, and best practices for worship production teams.`} canonical={`/kb/software/${app}`}>
  <section class="border-b border-border bg-bg px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <BreadcrumbNav items={[{ label: 'Knowledge Base', href: '/kb' }, { label: 'Streaming Software', href: '/kb/software' }, { label }]} />
      <h1 class="mt-8 font-display text-5xl text-white">{label} Guides</h1>
      <p class="mt-4 text-lg text-slate-300">{articles.length} church-specific guides for {label}.</p>
    </div>
  </section>
  <section class="bg-[#10151d] px-6 py-16">
    <div class="mx-auto max-w-7xl grid gap-6 lg:grid-cols-3">
      {articles.map(article => (
        <a href={`/kb/software/${app}/${article.id}`} class="group rounded-2xl border border-border bg-surface/80 p-6 shadow transition hover:-translate-y-0.5 hover:border-accent/40">
          <DifficultyBadge difficulty={article.data.difficulty} />
          <h3 class="mt-4 font-display text-xl text-white group-hover:text-blue-200">{article.data.title}</h3>
          <p class="mt-2 text-sm text-slate-400">{article.data.description}</p>
        </a>
      ))}
    </div>
  </section>
  <section class="bg-bg px-6 py-12">
    <div class="mx-auto max-w-5xl"><ProductCTA variant="banner" /></div>
  </section>
</BaseLayout>
