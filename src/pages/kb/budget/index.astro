---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProductCTA from '../../../components/kb/ProductCTA.astro';
import BreadcrumbNav from '../../../components/kb/BreadcrumbNav.astro';

const allBudget = await getCollection('budget');
const sorted = allBudget.sort((a,b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const tierLabels: Record<string, string> = {
  'under-500': 'Under $500',
  'under-1000': 'Under $1,000',
  'under-2500': 'Under $2,500',
  'under-5000': 'Under $5,000',
  'under-10000': 'Under $10,000',
  'upgrade-roadmap': 'Upgrade Roadmap',
};
---
<BaseLayout title="Church AV Budget Guides — Gear Packages by Price" description="Complete church AV system packages organized by budget. Find the right equipment setup for your church's financial capacity." canonical="/kb/budget">
  <section class="border-b border-border bg-bg px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <BreadcrumbNav items={[{ label: 'Knowledge Base', href: '/kb' }, { label: 'Budget Guides' }]} />
      <p class="mt-8 text-sm font-semibold uppercase tracking-[0.18em] text-blue-300">Packages by Price</p>
      <h1 class="mt-3 font-display text-5xl text-white">Budget Guides</h1>
      <p class="mt-5 max-w-3xl text-lg text-slate-300">Complete church AV system packages organized by budget tier — from starter setups under $500 to full production rigs over $10,000. Includes upgrade paths and ROI guidance.</p>
    </div>
  </section>
  <section class="bg-[#10151d] px-6 py-16">
    <div class="mx-auto max-w-7xl grid gap-6 lg:grid-cols-2">
      {sorted.map(b => (
        <a href={`/kb/budget/${b.id}`} class="group rounded-2xl border border-border bg-surface/80 p-6 shadow transition hover:-translate-y-0.5 hover:border-accent/40">
          <span class="rounded-full bg-green-900/50 px-3 py-1 text-sm text-green-200">{tierLabels[b.data.tier]}</span>
          <h3 class="mt-4 font-display text-xl text-white group-hover:text-blue-200">{b.data.title}</h3>
          <p class="mt-2 text-sm text-slate-400">{b.data.description}</p>
        </a>
      ))}
    </div>
  </section>
  <section class="bg-bg px-6 py-16">
    <div class="mx-auto max-w-5xl"><ProductCTA variant="banner" /></div>
  </section>
</BaseLayout>
