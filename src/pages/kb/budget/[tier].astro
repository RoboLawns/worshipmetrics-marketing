---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbNav from '../../../components/kb/BreadcrumbNav.astro';
import ProductCTA from '../../../components/kb/ProductCTA.astro';
import TableOfContents from '../../../components/kb/TableOfContents.astro';

export const prerender = true;

const tierLabels: Record<string, string> = {
  'under-500': 'Under $500',
  'under-1000': 'Under $1,000',
  'under-2500': 'Under $2,500',
  'under-5000': 'Under $5,000',
  'under-10000': 'Under $10,000',
  'upgrade-roadmap': 'Upgrade Roadmap',
};

export async function getStaticPaths() {
  const all = await getCollection('budget');
  return all.map(entry => ({ params: { tier: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---
<BaseLayout title={`${entry.data.title} | Church AV Knowledge Base`} description={entry.data.description} canonical={`/kb/budget/${entry.id}`} type="article" publishedAt={entry.data.publishedAt}>
  <section class="border-b border-border bg-bg px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <BreadcrumbNav items={[{ label: 'Knowledge Base', href: '/kb' }, { label: 'Budget Guides', href: '/kb/budget' }, { label: entry.data.title }]} />
      <div class="mt-8">
        <span class="rounded-full bg-green-900/50 px-3 py-1 text-sm text-green-200">{tierLabels[entry.data.tier]}</span>
      </div>
      <h1 class="mt-6 max-w-4xl font-display text-5xl leading-tight text-white">{entry.data.title}</h1>
      <p class="mt-5 max-w-3xl text-lg text-slate-300">{entry.data.description}</p>
    </div>
  </section>
  <section class="bg-white">
    <div class="mx-auto grid max-w-7xl gap-12 px-6 py-16 lg:grid-cols-[minmax(0,1fr)_18rem]">
      <article class="min-w-0">
        <div class="kb-prose prose prose-slate max-w-none" data-pagefind-body><Content /></div>
        <ProductCTA variant="banner" />
      </article>
      <div class="hidden lg:block"><TableOfContents headings={headings} /></div>
    </div>
  </section>
</BaseLayout>
