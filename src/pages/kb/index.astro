---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/kb/HeroSection.astro';
import ArticleCard from '../../components/kb/ArticleCard.astro';
import CategoryGrid from '../../components/kb/CategoryGrid.astro';
import ProductCTA from '../../components/kb/ProductCTA.astro';
import { categories } from '../../data/categories';

const articles = (await getCollection('articles')).sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const featuredArticles = articles.filter((article) => article.data.featured).slice(0, 3);
const latestArticles = articles.slice(0, 9);
const counts = Object.fromEntries(categories.map((category) => [category.slug, articles.filter((article) => article.data.category === category.slug).length]));
---

<BaseLayout
  title="Knowledge Base"
  description="The AV Knowledge Base for church production teams — streaming, device management, audio, display, and volunteer operations guides."
  canonical="/kb"
>
  <HeroSection />

  <section class="bg-bg px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <div class="flex items-end justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-300">Featured Articles</p>
          <h2 class="mt-3 font-display text-4xl text-white">Start with the biggest workflows</h2>
        </div>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {featuredArticles.map((article) => <ArticleCard article={article} />)}
      </div>
    </div>
  </section>

  <section class="bg-[#10151d] px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-300">Browse by Category</p>
      <h2 class="mt-3 font-display text-4xl text-white">Find the topic you need right now</h2>
      <div class="mt-10">
        <CategoryGrid counts={counts} />
      </div>
    </div>
  </section>

  <section class="bg-bg px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <div class="flex items-end justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-300">Latest Articles</p>
          <h2 class="mt-3 font-display text-4xl text-white">Fresh answers for common church AV problems</h2>
        </div>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {latestArticles.map((article) => <ArticleCard article={article} />)}
      </div>
    </div>
  </section>

  <section class="bg-[#10151d] px-6 py-16">
    <div class="mx-auto max-w-5xl">
      <ProductCTA variant="banner" />
    </div>
  </section>
</BaseLayout>
