---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/kb/HeroSection.astro';
import ArticleCard from '../../components/kb/ArticleCard.astro';
import CategoryGrid from '../../components/kb/CategoryGrid.astro';
import ProductCTA from '../../components/kb/ProductCTA.astro';
import { categories } from '../../data/categories';

const articles = (await getCollection('articles')).sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const cameras = await getCollection('cameras');
const devices = await getCollection('devices');
const softwareArticles = await getCollection('software');
const workflowArticles = await getCollection('workflows');
const comparisonArticles = await getCollection('comparisons');
const troubleshootingArticles = await getCollection('troubleshooting');
const budgetArticles = await getCollection('budget');

const featuredArticles = articles.filter((article) => article.data.featured).slice(0, 3);
const latestArticles = articles.slice(0, 9);
const counts = Object.fromEntries(categories.map((category) => [category.slug, articles.filter((article) => article.data.category === category.slug).length]));

const libraryCards = [
  {
    href: '/kb/cameras',
    eyebrow: 'PTZ Cameras',
    title: 'Brand-specific camera guides',
    description: 'Setup, integration, troubleshooting, presets, ONVIF, RTSP, and network help across the camera brands congregations actually use.',
    count: cameras.length,
  },
  {
    href: '/kb/switchers',
    eyebrow: 'Switchers',
    title: 'ATEM, Roland, and more',
    description: 'Practical setup and troubleshooting docs for switchers used in livestream, IMAG, and hybrid production workflows.',
    count: devices.filter((entry) => entry.data.deviceCategory === 'switcher').length,
  },
  {
    href: '/kb/encoders',
    eyebrow: 'Encoders',
    title: 'Streaming hardware knowledge base',
    description: 'Encoder setup, bitrate planning, cloud configuration, and recovery steps for the devices feeding your stream.',
    count: devices.filter((entry) => entry.data.deviceCategory === 'encoder').length,
  },
  {
    href: '/kb/mixers',
    eyebrow: 'Mixers',
    title: 'Audio console setup and streaming',
    description: 'X32, Yamaha, Allen & Heath, PreSonus, Mackie, and more — with routing, streaming, and volunteer-friendly workflows.',
    count: devices.filter((entry) => entry.data.deviceCategory === 'mixer').length,
  },
  {
    href: '/kb/software',
    eyebrow: 'Software',
    title: 'OBS, vMix, ProPresenter, and more',
    description: 'Software-specific guides for church production tools, from setup and performance to integration and troubleshooting.',
    count: softwareArticles.length,
  },
  {
    href: '/kb/troubleshooting',
    eyebrow: 'Troubleshooting',
    title: 'Fast answers when Sunday breaks',
    description: 'Issue-based troubleshooting for stream failures, camera problems, audio glitches, network issues, and display problems.',
    count: troubleshootingArticles.length,
  },
  {
    href: '/kb/compare',
    eyebrow: 'Compare',
    title: 'Head-to-head buying guides',
    description: 'Direct comparisons to help teams choose between PTZ cameras, encoders, switchers, mixers, and software platforms.',
    count: comparisonArticles.length,
  },
  {
    href: '/kb/workflows',
    eyebrow: 'Workflows',
    title: 'Complete production playbooks',
    description: 'Whole-system guides for small congregations, multi-campus environments, Sunday checklists, and volunteer-proof setups.',
    count: workflowArticles.length,
  },
  {
    href: '/kb/budget',
    eyebrow: 'Budget',
    title: 'Budget-based AV planning',
    description: 'Roadmaps and equipment planning guides based on realistic spending tiers, from under $500 to full upgrade strategy.',
    count: budgetArticles.length,
  },
];
---

<BaseLayout
  title="Knowledge Base"
  description="The AV Knowledge Base for church production teams — streaming, device management, audio, display, and volunteer operations guides."
  canonical="/kb"
>
  <HeroSection />

  <section class="bg-[#10151d] px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-300">Knowledge Base Libraries</p>
          <h2 class="mt-3 font-display text-4xl text-white">Browse the full church AV library</h2>
          <p class="mt-4 max-w-3xl text-lg leading-relaxed text-slate-300">The original 20 editorial articles are just one layer. The full knowledge base also includes brand-specific camera docs, switchers, encoders, mixers, software guides, troubleshooting, comparisons, workflows, and budget planning.</p>
        </div>
        <div class="rounded-full bg-white/5 px-4 py-2 text-sm font-semibold text-slate-300">
          {libraryCards.reduce((sum, card) => sum + card.count, 0)} indexed resources
        </div>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {libraryCards.map((card) => (
          <a href={card.href} class="rounded-3xl border border-border bg-surface/80 p-6 shadow-[0_12px_30px_rgba(0,0,0,0.18)] transition hover:-translate-y-0.5 hover:border-accent/40">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-300">{card.eyebrow}</p>
            <h3 class="mt-4 font-display text-3xl text-white">{card.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-300">{card.description}</p>
            <div class="mt-5 flex items-center justify-between text-sm">
              <span class="font-semibold text-slate-200">{card.count} pages</span>
              <span class="font-semibold text-blue-300">Open →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-bg px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <div class="flex items-end justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-300">Featured Articles</p>
          <h2 class="mt-3 font-display text-4xl text-white">Start with the biggest workflows</h2>
        </div>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {featuredArticles.map((article) => <ArticleCard article={article} />)}
      </div>
    </div>
  </section>

  <section class="bg-[#10151d] px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-300">Browse by Category</p>
      <h2 class="mt-3 font-display text-4xl text-white">Find the topic you need right now</h2>
      <div class="mt-10">
        <CategoryGrid counts={counts} />
      </div>
    </div>
  </section>

  <section class="bg-bg px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <div class="flex items-end justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-300">Latest Articles</p>
          <h2 class="mt-3 font-display text-4xl text-white">Fresh answers for common church AV problems</h2>
        </div>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {latestArticles.map((article) => <ArticleCard article={article} />)}
      </div>
    </div>
  </section>

  <section class="bg-[#10151d] px-6 py-16">
    <div class="mx-auto max-w-5xl">
      <ProductCTA variant="banner" />
    </div>
  </section>
</BaseLayout>
