---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbNav from '../../../components/kb/BreadcrumbNav.astro';
import ProductCTA from '../../../components/kb/ProductCTA.astro';
import TableOfContents from '../../../components/kb/TableOfContents.astro';

export async function getStaticPaths() {
  const all = await getCollection('comparisons');
  return all.map(entry => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---
<BaseLayout title={`${entry.data.title} | Church AV Knowledge Base`} description={entry.data.description} canonical={`/kb/compare/${entry.id}`} type="article" publishedAt={entry.data.publishedAt}>
  <section class="border-b border-border bg-bg px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <BreadcrumbNav items={[{ label: 'Knowledge Base', href: '/kb' }, { label: 'Comparisons', href: '/kb/compare' }, { label: entry.data.title }]} />
      <div class="mt-8">
        <p class="text-sm text-slate-400">{entry.data.competitorA} vs {entry.data.competitorB}{entry.data.competitorC ? ` vs ${entry.data.competitorC}` : ''}</p>
      </div>
      <h1 class="mt-3 max-w-4xl font-display text-5xl leading-tight text-white">{entry.data.title}</h1>
      <p class="mt-5 max-w-3xl text-lg text-slate-300">{entry.data.description}</p>
    </div>
  </section>
  <section class="bg-white">
    <div class="mx-auto grid max-w-7xl gap-12 px-6 py-16 lg:grid-cols-[minmax(0,1fr)_18rem]">
      <article class="min-w-0">
        <div class="rounded-2xl border-2 border-blue-500 bg-blue-50 p-6 mb-8">
          <p class="font-display text-xl text-blue-900">Verdict</p>
          <p class="mt-2 text-lg text-blue-800">{entry.data.verdict}</p>
        </div>
        <div class="kb-prose prose prose-slate max-w-none" data-pagefind-body><Content /></div>
        <ProductCTA variant="banner" />
      </article>
      <div class="hidden lg:block"><TableOfContents headings={headings} /></div>
    </div>
  </section>
</BaseLayout>
