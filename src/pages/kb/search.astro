---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbNav from '../../components/kb/BreadcrumbNav.astro';
import SearchBar from '../../components/kb/SearchBar.astro';
---

<BaseLayout
  title="Search"
  description="Search the WorshipMetrics church AV knowledge base."
  canonical="/kb/search"
>
  <section class="bg-bg px-6 py-20">
    <div class="mx-auto max-w-5xl">
      <BreadcrumbNav items={[{ label: 'Knowledge Base', href: '/kb' }, { label: 'Search' }]} />
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-300">Search</p>
      <h1 class="mt-3 font-display text-5xl text-white">Search the knowledge base</h1>
      <p class="mt-4 max-w-2xl text-lg text-slate-300">Find setup guides, troubleshooting steps, and workflow recommendations for church production teams.</p>
      <div class="mt-10 rounded-3xl border border-border bg-surface p-6 shadow-[0_18px_40px_rgba(0,0,0,0.24)]">
        <SearchBar mode="pagefind" />
      </div>
      <div class="mt-10 rounded-3xl border border-border bg-surface/80 p-6 shadow-[0_12px_30px_rgba(0,0,0,0.18)]">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-300">Browse instead</p>
        <div class="mt-4 flex flex-wrap gap-3 text-sm">
          <a href="/kb/category/device-management" class="rounded-full border border-border bg-bg px-4 py-2 text-slate-200 transition hover:border-blue-400 hover:text-white">Device Management</a>
          <a href="/kb/category/streaming" class="rounded-full border border-border bg-bg px-4 py-2 text-slate-200 transition hover:border-blue-400 hover:text-white">Streaming</a>
          <a href="/kb/category/operations" class="rounded-full border border-border bg-bg px-4 py-2 text-slate-200 transition hover:border-blue-400 hover:text-white">Operations</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
