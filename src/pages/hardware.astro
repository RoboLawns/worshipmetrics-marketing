---
import Layout from "../layouts/Layout.astro";

const R2 = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
---

<Layout
  title="Church Hardware for Attendance, Check-In, and AV Workflows"
  description="Compare the WorshipMetrics Hub and Tablet for church attendance automation, volunteer check-in, digital signage, and AV workflows."
  canonical="/hardware"
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-indigo-50 to-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">
        Purpose-built hardware for the way your church already works.
      </h1>
      <p class="mt-4 text-lg text-slate-600">
        Two options: a connected Hub for automatic attendance, signage, and production control — or a dedicated Tablet workflow for volunteers.
      </p>
    </div>
  </section>

  <!-- Hardware comparison visuals -->
  <section class="bg-white px-4 pb-8 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl grid gap-6 lg:grid-cols-2">
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img
          src={`${R2}/tablet/Worship%20Metrics%20Appliance%20Small.jpg`}
          alt="WorshipMetrics Hub hardware"
          loading="lazy"
          decoding="async"
          class="aspect-[16/10] w-full object-cover"
        />
      </div>
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img
          src={`${R2}/tablet/New%20Worship%20Metrics%20Tablet%20Hero.jpg`}
          alt="WorshipMetrics Tablet hardware"
          loading="lazy"
          decoding="async"
          class="aspect-[16/10] w-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- Product cards -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-8 lg:grid-cols-2">

        <!-- Hub -->
        <div class="flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <img
            src={`${R2}/homepage/new%20images/Stream%20Health.jpg`}
            alt="WorshipMetrics Hub stream health interface"
            loading="lazy"
            decoding="async"
            class="-mx-8 -mt-8 mb-6 aspect-[16/10] w-[calc(100%+4rem)] object-cover"
          />
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="text-xl font-bold text-slate-900">WorshipMetrics Hub</h2>
              <p class="mt-1 text-3xl font-extrabold text-slate-900">
                $499
                <span class="text-base font-normal text-slate-400"> one-time</span>
              </p>
            </div>
            <span class="flex-shrink-0 rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
              No subscription fees
            </span>
          </div>

          <ul class="mt-6 flex-1 space-y-3">
            {[
              "Automatic attendance capture",
              "Cloud-managed digital signage",
              "Remote PTZ camera control",
              "Remote OBS and vMix control",
              "AV health monitoring",
              "Works with your existing cameras",
            ].map((f) => (
              <li class="flex items-start gap-3 text-sm">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-slate-600">{f}</span>
              </li>
            ))}
          </ul>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a
              href="/appliance"
              class="flex-1 rounded-xl bg-indigo-600 py-3 text-center text-sm font-semibold text-white transition hover:bg-indigo-700"
            >
              See Hub details
            </a>
            <a
              href="mailto:support@worshipmetrics.com"
              class="flex-1 rounded-xl border border-slate-300 py-3 text-center text-sm font-semibold text-slate-700 transition hover:border-indigo-400 hover:text-indigo-600"
            >
              Talk to sales
            </a>
          </div>
        </div>

        <!-- Tablet -->
        <div class="flex flex-col overflow-hidden rounded-2xl border border-indigo-200 bg-white p-8 shadow-sm">
          <img
            src={`${R2}/tablet/Sync%20with%20multiple%20tablets.jpg`}
            alt="Multiple synchronized WorshipMetrics tablets"
            loading="lazy"
            decoding="async"
            class="-mx-8 -mt-8 mb-6 aspect-[16/10] w-[calc(100%+4rem)] object-cover"
          />
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="text-xl font-bold text-slate-900">WorshipMetrics Tablet</h2>
              <p class="mt-1 text-3xl font-extrabold text-slate-900">
                from $349
                <span class="text-base font-normal text-slate-400"> one-time</span>
              </p>
            </div>
            <span class="flex-shrink-0 rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-700">
              Includes free Essentials plan
            </span>
          </div>

          <ul class="mt-6 flex-1 space-y-3">
            {[
              "Dedicated volunteer workflow",
              "Welcome desk, check-in, and counting",
              "Syncs across multiple stations",
              "60-second setup",
              "30-day money-back guarantee",
            ].map((f) => (
              <li class="flex items-start gap-3 text-sm">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-slate-600">{f}</span>
              </li>
            ))}
          </ul>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a
              href="/tablet"
              class="flex-1 rounded-xl bg-indigo-600 py-3 text-center text-sm font-semibold text-white transition hover:bg-indigo-700"
            >
              See Tablet details
            </a>
            <a
              href="#"
              class="flex-1 rounded-xl border border-slate-300 py-3 text-center text-sm font-semibold text-slate-700 transition hover:border-indigo-400 hover:text-indigo-600"
            >
              Buy on Amazon
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Which one fits? -->
  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <h2 class="mb-2 text-center text-2xl font-bold text-slate-900 sm:text-3xl">
        Choose the hardware that matches your workflow.
      </h2>
      <p class="mb-10 text-center text-slate-500">Three simple rules of thumb.</p>
      <div class="grid gap-6 sm:grid-cols-3">
        {[
          {
            icon: "M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z",
            heading: "Choose Hub for connected operations",
            body: "Best for churches that want attendance, signage, camera control, and production in one cloud-managed device.",
          },
          {
            icon: "M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3",
            heading: "Choose Tablet for staffed workflows",
            body: "Best for churches that want a dedicated device at a welcome desk, check-in station, or counting position.",
          },
          {
            icon: "M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5",
            heading: "Both connect to the same system",
            body: "Whether you count automatically or use a staffed station, data flows into the same WorshipMetrics dashboard.",
          },
        ].map(({ icon, heading, body }) => (
          <div class="flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-50 text-indigo-600">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
              </svg>
            </div>
            <h3 class="font-semibold text-slate-900">{heading}</h3>
            <p class="mt-2 flex-1 text-sm text-slate-500 leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-indigo-600 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-white">Not sure which is right?</h2>
      <p class="mt-4 text-indigo-200">
        We'll walk through your space, team size, and goals to recommend the right fit — no pressure.
      </p>
      <a
        href="/discovery-call"
        class="mt-8 inline-block rounded-xl bg-white px-8 py-3 text-base font-semibold text-indigo-700 shadow transition hover:bg-indigo-50"
      >
        Book a discovery call
      </a>
    </div>
  </section>
</Layout>
