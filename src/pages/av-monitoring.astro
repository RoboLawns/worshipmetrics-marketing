---
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.worshipmetrics.com";
const SITE_URL = "https://worshipmetrics.com";
const R2 = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
const HERO_IMAGE = `${R2}/homepage/new%20images/Stream%20Health.jpg`;
const MONITOR_IMAGE = `${R2}/Tech%20Manager/WorshipMetrics%20Tech%20Manager%20Web-UI%20Panels.jpg`;

const features = [
  {
    title: "Stream health monitoring",
    body: "See your livestream bitrate, frame drops, and connection stability in real time. Know before the congregation notices that something is wrong.",
  },
  {
    title: "System status dashboard",
    body: "Every connected device, camera, and integration reports its status to one dashboard. No more walking around the booth checking each piece of gear individually.",
  },
  {
    title: "Booth observability",
    body: "Track what is happening across your entire AV system from a single surface. When something fails, you know what and where without tracing cables.",
  },
  {
    title: "Attendance + engagement metrics",
    body: "Pair stream health data with attendance numbers to understand how your online reach correlates with technical quality. Better data for better decisions.",
  },
];

const observabilityItems = [
  "Real-time stream bitrate, resolution, and frame drop monitoring",
  "Device connectivity status for cameras, switchers, and encoders",
  "Historical health data so you can spot patterns across Sundays",
  "Alerts when stream quality degrades below thresholds you set",
  "Integration with Central Control for ProAV gear monitoring",
  "One dashboard that replaces the pile of separate monitoring tools",
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "WorshipMetrics AV Monitoring",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web, Windows, Mac, iOS, Android",
  url: `${SITE_URL}/av-monitoring`,
  image: HERO_IMAGE,
  description: "Real-time stream health monitoring, system status dashboards, and booth observability built into WorshipMetrics. Know your AV system is healthy before the service starts.",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
    url: `${SITE_URL}/pricing`,
  },
};
---

<Layout
  title="AV Monitoring &amp; Stream Health — Diagnose"
  socialTitle="WorshipMetrics AV Monitoring & Stream Health — Diagnose"
  description="Real-time stream health monitoring, system status dashboards, and booth observability built into WorshipMetrics. Know your AV system is healthy before the service starts."
  canonical="/av-monitoring"
  ogImage={HERO_IMAGE}
  structuredData={structuredData}
>
  <Fragment slot="head">
    <link rel="preload" as="image" href={HERO_IMAGE} />
  </Fragment>

  <section class="bg-gradient-to-b from-indigo-50 via-white to-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)]">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">AV Monitoring</p>
        <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
          Know what&rsquo;s wrong before the congregation does.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-600 sm:text-xl">
          When your stream drops, you should not find out from a text. AV Monitoring gives you real-time visibility into every device, every signal, and every stream in your booth so you catch problems before the congregation notices.
        </p>
        <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:flex-wrap sm:items-center">
          <a href={`${APP_URL}/sign-up`} class="btn-primary" data-wm-track="cta_click" data-wm-track-label="av_monitoring_hero_get_started_free" data-wm-track-location="av_monitoring_hero">Get started free</a>
          <a href="/tech-manager" class="btn-outline">See Tech Manager</a>
          <a href="/integrations" class="btn-outline">See Integrations</a>
        </div>
        <p class="mt-4 text-sm text-slate-500">Stream health monitoring is included in Tech Manager.</p>
      </div>

      <div class="overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-[0_24px_60px_rgba(15,23,42,0.12)]">
        <img src={HERO_IMAGE} alt="Stream health monitoring dashboard in WorshipMetrics" loading="eager" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">What it monitors</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">One dashboard for everything that keeps your service running.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          AV Monitoring gives you visibility into your livestream, your connected devices, and your overall system health. The same tool that runs the service also watches it.
        </p>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {features.map(({ title, body }) => (
          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-8 shadow-sm">
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-indigo-600">{title}</p>
            <p class="mt-4 text-sm leading-relaxed text-slate-600 sm:text-base">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-2">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Booth observability</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Stop checking each piece of gear individually.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          Most church AV teams verify their setup by walking around the booth and checking each device one at a time. AV Monitoring surfaces the status of every connected camera, switcher, encoder, and integration in a single dashboard that updates in real time.
        </p>
        <ul class="mt-8 space-y-3">
          {observabilityItems.map((item) => (
            <li class="flex items-start gap-3 text-sm text-slate-700 sm:text-base"><span class="mt-2 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-indigo-500"></span><span>{item}</span></li>
          ))}
        </ul>
        <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
          <a href="/tech-manager" class="btn-primary">Download Tech Manager</a>
          <a href="/integrations" class="btn-outline">See supported gear</a>
        </div>
      </div>
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src={MONITOR_IMAGE} alt="System monitoring and control panels in WorshipMetrics" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-2">
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src={HERO_IMAGE} alt="Stream quality monitoring in WorshipMetrics" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Prove your AV is serving the mission</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Data that helps you make the case for better gear.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          When you can show leadership that your stream dropped three times last month and attendance dipped on those same Sundays, the conversation changes. AV Monitoring gives you the data to justify upgrades, plan installs, and prove that your AV investment is serving the mission.
        </p>
        <ul class="mt-8 space-y-3">
          {[
            "Historical stream health data across weeks and months",
            "Correlate technical issues with attendance and engagement trends",
            "Build a data-backed case for equipment upgrades and system improvements",
            "Show your leadership what your team is managing every Sunday",
          ].map((item) => (
            <li class="flex items-start gap-3 text-sm text-slate-700 sm:text-base"><span class="mt-2 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-indigo-500"></span><span>{item}</span></li>
          ))}
        </ul>
        <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
          <a href="/pilot-program" class="btn-primary">Start your pilot</a>
          <a href="/your-av-partner" class="btn-outline">See AV Partner services</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">How it works</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Three ways to keep eyes on your system.</h2>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {[
          {
            title: "Real-time",
            body: "Watch stream bitrate, frame drops, and device status during the service. Red flags surface before they become visible problems.",
          },
          {
            title: "Pre-service",
            body: "Run a health check before the room fills up. Confirm every camera, encoder, and integration is connected and reporting.",
          },
          {
            title: "Historical",
            body: "Review stream performance across Sundays. Spot patterns, correlate issues with attendance dips, and plan maintenance windows.",
          },
        ].map(({ title, body }) => (
          <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-indigo-600">{title}</p>
            <p class="mt-4 text-sm leading-relaxed text-slate-600 sm:text-base">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-950 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl rounded-[2rem] border border-white/10 bg-white/5 p-8 shadow-2xl sm:p-12">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-300">Attendance + stream health together</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">See how your stream quality actually affects who shows up.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-300 sm:text-lg">
          Most churches track attendance and stream quality in two completely separate tools. WorshipMetrics brings them together so you can see the real relationship between technical quality and online engagement.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row sm:flex-wrap">
          <a href="/platform/attendance" class="btn-primary">See Attendance</a>
          <a href={`${APP_URL}/sign-up`} class="btn-outline" style="border-color:rgba(255,255,255,0.16);color:#fff;">Get started free</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Know before they text you.</h2>
      <p class="mx-auto mt-4 max-w-3xl text-base leading-relaxed text-slate-600 sm:text-lg">
        Stop finding out about stream problems from the people watching at home. Monitor your system health, protect your online reach, and walk into Monday with real data about how Sunday actually went.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row sm:flex-wrap">
        <a href={`${APP_URL}/sign-up`} class="btn-primary" data-wm-track="cta_click" data-wm-track-label="av_monitoring_footer_get_started_free" data-wm-track-location="av_monitoring_footer_cta">Get started free</a>
        <a href="/discovery-call" class="btn-outline" data-wm-track="cta_click" data-wm-track-label="av_monitoring_footer_book_call" data-wm-track-location="av_monitoring_footer_cta">Book a demo</a>
        <a href="/pilot-program" class="btn-outline">Start your pilot</a>
      </div>
    </div>
  </section>
</Layout>
