---
import Layout from "../layouts/Layout.astro";

const SITE_URL = "https://worshipmetrics.com";
const OG_IMAGE = `${SITE_URL}/legacy-images/welcome-capture-wide.jpg`;
const faqItems = [
  {
    question: "What is church visitor follow-up software?",
    answer: "Church visitor follow-up software helps churches capture guest information, organize follow-up tasks, connect prayer requests, and track next steps after a first visit.",
  },
  {
    question: "Can WorshipMetrics capture paper welcome cards?",
    answer: "Yes. WorshipMetrics supports welcome card scanning so churches can move guest details into the system without manual re-entry later.",
  },
  {
    question: "Does WorshipMetrics connect visitor follow-up with attendance?",
    answer: "Yes. Visitor records, attendance signals, and prayer requests can all live in the same workflow so your team has more context before reaching out.",
  },
  {
    question: "Can online visitors be included too?",
    answer: "Yes. WorshipMetrics can help churches connect website, prayer, and livestream engagement to the same follow-up system used for in-person guests.",
  },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "WorshipMetrics Church Visitor Follow-Up Software",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web, iOS, Android",
    url: `${SITE_URL}/church-visitor-follow-up-software`,
    image: OG_IMAGE,
    description: "Church visitor follow-up software for guest capture, welcome card scanning, prayer request routing, and people workflows.",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
      availability: "https://schema.org/InStock",
      url: `${SITE_URL}/pricing`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map(({ question, answer }) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: { "@type": "Answer", text: answer },
    })),
  },
];
---

<Layout
  title="Church Visitor Follow-Up Software"
  description="Church visitor follow-up software for guest capture, welcome card scanning, prayer request routing, and people workflows."
  canonical="/church-visitor-follow-up-software"
  ogImage={OG_IMAGE}
  structuredData={structuredData}
>
  <section class="bg-gradient-to-b from-indigo-50 to-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Church visitor follow-up software</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">Church visitor follow-up software that helps your team respond faster and care better.</h1>
      <p class="mt-6 text-lg text-slate-600 sm:text-xl">Capture guests, scan welcome cards, route prayer requests, and connect follow-up with attendance and digital engagement in one system.</p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/platform/people" class="rounded-xl bg-indigo-600 px-8 py-3 text-base font-semibold text-white shadow transition hover:bg-indigo-700">See people workflows</a>
        <a href="/discovery-call" class="rounded-xl border border-slate-300 px-8 py-3 text-base font-semibold text-slate-700 transition hover:border-indigo-400 hover:text-indigo-600">Talk with our team</a>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 pb-8 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src={OG_IMAGE} alt="Church visitor follow-up software and welcome capture" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src="https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main/tablet/Pastoral%20Care%202.jpg" alt="Pastoral follow-up workflow in WorshipMetrics" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl grid gap-6 md:grid-cols-3">
      {[
        ["Capture every type of response", "Paper welcome cards, QR responses, prayer requests, and online inquiries can all move into one people workflow."],
        ["Keep context with the person", "Your team sees more than a name. They can understand attendance, prayer, guest history, and the next best follow-up step."],
        ["Make follow-up sustainable", "Good follow-up should not depend on one person remembering everything after service. WorshipMetrics helps create a repeatable system."],
      ].map(([title, body]) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900">{title}</h2>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">{body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-center text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">A better visitor follow-up flow for churches</h2>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {[
          ["1. Capture", "Collect guest details at the welcome desk, through QR codes, from prayer requests, or from online outreach."],
          ["2. Organize", "Keep records, attendance context, and follow-up notes in one place so the right team members know what to do."],
          ["3. Respond", "Move from raw guest data to real ministry follow-up before momentum is lost after Sunday."],
        ].map(([title, body]) => (
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-8">
            <h3 class="text-xl font-bold text-slate-900">{title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center text-2xl font-bold text-slate-900 sm:text-3xl">Related solutions</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {[
          { href: "/platform/people", title: "People and follow-up", body: "See the core guest capture and follow-up workflow inside WorshipMetrics." },
          { href: "/solutions/digital-engagement", title: "Digital engagement", body: "Connect online attention, prayer requests, and visitor records to the same church follow-up system." },
          { href: "/platform/attendance", title: "Attendance tracking", body: "Use attendance signals to notice new guests, missing families, and follow-up needs earlier." },
        ].map(({ href, title, body }) => (
          <a href={href} class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:bg-indigo-50/20">
            <h3 class="text-lg font-semibold text-slate-900">{title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{body}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-indigo-600">Explore →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">FAQ</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Questions churches ask about visitor follow-up software</h2>
      </div>
      <div class="mt-8 space-y-4">
        {faqItems.map(({ question, answer }) => (
          <details class="rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-sm">
            <summary class="cursor-pointer list-none text-lg font-semibold text-slate-900">{question}</summary>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-indigo-600 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-white">Build a visitor follow-up system your church can sustain.</h2>
      <p class="mt-4 text-indigo-200">We can help you connect guest capture, prayer routing, and follow-up so your team works from one clear process.</p>
      <a href="/discovery-call" class="mt-8 inline-block rounded-xl bg-white px-8 py-3 text-base font-semibold text-indigo-700 shadow transition hover:bg-indigo-50">Book a discovery call</a>
    </div>
  </section>
</Layout>
