---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Returns Policy"
  description="WorshipMetrics hardware returns and refund policy."
  canonical="/returns"
>
  <section class="bg-white px-6 py-20">
    <div class="mx-auto max-w-3xl">
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 mb-10">Returns Policy</h1>

      <div class="space-y-10">
        <div>
          <h2 class="text-xl font-bold text-slate-900 mb-3">Hardware Returns</h2>
          <p class="text-slate-600 leading-relaxed">
            WorshipMetrics hardware (Hub and Tablet) may be returned within 30 days of purchase.
            Hardware must be in original condition. We provide a prepaid return label. Refunds are
            processed within 7 business days of receiving the return.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-slate-900 mb-3">Software Refunds</h2>
          <p class="text-slate-600 leading-relaxed">
            Paid plans include a 30-day free trial. After the trial period, we do not provide
            refunds for the current billing period. Cancel anytime to stop future charges.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-slate-900 mb-3">Contact</h2>
          <p class="text-slate-600 leading-relaxed">
            To initiate a return or request a refund, contact{" "}
            <a
              href="mailto:support@worshipmetrics.com"
              class="text-indigo-600 hover:text-indigo-700 underline"
            >
              support@worshipmetrics.com
            </a>{" "}
            or call{" "}
            <a href="tel:9109677447" class="text-indigo-600 hover:text-indigo-700 underline">
              910-967-7447
            </a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
