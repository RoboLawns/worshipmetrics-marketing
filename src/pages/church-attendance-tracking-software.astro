---
import Layout from "../layouts/Layout.astro";

const SITE_URL = "https://worshipmetrics.com";
const OG_IMAGE = `${SITE_URL}/legacy-images/seat-counting-hero.jpg`;
const faqItems = [
  {
    question: "What is church attendance tracking software?",
    answer: "Church attendance tracking software helps churches record in-person and online attendance, compare trends, and connect attendance data to people follow-up and ministry reporting.",
  },
  {
    question: "Can WorshipMetrics track in-person and online attendance together?",
    answer: "Yes. WorshipMetrics combines in-person attendance and online viewership into one reporting workflow so churches do not have to reconcile numbers across disconnected tools.",
  },
  {
    question: "Can volunteers use WorshipMetrics for attendance counting?",
    answer: "Yes. Volunteers can use seat templates, tablet workflows, and quick count tools that make attendance tracking faster on Sundays.",
  },
  {
    question: "Does attendance tracking connect to guest follow-up?",
    answer: "Yes. WorshipMetrics ties attendance to people records so churches can notice guests, absences, and follow-up opportunities sooner.",
  },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "WorshipMetrics Church Attendance Tracking Software",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web, iOS, Android",
    url: `${SITE_URL}/church-attendance-tracking-software`,
    image: OG_IMAGE,
    description: "Church attendance tracking software for in-person and online attendance, seat templates, volunteer counting, and follow-up reporting.",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
      availability: "https://schema.org/InStock",
      url: `${SITE_URL}/pricing`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map(({ question, answer }) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: { "@type": "Answer", text: answer },
    })),
  },
];
---

<Layout
  title="Church Attendance Tracking Software"
  description="Church attendance tracking software for in-person and online attendance, seat templates, volunteer counting, and follow-up reporting."
  canonical="/church-attendance-tracking-software"
  ogImage={OG_IMAGE}
  structuredData={structuredData}
>
  <section class="bg-gradient-to-b from-indigo-50 to-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Church attendance tracking software</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
        Church attendance tracking software built for real Sunday workflows.
      </h1>
      <p class="mt-6 text-lg text-slate-600 sm:text-xl">
        Track in-person attendance, online attendance, seat counts, and follow-up signals in one connected system your staff and volunteers can actually use.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/platform/attendance" class="rounded-xl bg-indigo-600 px-8 py-3 text-base font-semibold text-white shadow transition hover:bg-indigo-700">See attendance workflows</a>
        <a href="/discovery-call" class="rounded-xl border border-slate-300 px-8 py-3 text-base font-semibold text-slate-700 transition hover:border-indigo-400 hover:text-indigo-600">Book a discovery call</a>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 pb-8 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)]">
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src={OG_IMAGE} alt="Church attendance tracking software in WorshipMetrics" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src="/legacy-images/attendance-tracking-dashboard.jpg" alt="Attendance dashboard for churches" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl grid gap-6 md:grid-cols-3">
      {[
        {
          title: "Track the room accurately",
          body: "Use seat templates, quick volunteer workflows, or automated counting tools to match the room you actually have each Sunday.",
        },
        {
          title: "Include online attendance",
          body: "Bring livestream and replay reporting into the same weekly review so leadership sees one clearer ministry picture.",
        },
        {
          title: "Turn attendance into action",
          body: "Attendance matters more when it helps your team notice guests, missed households, and pastoral follow-up needs.",
        },
      ].map(({ title, body }) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900">{title}</h2>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">{body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-center text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">How WorshipMetrics fits this workflow</h2>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {[
          ["Count", "Run seat-template counting, volunteer entry, or automated attendance workflows from one system."],
          ["Review", "See in-person and online numbers together with trends that make sense to staff and leadership."],
          ["Follow up", "Connect attendance data to guest capture, absences, and people workflows instead of leaving counts in isolation."],
        ].map(([title, body], index) => (
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-8">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Step {index + 1}</p>
            <h3 class="mt-3 text-xl font-bold text-slate-900">{title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center text-2xl font-bold text-slate-900 sm:text-3xl">Related church workflows</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {[
          { href: "/platform/attendance", title: "Attendance platform", body: "See the full church attendance tracking workflow inside WorshipMetrics." },
          { href: "/tablet", title: "Church check-in tablet", body: "Give greeters and volunteers a dedicated attendance and guest capture device." },
          { href: "/platform/people", title: "Visitor follow-up", body: "Connect attendance signals to people records and pastoral next steps." },
        ].map(({ href, title, body }) => (
          <a href={href} class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:bg-indigo-50/20">
            <h3 class="text-lg font-semibold text-slate-900">{title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{body}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-indigo-600">Explore →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">FAQ</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Questions churches ask about attendance tracking software</h2>
      </div>
      <div class="mt-8 space-y-4">
        {faqItems.map(({ question, answer }) => (
          <details class="rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-sm">
            <summary class="cursor-pointer list-none text-lg font-semibold text-slate-900">{question}</summary>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-indigo-600 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-white">See how church attendance tracking can fit your team.</h2>
      <p class="mt-4 text-indigo-200">We will walk through your current attendance process and show you the simplest path to a more connected workflow.</p>
      <a href="/discovery-call" class="mt-8 inline-block rounded-xl bg-white px-8 py-3 text-base font-semibold text-indigo-700 shadow transition hover:bg-indigo-50">Book a discovery call</a>
    </div>
  </section>
</Layout>
