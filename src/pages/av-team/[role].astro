---
import Layout from "../../layouts/Layout.astro";
import AVTeamCarousel from "../../components/AVTeamCarousel.astro";
import AVTeamRoleNav from "../../components/AVTeamRoleNav.astro";
import { avTeamRoles, getAVTeamRole, getAVTeamNeighbors } from "../../data/avTeam";

export const prerender = true;

export function getStaticPaths() {
  return avTeamRoles.map((role) => ({
    params: { role: role.slug },
    props: { role },
  }));
}

const { role } = Astro.props;
const SITE_URL = "https://worshipmetrics.com";
const R2 = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
const DEFAULT_IMAGE = `${R2}/Tech%20Manager/WorshipMetrics%20Tech%20Manager%20Web-UI%20Panels.jpg`;

const roleImages: Record<string, string> = {
  "service-director": `${R2}/Tech%20Manager/WorshipMetrics%20Tech%20Manager%20Hero.jpg`,
  "camera-operator": `${R2}/Tech%20Manager/WorshipMetrics%20Tech%20Manager%20Hero.jpg`,
  "audio-engineer": `${R2}/Tech%20Manager/WorshipMetrics%20Tech%20Manager%20Pro.jpg`,
  "lyrics-operator": `${R2}/homepage/Team%20Collaboration%20hero.jpg`,
  "stream-operator": `${R2}/Tech%20Manager/WorshipMetrics%20Tech%20Manager%20Pro.jpg`,
  "lighting-operator": `${R2}/homepage/new%20images/Worship%20Digital%20Signage%20System.jpg`,
  "recording-archivist": `${R2}/homepage/Worship%20Clips%20Hero%202.jpg`,
};

const image = roleImages[role.slug] || DEFAULT_IMAGE;
const neighbors = getAVTeamNeighbors(role.slug);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: role.metaTitle,
  url: `${SITE_URL}/av-team/${role.slug}`,
  description: role.metaDescription,
  image,
};
---

<Layout
  title={role.metaTitle}
  description={role.metaDescription}
  canonical={`/av-team/${role.slug}`}
  ogImage={image}
  structuredData={structuredData}
>
  <section class="bg-gradient-to-b from-indigo-50 via-white to-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <AVTeamRoleNav slug={role.slug} />
      <div class="mt-8 grid items-center gap-12 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)]">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em]" style={`color:${role.accentColor}`}>{role.subtitle}</p>
          <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">{role.heroHeading}</h1>
          <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-600 sm:text-xl">{role.heroSubheading}</p>
        </div>
        <div class="overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-[0_24px_60px_rgba(15,23,42,0.12)]">
          <img src={image} alt={role.title} loading="eager" decoding="async" class="aspect-[16/10] w-full object-cover" />
        </div>
      </div>
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {[
          { label: "Skill level", value: role.skillLevel },
          { label: "Typical age", value: role.typicalAge },
          { label: "Intercom", value: role.intercomPriority },
        ].map(({ label, value }) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-indigo-600">{label}</p>
            <p class="mt-2 text-sm font-semibold text-slate-900">{value}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em]" style={`color:${role.accentColor}`}>The role in one sentence</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">{role.roleSentence}</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">{role.whoIntro}</p>
        <ul class="mt-8 space-y-3 text-sm text-slate-700 sm:text-base">
          {role.whoTraits.map((item) => (
            <li class="flex items-start gap-3"><span class="mt-2 h-2.5 w-2.5 flex-shrink-0 rounded-full" style={`background:${role.accentColor}`}></span><span>{item}</span></li>
          ))}
        </ul>
      </div>
      <div class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-8 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.18em]" style={`color:${role.accentColor}`}>Why this matters for youth teams</p>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">{role.youthAngle}</p>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm sm:p-10">
      <p class="text-sm font-semibold uppercase tracking-[0.18em]" style={`color:${role.accentColor}`}>What the panel does</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">A volunteer-friendly control surface for one real seat.</h2>
      <p class="mt-4 max-w-4xl text-base leading-relaxed text-slate-600 sm:text-lg">{role.panelIntro}</p>
      <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {role.controls.map((control) => (
          <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50 p-6 text-sm leading-relaxed text-slate-700">{control}</div>
        ))}
      </div>
      <p class="mt-8 text-base leading-relaxed text-slate-600 sm:text-lg">{role.behavior}</p>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-3">
      <div class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-8 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.18em]" style={`color:${role.accentColor}`}>Tech reassurance</p>
        <p class="mt-4 text-sm leading-relaxed text-slate-600 sm:text-base">{role.techReassurance}</p>
      </div>
      <div class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-8 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.18em]" style={`color:${role.accentColor}`}>Why this works on a tablet</p>
        <p class="mt-4 text-sm leading-relaxed text-slate-600 sm:text-base">{role.tabletBody}</p>
      </div>
      <div class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-8 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.18em]" style={`color:${role.accentColor}`}>Intercom</p>
        <p class="mt-4 text-sm leading-relaxed text-slate-600 sm:text-base">{role.intercomBody}</p>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.95fr)]">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em]" style={`color:${role.accentColor}`}>What it can work with</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Built to fit the systems churches already use.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">{role.compatibilityIntro}</p>
      </div>
      <div class="space-y-4">
        {role.compatibilityGroups.map((group) => (
          <div class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900">{group.heading}</h3>
            <ul class="mt-4 space-y-3 text-sm text-slate-600">
              {group.items.map((item) => (
                <li class="flex items-start gap-3"><span class="mt-2 h-2.5 w-2.5 flex-shrink-0 rounded-full" style={`background:${role.accentColor}`}></span><span>{item}</span></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl rounded-[2rem] border border-slate-200 bg-slate-950 p-8 shadow-2xl sm:p-12">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-300">Where this role sits in your team</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">This seat should lead somewhere.</h2>
      <p class="mt-4 text-base leading-relaxed text-slate-300 sm:text-lg">{role.teamPlacement}</p>
      <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:flex-wrap sm:items-center">
        {neighbors.next ? (
          <a href={`/av-team/${neighbors.next.slug}`} class="btn-primary">Next role: {neighbors.next.title}</a>
        ) : (
          <a href="/av-team" class="btn-primary">Back to the AV Team hub</a>
        )}
        <a href="/discovery-call" class="btn-outline" style="border-color:rgba(255,255,255,0.2);color:#fff;">Book a demo</a>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <AVTeamCarousel currentSlug={role.slug} heading="Explore the rest of the team." compact={true} />
    </div>
  </section>
</Layout>
