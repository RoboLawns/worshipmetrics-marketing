---
import Layout from "../layouts/Layout.astro";

const SITE_URL = "https://worshipmetrics.com";
const DISCOVERY_URL = "/discovery-call";
const R2 = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
const R2NEW = `${R2}/homepage/new%20images`;
const TECH_MANAGER_HERO_IMAGE = `${R2}/Tech%20Manager/WorshipMetrics%20Tech%20Manager%20Hero.jpg`;
const TECH_MANAGER_PRO_IMAGE = `${R2}/Tech%20Manager/WorshipMetrics%20Tech%20Manager%20Pro.jpg`;
const OG_IMAGE = TECH_MANAGER_HERO_IMAGE;

const systemDocumentation = [
  "Computer name, operating system, version, and last update",
  "Processor model, core count, clock speed, RAM, GPU, and storage",
  "OBS version, plugin list, startup programs, and power-plan health",
  "Wired vs WiFi status, internet speed, upload, latency, and jitter",
  "Every camera, encoder, switcher, and display on the network",
  "PTZ cameras discovered and mapped automatically via ONVIF",
];

const monitoringFeatures = [
  "Stream status — live, offline, or degraded",
  "Bitrate and dropped frames in real time",
  "Encoder CPU load before it causes a drop",
  "OBS connection and log warnings",
  "Every camera on the network — online/offline",
  "Every display — active and showing correct content",
  "Internet connectivity and upload speed",
  "Local network device availability",
];

const selfHealingRows = [
  ["OBS crashes", "Restarts OBS and resumes the stream"],
  ["Stream drops", "Attempts immediate stream restart"],
  ["Bitrate degrades", "Reduces resolution to stabilize stream"],
  ["Camera goes offline", "Sends wake command via ONVIF"],
  ["Signage player crashes", "Restarts local signage server"],
  ["Local recording stops", "Restarts recording, flags the gap"],
  ["Disk space low", "Clears cached signage files, alerts team"],
  ["Internet drops", "Switches displays to local cached content"],
];

const tierRows = [
  ["System documentation", "Full", "Full", "Full"],
  ["OBS monitoring", "Basic", "Full", "Full + Luminos AI"],
  ["Cloud monitoring", "On-demand", "Continuous", "Continuous 24/7"],
  ["Self-healing", "Yes", "Yes", "Yes"],
  ["Luminos AV diagnostics", "Basic", "Full", "Full + remote action"],
  ["Local signage hosting", "1 screen", "Unlimited", "Unlimited"],
  ["PTZ camera control", "No", "Yes", "Yes + remote cloud"],
  ["Stream health alerts", "No", "Email", "Push + phone"],
  ["Remote OBS control", "No", "No", "Yes"],
];

const supportTabs = [
  {
    id: "ptz-cameras",
    label: "PTZ Cameras",
    title: "Your PTZ cameras, discovered and pre-configured.",
    body: "Tech Manager supports the full range of PTZ cameras found in congregations today, from broadcast-grade Sony and Panasonic units to the most common Amazon-native brands. When a camera is found on your network, Tech Manager pre-fills the RTSP stream URL, VISCA control port, and PTZ settings automatically.",
    supported: [
      "PTZOptics", "SMTAV", "Avkans", "Minrray", "Zowietek", "Birddog", "BZBGEAR", "Wivien", "Nelopes", "Glocom", "Aferiy", "Zcvideo", "Intelix", "Sony", "Panasonic", "Marshall", "Vaddio", "Aver", "OBSBOT", "Axis", "Hikvision", "Amcrest", "Dahua", "Reolink", "Foscam"
    ],
    notes: [
      {
        heading: "PTZOptics users",
        body: "Tech Manager natively understands the PTZOptics VISCA protocol on TCP port 5678. NDI-enabled PTZOptics cameras also appear in the NDI device list automatically.",
      },
      {
        heading: "Budget Amazon PTZ users",
        body: "Tech Manager handles the common RTSP, VISCA, and ONVIF patterns automatically. If your camera has a network connection, we can likely remotely monitor and manage it for you.",
      },
    ],
  },
  {
    id: "switchers-encoders",
    label: "Switchers & Encoders",
    title: "Production hardware that already belongs in your booth.",
    body: "Tech Manager recognizes the switching and encoding gear congregations actually use, from the Blackmagic ATEM family to Roland, Ross, Epiphan, AJA, Magewell, Kiloview, Teradek, and LiveU.",
    supported: [
      "Blackmagic ATEM Mini", "ATEM Mini Pro", "ATEM Mini Extreme", "ATEM Television Studio HD", "ATEM 4 M/E", "Blackmagic HyperDeck", "Blackmagic Smart Videohub", "Roland V-8HD", "Roland V-160HD", "vMix", "Ross Video Carbonite", "Kramer VS series", "Epiphan Pearl Nano", "Epiphan Pearl-2", "AJA HELO", "AJA Ki Pro Ultra", "Magewell Pro Convert", "Magewell Ultra Encode", "Teradek VidiU Pro", "Teradek Cube 655", "Kiloview E1", "Kiloview N2", "LiveU Solo"
    ],
  },
  {
    id: "audio-dante",
    label: "Audio & Dante",
    title: "Audio consoles, wireless, and Dante-aware discovery.",
    body: "Tech Manager supports the digital consoles and Dante-connected devices congregations rely on every week, including Yamaha, Behringer, PreSonus, Allen & Heath, QSC, Shure, Crown, Mackie, Focusrite, and RME.",
    supported: [
      "Yamaha DM3", "Yamaha TF1", "Yamaha MG10XU", "Behringer X32", "Behringer XR18", "Behringer X18", "PreSonus StudioLive 32SX", "PreSonus StudioLive 16", "Allen & Heath SQ-5", "Allen & Heath dLive", "DiGiCo SD11", "QSC Q-SYS Core", "Shure ULXD / QLXD / Axient", "Crown DCi-D", "Mackie DL32R", "Focusrite RedNet", "RME Dante interfaces", "Any Dante-enabled device"
    ],
    notes: [
      {
        heading: "Dante networks",
        body: "Tech Manager identifies Dante devices by their Audinate discovery traffic. Any gear with a Dante card, from Shure wireless receivers to Crown amplifiers, can appear in your AV inventory automatically.",
      },
    ],
  },
  {
    id: "control-ndi-network",
    label: "Control, NDI & Network",
    title: "Control systems, NDI sources, and the network gear around them.",
    body: "Tech Manager also recognizes the control and network layer around your production chain, including Crestron, Extron, WolfVision, Atlona, Ross openGear, NDI broadcasters, Ubiquiti UniFi, TP-Link Omada, Netgear ProSafe, and managed switch environments.",
    supported: [
      "Crestron CP4N", "Crestron DM-NVX", "Extron IP Link Pro", "Extron SMP Streaming Processor", "Kramer Protocol 3000 devices", "WolfVision Cynap Pro", "Atlona OmniStream", "Ross Video openGear / DashBoard", "OBS NDI Output plugin", "Birddog PTZ cameras", "Kiloview N2", "Magewell Pro Convert", "OBSBOT Tail Air", "PTZOptics Link 4K", "Ubiquiti UniFi", "TP-Link Omada", "Netgear ProSafe"
    ],
    notes: [
      {
        heading: "Crestron hardware",
        body: "Crestron hardware can be identified by its IANA-registered control port, which means Tech Manager can often discover it without needing credentials just to know it exists.",
      },
      {
        heading: "NDI sources",
        body: "Any device or software broadcasting an NDI source on your network can be discovered and added to your AV inventory automatically.",
      },
    ],
  },
];

const faqItems = [
  {
    question: "What is Tech Manager?",
    answer: "Tech Manager is a free desktop app for Windows and Mac that powers the booth inside the broader WorshipMetrics platform. It documents your AV system, monitors signals continuously, and gives Luminos the context it needs to diagnose issues fast.",
  },
  {
    question: "Does Tech Manager require the Hub?",
    answer: "No. Tech Manager is the desktop bridge between your physical AV system and the WorshipMetrics cloud, and it can work with or without the Hub.",
  },
  {
    question: "Does Tech Manager fix problems automatically?",
    answer: "Yes. Tech Manager includes a self-healing layer for common issues like OBS crashes, stream drops, camera reconnects, signage restarts, and cached local signage during internet outages.",
  },
  {
    question: "Why does Luminos need Tech Manager for AV support?",
    answer: "Without Tech Manager, Luminos can answer questions about ministry data. With Tech Manager installed, Luminos gains real-time visibility into your actual hardware, OBS state, cameras, network health, and support history so it can diagnose AV problems specifically instead of generically.",
  },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "WorshipMetrics Tech Manager",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Windows, Mac",
    url: `${SITE_URL}/tech-manager`,
    image: OG_IMAGE,
  description: "Tech Manager is the desktop app that powers your booth with AV monitoring, system mapping, PTZ control, and Luminos diagnostics inside WorshipMetrics.",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
      availability: "https://schema.org/InStock",
      url: `${SITE_URL}${DISCOVERY_URL}`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map(({ question, answer }) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: {
        "@type": "Answer",
        text: answer,
      },
    })),
  },
];
---

<Layout
  title="Tech Manager"
  description="Tech Manager is the desktop app that powers your booth with AV monitoring, system mapping, PTZ control, and Luminos diagnostics inside WorshipMetrics."
  canonical="/tech-manager"
  ogImage={OG_IMAGE}
  structuredData={structuredData}
>
  <section class="bg-slate-950 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-300">Tech Manager</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        The desktop app that powers<br />
        your booth.
      </h1>
      <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-slate-300 sm:text-xl">
        Tech Manager is a free desktop app for Windows and Mac that runs alongside Services inside WorshipMetrics. It maps your AV system, monitors the booth continuously, and gives Luminos the real context it needs to diagnose problems with specificity.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={DISCOVERY_URL} class="rounded-xl bg-indigo-600 px-8 py-3 text-base font-semibold text-white shadow transition hover:bg-indigo-500">
          Download free for Windows
        </a>
        <a href="/services" class="rounded-xl border border-indigo-300 px-8 py-3 text-base font-semibold text-white transition hover:border-white">
          See how it fits Services
        </a>
      </div>
        <p class="mt-4 text-sm text-slate-400">Free account required. Works on all plans. Tech Manager is one feature of the broader WorshipMetrics platform.</p>
    </div>

    <div class="mx-auto mt-16 max-w-6xl overflow-hidden rounded-3xl border border-white/10 bg-white/5 shadow-2xl">
      <img src={TECH_MANAGER_HERO_IMAGE} alt="WorshipMetrics Tech Manager hero interface" loading="lazy" decoding="async" class="w-full object-cover" />
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl rounded-3xl border border-slate-200 bg-slate-50 p-8 text-center shadow-sm sm:p-10">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">The one-line explanation</p>
      <p class="mt-4 text-lg leading-relaxed text-slate-700 sm:text-xl">
        Tech Manager is the desktop bridge between your physical AV system and the WorshipMetrics platform. It keeps the booth grounded in reality while Services runs the plan and Luminos understands what changed in the system.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/av-monitoring-for-houses-of-worship" class="rounded-xl bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow transition hover:bg-indigo-700">See AV monitoring</a>
        <a href="/luminos-ai-assistant" class="rounded-xl border border-slate-300 px-6 py-3 text-sm font-semibold text-slate-700 transition hover:border-indigo-400 hover:text-indigo-600">See Luminos</a>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 pb-16 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)]">
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src={TECH_MANAGER_PRO_IMAGE} alt="Tech Manager Pro dashboard showing booth system visibility" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
      <div class="rounded-3xl border border-slate-200 bg-slate-50 p-8 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">What the booth actually sees</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">One screen that makes the system legible.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          This view is the practical value of Tech Manager. Instead of keeping the booth state in one operator&apos;s head, the system map, device health, and production context are visible in software the rest of the platform can understand.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">What it does</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Runs silently. Works constantly. Keeps the booth connected to the platform.</h2>
      <p class="mx-auto mt-4 max-w-3xl text-base leading-relaxed text-slate-600 sm:text-lg">
        Tech Manager runs in your system tray from the moment your production computer starts. You do not manage it. You do not interact with it. It just works — watching your system, feeding data to the cloud, and stepping in automatically when something goes wrong.
      </p>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-4xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Auto-discovery</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">80+ supported devices across the production chain.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">Tech Manager recognizes the gear congregations actually use. Scan your network and your AV inventory builds itself — from PTZ cameras and encoders to Dante devices, NDI sources, and managed switches.</p>
      </div>

      <div class="mt-10 flex flex-wrap justify-center gap-3" role="tablist" aria-label="Supported device groups">
        {supportTabs.map((tab, index) => (
          <button
            type="button"
            class:list={[
              "tech-tab rounded-full border px-4 py-2 text-sm font-semibold transition",
              index === 0 ? "border-indigo-600 bg-indigo-600 text-white" : "border-slate-300 bg-white text-slate-700 hover:border-indigo-400 hover:text-indigo-700",
            ]}
            data-tech-tab={tab.id}
            aria-selected={index === 0 ? "true" : "false"}
          >
            {tab.label}
          </button>
        ))}
      </div>

      <div class="mt-8">
        {supportTabs.map((tab, index) => (
          <div class:list={["tech-panel rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm sm:p-8", index !== 0 && "hidden"]} data-tech-panel={tab.id}>
            <div class="grid gap-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">{tab.label}</p>
                <h3 class="mt-3 text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">{tab.title}</h3>
                <p class="mt-4 text-sm leading-relaxed text-slate-600 sm:text-base">{tab.body}</p>
                {tab.notes && (
                  <div class="mt-6 space-y-3">
                    {tab.notes.map((note) => (
                      <div class="rounded-2xl border border-indigo-200 bg-indigo-50 p-4">
                        <p class="text-sm font-semibold text-indigo-700">{note.heading}</p>
                        <p class="mt-2 text-sm leading-relaxed text-slate-700">{note.body}</p>
                      </div>
                    ))}
                  </div>
                )}
              </div>

              <div>
                <details class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm" open>
                  <summary class="cursor-pointer list-none text-sm font-semibold uppercase tracking-[0.16em] text-slate-700">View supported brands and devices</summary>
                  <div class="mt-4 flex flex-wrap gap-2">
                    {tab.supported.map((item) => (
                      <span class="inline-flex rounded-full border border-slate-200 bg-slate-50 px-3 py-1.5 text-xs font-semibold text-slate-700">{item}</span>
                    ))}
                  </div>
                </details>

                <details class="mt-4 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                  <summary class="cursor-pointer list-none text-sm font-semibold uppercase tracking-[0.16em] text-slate-700">Need something custom?</summary>
                  <p class="mt-4 text-sm leading-relaxed text-slate-600">Don&apos;t see your exact device? Add it manually and Tech Manager will remember it — including RTSP URL, PTZ settings, and notes — so the next scan still knows what belongs in your system.</p>
                </details>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mx-auto mt-8 max-w-4xl rounded-2xl border border-slate-200 bg-slate-950 p-6 text-center shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-300">Quick summary</p>
        <p class="mt-3 text-base leading-relaxed text-slate-200 sm:text-lg">80+ supported devices. Tech Manager recognizes the gear congregations actually use — from PTZOptics and Blackmagic ATEM to Yamaha DM3, QSC Q-SYS, Shure wireless, and your entire Dante network.</p>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Feature 1 — System documentation</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Your AV system, fully documented. Automatically.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">The moment Tech Manager installs, it starts building a complete profile of your production environment without you filling out a single form.</p>
        <p class="mt-6 text-sm font-semibold uppercase tracking-[0.16em] text-slate-500">What it captures automatically</p>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          {systemDocumentation.map((item) => (
            <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-700 shadow-sm">{item}</div>
          ))}
        </div>
        <p class="mt-6 text-sm leading-relaxed text-slate-600">You add the human details once: friendly names, physical locations, cable connections, input assignments, passwords, notes, and photos of physical hardware. The knowledge stays in the cloud even when a volunteer moves on.</p>
        <a href="/your-av-partner" class="mt-8 inline-block rounded-xl bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow transition hover:bg-indigo-700">See the wiring diagram tool →</a>
      </div>
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src="https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main/homepage/1%20Worship%20Technology%20Assistance.jpg" alt="Worship technology assistance and AV documentation" loading="lazy" decoding="async" class="aspect-[4/3] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Feature 2 — AV monitoring</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">We know something is wrong before you do.</h2>
      <p class="mt-4 max-w-4xl text-base leading-relaxed text-slate-600 sm:text-lg">Tech Manager sends a health snapshot to the WorshipMetrics cloud every 30 seconds. Stream bitrate. Encoder CPU. Camera status. Display connectivity. Network speed. All of it, continuously.</p>
      <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {monitoringFeatures.map((item) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm text-sm text-slate-700">{item}</div>
        ))}
      </div>
      <p class="mt-8 text-sm leading-relaxed text-slate-600">When something goes wrong, Tech Manager attempts to fix it automatically first. If it cannot, Luminos opens a support ticket with a full 30-minute timeline of exactly what happened leading up to the issue.</p>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Feature 3 — Self-healing</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Most problems fix themselves. You never know they happened.</h2>
      <div class="mt-10 overflow-hidden rounded-3xl border border-slate-200 shadow-sm">
        <table class="w-full text-sm">
          <thead class="bg-slate-50 text-left">
            <tr>
              <th class="px-6 py-4 font-semibold text-slate-700">What happened</th>
              <th class="px-6 py-4 font-semibold text-slate-700">What Tech Manager does</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 bg-white">
            {selfHealingRows.map(([issue, action]) => (
              <tr>
                <td class="px-6 py-4 font-semibold text-slate-900">{issue}</td>
                <td class="px-6 py-4 text-slate-600">{action}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-6 text-sm leading-relaxed text-slate-600">Every self-healing action is logged silently in the background and included in your weekly health digest so you know what was handled on your behalf.</p>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-2">
      <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Feature 4 — OBS management</p>
        <h2 class="mt-3 text-2xl font-bold text-slate-900">OBS support that actually knows your setup.</h2>
        <ul class="mt-6 space-y-3 text-sm text-slate-700">
          {[
            "OBS connection status monitored continuously",
            "OBS log file read in real time, with warnings surfaced early",
            "Scene collection backed up to cloud automatically",
            "Stream health overlay for bitrate, dropped frames, and encoder load",
            "Remote OBS control via WorshipMetrics cloud on Pro plans",
            "Luminos reads the full log, identifies the cause, and tells you what to fix",
          ].map((item) => (
            <li class="flex items-start gap-3"><span class="mt-1.5 h-2 w-2 rounded-full bg-indigo-500"></span><span>{item}</span></li>
          ))}
        </ul>
      </div>
      <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Feature 5 — Local signage hosting</p>
        <h2 class="mt-3 text-2xl font-bold text-slate-900">Your lobby screens stay live. Even when the internet doesn't.</h2>
        <p class="mt-4 text-sm leading-relaxed text-slate-600">Tech Manager runs a local signage server on your production computer. Displays on your network load from the local server — faster, more reliable, and immune to internet outages.</p>
        <ul class="mt-6 space-y-3 text-sm text-slate-700">
          {[
            "Playlist synced from WorshipMetrics cloud when online",
            "Full playlist cached locally so screens never go black",
            "Multiple displays managed independently on the same network",
            "Free tier: 1 local screen. Paid plans: unlimited",
          ].map((item) => (
            <li class="flex items-start gap-3"><span class="mt-1.5 h-2 w-2 rounded-full bg-indigo-500"></span><span>{item}</span></li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl grid gap-8 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)]">
      <div>
