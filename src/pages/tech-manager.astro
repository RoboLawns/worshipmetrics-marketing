  <script>
    (() => {
      const tabs = Array.from(document.querySelectorAll('[data-tech-tab]'));
      const panels = Array.from(document.querySelectorAll('[data-tech-panel]'));
      if (!tabs.length || !panels.length) return;

      const setActive = (id) => {
        tabs.forEach((tab) => {
          const active = tab.getAttribute('data-tech-tab') === id;
          tab.setAttribute('aria-selected', active ? 'true' : 'false');
          tab.classList.toggle('border-indigo-600', active);
          tab.classList.toggle('bg-indigo-600', active);
          tab.classList.toggle('text-white', active);
          tab.classList.toggle('border-slate-300', !active);
          tab.classList.toggle('bg-white', !active);
          tab.classList.toggle('text-slate-700', !active);
        });

        panels.forEach((panel) => {
          panel.classList.toggle('hidden', panel.getAttribute('data-tech-panel') !== id);
        });
      };

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => setActive(tab.getAttribute('data-tech-tab')));
      });
    })();
  </script>
