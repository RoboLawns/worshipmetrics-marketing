---
import Layout from "../layouts/Layout.astro";

const SITE_URL = "https://worshipmetrics.com";
const R2 = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
const R2NEW = `${R2}/homepage/new%20images`;
const OG_IMAGE = `${R2NEW}/Worship%20Volunteers%20Working%20Together.jpg`;

const roles = [
  {
    emoji: "🙋",
    name: "Greeter",
    job: "Welcome desk",
    desc: "Check in guests, capture first-time visitors, and keep the front door moving without juggling disconnected tools.",
  },
  {
    emoji: "👶",
    name: "Children's Team",
    job: "Kids ministry",
    desc: "Run safe, fast family check-in that connects to the same congregation record used by the rest of the team.",
  },
  {
    emoji: "🎬",
    name: "AV Volunteer",
    job: "Production booth",
    desc: "Monitor streams, respond to alerts, control cameras, and help the service run smoothly even when the room gets busy.",
  },
  {
    emoji: "✝️",
    name: "Pastor / Leader",
    job: "Leadership",
    desc: "See who is new, who is missing, and what needs pastoral attention without waiting for someone to build a report later.",
  },
];

const faqItems = [
  {
    question: "What are volunteer tools for congregations?",
    answer: "Volunteer tools for congregations are role-specific workflows that help greeters, children's teams, AV volunteers, and leaders serve well without needing the same permissions or screens.",
  },
  {
    question: "Can different volunteers have different access levels?",
    answer: "Yes. WorshipMetrics is built around role-based access so volunteers see the workflows they need while staff and leaders keep broader visibility.",
  },
  {
    question: "Do volunteer tools work with attendance and guest capture?",
    answer: "Yes. Volunteer workflows connect to attendance, guest records, follow-up, and operations so each role contributes to one shared system instead of separate tools.",
  },
  {
    question: "Can churches use these tools without a large staff?",
    answer: "Yes. The point is to make it easier for smaller teams and volunteers to serve consistently, even when one person is wearing multiple hats on Sunday.",
  },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "WorshipMetrics Volunteer Tools",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web, iOS, Android",
    url: `${SITE_URL}/volunteer-tools-for-congregations`,
    image: OG_IMAGE,
    description: "Volunteer tools for congregations with role-based workflows for greeters, children's ministry, AV teams, and leaders.",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
      availability: "https://schema.org/InStock",
      url: `${SITE_URL}/pricing`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map(({ question, answer }) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: {
        "@type": "Answer",
        text: answer,
      },
    })),
  },
];
---

<Layout
  title="Volunteer Tools for Congregations"
  description="Volunteer tools for congregations with role-based workflows for greeters, children's ministry, AV teams, and leaders."
  canonical="/volunteer-tools-for-congregations"
  ogImage={OG_IMAGE}
  structuredData={structuredData}
>
  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Volunteer Tools</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
        Every volunteer deserves a role that matters.
      </h1>
      <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-slate-600 sm:text-xl">
        WorshipMetrics is built around the idea that technology should create opportunities to serve, not replace them. Every role gets tools designed for what they actually need on Sunday.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/platform/operations" class="rounded-xl bg-indigo-600 px-8 py-3 text-base font-semibold text-white shadow transition hover:bg-indigo-700">
          See operations workflows
        </a>
        <a href="/discovery-call" class="rounded-xl border border-slate-300 px-8 py-3 text-base font-semibold text-slate-700 transition hover:border-indigo-400 hover:text-indigo-600">
          Book a discovery call
        </a>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 pb-8 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src={OG_IMAGE} alt="Volunteers using WorshipMetrics together" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src={`${R2}/homepage/Team%20Collaboration%20hero.jpg`} alt="Team collaboration in WorshipMetrics" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {roles.map(({ emoji, name, job, desc }) => (
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-8 shadow-sm">
            <div class="text-3xl">{emoji}</div>
            <p class="mt-4 text-lg font-semibold text-slate-900">{name}</p>
            <p class="mt-1 text-xs font-semibold uppercase tracking-[0.16em] text-indigo-600">{job}</p>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl grid gap-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Why role-based matters</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">The right tools for each person, without giving everyone the same screen.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">Volunteers should not have to work around the software. They should walk into a workflow built for the way they actually serve.</p>
      </div>
      <div class="space-y-3">
        {[
          "Greeters can focus on welcome and guest capture instead of navigating admin screens.",
          "Children's teams can move families through check-in faster with safer, simpler workflows.",
          "AV volunteers can respond to monitoring, camera control, and production needs without unnecessary noise.",
          "Leaders can see the full picture while confirmation-required actions stay protected.",
        ].map((item) => (
          <div class="flex items-start gap-3 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
            <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm text-slate-700">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">What these volunteer tools connect to</h2>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {[
          { href: "/platform/attendance", title: "Attendance", body: "Volunteers count the room, confirm seats, and support the weekly attendance workflow without slowing the service down." },
          { href: "/platform/operations", title: "AV operations", body: "Volunteer tools stay connected to the booth workflow, device roles, and service-day responsibilities." },
          { href: "/tablet", title: "Tablet workflows", body: "A dedicated device gives greeters, welcome teams, and counting stations a cleaner Sunday experience." },
        ].map(({ href, title, body }) => (
          <a href={href} class="rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-sm transition hover:border-indigo-300 hover:bg-white">
            <h3 class="text-lg font-semibold text-slate-900">{title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{body}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-indigo-600">Explore →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">Related pages</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {[
          { href: "/platform/operations", title: "Operations workflows", body: "See the permissions, campus visibility, and team-management layer behind these volunteer tools." },
          { href: "/av-monitoring-for-houses-of-worship", title: "AV monitoring", body: "AV volunteers are stronger when they can see alerts, stream health, and camera state before problems escalate." },
          { href: "/tech-manager", title: "Tech Manager", body: "Give booth volunteers better context and more stable Sunday workflows with the desktop monitoring layer." },
        ].map(({ href, title, body }) => (
          <a href={href} class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:bg-indigo-50/20">
            <h3 class="text-lg font-semibold text-slate-900">{title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{body}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-indigo-600">Explore →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">FAQ</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Questions about volunteer tools for congregations</h2>
      </div>
      <div class="mt-8 space-y-4">
        {faqItems.map(({ question, answer }) => (
          <details class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <summary class="cursor-pointer list-none text-lg font-semibold text-slate-900">{question}</summary>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>
