---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Volunteers"
  description="Volunteer capabilities, scheduling, communications, and replacement workflows built into the same system that runs Sunday."
  canonical="/volunteers"
  robots="noindex,follow"
>
  <meta http-equiv="refresh" content="0;url=/volunteers/" slot="head" />
  <script slot="head">
    window.location.replace("/volunteers/");
  </script>

  <section class="bg-white px-4 py-24 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Redirecting</p>
      <h1 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">The Volunteers page moved.</h1>
      <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
        If you are not redirected automatically, use the link below.
      </p>
      <div class="mt-8">
        <a href="/volunteers/" class="btn-primary">Go to Volunteers</a>
      </div>
    </div>
  </section>
</Layout>
