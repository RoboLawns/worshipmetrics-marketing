---
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.worshipmetrics.com";

const plans = [
  {
    name: "Starter",
    price: "Free",
    period: "",
    description: "For small churches just getting started.",
    cta: "Get started free",
    ctaHref: `${APP_URL}/sign-up`,
    highlighted: false,
    features: [
      "Up to 1 service per week",
      "Attendance tracking",
      "Basic member directory",
      "Mobile-friendly interface",
      "Email support",
    ],
  },
  {
    name: "Growing",
    price: "$19",
    period: "/month",
    description: "For growing churches that need more power.",
    cta: "Start free trial",
    ctaHref: `${APP_URL}/sign-up`,
    highlighted: true,
    features: [
      "Unlimited services",
      "Full member management",
      "Analytics & reports",
      "Birthday & anniversary alerts",
      "Team roles & permissions",
      "CSV & PDF exports",
      "Priority support",
    ],
  },
  {
    name: "Established",
    price: "$49",
    period: "/month",
    description: "For established churches with advanced needs.",
    cta: "Start free trial",
    ctaHref: `${APP_URL}/sign-up`,
    highlighted: false,
    features: [
      "Everything in Growing",
      "Multi-campus support",
      "WorshipMetrics Hub device support",
      "Signage & TV displays",
      "Social media monitoring",
      "Worship clips publishing",
      "Advanced analytics",
      "Dedicated onboarding",
    ],
  },
];
---

<Layout
  title="Pricing"
  description="Simple, transparent pricing for churches of every size. Start free and upgrade when you're ready."
  canonical="/pricing"
>
  <!-- Page hero -->
  <section class="bg-gradient-to-b from-indigo-50 to-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">
        Simple, honest pricing
      </h1>
      <p class="mt-4 text-lg text-slate-600">
        Start free. Upgrade when you need more. No hidden fees, no long-term contracts.
      </p>
    </div>
  </section>

  <!-- Pricing cards -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-8 md:grid-cols-3">
        {plans.map(({ name, price, period, description, cta, ctaHref, highlighted, features }) => (
          <div
            class={[
              "relative flex flex-col rounded-2xl border p-8 shadow-sm",
              highlighted
                ? "border-indigo-500 bg-indigo-600 text-white shadow-indigo-200 shadow-lg"
                : "border-slate-200 bg-white",
            ].join(" ")}
          >
            {highlighted && (
              <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 rounded-full bg-amber-400 px-4 py-0.5 text-xs font-bold uppercase tracking-wider text-slate-900">
                Most popular
              </span>
            )}

            <div>
              <h2 class={["text-lg font-bold", highlighted ? "text-white" : "text-slate-900"].join(" ")}>
                {name}
              </h2>
              <p class={["mt-1 text-sm", highlighted ? "text-indigo-200" : "text-slate-500"].join(" ")}>
                {description}
              </p>
              <div class="mt-6 flex items-end gap-1">
                <span class={["text-4xl font-extrabold", highlighted ? "text-white" : "text-slate-900"].join(" ")}>
                  {price}
                </span>
                {period && (
                  <span class={["mb-1 text-sm", highlighted ? "text-indigo-300" : "text-slate-400"].join(" ")}>
                    {period}
                  </span>
                )}
              </div>
            </div>

            <a
              href={ctaHref}
              class={[
                "mt-8 block rounded-xl py-3 text-center text-sm font-semibold transition",
                highlighted
                  ? "bg-white text-indigo-700 hover:bg-indigo-50"
                  : "bg-indigo-600 text-white hover:bg-indigo-700",
              ].join(" ")}
            >
              {cta}
            </a>

            <ul class="mt-8 space-y-3">
              {features.map((f) => (
                <li class="flex items-start gap-3 text-sm">
                  <svg
                    class={["mt-0.5 h-4 w-4 flex-shrink-0", highlighted ? "text-indigo-300" : "text-indigo-500"].join(" ")}
                    fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"
                    aria-hidden="true"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class={highlighted ? "text-indigo-100" : "text-slate-600"}>{f}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- FAQ note -->
      <p class="mt-12 text-center text-sm text-slate-500">
        All paid plans include a 14-day free trial. Questions?{" "}
        <a href="mailto:support@worshipmetrics.com" class="text-indigo-600 hover:underline">
          Contact us
        </a>
      </p>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-slate-900 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-white">Start tracking attendance today</h2>
      <p class="mt-4 text-slate-400">
        Create your free account in under a minute. No credit card required.
      </p>
      <a
        href={`${APP_URL}/sign-up`}
        class="mt-8 inline-block rounded-xl bg-indigo-600 px-8 py-3 text-base font-semibold text-white shadow transition hover:bg-indigo-700"
      >
        Get started free
      </a>
    </div>
  </section>
</Layout>
