---
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.worshipmetrics.com";
const SITE_URL = "https://worshipmetrics.com";
const R2 = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
const faqItems = [
  {
    question: "Does WorshipMetrics offer a free plan?",
    answer: "Yes. WorshipMetrics offers a free plan for churches that want to start tracking data without a credit card or time limit.",
  },
  {
    question: "Which plan includes church attendance automation?",
    answer: "The Established plan includes the advanced automation features, and the WorshipMetrics Hub can unlock those workflows in a plug-and-play hardware setup.",
  },
  {
    question: "Does the WorshipMetrics Tablet include software?",
    answer: "Yes. The WorshipMetrics Tablet includes a free Essentials plan so churches can start using check-in, attendance, and guest capture workflows immediately.",
  },
  {
    question: "Can we talk with someone before choosing a plan?",
    answer: "Yes. Churches can book a discovery call to compare plans, hardware, and services based on their real workflow and team size.",
  },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "OfferCatalog",
    name: "WorshipMetrics Pricing",
    url: `${SITE_URL}/pricing`,
    itemListElement: [
      { "@type": "Offer", name: "Free", price: "0", priceCurrency: "USD", url: `${SITE_URL}/pricing` },
      { "@type": "Offer", name: "Essentials", price: "19.99", priceCurrency: "USD", url: `${SITE_URL}/pricing` },
      { "@type": "Offer", name: "Established", price: "49.99", priceCurrency: "USD", url: `${SITE_URL}/pricing` },
      { "@type": "Offer", name: "WorshipMetrics Hub", price: "499", priceCurrency: "USD", url: `${SITE_URL}/appliance` },
      { "@type": "Offer", name: "WorshipMetrics Tablet", price: "349", priceCurrency: "USD", url: `${SITE_URL}/tablet` },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: SITE_URL },
      { "@type": "ListItem", position: 2, name: "Pricing", item: `${SITE_URL}/pricing` },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map(({ question, answer }) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: {
        "@type": "Answer",
        text: answer,
      },
    })),
  },
];
---

<Layout
  title="Church Attendance Software Pricing"
  description="See WorshipMetrics pricing for church attendance software, visitor follow-up tools, hardware, and ministry support services."
  canonical="/pricing"
  structuredData={structuredData}
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-indigo-50 to-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-indigo-600">Pricing</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">
        Simple pricing. Clear next steps.
      </h1>
      <p class="mt-4 text-lg text-slate-600">
        Monthly or annual billing. Every paid plan includes a free onboarding session. Cancel anytime.
      </p>
    </div>
  </section>

  <!-- Pricing proof -->
  <section class="bg-white px-4 pb-8 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
      <div class="grid items-center gap-0 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
        <div class="p-8 sm:p-10">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Included in paid plans</p>
          <h2 class="mt-3 text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">
            Pricing is easier when the value is visible.
          </h2>
          <p class="mt-4 text-sm leading-relaxed text-slate-600 sm:text-base">
            Luminos, Worship Clips, outreach tools, and team workflows are not abstract add-ons. They are part of the weekly ministry system your staff and volunteers actually use.
          </p>
        </div>
        <img
          src={`${R2}/homepage/Luminos%20Interface.png`}
          alt="Luminos AI interface included in WorshipMetrics paid plans"
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- Plan cards -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="grid items-stretch gap-8 md:grid-cols-3">

        <!-- Free -->
        <div class="relative flex flex-col rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <div>
            <h2 class="text-lg font-bold text-slate-900">Free</h2>
            <p class="mt-4 text-3xl font-extrabold text-slate-900">$0/month — forever</p>
            <p class="mt-3 text-sm text-slate-600">For churches getting started with data</p>
          </div>
          <a
            href={`${APP_URL}/sign-up`}
            class="mt-8 block rounded-xl bg-indigo-600 py-3 text-center text-sm font-semibold text-white transition hover:bg-indigo-700"
          >
            Start free
          </a>
          <ul class="mt-8 flex-1 space-y-3">
            {[
              "Unlimited users",
              "Unlimited data retention",
              "Attendance, giving, salvations, volunteers, and custom tracking",
              "Basic reports and dashboards",
              "1 digital signage screen",
              "Basic announcement templates",
              "Community support",
            ].map((f) => (
              <li class="flex items-start gap-3 text-sm">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-slate-600">{f}</span>
              </li>
            ))}
          </ul>
          <p class="mt-6 text-sm text-slate-500">No credit card required. No time limit. No catch.</p>
        </div>

        <!-- Essentials — highlighted -->
        <div class="relative flex flex-col rounded-2xl border border-indigo-500 bg-indigo-600 p-8 shadow-lg shadow-indigo-200">
          <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 rounded-full bg-amber-400 px-4 py-0.5 text-xs font-bold uppercase tracking-wider text-slate-900">
            Most popular
          </span>
          <div>
            <h2 class="text-lg font-bold text-white">Essentials ⭐</h2>
            <p class="mt-4 text-3xl font-extrabold text-white">$19.99/month</p>
            <p class="mt-1 text-sm text-indigo-200">or $190/year — saves $49.88</p>
            <p class="mt-3 text-sm text-indigo-200">For churches ready to grow</p>
          </div>
          <a
            href={`${APP_URL}/sign-up`}
            class="mt-8 block rounded-xl bg-white py-3 text-center text-sm font-semibold text-indigo-700 transition hover:bg-indigo-50"
          >
            Start 30-day trial
          </a>
          <ul class="mt-8 flex-1 space-y-3">
            {[
              "Everything in Free, plus:",
              "Advanced reports and trend analysis",
              "Year-over-year comparisons",
              "Multi-user roles and permissions",
              "Luminos AI assistant",
              "Outreach tools and visitor follow-up",
              "Worship Clips — 1 sermon clip/week",
              "Unlimited digital signage screens",
              "One-Button Attendance — log your count from any device in seconds",
              "Email support + free onboarding session",
              "30-day free trial",
            ].map((f) => (
              <li class="flex items-start gap-3 text-sm">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-indigo-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-indigo-100">{f}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Established -->
        <div class="relative flex flex-col rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <div>
            <h2 class="text-lg font-bold text-slate-900">Established</h2>
            <p class="mt-4 text-3xl font-extrabold text-slate-900">$49.99/month</p>
            <p class="mt-1 text-sm text-slate-500">or $490/year — saves $109.88</p>
            <p class="mt-3 text-sm text-slate-600">For ministries serious about automation</p>
          </div>
          <a
            href={`${APP_URL}/sign-up`}
            class="mt-8 block rounded-xl bg-indigo-600 py-3 text-center text-sm font-semibold text-white transition hover:bg-indigo-700"
          >
            Start 30-day trial
          </a>
          <ul class="mt-8 flex-1 space-y-3">
            {[
              "Everything in Essentials, plus:",
              "Fully Automatic Attendance — your camera counts your congregation so you never have to",
              "Remote PTZ camera control with saved presets",
              "Remote OBS and vMix production control",
              "AV health monitoring — stream, audio, video, and display status in real time",
              "Auto video upload and sermon clipping",
              "Podcast auto-export",
              "Social media scheduling queue",
              "Multi-campus support and consolidated dashboards",
              "Unlimited Worship Clips",
              "Social monitoring",
              "API access",
              "Priority support + onboarding",
              "30-day free trial",
            ].map((f) => (
              <li class="flex items-start gap-3 text-sm">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-slate-600">{f}</span>
              </li>
            ))}
          </ul>
          <p class="mt-6 text-sm text-slate-500">
            Established features run on your own computer or unlock automatically with the Worship Metrics Hub.
          </p>
        </div>
      </div>

      <p class="mt-10 text-center text-sm text-slate-500">
        Questions?{" "}
        <a href="/contact" class="text-indigo-600 hover:underline">Contact us →</a>
      </p>
    </div>
  </section>

  <!-- Compare by workflow -->
  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center text-2xl font-bold text-slate-900 sm:text-3xl">Compare pricing by workflow, not just by plan.</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {[
          {
            href: "/platform/attendance",
            title: "Attendance workflows",
            body: "See how seat templates, Auto-Count, and livestream reporting fit into the plans.",
          },
          {
            href: "/tablet",
            title: "Tablet hardware",
            body: "See the dedicated church tablet for check-in, counting, and guest capture.",
          },
          {
            href: "/appliance",
            title: "Hub automation",
            body: "See the hardware option for automatic attendance, AV monitoring, and signage.",
          },
        ].map(({ href, title, body }) => (
          <a href={href} class="rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-sm transition hover:border-indigo-300 hover:bg-white">
            <h3 class="text-lg font-semibold text-slate-900">{title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{body}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-indigo-600">Explore →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Hardware -->
  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <h2 class="mb-2 text-center text-2xl font-bold text-slate-900 sm:text-3xl">Hardware</h2>
      <p class="mb-10 text-center text-slate-500">Purpose-built devices for churches that want plug-and-play simplicity.</p>
      <div class="grid gap-8 sm:grid-cols-2">

        <!-- Hub -->
        <div class="flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <img
            src={`${R2}/tablet/Worship%20Metrics%20Appliance%20Small.jpg`}
            alt="WorshipMetrics Hub product image"
            loading="lazy"
            decoding="async"
            class="-mx-8 -mt-8 mb-6 aspect-[16/10] w-[calc(100%+4rem)] object-cover"
          />
          <div class="flex items-start justify-between">
            <div>
              <h3 class="text-lg font-bold text-slate-900">Worship Metrics Hub</h3>
              <p class="mt-1 text-2xl font-extrabold text-slate-900">$499 <span class="text-sm font-normal text-slate-400">one-time</span></p>
            </div>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">No subscription required</span>
          </div>
          <p class="mt-4 text-sm text-slate-600">The Hub runs all Established features automatically — no computer needed, no setup headaches. Plug it in and it works.</p>
          <a
            href="/appliance"
            class="mt-6 block rounded-xl border border-indigo-600 py-3 text-center text-sm font-semibold text-indigo-600 transition hover:bg-indigo-50"
          >
            See Hub details
          </a>
        </div>

        <!-- Tablet -->
        <div class="flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <img
            src={`${R2}/tablet/New%20Worship%20Metrics%20Tablet%20Hero.jpg`}
            alt="WorshipMetrics Tablet product image"
            loading="lazy"
            decoding="async"
            class="-mx-8 -mt-8 mb-6 aspect-[16/10] w-[calc(100%+4rem)] object-cover"
          />
          <div class="flex items-start justify-between">
            <div>
              <h3 class="text-lg font-bold text-slate-900">Worship Metrics Tablet</h3>
              <p class="mt-1 text-2xl font-extrabold text-slate-900">From $349 <span class="text-sm font-normal text-slate-400">one-time</span></p>
            </div>
            <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-700">Includes free Essentials plan</span>
          </div>
          <p class="mt-4 text-sm text-slate-600">Dedicated welcome desk device for volunteer check-in, head counting, and visitor capture.</p>
          <a
            href="/tablet"
            class="mt-6 block rounded-xl border border-indigo-600 py-3 text-center text-sm font-semibold text-indigo-600 transition hover:bg-indigo-50"
          >
            See Tablet details
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <h2 class="mb-2 text-center text-2xl font-bold text-slate-900 sm:text-3xl">Professional Services</h2>
      <p class="mb-10 text-center text-slate-500">Implementation and support options tailored to your church.</p>
      <div class="grid gap-8 sm:grid-cols-3">
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <h3 class="text-lg font-bold text-slate-900">Implementation &amp; Training</h3>
          <p class="mt-1 text-sm font-medium text-indigo-600">Custom scoped</p>
          <p class="mt-3 text-sm text-slate-600">Migration, onboarding, staff training, and ongoing strategic support.</p>
          <a href="/professional-services" class="mt-5 inline-block text-sm font-semibold text-indigo-600 hover:underline">Learn more →</a>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <h3 class="text-lg font-bold text-slate-900">Outreach Services</h3>
          <p class="mt-1 text-sm font-medium text-indigo-600">Custom scoped</p>
          <p class="mt-3 text-sm text-slate-600">Visitor follow-up campaigns, digital outreach strategy, and engagement programs.</p>
          <a href="/outreach-services" class="mt-5 inline-block text-sm font-semibold text-indigo-600 hover:underline">Learn more →</a>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <h3 class="text-lg font-bold text-slate-900">Community Platform Setup</h3>
          <p class="mt-1 text-sm font-medium text-indigo-600">From $299</p>
          <p class="mt-3 text-sm text-slate-600">Discord community setup, welcome automation, YouTube chat mirroring, and website integration.</p>
          <a href="/professional-services" class="mt-5 inline-block text-sm font-semibold text-indigo-600 hover:underline">Learn more →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">FAQ</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Common questions about WorshipMetrics pricing</h2>
      </div>
      <div class="mt-8 space-y-4">
        {faqItems.map(({ question, answer }) => (
          <details class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <summary class="cursor-pointer list-none text-lg font-semibold text-slate-900">{question}</summary>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-indigo-600 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-white">Need help choosing the right plan?</h2>
      <p class="mt-4 text-indigo-200">
        Get a free onboarding session and map out the best setup for your church's workflow and goals.
      </p>
      <a
        href="/discovery-call"
        class="mt-8 inline-block rounded-xl bg-white px-8 py-3 text-base font-semibold text-indigo-700 shadow transition hover:bg-indigo-50"
      >
        Book free onboarding
      </a>
    </div>
  </section>
</Layout>
