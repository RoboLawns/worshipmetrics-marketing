---
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.worshipmetrics.com";
---

<Layout
  title="Pricing"
  description="Simple, transparent pricing for churches of every size. Software plans, hardware, and services."
  canonical="/pricing"
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-indigo-50 to-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-indigo-600">Pricing</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">
        Simple pricing. Clear next steps.
      </h1>
      <p class="mt-4 text-lg text-slate-600">
        Monthly or annual. Every paid plan includes a free onboarding session. Cancel anytime.
      </p>
    </div>
  </section>

  <!-- Plan cards -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="grid items-stretch gap-8 md:grid-cols-3">

        <!-- Free -->
        <div class="relative flex flex-col rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <div>
            <h2 class="text-lg font-bold text-slate-900">Free</h2>
            <div class="mt-4 flex items-end gap-1">
              <span class="text-4xl font-extrabold text-slate-900">$0</span>
              <span class="mb-1 text-sm text-slate-400">/month</span>
            </div>
          </div>
          <a
            href={`${APP_URL}/sign-up`}
            class="mt-8 block rounded-xl bg-indigo-600 py-3 text-center text-sm font-semibold text-white transition hover:bg-indigo-700"
          >
            Start free
          </a>
          <ul class="mt-8 flex-1 space-y-3">
            {[
              "3 users",
              "90-day data retention",
              "Basic attendance tracking",
            ].map((f) => (
              <li class="flex items-start gap-3 text-sm">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-slate-600">{f}</span>
              </li>
            ))}
            {[
              "No reports",
              "No support",
            ].map((f) => (
              <li class="flex items-start gap-3 text-sm">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
                <span class="text-slate-400">{f}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Essentials — highlighted -->
        <div class="relative flex flex-col rounded-2xl border border-indigo-500 bg-indigo-600 p-8 shadow-lg shadow-indigo-200">
          <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 rounded-full bg-amber-400 px-4 py-0.5 text-xs font-bold uppercase tracking-wider text-slate-900">
            Most popular
          </span>
          <div>
            <h2 class="text-lg font-bold text-white">Essentials</h2>
            <div class="mt-4 flex items-end gap-1">
              <span class="text-4xl font-extrabold text-white">$19.99</span>
              <span class="mb-1 text-sm text-indigo-300">/month</span>
            </div>
            <p class="mt-1 text-sm text-indigo-200">or $190/year — saves $49.88</p>
          </div>
          <a
            href={`${APP_URL}/sign-up`}
            class="mt-8 block rounded-xl bg-white py-3 text-center text-sm font-semibold text-indigo-700 transition hover:bg-indigo-50"
          >
            Start free trial
          </a>
          <ul class="mt-8 flex-1 space-y-3">
            {[
              "10 users",
              "Reports included",
              "Luminos AI (90 questions/day)",
              "Outreach tools",
              "Worship Clips (1 sermon clip/week, 52/year)",
              "Free onboarding + support",
              "30-day free trial",
            ].map((f) => (
              <li class="flex items-start gap-3 text-sm">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-indigo-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-indigo-100">{f}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Established -->
        <div class="relative flex flex-col rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <div>
            <h2 class="text-lg font-bold text-slate-900">Established</h2>
            <div class="mt-4 flex items-end gap-1">
              <span class="text-4xl font-extrabold text-slate-900">$49.99</span>
              <span class="mb-1 text-sm text-slate-400">/month</span>
            </div>
            <p class="mt-1 text-sm text-slate-500">or $490/year — saves $109.88</p>
          </div>
          <a
            href={`${APP_URL}/sign-up`}
            class="mt-8 block rounded-xl bg-indigo-600 py-3 text-center text-sm font-semibold text-white transition hover:bg-indigo-700"
          >
            Start free trial
          </a>
          <ul class="mt-8 flex-1 space-y-3">
            {[
              "Unlimited users",
              "Multi-campus support",
              "Reports included",
              "Luminos AI (250 questions/day)",
              "Outreach tools",
              "Worship Clips (unlimited)",
              "Social monitoring",
              "Priority support + onboarding",
              "30-day free trial",
            ].map((f) => (
              <li class="flex items-start gap-3 text-sm">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-slate-600">{f}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <p class="mt-10 text-center text-sm text-slate-500">
        All paid plans include a 14-day free trial. Questions?{" "}
        <a href="/contact" class="text-indigo-600 hover:underline">Contact us →</a>
      </p>
    </div>
  </section>

  <!-- Hardware -->
  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <h2 class="mb-2 text-center text-2xl font-bold text-slate-900 sm:text-3xl">Not just software</h2>
      <p class="mb-10 text-center text-slate-500">Purpose-built hardware that connects to the same system.</p>
      <div class="grid gap-8 sm:grid-cols-2">

        <!-- Hub -->
        <div class="flex flex-col rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="text-lg font-bold text-slate-900">WorshipMetrics Hub</h3>
              <p class="mt-1 text-2xl font-extrabold text-slate-900">$499 <span class="text-sm font-normal text-slate-400">one-time</span></p>
            </div>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">No subscription fees</span>
          </div>
          <p class="mt-4 text-sm text-slate-600">Automatic attendance + signage + production control — in one connected device.</p>
          <a
            href="/appliance"
            class="mt-6 block rounded-xl border border-indigo-600 py-3 text-center text-sm font-semibold text-indigo-600 transition hover:bg-indigo-50"
          >
            See Hub details
          </a>
        </div>

        <!-- Tablet -->
        <div class="flex flex-col rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="text-lg font-bold text-slate-900">WorshipMetrics Tablet</h3>
              <p class="mt-1 text-2xl font-extrabold text-slate-900">from $349 <span class="text-sm font-normal text-slate-400">one-time</span></p>
            </div>
            <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-700">Includes free Essentials</span>
          </div>
          <p class="mt-4 text-sm text-slate-600">Dedicated volunteer workflow — welcome desk, check-in, and counting in one device.</p>
          <a
            href="/tablet"
            class="mt-6 block rounded-xl border border-indigo-600 py-3 text-center text-sm font-semibold text-indigo-600 transition hover:bg-indigo-50"
          >
            See Tablet details
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <h2 class="mb-2 text-center text-2xl font-bold text-slate-900 sm:text-3xl">Services</h2>
      <p class="mb-10 text-center text-slate-500">Done-for-you options scoped to your church's needs.</p>
      <div class="grid gap-8 sm:grid-cols-2">
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <h3 class="text-lg font-bold text-slate-900">Professional Services</h3>
          <p class="mt-1 text-sm font-medium text-indigo-600">Custom scoped</p>
          <p class="mt-3 text-sm text-slate-600">Implementation, training, migration, and ongoing strategic support tailored to your team.</p>
          <a href="/professional-services" class="mt-5 inline-block text-sm font-semibold text-indigo-600 hover:underline">Learn more →</a>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <h3 class="text-lg font-bold text-slate-900">Outreach Services</h3>
          <p class="mt-1 text-sm font-medium text-indigo-600">Custom scoped</p>
          <p class="mt-3 text-sm text-slate-600">Community outreach campaigns, digital visitor follow-up, and engagement strategy built around your church.</p>
          <a href="/outreach-services" class="mt-5 inline-block text-sm font-semibold text-indigo-600 hover:underline">Learn more →</a>
        </div>
      </div>

      <!-- Community Platform Setup -->
      <div class="mt-10">
        <h3 class="mb-6 text-xl font-bold text-slate-900">Community Platform Setup</h3>
        <div class="grid gap-6 sm:grid-cols-3">
          {[
            {
              name: "Starter",
              price: "$299",
              note: "one-time",
              features: [
                "Discord template",
                "Basic roles & channels",
                "Welcome bot",
                "30-day email support",
              ],
            },
            {
              name: "Connected",
              price: "$599",
              note: "one-time",
              features: [
                "Everything in Starter",
                "Website widget",
                "YouTube chat mirror",
                "Custom branding",
              ],
            },
            {
              name: "Full Platform",
              price: "$999",
              note: "one-time",
              features: [
                "Everything in Connected",
                "WorshipMetrics dashboard",
                "Monthly reports",
                "90-day support",
                "1-hour staff training",
              ],
            },
          ].map(({ name, price, note, features }) => (
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
              <h4 class="font-bold text-slate-900">{name}</h4>
              <p class="mt-1 text-xl font-extrabold text-slate-900">
                {price} <span class="text-xs font-normal text-slate-400">{note}</span>
              </p>
              <ul class="mt-4 space-y-2">
                {features.map((f) => (
                  <li class="flex items-start gap-2 text-sm">
                    <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="text-slate-600">{f}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-indigo-600 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-white">Not sure which plan fits?</h2>
      <p class="mt-4 text-indigo-200">
        Talk through your church's size, workflow, and goals in a free 30-minute discovery call.
      </p>
      <a
        href="/discovery-call"
        class="mt-8 inline-block rounded-xl bg-white px-8 py-3 text-base font-semibold text-indigo-700 shadow transition hover:bg-indigo-50"
      >
        Book a discovery call
      </a>
    </div>
  </section>
</Layout>
