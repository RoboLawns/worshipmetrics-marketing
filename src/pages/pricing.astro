---
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.worshipmetrics.com";
const SITE_URL = "https://worshipmetrics.com";
const R2 = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
const LUMINOS_PROFILE = `${R2}/Luminos/Luminos%20Profile.jpg`;
const HUB_IMAGE = `${R2}/tablet/Worship%20Metrics%20Appliance%20Small.jpg`;
const TABLET_IMAGE = `${R2}/tablet/New%20Worship%20Metrics%20Tablet%20Hero.jpg`;

const plans = [
  {
    name: "Free",
    price: "$0",
    suffix: "/month",
    tag: "Organize your Sunday",
    body: "Start with the shared workflow: plan the service, coordinate volunteers, and prove the system before you pay.",
    cta: "Get started free",
    href: `${APP_URL}/sign-up`,
    featured: false,
    items: [
      "Services planning",
      "Volunteer management",
      "Worship Clips local workflow",
      "Digital Signage for 1 screen",
      "Attendance basics",
      "Tech Manager desktop app",
      "Knowledge Base and community support",
      "Mobile apps",
    ],
  },
  {
    name: "Starter",
    price: "$29",
    suffix: "/month",
    tag: "Get your team in sync",
    body: "Uncap the workflow and add the cloud, reporting, and support layers that make the free plan feel production-ready.",
    cta: "Start with Starter",
    href: `${APP_URL}/sign-up`,
    featured: true,
    items: [
      "Everything in Free",
      "Worship Clips cloud sync and auto-publish",
      "Unlimited signage screens",
      "Real-time AV alerts",
      "Historical reports",
      "Email support",
      "Basic API access",
    ],
  },
  {
    name: "Pro",
    price: "$99",
    suffix: "/month",
    tag: "Automate Sunday",
    body: "This is where the paid tier gains its clearest upgrade reason: real execution automation powered by Central Control.",
    cta: "Book a setup call",
    href: "/discovery-call",
    featured: false,
    items: [
      "Everything in Starter",
      "Central Control integration",
      "WebPanel volunteer execution",
      "Rundown and Flex Macro automation",
      "MCP-driven cue authoring",
      "Priority support",
    ],
  },
  {
    name: "Premium",
    price: "$249",
    suffix: "/month",
    tag: "For multi-campus churches",
    body: "For churches with heavier production complexity, multiple locations, and more involved rollout needs.",
    cta: "Talk to us",
    href: "/discovery-call",
    featured: false,
    items: [
      "Everything in Pro",
      "Multi-campus support",
      "White-label options",
      "Phone support",
      "Custom Central Control configuration",
      "Dedicated integrator",
    ],
  },
];

const comparisonRows = [
  ["Services planning", "Included", "Included", "Included", "Included"],
  ["Volunteer management", "Included", "Included", "Included", "Included"],
  ["Worship Clips", "Local workflow", "Cloud sync", "Cloud sync", "Cloud sync"],
  ["Digital Signage", "1 screen", "Unlimited", "Unlimited", "Unlimited"],
  ["Attendance", "Included", "Included", "Included", "Included"],
  ["Tech Manager", "Included", "Included", "Included", "Included"],
  ["Real-time AV alerts", "No", "Included", "Included", "Included"],
  ["Historical reports", "No", "Included", "Included", "Included"],
  ["Central Control automation", "No", "No", "Included", "Included"],
  ["Multi-campus", "No", "No", "No", "Included"],
  ["White-label", "No", "No", "No", "Included"],
  ["Support", "Community", "Email", "Priority", "Phone + dedicated"],
];

const faqItems = [
  {
    question: "Does Worship Metrics offer a free plan?",
    answer: "Yes. The free plan is designed to get your church organized first: service planning, volunteer management, the Tech Manager desktop app, attendance basics, one signage screen, and the core workflow that proves the product before you pay.",
  },
  {
    question: "What makes the paid plans worth it?",
    answer: "Starter removes caps and adds cloud workflows, alerts, and reporting. Pro is the bigger step change because it adds Central Control-powered Sunday automation: rundown sync, macro-driven cues, and volunteer execution surfaces that turn the plan into an execution layer.",
  },
  {
    question: "Is hardware included in the subscription?",
    answer: "No. The Worship Metrics Hub and Tablet are sold separately. They support the software platform, but they are not required to start using the core product story.",
  },
  {
    question: "Do you offer annual pricing, nonprofit pricing, or multi-campus discounts?",
    answer: "Yes. Churches with annual billing preferences, nonprofit constraints, or multi-campus needs should book a call so pricing can match the real rollout instead of forcing a one-size-fits-all decision.",
  },
  {
    question: "Can we cancel or change plans later?",
    answer: "Yes. Churches can start free, upgrade when the workflow justifies it, and talk with the team about the right timing for deeper rollout or hardware decisions.",
  },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "OfferCatalog",
    name: "WorshipMetrics Pricing",
    url: `${SITE_URL}/pricing`,
    itemListElement: [
      { "@type": "Offer", name: "Free", price: "0", priceCurrency: "USD", url: `${SITE_URL}/pricing` },
      { "@type": "Offer", name: "Starter", price: "29", priceCurrency: "USD", url: `${SITE_URL}/pricing` },
      { "@type": "Offer", name: "Pro", price: "99", priceCurrency: "USD", url: `${SITE_URL}/pricing` },
      { "@type": "Offer", name: "Premium", price: "249", priceCurrency: "USD", url: `${SITE_URL}/pricing` },
      { "@type": "Offer", name: "Worship Metrics Hub", price: "499", priceCurrency: "USD", url: `${SITE_URL}/appliance` },
      { "@type": "Offer", name: "Worship Metrics Tablet", price: "349", priceCurrency: "USD", url: `${SITE_URL}/tablet` },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: SITE_URL },
      { "@type": "ListItem", position: 2, name: "Pricing", item: `${SITE_URL}/pricing` },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map(({ question, answer }) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: {
        "@type": "Answer",
        text: answer,
      },
    })),
  },
];
---

<Layout
  title="Pricing"
  description="Free to start. Grows with your church. Compare WorshipMetrics plans for service planning, volunteers, production automation, and hardware."
  canonical="/pricing"
  structuredData={structuredData}
>
  <section class="bg-gradient-to-b from-indigo-50 to-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Pricing</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">Free to start. Grows with your church.</h1>
      <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-slate-600 sm:text-xl">
        Start with the workflow that gets your church more organized. Upgrade when your team needs deeper cloud workflows, reporting, and the automation layer that makes Sunday run with less friction.
      </p>
    </div>
  </section>

  <section class="bg-white px-4 pb-8 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm">
      <div class="grid items-center gap-0 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
        <div class="p-8 sm:p-10">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">What makes paid worth it?</p>
          <h2 class="mt-3 text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">Paid is not just more features. It is a different operating model.</h2>
          <p class="mt-4 text-sm leading-relaxed text-slate-600 sm:text-base">
            Starter adds the cloud and reporting layers that help your team stay in sync. Pro is where the upgrade reason becomes unmistakable: Services automation powered by Central Control. That is the moment the plan turns into an execution layer the booth can trust.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/integrations/central-control" class="btn-outline">See the technical integration</a>
            <a href="/services#automate" class="btn-primary">See the automation story</a>
          </div>
        </div>
        <div class="flex h-full items-center justify-center bg-[radial-gradient(circle_at_top,_#ffffff_0%,_#eef2ff_58%,_#dbe5ff_100%)] p-10 sm:p-12">
          <img
            src={LUMINOS_PROFILE}
            alt="Luminos profile illustration"
            loading="lazy"
            decoding="async"
            width="320"
            height="320"
            class="aspect-square w-full max-w-[14rem] rounded-full border-4 border-white object-cover shadow-[0_18px_44px_rgba(67,97,238,0.2)] sm:max-w-[16rem]"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid items-stretch gap-8 lg:grid-cols-4">
        {plans.map(({ name, price, suffix, tag, body, cta, href, featured, items }) => (
          <div class:list={[
            "relative flex flex-col rounded-[1.75rem] border p-8 shadow-sm",
            featured ? "border-indigo-500 bg-indigo-600 shadow-lg shadow-indigo-200" : "border-slate-200 bg-white",
          ]}>
            {featured && (
              <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 rounded-full bg-amber-400 px-4 py-0.5 text-xs font-bold uppercase tracking-wider text-slate-900">
                Most popular
              </span>
            )}
            <div>
              <p class:list={["text-sm font-semibold uppercase tracking-[0.16em]", featured ? "text-indigo-200" : "text-indigo-600"]}>{tag}</p>
              <h2 class:list={["mt-3 text-2xl font-bold", featured ? "text-white" : "text-slate-900"]}>{name}</h2>
              <p class:list={["mt-4 text-4xl font-extrabold tracking-tight", featured ? "text-white" : "text-slate-900"]}>{price}<span class:list={["text-base font-medium", featured ? "text-indigo-200" : "text-slate-500"]}>{suffix}</span></p>
              <p class:list={["mt-4 text-sm leading-relaxed", featured ? "text-indigo-100" : "text-slate-600"]}>{body}</p>
            </div>
            <a href={href} class:list={[
              "mt-8 block rounded-xl py-3 text-center text-sm font-semibold transition",
              featured ? "bg-white text-indigo-700 hover:bg-indigo-50" : "bg-indigo-600 text-white hover:bg-indigo-700",
            ]}>
              {cta}
            </a>
            <ul class="mt-8 flex-1 space-y-3">
              {items.map((item) => (
                <li class="flex items-start gap-3 text-sm">
                  <svg class:list={["mt-0.5 h-4 w-4 flex-shrink-0", featured ? "text-indigo-300" : "text-indigo-500"]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class:list={[featured ? "text-indigo-100" : "text-slate-600"]}>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Compare the plans in one table.</h2>
      </div>
      <div class="mt-10 overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm">
        <table class="w-full text-sm">
          <thead class="bg-slate-50 text-left">
            <tr>
              <th class="px-6 py-4 font-semibold text-slate-700">Capability</th>
              <th class="px-6 py-4 font-semibold text-slate-700">Free</th>
              <th class="px-6 py-4 font-semibold text-slate-700">Starter</th>
              <th class="px-6 py-4 font-semibold text-slate-700">Pro</th>
              <th class="px-6 py-4 font-semibold text-slate-700">Premium</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 bg-white">
            {comparisonRows.map(([feature, free, starter, pro, premium]) => (
              <tr>
                <td class="px-6 py-4 font-semibold text-slate-900">{feature}</td>
                <td class="px-6 py-4 text-slate-600">{free}</td>
                <td class="px-6 py-4 text-slate-600">{starter}</td>
                <td class="px-6 py-4 text-slate-600">{pro}</td>
                <td class="px-6 py-4 text-slate-600">{premium}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Hardware sold separately</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Add hardware where it helps the workflow.</h2>
      </div>
      <div class="mt-10 grid gap-8 sm:grid-cols-2">
        <div class="flex flex-col overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm">
          <img src={HUB_IMAGE} alt="Worship Metrics Hub product image" loading="lazy" decoding="async" class="-mx-8 -mt-8 mb-6 aspect-[16/10] w-[calc(100%+4rem)] object-cover" />
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="text-xl font-bold text-slate-900">Worship Metrics Hub</h3>
              <p class="mt-1 text-2xl font-extrabold text-slate-900">$499 <span class="text-sm font-normal text-slate-400">one-time</span></p>
            </div>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">Optional hardware</span>
          </div>
          <p class="mt-4 text-sm leading-relaxed text-slate-600">Always-on hardware for churches that want local reliability, deeper monitoring resilience, and a system that does not depend on one booth PC staying awake.</p>
          <a href="/appliance" class="mt-6 block rounded-xl border border-indigo-600 py-3 text-center text-sm font-semibold text-indigo-600 transition hover:bg-indigo-50">See Hub details</a>
        </div>

        <div class="flex flex-col overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm">
          <img src={TABLET_IMAGE} alt="Worship Metrics Tablet product image" loading="lazy" decoding="async" class="-mx-8 -mt-8 mb-6 aspect-[16/10] w-[calc(100%+4rem)] object-cover" />
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="text-xl font-bold text-slate-900">Worship Metrics Tablet</h3>
              <p class="mt-1 text-2xl font-extrabold text-slate-900">From $349 <span class="text-sm font-normal text-slate-400">one-time</span></p>
            </div>
            <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-700">Volunteer workflow device</span>
          </div>
          <p class="mt-4 text-sm leading-relaxed text-slate-600">A dedicated device for welcome desks, attendance workflows, and service-day roles that deserve something cleaner than a borrowed personal tablet.</p>
          <a href="/tablet" class="mt-6 block rounded-xl border border-indigo-600 py-3 text-center text-sm font-semibold text-indigo-600 transition hover:bg-indigo-50">See Tablet details</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">FAQ</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Common questions about WorshipMetrics pricing</h2>
      </div>
      <div class="mt-8 space-y-4">
        {faqItems.map(({ question, answer }) => (
          <details class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <summary class="cursor-pointer list-none text-lg font-semibold text-slate-900">{question}</summary>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-indigo-600 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Choose the plan that matches how your church actually works.</h2>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={`${APP_URL}/sign-up`} class="btn-primary" style="background:#fff;color:#4361ee;box-shadow:0 10px 30px rgba(15,23,42,0.18);" data-wm-track="cta_click" data-wm-track-label="pricing_footer_get_started_free" data-wm-track-location="pricing_footer_cta">Get started free</a>
        <a href="/discovery-call" class="btn-outline" style="border-color:rgba(255,255,255,0.35);color:#fff;" data-wm-track="cta_click" data-wm-track-label="pricing_footer_book_call" data-wm-track-location="pricing_footer_cta">Book a call</a>
        <a href="/services" class="btn-outline" style="border-color:rgba(255,255,255,0.35);color:#fff;">See Services</a>
      </div>
    </div>
  </section>
</Layout>
