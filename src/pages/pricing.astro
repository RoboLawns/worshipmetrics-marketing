---
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.worshipmetrics.com";
const SITE_URL = "https://worshipmetrics.com";
const R2 = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
const PANELS_IMAGE = `${R2}/Tech%20Manager/WorshipMetrics%20Tech%20Manager%20Web-UI%20Panels.jpg`;
const HUB_IMAGE = `${R2}/tablet/Worship%20Metrics%20Appliance%20Small.jpg`;
const TABLET_IMAGE = `${R2}/tablet/New%20Worship%20Metrics%20Tablet%20Hero.jpg`;

const plans = [
  {
    name: "Free Forever",
    price: "$0",
    suffix: "/mo",
    tag: "Start with the whole team",
    badge: "No credit card",
    body: "Prove the system before you pay. Free Forever includes the full Services planning workflow and the volunteer foundation most churches need first.",
    cta: "Get started free",
    href: `${APP_URL}/sign-up`,
    featured: false,
    supportLabel: "Community",
    supportBody: "Community support",
    supportBandClass: "bg-slate-200 text-slate-700",
    items: [
      "Service Planning with unlimited services and templates",
      "Volunteer Management with scheduling and find-a-replacement",
      "Worship Clips local workflow",
      "Digital Signage for 1 screen",
      "Attendance manual and one-tap counting",
      "AV Management and system mapping",
      "Stream Health Monitoring for OBS and vMix",
      "Remote switcher control for OBS and vMix",
      "Slides with NDI output",
      "Tech Manager desktop app",
      "Luminos AI daily troubleshooting allowance",
      "Mobile apps and community support",
    ],
  },
  {
    name: "Starter",
    price: "$29",
    suffix: "/mo",
    tag: "Get your team fully in sync",
    body: "Add cloud workflows, alerts, analytics, and support so the free system becomes the center of your week.",
    cta: "Start with Starter",
    href: `${APP_URL}/sign-up`,
    featured: false,
    supportLabel: "Email + Tickets",
    supportBody: "Email + ticket support",
    supportBandClass: "bg-blue-600 text-white",
    items: [
      "Everything in Free Forever",
      "Worship Clips cloud sync and auto-publish",
      "Unlimited digital signage screens",
      "Real-time AV alerts by SMS and email",
      "Historical reports with 90-day retention",
      "Stream scheduling and automated countdowns",
      "Luminos AI with unlimited queries",
      "Email support and basic API access",
    ],
  },
  {
    name: "Pro",
    price: "$99",
    suffix: "/mo",
    tag: "Automate Sunday",
    body: "This is where Sunday starts to run smoother. Pro adds the production engine, volunteer control panels, and cue workflow that help more people serve well.",
    cta: "Book a demo",
    href: "/discovery-call",
    featured: true,
    supportLabel: "Email + Tickets + Phone",
    supportBody: "Email, tickets, and phone support",
    supportBandClass: "bg-amber-400 text-slate-950",
    items: [
      "Everything in Starter",
      "Automated production engine",
      "Volunteer control panels for any device",
      "Natural-language cue authoring with AI",
      "Production intercom for volunteer teams",
      "Automated macro and cue firing",
      "Extended data retention for 1 year",
      "Priority email support",
    ],
  },
  {
    name: "Multi-Site",
    price: "Custom",
    suffix: "",
    tag: "For networks of 2+ campuses",
    body: "Pro for every campus, centralized admin, and partner-level support for ministries growing across multiple locations.",
    cta: "Talk to sales",
    href: "/discovery-call",
    featured: false,
    supportLabel: "Dedicated Account Manager",
    supportBody: "Dedicated account manager",
    supportBandClass: "bg-purple-700 text-white",
    items: [
      "Everything in Pro",
      "Pro features for every campus",
      "Centralized admin across campuses",
      "Custom service templates built by our team",
      "Dedicated onboarding specialist",
      "Partner-level support and planning",
      "Quarterly strategy review",
      "Unlimited data retention",
    ],
  },
];

const comparisonRows = [
  ["Service Planning", "Included", "Included", "Included", "Included"],
  ["Volunteer Management", "Included", "Included", "Included", "Included"],
  ["Worship Clips", "Local", "Cloud + auto-publish", "Cloud + auto-publish", "Cloud + auto-publish"],
  ["Digital Signage", "1 screen", "Unlimited", "Unlimited", "Unlimited"],
  ["Attendance", "Included", "Included", "Included", "Included"],
  ["AV Management", "Included", "Included", "Included", "Included"],
  ["Stream Health Monitoring", "Included", "Alerts + reports", "Alerts + reports", "Alerts + reports"],
  ["Remote Switcher Control", "Included", "Included", "Included", "Included"],
  ["Stream Scheduling", "No", "Included", "Included", "Included"],
  ["Volunteer control panels", "No", "No", "Included", "Included"],
  ["Automated production engine", "No", "No", "Included", "Included"],
  ["Production intercom", "No", "No", "Included", "Included"],
  ["Support", "Community", "Email + Tickets", "Email + Tickets + Phone", "Dedicated Account Manager"],
];

const faqItems = [
  { question: "Is Free Forever really free forever?", answer: "Yes. No credit card, no trial timer, and no forced expiration. Churches can start with the whole team and prove the system before they ever pay." },
  { question: "Can I upgrade and downgrade?", answer: "Yes. You can move between plans anytime as your ministry grows or your needs change." },
  { question: "What kind of support comes with each tier?", answer: "Free Forever is community-supported. Starter includes email and ticket support. Pro adds phone support alongside email and tickets. Multi-Site includes a dedicated account manager and partner-level support." },
  { question: "Do you offer a nonprofit discount?", answer: "Yes. Contact us and we will talk through the right fit for your ministry and budget." },
  { question: "Do you offer a multi-church discount?", answer: "Yes. Multi-campus and multi-church organizations should talk with us directly so pricing can match the real rollout." },
  { question: "What happens to my data if I cancel?", answer: "Your data stays exportable. We will help you make sure your ministry can keep what it needs." },
  { question: "Do you offer annual billing?", answer: "Yes. Annual billing includes 2 months free, which means you pay 10-month pricing for the year." },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "OfferCatalog",
    name: "WorshipMetrics Pricing",
    url: `${SITE_URL}/pricing`,
    itemListElement: [
      { "@type": "Offer", name: "Free Forever", price: "0", priceCurrency: "USD", url: `${SITE_URL}/pricing` },
      { "@type": "Offer", name: "Starter", price: "29", priceCurrency: "USD", url: `${SITE_URL}/pricing` },
      { "@type": "Offer", name: "Pro", price: "99", priceCurrency: "USD", url: `${SITE_URL}/pricing` },
      { "@type": "Offer", name: "Worship Metrics Hub", price: "499", priceCurrency: "USD", url: `${SITE_URL}/appliance` },
      { "@type": "Offer", name: "Worship Metrics Tablet", price: "349", priceCurrency: "USD", url: `${SITE_URL}/tablet` },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map(({ question, answer }) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: { "@type": "Answer", text: answer },
    })),
  },
];
---

<Layout
  title="Pricing"
  description="Free to start. Grows with your ministry. Compare WorshipMetrics plans for Services, volunteers, production automation, and hardware."
  canonical="/pricing"
  structuredData={structuredData}
>
  <section class="bg-gradient-to-b from-indigo-50 to-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Pricing</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">Free to start. Grows with your ministry.</h1>
      <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-slate-600 sm:text-xl">
        Start with the whole team on Free Forever. Upgrade when your ministry needs cloud workflows, stronger alerts, and the production engine that makes Sunday easier to share.
      </p>
    </div>
  </section>

  <section class="px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid items-stretch gap-8 lg:grid-cols-4">
        {plans.map(({ name, price, suffix, tag, badge, body, cta, href, featured, items, supportLabel, supportBody, supportBandClass }) => (
          <div class:list={[
            "relative flex flex-col rounded-[1.75rem] border p-8 shadow-sm",
            featured ? "border-indigo-500 bg-indigo-600 shadow-lg shadow-indigo-200" : "border-slate-200 bg-white",
          ]}>
            {featured && <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 rounded-full bg-amber-400 px-4 py-0.5 text-xs font-bold uppercase tracking-wider text-slate-900">Most popular</span>}
            {badge && <span class:list={["mb-4 inline-flex w-fit rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em]", featured ? "bg-white/15 text-white" : "bg-indigo-50 text-indigo-700"]}>{badge}</span>}
            <div>
              <p class:list={["text-sm font-semibold uppercase tracking-[0.16em]", featured ? "text-indigo-200" : "text-indigo-600"]}>{tag}</p>
              <h2 class:list={["mt-3 text-2xl font-bold", featured ? "text-white" : "text-slate-900"]}>{name}</h2>
              <p class:list={["mt-4 text-4xl font-extrabold tracking-tight", featured ? "text-white" : "text-slate-900"]}>{price}<span class:list={["text-base font-medium", featured ? "text-indigo-200" : "text-slate-500"]}>{suffix}</span></p>
              <p class:list={["mt-4 text-sm leading-relaxed", featured ? "text-indigo-100" : "text-slate-600"]}>{body}</p>
            </div>
            <a href={href} class:list={["mt-8 block rounded-xl py-3 text-center text-sm font-semibold transition", featured ? "bg-white text-indigo-700 hover:bg-indigo-50" : "bg-indigo-600 text-white hover:bg-indigo-700"]}>{cta}</a>
            <ul class="mt-8 flex-1 space-y-3">
              {items.map((item) => (
                <li class="flex items-start gap-3 text-sm">
                  <svg class:list={["mt-0.5 h-4 w-4 flex-shrink-0", featured ? "text-indigo-300" : "text-indigo-500"]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <span class:list={[featured ? "text-indigo-100" : "text-slate-600"]}>{item}</span>
                </li>
              ))}
            </ul>
            <div class:list={["mt-8 -mx-8 -mb-8 border-t border-white/10 px-6 py-5", supportBandClass]}>
              <div class="flex min-h-[7.5rem] flex-col justify-between">
                <div>
                  <p class="text-[11px] font-bold uppercase tracking-[0.18em]">Support</p>
                  <p class="mt-2 text-base font-bold leading-tight">{supportLabel}</p>
                  <p class:list={["mt-2 text-sm leading-relaxed", featured ? "text-slate-800/85" : "opacity-95"]}>{supportBody}</p>
                </div>
                <div class:list={["mt-4 h-1.5 w-full rounded-full", featured ? "bg-white/35" : "bg-black/10"]}></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 pb-6 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl rounded-[2rem] border border-slate-200 bg-slate-50 p-8 shadow-sm sm:p-10">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Why support is part of the product</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Church production software should not leave the team alone on Sunday.</h2>
          <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
            WorshipMetrics is not just software you buy and figure out in isolation. Support is part of the value because churches need different levels of help as their production grows from one operator to a real team.
          </p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {[
            "Free Forever gives smaller churches a low-risk way to start with community help.",
            "Starter gives growing teams a reliable email and ticket path when the workflow starts to matter every week.",
            "Pro adds phone access because live production issues do not always wait for async support.",
            "Multi-Site gets partner-level help because cross-campus rollout is a different kind of operational challenge.",
          ].map((item) => (
            <div class="rounded-[1.5rem] border border-slate-200 bg-white p-5 text-sm leading-relaxed text-slate-600">{item}</div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm">
      <div class="grid items-center gap-0 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
        <div class="p-8 sm:p-10">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">What you get with Pro</p>
          <h2 class="mt-3 text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">The room gets easier to run because more people can carry it well.</h2>
          <p class="mt-4 text-sm leading-relaxed text-slate-600 sm:text-base">
            Pro adds the automation workflow, volunteer control panels, and cue-building tools that help directors, students, and first-time volunteers all contribute in the same service with less chaos.
          </p>
          <div class="mt-6 space-y-3 text-sm text-slate-700">
            {[
              "Timeline-synced show control keeps key moments moving together.",
              "Volunteer control panels work on any device with only the controls that role needs.",
              "Natural-language cue authoring helps teams build production moments faster.",
            ].map((item) => (
              <div class="flex items-start gap-3"><span class="mt-2 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-indigo-500"></span><span>{item}</span></div>
            ))}
          </div>
          <p class="mt-6 text-sm text-slate-500">Includes role-based volunteer control panels, which is part of what makes AV Clubs possible.</p>
          <div class="mt-4">
            <a href="/av-team" class="btn-outline">See the AV Team roles</a>
          </div>
        </div>
        <div class="overflow-hidden border-l border-slate-200 bg-slate-50">
          <img src={PANELS_IMAGE} alt="Volunteer control panels on tablets in WorshipMetrics" loading="lazy" decoding="async" class="aspect-[16/10] h-full w-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Compare the plans in one table.</h2>
      </div>
      <div class="mt-10 overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm">
        <table class="w-full text-sm">
          <thead class="bg-slate-50 text-left">
            <tr>
              <th class="px-6 py-4 font-semibold text-slate-700">Capability</th>
              <th class="px-6 py-4 font-semibold text-slate-700">Free Forever</th>
              <th class="px-6 py-4 font-semibold text-slate-700">Starter</th>
              <th class="px-6 py-4 font-semibold text-slate-700">Pro</th>
              <th class="px-6 py-4 font-semibold text-slate-700">Multi-Site</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 bg-white">
            {comparisonRows.map(([feature, free, starter, pro, premium]) => (
              <tr class:list={[feature === "Support" ? "bg-slate-50" : ""]}>
                <td class="px-6 py-4 font-semibold text-slate-900">{feature}</td>
                <td class="px-6 py-4 text-slate-600">{free}</td>
                <td class="px-6 py-4 text-slate-600">{starter}</td>
                <td class="px-6 py-4 text-slate-600">{pro}</td>
                <td class="px-6 py-4 text-slate-600">{premium}</td>
              </tr>
            ))}
            <tr class="border-t-2 border-slate-300 bg-slate-950 text-white">
              <td class="px-6 py-4 font-semibold">Support band</td>
              <td class="px-6 py-4"><span class="inline-flex rounded-full bg-slate-200 px-3 py-1 text-xs font-semibold text-slate-700">Community</span></td>
              <td class="px-6 py-4"><span class="inline-flex rounded-full bg-blue-600 px-3 py-1 text-xs font-semibold text-white">Email + Tickets</span></td>
              <td class="px-6 py-4"><span class="inline-flex rounded-full bg-amber-400 px-3 py-1 text-xs font-semibold text-slate-950">Email + Tickets + Phone</span></td>
              <td class="px-6 py-4"><span class="inline-flex rounded-full bg-purple-700 px-3 py-1 text-xs font-semibold text-white">Dedicated Account Manager</span></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Hardware sold separately</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Add hardware where it helps the workflow.</h2>
      </div>
      <div class="mt-10 grid gap-8 sm:grid-cols-2 xl:grid-cols-3">
        <div class="flex flex-col overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm">
          <img src={HUB_IMAGE} alt="Worship Metrics Hub product image" loading="lazy" decoding="async" class="-mx-8 -mt-8 mb-6 aspect-[16/10] w-[calc(100%+4rem)] object-cover" />
          <h3 class="text-xl font-bold text-slate-900">Worship Metrics Hub</h3>
          <p class="mt-1 text-2xl font-extrabold text-slate-900">$499 <span class="text-sm font-normal text-slate-400">one-time</span></p>
          <p class="mt-4 text-sm leading-relaxed text-slate-600">Always-on hardware for ministries that want local reliability and deeper monitoring resilience.</p>
          <a href="/appliance" class="mt-6 block rounded-xl border border-indigo-600 py-3 text-center text-sm font-semibold text-indigo-600 transition hover:bg-indigo-50">See Hub details</a>
        </div>

        <div class="flex flex-col overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-sm">
          <img src={TABLET_IMAGE} alt="Worship Metrics Tablet product image" loading="lazy" decoding="async" class="-mx-8 -mt-8 mb-6 aspect-[16/10] w-[calc(100%+4rem)] object-cover" />
          <h3 class="text-xl font-bold text-slate-900">Worship Metrics Tablet</h3>
          <p class="mt-1 text-2xl font-extrabold text-slate-900">From $349 <span class="text-sm font-normal text-slate-400">one-time</span></p>
          <p class="mt-4 text-sm leading-relaxed text-slate-600">A dedicated device for welcome desks, attendance workflows, and volunteer control surfaces.</p>
          <a href="/tablet" class="mt-6 block rounded-xl border border-indigo-600 py-3 text-center text-sm font-semibold text-indigo-600 transition hover:bg-indigo-50">See Tablet details</a>
        </div>

        <div class="flex flex-col rounded-[1.75rem] border border-dashed border-slate-300 bg-white p-8 shadow-sm">
          <h3 class="text-xl font-bold text-slate-900">Production Bundle</h3>
          <p class="mt-1 text-sm font-semibold uppercase tracking-[0.16em] text-indigo-600">Coming soon</p>
          <p class="mt-4 text-sm leading-relaxed text-slate-600">A packaged option for churches that want the software, hardware, and volunteer-device strategy to launch together.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">FAQ</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Common questions about WorshipMetrics pricing</h2>
      </div>
      <div class="mt-8 space-y-4">
        {faqItems.map(({ question, answer }) => (
          <details class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <summary class="cursor-pointer list-none text-lg font-semibold text-slate-900">{question}</summary>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-indigo-600 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Still not sure which tier fits? Book a 15-minute call.</h2>
      <p class="mx-auto mt-4 max-w-3xl text-base leading-relaxed text-indigo-100 sm:text-lg">
        We will help you choose the right level for your team, your current workflow, and the kind of support your ministry actually needs.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row sm:flex-wrap">
        <a href={`${APP_URL}/sign-up`} class="btn-primary" style="background:#fff;color:#4361ee;box-shadow:0 10px 30px rgba(15,23,42,0.18);" data-wm-track="cta_click" data-wm-track-label="pricing_footer_get_started_free" data-wm-track-location="pricing_footer_cta">Get started free</a>
        <a href="/discovery-call" class="btn-outline" style="border-color:rgba(255,255,255,0.35);color:#fff;" data-wm-track="cta_click" data-wm-track-label="pricing_footer_book_demo" data-wm-track-location="pricing_footer_cta">Book a demo</a>
        <a href="/contact" class="btn-outline" style="border-color:rgba(255,255,255,0.35);color:#fff;">Talk to sales</a>
      </div>
    </div>
  </section>
</Layout>
