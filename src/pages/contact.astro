---
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.worshipmetrics.com";
---

<Layout
  title="Contact"
  description="Get in touch with the WorshipMetrics team. Talk with Paul Richards about your church's needs."
  canonical="/contact"
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-indigo-50 via-white to-slate-50 px-4 py-24 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-4xl font-extrabold leading-tight tracking-tight text-slate-900 sm:text-5xl">
        Let's connect.
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg text-slate-600">
        Whether you're ready to get started or just have questions, we're here to help.
      </p>
    </div>
    <div class="pointer-events-none absolute -top-32 -right-32 h-96 w-96 rounded-full bg-indigo-200 opacity-20 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-violet-300 opacity-20 blur-3xl"></div>
  </section>

  <!-- 2-column contact options -->
  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl grid gap-8 sm:grid-cols-2">
      <!-- Small & growing churches -->
      <div class="rounded-2xl border border-slate-100 bg-slate-50 p-8 shadow-sm flex flex-col">
        <h2 class="text-xl font-bold text-slate-900">Small &amp; growing churches</h2>
        <p class="mt-3 text-slate-600 leading-relaxed">
          Simple tools, honest pricing, and Free Forever to start. No technical complexity, no long
          contracts.
        </p>
        <ul class="mt-6 space-y-2">
          {["Free Forever available", "Easy setup", "Dedicated support"].map((item) => (
            <li class="flex items-center gap-2 text-sm text-slate-600">
              <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-indigo-100 text-xs text-indigo-700">✓</span>
              {item}
            </li>
          ))}
        </ul>
        <div class="mt-8">
          <a
            href={`${APP_URL}/sign-up`}
            class="inline-block w-full rounded-xl bg-indigo-600 px-6 py-3 text-center text-base font-semibold text-white shadow-md transition hover:bg-indigo-700"
          >
            Get started free
          </a>
        </div>
      </div>

      <!-- Larger & multi-campus churches -->
      <div class="rounded-2xl border border-slate-100 bg-slate-50 p-8 shadow-sm flex flex-col">
        <h2 class="text-xl font-bold text-slate-900">Larger &amp; multi-campus churches</h2>
        <p class="mt-3 text-slate-600 leading-relaxed">
          Multi-campus support, deeper analytics, and hands-on onboarding for established
          congregations.
        </p>
        <ul class="mt-6 space-y-2">
          {["Multi-campus support", "Custom integrations", "Priority support and training"].map((item) => (
            <li class="flex items-center gap-2 text-sm text-slate-600">
              <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-indigo-100 text-xs text-indigo-700">✓</span>
              {item}
            </li>
          ))}
        </ul>
        <div class="mt-8">
          <a
            href="/discovery-call"
            class="inline-block w-full rounded-xl border border-slate-300 bg-white px-6 py-3 text-center text-base font-semibold text-slate-700 transition hover:border-indigo-400 hover:text-indigo-600"
          >
            Book a discovery call
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Reach us directly -->
  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-slate-900">Reach us directly.</h2>
      <div class="mt-8 rounded-2xl border border-slate-100 bg-white p-8 shadow-sm text-left">
        <p class="text-lg font-semibold text-slate-900">Paul Richards</p>
        <div class="mt-4 space-y-2">
          <p class="text-slate-600">
            <span class="font-medium text-slate-700">Email:</span>{" "}
            <a href="mailto:paul@worshipmetrics.com" class="text-indigo-600 hover:text-indigo-800">
              paul@worshipmetrics.com
            </a>
          </p>
          <p class="text-slate-600">
            <span class="font-medium text-slate-700">Phone:</span>{" "}
            <a href="tel:4107257500" class="text-indigo-600 hover:text-indigo-800">
              410-725-7500
            </a>
          </p>
        </div>
        <p class="mt-6 text-sm text-slate-400">
          Include your church size and specific needs and we'll reply within one business day.
        </p>
      </div>
    </div>
  </section>
</Layout>
