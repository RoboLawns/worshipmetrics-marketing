---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Pilot Program"
  description="A free 30–60 day trial to see if WorshipMetrics helps your church. No permanent commitment. Works on any smartphone."
  canonical="/pilot-program"
>
  <!-- Hero -->
  <section class="bg-white px-6 py-20 sm:py-28">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-indigo-600">
        Free 30–60 day trial
      </p>
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
        Start your pilot. Prove what's working before you invest in what's next.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-600 sm:text-xl">
        A low-pressure trial designed to help your church gain clarity — not make judgments. Works
        on any smartphone. Takes 1–3 minutes per service.
      </p>
    </div>
  </section>

  <!-- Pilot visuals -->
  <section class="bg-slate-50 px-6 pb-8 sm:pb-12">
    <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img
          src="/legacy-images/seat-counting-hero.jpg"
          alt="Seat counting workflow during a WorshipMetrics pilot"
          loading="lazy"
          decoding="async"
          class="aspect-[16/10] w-full object-cover"
        />
      </div>
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img
          src="/legacy-images/attendance-tracking-dashboard.jpg"
          alt="Attendance dashboard view during a WorshipMetrics pilot"
          loading="lazy"
          decoding="async"
          class="aspect-[16/10] w-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- What the pilot is -->
  <section class="bg-slate-50 px-6 py-20">
    <div class="mx-auto max-w-5xl">
      <div class="grid gap-8 sm:grid-cols-3">
        <div class="rounded-2xl bg-white p-8 shadow-sm border border-slate-100">
          <h3 class="text-lg font-bold text-slate-900 mb-3">Not a permanent commitment</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Test it for 30–60 days, then decide.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-8 shadow-sm border border-slate-100">
          <h3 class="text-lg font-bold text-slate-900 mb-3">Focus on care, not judgment</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            See who's new, who's missing, where care is needed.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-8 shadow-sm border border-slate-100">
          <h3 class="text-lg font-bold text-slate-900 mb-3">You're a partner, not just a user</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Your feedback shapes the product.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Success criteria -->
  <section class="bg-white px-6 py-16">
    <div class="mx-auto max-w-2xl">
      <h2 class="text-2xl font-bold tracking-tight text-slate-900 mb-6 text-center">
        The pilot succeeds if&hellip;
      </h2>
      <ul class="space-y-4">
        {[
          "Volunteers are comfortable using it",
          "Leadership finds the insights helpful",
          "Follow-up conversations feel more informed",
          "You have data you can show your board when planning the next AV investment",
        ].map((item) => (
          <li class="flex items-start gap-3 rounded-xl border border-slate-200 px-5 py-4">
            <span class="text-indigo-600 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
              </svg>
            </span>
            <span class="text-slate-700 text-sm">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Request form -->
  <section class="bg-slate-50 px-6 py-20">
    <div class="mx-auto max-w-xl">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl mb-4 text-center">
        Request your pilot program.
      </h2>
      <p class="text-center text-slate-600 mb-6">
        The pilot is the front door to everything we do. Some churches stay on the platform and never need anything else. Others use what they learn to plan a real AV upgrade, and when that day comes, we can help with that too. Either way, you start by measuring what you already have.
      </p>
      <p class="text-center text-slate-600 mb-10">
        Fill out the form below and we'll reach out within 1–2 business days to schedule a quick
        call.
      </p>

      <form
        method="POST"
        action="/api/pilot-request"
        class="space-y-5 rounded-2xl bg-white p-8 shadow-sm border border-slate-200"
      >
        <div>
          <label for="church-name" class="block text-sm font-semibold text-slate-800 mb-1">
            Church Name <span class="text-red-500">*</span>
          </label>
          <input
            id="church-name"
            name="church_name"
            type="text"
            required
            placeholder="Grace Community Church"
            class="w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200"
          />
        </div>

        <div>
          <label for="your-name" class="block text-sm font-semibold text-slate-800 mb-1">
            Your Name <span class="text-red-500">*</span>
          </label>
          <input
            id="your-name"
            name="your_name"
            type="text"
            required
            placeholder="Pastor John Smith"
            class="w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-semibold text-slate-800 mb-1">
            Email <span class="text-red-500">*</span>
          </label>
          <input
            id="email"
            name="email"
            type="email"
            required
            placeholder="john@gracechurch.org"
            class="w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200"
          />
        </div>

        <div>
          <label for="phone" class="block text-sm font-semibold text-slate-800 mb-1">
            Phone <span class="text-slate-400 font-normal">(optional)</span>
          </label>
          <input
            id="phone"
            name="phone"
            type="tel"
            placeholder="(555) 000-0000"
            class="w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200"
          />
        </div>

        <div>
          <label for="congregation-size" class="block text-sm font-semibold text-slate-800 mb-1">
            Congregation Size <span class="text-red-500">*</span>
          </label>
          <select
            id="congregation-size"
            name="congregation_size"
            required
            class="w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200 bg-white"
          >
            <option value="" disabled selected>Select a range…</option>
            <option value="under-50">Under 50</option>
            <option value="50-100">50–100</option>
            <option value="100-250">100–250</option>
            <option value="250-500">250–500</option>
            <option value="500-1000">500–1,000</option>
            <option value="over-1000">Over 1,000</option>
          </select>
        </div>

        <div>
          <label for="services-per-week" class="block text-sm font-semibold text-slate-800 mb-1">
            Services per week <span class="text-red-500">*</span>
          </label>
          <input
            id="services-per-week"
            name="services_per_week"
            type="text"
            required
            placeholder="e.g. 2 (9am &amp; 11am)"
            class="w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200"
          />
        </div>

        <div>
          <label for="notes" class="block text-sm font-semibold text-slate-800 mb-1">
            Questions or notes <span class="text-slate-400 font-normal">(optional)</span>
          </label>
          <textarea
            id="notes"
            name="notes"
            rows="4"
            placeholder="Anything you'd like us to know before we connect…"
            class="w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200 resize-y"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full rounded-lg bg-indigo-600 px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-indigo-700 transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600"
        >
          Request pilot program
        </button>

        <p class="text-center text-xs text-slate-400">
          We'll reach out within 1–2 business days to schedule a quick call.
        </p>
      </form>
    </div>
  </section>
</Layout>
