---
import Layout from "../layouts/Layout.astro";

const SITE_URL = "https://worshipmetrics.com";
const OG_IMAGE = `${SITE_URL}/legacy-images/welcome-capture-wide.jpg`;
const faqItems = [
  {
    question: "What is a church guest follow-up system?",
    answer: "A church guest follow-up system helps churches capture first-time visitor information, organize response steps, and connect follow-up with attendance, prayer, and ministry context.",
  },
  {
    question: "Why do churches need a follow-up system instead of a spreadsheet?",
    answer: "A real system keeps guest details, attendance signals, prayer requests, and next steps together so follow-up is less dependent on memory or manual handoffs.",
  },
  {
    question: "Can WorshipMetrics work for in-person and online guests?",
    answer: "Yes. WorshipMetrics supports guest capture and follow-up from in-person welcome workflows as well as digital engagement and prayer pathways.",
  },
  {
    question: "Does it help pastors and staff see who needs a response?",
    answer: "Yes. WorshipMetrics helps surface guests, missed attendees, and follow-up opportunities so staff and leaders can act sooner.",
  },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "WorshipMetrics Church Guest Follow-Up System",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web, iOS, Android",
    url: `${SITE_URL}/church-guest-follow-up-system`,
    image: OG_IMAGE,
    description: "Church guest follow-up system for first-time visitors, welcome cards, prayer routing, and connected people workflows.",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
      availability: "https://schema.org/InStock",
      url: `${SITE_URL}/pricing`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map(({ question, answer }) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: { "@type": "Answer", text: answer },
    })),
  },
];
---

<Layout
  title="Church Guest Follow-Up System"
  description="Church guest follow-up system for first-time visitors, welcome cards, prayer routing, and connected people workflows."
  canonical="/church-guest-follow-up-system"
  ogImage={OG_IMAGE}
  structuredData={structuredData}
>
  <section class="bg-gradient-to-b from-indigo-50 to-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Church guest follow-up system</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">A church guest follow-up system that helps your team move from first visit to real care.</h1>
      <p class="mt-6 text-lg text-slate-600 sm:text-xl">Keep guest capture, prayer routing, attendance context, and next steps together so your church can follow up consistently instead of reactively.</p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/av-monitoring-for-houses-of-worship" class="rounded-xl bg-indigo-600 px-8 py-3 text-base font-semibold text-white shadow transition hover:bg-indigo-700">See AV monitoring</a>
        <a href="/appliance" class="rounded-xl border border-slate-300 px-8 py-3 text-base font-semibold text-slate-700 transition hover:border-indigo-400 hover:text-indigo-600">See the Hub</a>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 pb-8 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm"><img src={OG_IMAGE} alt="Church guest follow-up system in WorshipMetrics" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" /></div>
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm"><img src="https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main/tablet/Pastoral%20Care%202.jpg" alt="Pastoral follow-up system for churches" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" /></div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl grid gap-6 md:grid-cols-3">
      {[
        ["Capture guests in more than one way", "Welcome cards, QR forms, prayer requests, and digital engagement can all become usable people records."],
        ["Keep follow-up connected to context", "Attendance, guest history, notes, and prayer needs should help shape the next conversation."],
        ["Make the system repeatable", "A good church guest follow-up system supports volunteers, staff, and pastors without relying on one person holding everything together."],
      ].map(([title, body]) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm"><h2 class="text-xl font-bold text-slate-900">{title}</h2><p class="mt-3 text-sm leading-relaxed text-slate-600">{body}</p></div>
      ))}
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl grid gap-6 md:grid-cols-3">
      {[
          { href: "/av-monitoring-for-houses-of-worship", title: "AV monitoring", body: "See the monitoring layer the booth actually uses every week." },
        { href: "/church-visitor-follow-up-software", title: "Visitor follow-up software", body: "A related guide focused more specifically on guest capture and follow-up software." },
          { href: "/appliance", title: "WorshipMetrics Hub", body: "See the hardware layer for always-on monitoring, automation, and booth reliability." },
      ].map(({ href, title, body }) => (
        <a href={href} class="rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-sm transition hover:border-indigo-300 hover:bg-white"><h3 class="text-lg font-semibold text-slate-900">{title}</h3><p class="mt-2 text-sm leading-relaxed text-slate-600">{body}</p><span class="mt-4 inline-block text-sm font-semibold text-indigo-600">Explore →</span></a>
      ))}
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl"><div class="text-center"><p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">FAQ</p><h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Questions churches ask about guest follow-up systems</h2></div><div class="mt-8 space-y-4">{faqItems.map(({ question, answer }) => (<details class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm"><summary class="cursor-pointer list-none text-lg font-semibold text-slate-900">{question}</summary><p class="mt-3 text-sm leading-relaxed text-slate-600">{answer}</p></details>))}</div></div>
  </section>
</Layout>
