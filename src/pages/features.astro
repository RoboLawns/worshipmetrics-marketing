---
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.worshipmetrics.com";
const R2 = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";

const featureGroups = [
  {
    category: "Attendance",
    items: [
      {
        title: "One-tap count entry",
        description: "Quickly log attendance for any service in seconds. No forms, no friction.",
      },
      {
        title: "Recurring service templates",
        description: "Define your service schedule once and let WorshipMetrics auto-create service instances.",
      },
      {
        title: "Manual & camera-based counts",
        description: "Enter numbers by hand, use your device camera, or connect a WorshipMetrics Hub device.",
      },
      {
        title: "Historical trend reports",
        description: "View week-over-week, month-over-month, and year-over-year attendance trends in seconds.",
      },
    ],
  },
  {
    category: "People & Members",
    items: [
      {
        title: "Member directory",
        description: "Store contact info, roles, birthdays, anniversaries, and custom fields for every person.",
      },
      {
        title: "Birthday & anniversary alerts",
        description: "Automated celebration reminders delivered to leaders at the right time.",
      },
      {
        title: "Role-based access",
        description: "Admins, leaders, volunteers, and members each see only what they need.",
      },
      {
        title: "Guest & visitor tracking",
        description: "Capture first-time visitor info and track follow-up through your pipeline.",
      },
    ],
  },
  {
    category: "Insights & Analytics",
    items: [
      {
        title: "Dashboard overview",
        description: "A real-time snapshot of attendance, member activity, and upcoming services.",
      },
      {
        title: "Segment by service type",
        description: "Compare main service vs. small group vs. special events side by side.",
      },
      {
        title: "Exportable reports",
        description: "Download CSV or PDF reports to share with your board or denomination.",
      },
      {
        title: "Shared report links",
        description: "Generate a shareable link to a read-only report view — no login required for recipients.",
      },
    ],
  },
  {
    category: "Devices & Hardware",
    items: [
      {
        title: "WorshipMetrics Hub",
        description: "An optional physical device that automates attendance counting using computer vision.",
      },
      {
        title: "Signage & TV displays",
        description: "Display live welcome slides, service info, and announcements on any screen.",
      },
      {
        title: "Kiosk mode",
        description: "Lock down a tablet to a dedicated check-in or count-entry screen.",
      },
    ],
  },
];
---

<Layout
  title="Church Attendance, Follow-Up, and Analytics Features"
  description="Explore WorshipMetrics features for church attendance tracking, guest follow-up, analytics, hardware, digital engagement, and volunteer workflows."
  canonical="/features"
>
  <!-- Page hero -->
  <section class="bg-gradient-to-b from-indigo-50 to-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">
        Features
      </h1>
      <p class="mt-4 text-lg text-slate-600">
        Everything you need to run a healthy, connected congregation — in one simple platform.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={`${APP_URL}/sign-up`}
          class="rounded-xl bg-indigo-600 px-8 py-3 text-sm font-semibold text-white shadow transition hover:bg-indigo-700"
        >
          Start for free
        </a>
        <a
          href="/pricing"
          class="rounded-xl border border-slate-300 px-8 py-3 text-sm font-semibold text-slate-700 transition hover:border-indigo-400 hover:text-indigo-600"
        >
          View pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Feature visuals -->
  <section class="bg-white px-4 pb-8 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          {
            title: "Attendance",
            body: "Seat templates, Auto-Count, and weekly reporting in one workflow.",
            src: "/legacy-images/seat-counting-hero.jpg",
            alt: "Attendance tracking in WorshipMetrics",
          },
          {
            title: "People & Members",
            body: "Capture guests, scan cards, and keep follow-up tied to real people.",
            src: "/legacy-images/welcome-capture-wide.jpg",
            alt: "Welcome capture workflow in WorshipMetrics",
          },
          {
            title: "Insights & Analytics",
            body: "Dashboards that help leaders see patterns, not just raw counts.",
            src: "/legacy-images/attendance-tracking-dashboard.jpg",
            alt: "Attendance analytics dashboard in WorshipMetrics",
          },
          {
            title: "Devices & Hardware",
            body: "Hub and Tablet workflows that connect directly to the same system.",
            src: `${R2}/tablet/New%20Worship%20Metrics%20Tablet%20Hero.jpg`,
            alt: "WorshipMetrics tablet hardware",
          },
        ].map(({ title, body, src, alt }) => (
          <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
            <img src={src} alt={alt} loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
            <div class="p-6">
              <h2 class="text-lg font-semibold text-slate-900">{title}</h2>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">{body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Feature groups -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl space-y-20">
      {featureGroups.map(({ category, items }) => (
        <div>
          <h2 class="mb-8 text-2xl font-bold text-slate-900 border-b border-slate-100 pb-3">
            {category}
          </h2>
          <div class="grid gap-6 sm:grid-cols-2">
            {items.map(({ title, description }) => (
              <div class="flex gap-4 rounded-2xl border border-slate-100 bg-slate-50 p-5">
                <div class="mt-0.5 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-indigo-100 text-indigo-600">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-slate-900">{title}</h3>
                  <p class="mt-1 text-sm text-slate-600 leading-relaxed">{description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Popular guides</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Explore common church software use cases</h2>
      </div>
      <div class="mt-8 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {[
          { href: "/free-church-attendance-software", title: "Free church attendance software", body: "A conversion-focused page for churches ready to start tracking attendance without paying first." },
          { href: "/free-church-digital-signage", title: "Free church digital signage", body: "A conversion-focused page for churches that want to manage lobby screens without monthly fees." },
          { href: "/church-attendance-tracking-software", title: "Church attendance tracking software", body: "How churches track in-person and online attendance with one connected workflow." },
          { href: "/church-visitor-follow-up-software", title: "Church visitor follow-up software", body: "How guest capture, prayer requests, and follow-up can work from one system." },
          { href: "/church-check-in-tablet", title: "Church check-in tablet", body: "A dedicated tablet workflow for welcome desks, check-in, and volunteer teams." },
          { href: "/church-digital-signage-software", title: "Church digital signage software", body: "How churches manage lobby screens and announcements without extra complexity." },
          { href: "/church-livestream-analytics", title: "Church livestream analytics", body: "How churches track live viewers, replays, and online attendance in one reporting flow." },
          { href: "/church-guest-follow-up-system", title: "Church guest follow-up system", body: "How churches move from first visit to real follow-up with a repeatable process." },
          { href: "/church-attendance-app", title: "Church attendance app", body: "How mobile attendance workflows support staff and volunteers on the go." },
          { href: "/sermon-clips-software", title: "Sermon clips software", body: "How churches turn Sunday messages into social content without manual editing." },
        ].map(({ href, title, body }) => (
          <a href={href} class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:bg-indigo-50/20">
            <h3 class="text-lg font-semibold text-slate-900">{title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{body}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-indigo-600">Read guide →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-indigo-600 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-white">See it in action</h2>
      <p class="mt-4 text-indigo-200">
        Sign up in under a minute — no credit card, no commitment.
      </p>
      <a
        href={`${APP_URL}/sign-up`}
        class="mt-8 inline-block rounded-xl bg-white px-8 py-3 text-base font-semibold text-indigo-700 shadow transition hover:bg-indigo-50"
      >
        Get started free
      </a>
    </div>
  </section>
</Layout>
