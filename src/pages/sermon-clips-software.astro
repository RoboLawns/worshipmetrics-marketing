---
import Layout from "../layouts/Layout.astro";

const SITE_URL = "https://worshipmetrics.com";
const OG_IMAGE = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main/homepage/Worship%20Clips%20Hero%202.jpg";
const faqItems = [
  {
    question: "What is sermon clips software?",
    answer: "Sermon clips software helps churches turn services or message recordings into short social video clips for platforms like Instagram Reels, YouTube Shorts, TikTok, and Facebook.",
  },
  {
    question: "Does WorshipMetrics create sermon clips automatically?",
    answer: "Yes. WorshipMetrics can turn livestreams or uploaded recordings into mobile-ready sermon clips without requiring traditional video editing software.",
  },
  {
    question: "What social platforms are supported?",
    answer: "Worship Clips is designed for common church social formats including Instagram Reels, YouTube Shorts, TikTok, and Facebook clips.",
  },
  {
    question: "Do churches need a video editor to use it?",
    answer: "No. The goal is to make sermon clipping accessible to church teams that do not have a dedicated video editor or post-production workflow.",
  },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "WorshipMetrics Sermon Clips Software",
    applicationCategory: "MultimediaApplication",
    operatingSystem: "Web",
    url: `${SITE_URL}/sermon-clips-software`,
    image: OG_IMAGE,
    description: "Sermon clips software for churches to create social-ready message clips without manual video editing.",
    offers: {
      "@type": "Offer",
      price: "19.99",
      priceCurrency: "USD",
      availability: "https://schema.org/InStock",
      url: `${SITE_URL}/pricing`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map(({ question, answer }) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: { "@type": "Answer", text: answer },
    })),
  },
];
---

<Layout
  title="Sermon Clips Software"
  description="Sermon clips software for churches to create social-ready message clips without manual video editing."
  canonical="/sermon-clips-software"
  ogImage={OG_IMAGE}
  structuredData={structuredData}
>
  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Sermon clips software</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">Sermon clips software that helps churches keep the message moving all week.</h1>
      <p class="mt-6 text-lg text-slate-600 sm:text-xl">Turn your service into short-form social content for Reels, Shorts, TikTok, and Facebook without building a full post-production team.</p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/solutions/worship-clips" class="rounded-xl bg-indigo-600 px-8 py-3 text-base font-semibold text-white shadow transition hover:bg-indigo-700">See Worship Clips</a>
        <a href="/pricing" class="rounded-xl border border-slate-300 px-8 py-3 text-base font-semibold text-slate-700 transition hover:border-indigo-400 hover:text-indigo-600">See pricing</a>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 pb-8 sm:px-6 lg:px-8"><div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)]"><div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm"><img src={OG_IMAGE} alt="Sermon clips software for churches" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" /></div><div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm"><img src="https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main/homepage/Worship%20Metrics%20Clip%20Social%20Formatting.jpg" alt="Church social clip formatting" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" /></div></div></section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8"><div class="mx-auto max-w-6xl grid gap-6 md:grid-cols-3">{[["Clip faster","Reduce the gap between Sunday service and weekday social content by using an automated sermon clipping workflow."],["Format for mobile","Clips need to fit the platforms people actually use, not just sit as long-form videos after service."],["Expand reach","Sermon clips help your church stay visible between Sundays and put your message in front of people who were never in the room."]].map(([title, body]) => (<div class="rounded-2xl border border-slate-200 bg-slate-50 p-8"><h2 class="text-xl font-bold text-slate-900">{title}</h2><p class="mt-3 text-sm leading-relaxed text-slate-600">{body}</p></div>))}</div></section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8"><div class="mx-auto max-w-6xl grid gap-6 md:grid-cols-3">{[{ href: "/solutions/worship-clips", title: "Worship Clips", body: "See the full sermon clipping workflow inside WorshipMetrics." },{ href: "/church-digital-signage-software", title: "Digital signage software", body: "Connect social content and in-building communication to the same weekly church media rhythm." },{ href: "/appliance", title: "WorshipMetrics Hub", body: "See the connected hardware workflow that can support automated media operations." }].map(({ href, title, body }) => (<a href={href} class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:bg-indigo-50/20"><h3 class="text-lg font-semibold text-slate-900">{title}</h3><p class="mt-2 text-sm leading-relaxed text-slate-600">{body}</p><span class="mt-4 inline-block text-sm font-semibold text-indigo-600">Explore →</span></a>))}</div></section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8"><div class="mx-auto max-w-4xl"><div class="text-center"><p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">FAQ</p><h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Questions churches ask about sermon clips software</h2></div><div class="mt-8 space-y-4">{faqItems.map(({ question, answer }) => (<details class="rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-sm"><summary class="cursor-pointer list-none text-lg font-semibold text-slate-900">{question}</summary><p class="mt-3 text-sm leading-relaxed text-slate-600">{answer}</p></details>))}</div></div></section>
</Layout>
