---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Book a Discovery Call"
  description="A free 30-minute call with Paul Richards. No pressure — we learn about your church and recommend what actually makes sense."
  canonical="/discovery-call"
>
  <Fragment slot="head">
    <script>
      (() => {
        const sendDiscoveryCallConversion = () => {
          if (window.__wmDiscoveryCallConversionSent) return true;
          if (typeof window.gtag !== 'function') return false;

          window.gtag('event', 'conversion', {
            send_to: 'AW-18048317342/r89HCOXszZEcEJ7vjZ5D',
            transport_type: 'beacon',
          });

          window.__wmDiscoveryCallConversionSent = true;
          return true;
        };

        if (!sendDiscoveryCallConversion()) {
          window.setTimeout(sendDiscoveryCallConversion, 500);
          window.setTimeout(sendDiscoveryCallConversion, 1500);
        }
      })();
    </script>
  </Fragment>

  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-indigo-50 via-white to-slate-50 px-4 py-24 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <span class="inline-block rounded-full bg-indigo-100 px-4 py-1 text-xs font-semibold uppercase tracking-widest text-indigo-700">
        Free · 30 minutes · No sales pitch
      </span>
      <h1 class="mt-6 text-4xl font-extrabold leading-tight tracking-tight text-slate-900 sm:text-5xl">
        A free conversation about what fits your church.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-600">
        No pressure. No script. We learn about your church size, your staff capacity, and your
        current tools — then recommend what actually makes sense.
      </p>
      <div class="mt-10">
        <a
          href="https://calendar.app.google/HY4jxa7LzqBp9JiV6"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block rounded-xl bg-indigo-600 px-10 py-4 text-base font-semibold text-white shadow-md transition hover:bg-indigo-700"
        >
          Book a meeting instantly
        </a>
      </div>
    </div>
    <div class="pointer-events-none absolute -top-32 -right-32 h-96 w-96 rounded-full bg-indigo-200 opacity-20 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-violet-300 opacity-20 blur-3xl"></div>
  </section>

  <!-- What to expect -->
  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <div class="text-center">
        <h2 class="text-3xl font-bold text-slate-900">What to expect</h2>
      </div>
      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          {
            number: "1",
            title: "30 minutes, no pressure",
            body: "A real conversation, not a demo. We listen first.",
          },
          {
            number: "2",
            title: "We learn your situation",
            body: "Church size, staff capacity, current tools, and what's not working.",
          },
          {
            number: "3",
            title: "Honest recommendation",
            body: "We tell you what fits — the platform, outreach services, hardware, or none of the above.",
          },
          {
            number: "4",
            title: "Clear next steps",
            body: "You leave with a concrete plan, whether or not you become a customer.",
          },
        ].map(({ number, title, body }) => (
          <div class="rounded-2xl border border-slate-100 bg-slate-50 p-7 shadow-sm">
            <span class="flex h-9 w-9 items-center justify-center rounded-full bg-indigo-600 text-sm font-bold text-white">
              {number}
            </span>
            <h3 class="mt-4 font-semibold text-slate-900">{title}</h3>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact fallback -->
  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-slate-600">
        Prefer email?{" "}
        <a href="mailto:paul@worshipmetrics.com" class="font-medium text-indigo-600 hover:text-indigo-800">
          paul@worshipmetrics.com
        </a>
        {" · "}
        <a href="tel:9109677447" class="font-medium text-indigo-600 hover:text-indigo-800">
          910-WORSHIP (910-967-7447)
        </a>
      </p>
      <p class="mt-3 text-sm text-slate-400">
        Available Monday–Friday. We respond within one business day.
      </p>
    </div>
  </section>
</Layout>
