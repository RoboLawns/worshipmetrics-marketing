---
import Layout from "../layouts/Layout.astro";

const PAUL_HEADSHOT = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main/paul.jpg";
const ANDREW_HEADSHOT = "/legacy-images/rev-andrew-esqueda.jpeg";
const SETH_HEADSHOT = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main/homepage/Seth%20Haberman.jpeg";

const team = [
  {
    name: "Paul Richards",
    title: "Educator & Onboarding Lead",
    photo: PAUL_HEADSHOT,
    bio: "Paul brings 20 years of professional AV experience to WorshipMetrics, most recently as a technology business leader at PTZOptics, where he helped thousands of churches and broadcasters get their live streams off the ground. He&apos;s the author of <em>Helping Your Church Live Stream</em> and has spent his career translating complex production tech into plain-language workflows that volunteers can actually run on a Sunday morning. At WorshipMetrics, Paul leads onboarding — making sure every church that joins the platform gets set up for success, not handed a manual and a prayer.",
    links: [
      { label: "LinkedIn", href: "https://www.linkedin.com/in/paulrichards87/" },
      { label: "Helping Your Church Live Stream", href: "https://www.amazon.com/Helping-Your-Church-Live-Stream/dp/1955957004" },
    ],
  },
  {
    name: "Seth Haberman",
    title: "CTO & Digital Pastor",
    photo: SETH_HEADSHOT,
    bio: "Seth is the engineer behind the product, but he&apos;s also a worship leader who has lived inside the booth, on the stage, and behind the camera. He understands worship tech because he&apos;s done worship tech. As CTO, Seth turns ministry insight into working software — building the platform with the unique reality of church production in mind: limited budgets, volunteer teams, multi-cam services, and the need for everything to just work on Sunday.",
    links: [
      { label: "LinkedIn", href: "https://www.linkedin.com/in/sethhaberman/" },
    ],
  },
  {
    name: "Rev. Andrew Esqueda",
    title: "Pastor & Visionary",
    photo: ANDREW_HEADSHOT,
    bio: "Andrew is the visionary voice behind WorshipMetrics and the active pastor of First Presbyterian Church. He keeps us honest. Every feature, every metric, every workflow gets pressure-tested against one question: does this actually help the local church? Andrew lives the pain points our users live — staffing, attendance, engagement, the weekly grind of preparing for Sunday — and his perspective shapes everything we build.",
    links: [
      { label: "LinkedIn", href: "https://www.linkedin.com/in/rev-andrew-esqueda/" },
      { label: "First Presbyterian Church", href: "https://fpcwestchester.org" },
    ],
  },
];

const missionCards = [
  {
    title: "Ministry comes first",
    body: "Every feature has to help a real church carry real ministry better, not just add more software vocabulary.",
  },
  {
    title: "Technology should bring people in",
    body: "The right product does not just help the tech director. It gives students, new volunteers, and curious helpers a place to start.",
  },
  {
    title: "Every church deserves great tools",
    body: "Powerful and easy-to-learn tools should not be reserved for the biggest ministries with the biggest budgets.",
  },
];
---

<Layout
  title="About"
  description="Meet the team behind WorshipMetrics. Three perspectives — a pastor, a builder, and an educator — building tools that help churches run Sunday well."
  canonical="/about"
>
  <section class="relative overflow-hidden bg-gradient-to-br from-indigo-50 via-white to-slate-50 px-4 py-24 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <span class="inline-block rounded-full bg-indigo-100 px-4 py-1 text-xs font-semibold uppercase tracking-widest text-indigo-700">Meet the Team</span>
      <h1 class="mt-6 text-4xl font-extrabold leading-tight tracking-tight text-slate-900 sm:text-5xl">Three perspectives. One conviction.</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-600">
        WorshipMetrics exists because three different perspectives — a pastor, a builder, and an educator — kept arriving at the same conclusion: church tech is hard, and the people running it deserve better tools. We built the company we wished existed when we were each in the trenches.
      </p>
    </div>
    <div class="pointer-events-none absolute -top-32 -right-32 h-96 w-96 rounded-full bg-indigo-200 opacity-20 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-violet-300 opacity-20 blur-3xl"></div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-3">
      {team.map(({ name, title, photo, bio, links }) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition hover:border-indigo-200 hover:shadow-md">
          <img src={photo} alt={name} loading="lazy" decoding="async" class="mb-6 aspect-[4/3] w-full rounded-2xl object-cover" />
          <h2 class="text-xl font-semibold text-slate-900">{name}</h2>
          <p class="mt-1 text-sm font-medium text-indigo-600">{title}</p>
          <p class="mt-4 leading-relaxed text-slate-600" set:html={bio} />
          {links.length > 0 && (
            <div class="mt-5 flex flex-wrap gap-x-5 gap-y-2">
              {links.map(({ label, href }) => (
                <a href={href} target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-indigo-600 hover:text-indigo-800">{label} &rarr;</a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <span class="inline-block rounded-full bg-indigo-100 px-4 py-1 text-xs font-semibold uppercase tracking-widest text-indigo-700">Why this team works</span>
      <h2 class="mt-6 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Vision, build, adoption — fully covered.</h2>
      <p class="mt-6 text-lg leading-relaxed text-slate-600">
        Most church tech is built by engineers who&apos;ve never led a worship service, or by ministry leaders who can&apos;t ship software. WorshipMetrics is different. Andrew anchors us in real ministry needs. Seth translates those needs into product. Paul makes sure churches actually succeed once they&apos;re in the door. That&apos;s the dream team, and that&apos;s why we&apos;re here.
      </p>
    </div>
  </section>

  <section class="bg-indigo-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <span class="inline-block rounded-full bg-indigo-100 px-4 py-1 text-xs font-semibold uppercase tracking-widest text-indigo-700">Our mission</span>
      <h2 class="mt-6 text-3xl font-bold text-slate-900">Technology should serve the sacred, not complicate it.</h2>
      <p class="mt-6 text-lg leading-relaxed text-slate-600">
        WorshipMetrics exists to help churches make streaming easier, share the Sunday workload, and create more meaningful places for people to serve. We think a healthy church should be able to bring new volunteers in, train them well, and trust them with real responsibility.
      </p>
    </div>

    <div class="mx-auto mt-14 grid max-w-5xl gap-6 sm:grid-cols-3">
      {missionCards.map(({ title, body }) => (
        <div class="rounded-2xl border border-indigo-100 bg-white p-7 shadow-sm">
          <h3 class="font-semibold text-slate-900">{title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">{body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl rounded-[2rem] border border-slate-200 bg-slate-50 p-8 text-center shadow-sm sm:p-10">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Talk with the team</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Call 910-WORSHIP and talk to a real person who knows the product.</h2>
      <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
        Not a call center. Not a ticket queue with a three-day turnaround. Paul or Noah picks up the phone, and they both know how the platform works because they built it with churches like yours.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row sm:flex-wrap">
        <a href="tel:+19109677447" class="btn-primary">Call 910-WORSHIP</a>
        <a href="/discovery-call" class="btn-outline">Book a discovery call</a>
        <a href="mailto:paul@worshipmetrics.com" class="btn-outline">Email Paul</a>
      </div>
    </div>
  </section>
</Layout>
