---
import Layout from "../layouts/Layout.astro";

const PAUL_HEADSHOT = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main/paul.jpg";
---

<Layout
  title="About"
  description="Meet the founders behind WorshipMetrics — Rev. Andrew Esqueda and Paul Richards — and the mission to equip churches with tools that put ministry first."
  canonical="/about"
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-indigo-50 via-white to-slate-50 px-4 py-24 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <span class="inline-block rounded-full bg-indigo-100 px-4 py-1 text-xs font-semibold uppercase tracking-widest text-indigo-700">
        About WorshipMetrics
      </span>
      <h1 class="mt-6 text-4xl font-extrabold leading-tight tracking-tight text-slate-900 sm:text-5xl">
        Where faith meets innovation.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-600">
        A platform born from ministry needs, built to help church leaders care for their congregation
        with greater clarity.
      </p>
    </div>
    <div class="pointer-events-none absolute -top-32 -right-32 h-96 w-96 rounded-full bg-indigo-200 opacity-20 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-20 -left-20 h-72 w-72 rounded-full bg-violet-300 opacity-20 blur-3xl"></div>
  </section>

  <!-- Origin story -->
  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-3xl font-bold text-slate-900">It started with a pastor's question.</h2>
      <p class="mt-6 text-lg text-slate-600 leading-relaxed">
        Rev. Andrew Esqueda had tried every available tool to track attendance at First Presbyterian
        Church of West Chester. Nothing fit. So he brought the problem to his community. With cameras
        already installed for livestreaming, an idea formed: use those same tools to track attendance
        accurately, without adding work to an already full Sunday. Week after week, the system
        improved. What started as a local experiment became WorshipMetrics.
      </p>
    </div>
  </section>

  <!-- Founders -->
  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-center text-3xl font-bold text-slate-900">The people behind WorshipMetrics</h2>
      <div class="mt-14 grid gap-8 sm:grid-cols-2">
        <!-- Andrew -->
        <div class="rounded-2xl border border-slate-100 bg-white p-8 shadow-sm">
          <img
            src="/legacy-images/rev-andrew-esqueda.jpeg"
            alt="Rev. Andrew Esqueda"
            loading="lazy"
            decoding="async"
            class="mb-6 aspect-[4/3] w-full rounded-2xl object-cover"
          />
          <h3 class="text-xl font-semibold text-slate-900">Rev. Andrew Esqueda</h3>
          <p class="mt-1 text-sm font-medium text-indigo-600">Co-Founder & Visionary</p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            Andrew's background in theology and worship leadership gives WorshipMetrics its soul.
            This was never about numbers — it was about equipping pastors to better understand and
            serve the people in their care. Today, Andrew personally guides churches through
            onboarding, translating data into practical ministry insight. He is the reason
            WorshipMetrics exists.
          </p>
          <a
            href="https://www.linkedin.com/in/rev-andrew-esqueda/"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-5 inline-block text-sm font-semibold text-indigo-600 hover:text-indigo-800"
          >
            LinkedIn →
          </a>
        </div>

        <!-- Paul -->
        <div class="rounded-2xl border border-slate-100 bg-white p-8 shadow-sm">
          <img
            src={PAUL_HEADSHOT}
            alt="Paul Richards"
            loading="lazy"
            decoding="async"
            class="mb-6 aspect-[4/3] w-full rounded-2xl object-cover"
          />
          <h3 class="text-xl font-semibold text-slate-900">Paul Richards</h3>
          <p class="mt-1 text-sm font-medium text-indigo-600">Co-Founder & Technology Lead</p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            Paul spent years as Co-CEO of PTZOptics, shaping the frontier of camera technology and
            computer vision. He found himself asking: what if this technology could do something that
            truly mattered? That question led him to Andrew — and to a career transition he describes
            as the most meaningful of his life.
          </p>
          <a
            href="https://www.linkedin.com/in/paulrichards87/"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-5 inline-block text-sm font-semibold text-indigo-600 hover:text-indigo-800"
          >
            LinkedIn →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="bg-indigo-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <span class="inline-block rounded-full bg-indigo-100 px-4 py-1 text-xs font-semibold uppercase tracking-widest text-indigo-700">
        Our mission
      </span>
      <h2 class="mt-6 text-3xl font-bold text-slate-900">
        Technology should serve the sacred, not complicate it.
      </h2>
      <p class="mt-6 text-lg text-slate-600 leading-relaxed">
        WorshipMetrics exists to give worship leaders the clarity they need to lead with confidence.
        We believe that when faith communities understand themselves better, they can serve their
        people more fully. Meaningful data, in the right hands, is an act of care.
      </p>
    </div>

    <!-- Belief cards -->
    <div class="mx-auto mt-14 max-w-5xl grid gap-6 sm:grid-cols-3">
      {[
        {
          title: "Ministry comes first",
          body: "Every feature asks the same question Andrew asked at the start: does this actually help a pastor lead better?",
        },
        {
          title: "Technology should bring people together",
          body: "Whether someone finds your church through a Sunday service or a YouTube livestream, they deserve a warm welcome and a clear path in.",
        },
        {
          title: "Every church deserves great tools",
          body: "Powerful and easy-to-use tools should not require a large staff or budget.",
        },
      ].map(({ title, body }) => (
        <div class="rounded-2xl border border-indigo-100 bg-white p-7 shadow-sm">
          <h3 class="font-semibold text-slate-900">{title}</h3>
          <p class="mt-3 text-sm text-slate-600 leading-relaxed">{body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Contact / CTA -->
  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-slate-900">Have questions? Talk directly with Paul.</h2>
      <p class="mt-4 text-slate-600">
        <a href="mailto:paul@worshipmetrics.com" class="text-indigo-600 hover:text-indigo-800">paul@worshipmetrics.com</a>
        {" · "}
        <a href="tel:9109677447" class="text-indigo-600 hover:text-indigo-800">910-967-7447</a>
      </p>
      <div class="mt-8">
        <a
          href="/discovery-call"
          class="inline-block rounded-xl bg-indigo-600 px-8 py-3.5 text-base font-semibold text-white shadow-md transition hover:bg-indigo-700"
        >
          Book a free discovery call
        </a>
      </div>
    </div>
  </section>
</Layout>
