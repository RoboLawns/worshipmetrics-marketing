---
import Layout from "../../layouts/Layout.astro";

const R2 = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
const SITE_URL = "https://worshipmetrics.com";
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "WorshipMetrics People and Follow-Up",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web, iOS, Android",
    url: `${SITE_URL}/platform/people`,
    image: `${SITE_URL}/legacy-images/welcome-capture-wide.jpg`,
    description: "Capture church guests, scan welcome cards, route prayer requests, and organize visitor follow-up in one connected workflow.",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
      availability: "https://schema.org/InStock",
      url: `${SITE_URL}/pricing`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: SITE_URL },
      { "@type": "ListItem", position: 2, name: "Platform", item: `${SITE_URL}/platform` },
      { "@type": "ListItem", position: 3, name: "People", item: `${SITE_URL}/platform/people` },
    ],
  },
];
---

<Layout
  title="Church Visitor Follow-Up and Guest Capture"
  description="Capture church guests, scan welcome cards, route prayer requests, and organize visitor follow-up in one connected people workflow."
  canonical="/platform/people"
  ogImage="/legacy-images/welcome-capture-wide.jpg"
  structuredData={structuredData}
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-indigo-50 to-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">
        Turn guest responses into people your church can care for well.
      </h1>
      <p class="mt-4 text-lg text-slate-600">
        Welcome capture, visitor records, prayer routing, and member insight — from first contact to faithful follow-up.
      </p>
    </div>

    <!-- Why-use-it cards -->
    <div class="mx-auto mt-12 grid max-w-5xl gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {[
        {
          heading: "Capture people however they respond",
          body: "Paper cards, QR codes, website widgets, and livestream handoff all work.",
        },
        {
          heading: "Turn anonymous interest into known people",
          body: "As soon as someone shares their info, a visitor or member record is created.",
        },
        {
          heading: "Keep prayer and follow-up connected",
          body: "Requests, notes, and next steps stay together — not scattered across inboxes.",
        },
        {
          heading: "See the whole relationship over time",
          body: "From guest capture to member context so staff understands patterns, not just isolated moments.",
        },
      ].map(({ heading, body }) => (
        <div class="rounded-2xl border border-slate-100 bg-white p-6 shadow-sm">
          <h3 class="font-semibold text-slate-900">{heading}</h3>
          <p class="mt-2 text-sm text-slate-500 leading-relaxed">{body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Visual workflow -->
  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto mb-10 max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">People workflow</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
          From first response to faithful follow-up.
        </h2>
      </div>
      <div class="grid gap-6 lg:grid-cols-3">
        {[
          {
            title: "Scan paper welcome cards",
            body: "Bring handwritten guest info into WorshipMetrics in seconds instead of after-hours data entry.",
            src: `${R2}/tablet/Auto-Scan%20Welcome%20Cards.jpg`,
            alt: "Auto scanning welcome cards in WorshipMetrics",
          },
          {
            title: "Capture QR responses instantly",
            body: "Phone-first guests can respond in the moment and create a people record immediately.",
            src: `${R2}/tablet/QR%20Code%20Scanning.jpg`,
            alt: "QR code scanning workflow in WorshipMetrics",
          },
          {
            title: "See the pastoral picture sooner",
            body: "Attendance signals, prayer needs, and guest history come together in one care workflow.",
            src: `${R2}/tablet/Pastoral%20Care%202.jpg`,
            alt: "Pastoral care dashboard in WorshipMetrics",
          },
        ].map(({ title, body, src, alt }) => (
          <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
            <img src={src} alt={alt} loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
            <div class="p-6">
              <h3 class="text-lg font-semibold text-slate-900">{title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">{body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Capture paths -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <h2 class="mb-10 text-2xl font-bold text-slate-900 sm:text-3xl">
        Meet people where they actually respond.
      </h2>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          {
            num: "01",
            heading: "Paper welcome cards",
            body: "Scan after service. Computer vision pulls names and contact details automatically.",
            icon: "M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z",
          },
          {
            num: "02",
            heading: "QR code check-in",
            body: "Phone-first guests scan and respond digitally. The people record is created immediately.",
            icon: "M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 013.75 9.375v-4.5zM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5zM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0113.5 9.375v-4.5z M6.75 6.75h.75v.75h-.75v-.75z M6.75 17.25h.75v.75h-.75v-.75z M17.25 6.75h.75v.75h-.75v-.75z M13.5 13.5h.75v.75h-.75v-.75z M13.5 19.5h.75v.75h-.75v-.75z M19.5 13.5h.75v.75h-.75v-.75z M19.5 19.5h.75v.75h-.75v-.75z",
          },
          {
            num: "03",
            heading: "Website and livestream",
            body: "Outreach widgets, chat handoff, and prayer request forms create visitor records from online interactions.",
            icon: "M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418",
          },
        ].map(({ num, heading, body, icon }) => (
          <div class="relative flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <span class="mb-4 text-4xl font-extrabold text-indigo-100 leading-none">{num}</span>
            <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-lg bg-indigo-50 text-indigo-600">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
              </svg>
            </div>
            <h3 class="font-semibold text-slate-900">{heading}</h3>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Follow-up section -->
  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <h2 class="mb-10 text-2xl font-bold text-slate-900 sm:text-3xl">
        Follow-up that starts with real context, not guesswork.
      </h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {[
          {
            heading: "Visitor context for your team",
            body: "If a volunteer marks a new guest during counting, follow-up starts with a name and story — not a blank form.",
          },
          {
            heading: "Prayer request routing",
            body: "Receive, triage, and route requests so every concern lands with the right person at the right time.",
          },
          {
            heading: "One clear pastoral queue",
            body: "Digital interactions, attendance signals, and visitor records in one place for Monday morning.",
          },
        ].map(({ heading, body }) => (
          <div class="flex gap-4 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="mt-0.5 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-indigo-100 text-indigo-600">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-slate-900">{heading}</h3>
              <p class="mt-1 text-sm text-slate-600 leading-relaxed">{body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Related pages -->
  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-6 md:grid-cols-3">
        {[
          {
            href: "/platform/attendance",
            title: "Attendance tracking",
            body: "Connect guests and absences to the weekly attendance picture your leaders already review.",
          },
          {
            href: "/solutions/digital-engagement",
            title: "Digital engagement",
            body: "Carry visitor follow-up from the lobby to your livestream, prayer requests, and website outreach.",
          },
          {
            href: "/pricing",
            title: "See plan options",
            body: "Compare plans for church guest capture, follow-up, and member-care workflows.",
          },
        ].map(({ href, title, body }) => (
          <a href={href} class="rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-sm transition hover:border-indigo-300 hover:bg-white">
            <h3 class="text-lg font-semibold text-slate-900">{title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{body}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-indigo-600">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">Related people guides</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {[
          { href: "/church-visitor-follow-up-software", title: "Church visitor follow-up software", body: "See the software-focused guide for guest capture and follow-up workflows." },
          { href: "/church-guest-follow-up-system", title: "Church guest follow-up system", body: "See the system-focused guide for building a repeatable guest response process." },
          { href: "/solutions/digital-engagement", title: "Digital engagement", body: "Connect online responses and digital attention to the same people workflow." },
        ].map(({ href, title, body }) => (
          <a href={href} class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:bg-indigo-50/20"><h3 class="text-lg font-semibold text-slate-900">{title}</h3><p class="mt-2 text-sm leading-relaxed text-slate-600">{body}</p><span class="mt-4 inline-block text-sm font-semibold text-indigo-600">Read guide →</span></a>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-indigo-600 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-white">Build a follow-up system your team can actually sustain.</h2>
      <p class="mt-4 text-indigo-200">
        We'll map your current guest capture and follow-up workflow and show you where things can connect.
      </p>
      <a
        href="/discovery-call"
        class="mt-8 inline-block rounded-xl bg-white px-8 py-3 text-base font-semibold text-indigo-700 shadow transition hover:bg-indigo-50"
      >
        Book a discovery call
      </a>
    </div>
  </section>
</Layout>
