  <script>
    (() => {
      const sections = [
        {
          id: "left",
          name: "Left section",
          shortName: "Left",
          rows: 5,
          cols: 8,
          counts: [5, 6, 6, 5, 5],
          copy: "Greeters can tap through this section in seconds and move on, because the layout is already familiar.",
        },
        {
          id: "center",
          name: "Center section",
          shortName: "Center",
          rows: 8,
          cols: 10,
          counts: [5, 6, 7, 8, 8, 7, 6, 6],
          copy: "The largest section still feels manageable when volunteers start with a saved template instead of a blank room.",
        },
        {
          id: "right",
          name: "Right section",
          shortName: "Right",
          rows: 5,
          cols: 8,
          counts: [5, 6, 6, 5, 5],
          copy: "A second volunteer can confirm this side independently while the total updates across the whole sanctuary.",
        },
      ];

      const createBaseline = (section) => {
        const baseline = [];

        for (let row = 0; row < section.rows; row += 1) {
          const occupiedInRow = section.counts[row];
          const start = Math.floor((section.cols - occupiedInRow) / 2);

          for (let col = 0; col < section.cols; col += 1) {
            baseline.push(col >= start && col < start + occupiedInRow);
          }
        }

        return baseline;
      };

      const sectionState = sections.reduce((acc, section) => {
        const baseline = createBaseline(section);
        acc[section.id] = {
          baseline,
          current: [...baseline],
        };
        return acc;
      }, {});

      let activeSectionId = "left";

      const totalCountEl = document.getElementById("seat-demo-total-count");
      const totalPercentEl = document.getElementById("seat-demo-total-percent");
      const activeTitleEl = document.getElementById("seat-demo-active-title");
      const activeCopyEl = document.getElementById("seat-demo-active-copy");
      const activeCountEl = document.getElementById("seat-demo-active-count");
      const deltaEl = document.getElementById("seat-demo-delta");
      const gridEl = document.getElementById("seat-demo-grid");
      const resetButton = document.getElementById("seat-demo-reset");
      const sectionButtons = Array.from(document.querySelectorAll("[data-seat-demo-section]"));

      if (!totalCountEl || !totalPercentEl || !activeTitleEl || !activeCopyEl || !activeCountEl || !deltaEl || !gridEl || !resetButton || sectionButtons.length === 0) {
        return;
      }

      const countFilled = (list) => list.filter(Boolean).length;

      const getSection = (id) => sections.find((section) => section.id === id);

      const updateSummary = () => {
        const totals = sections.reduce(
          (acc, section) => {
            acc.capacity += section.rows * section.cols;
            acc.filled += countFilled(sectionState[section.id].current);
            acc.changed += sectionState[section.id].current.reduce((sum, occupied, index) => {
              return sum + Number(occupied !== sectionState[section.id].baseline[index]);
            }, 0);
            return acc;
          },
          { filled: 0, capacity: 0, changed: 0 }
        );

        const percent = Math.round((totals.filled / totals.capacity) * 100);
        totalCountEl.textContent = String(totals.filled);
        totalPercentEl.textContent = `${percent}% of your saved layout`;

        sections.forEach((section) => {
          const filled = countFilled(sectionState[section.id].current);
          const capacity = section.rows * section.cols;
          const sectionPercent = (filled / capacity) * 100;
          const countEl = document.querySelector(`[data-seat-demo-count="${section.id}"]`);
          const barEl = document.querySelector(`[data-seat-demo-bar="${section.id}"]`);

          if (countEl) countEl.textContent = `${filled}/${capacity}`;
          if (barEl) barEl.style.width = `${sectionPercent}%`;
        });

        if (totals.changed === 0) {
          deltaEl.textContent = "No changes from the saved baseline yet. Tap seats to simulate what a volunteer sees on Sunday.";
        } else if (totals.changed === 1) {
          deltaEl.textContent = "1 seat has changed from the saved baseline. Volunteers confirm what is different instead of recounting the whole room.";
        } else {
          deltaEl.textContent = `${totals.changed} seats have changed from the saved baseline. That is the whole point of templates: confirm exceptions, not every seat.`;
        }
      };

      const renderActiveSection = () => {
        const section = getSection(activeSectionId);
        if (!section) return;

        const state = sectionState[section.id];
        const capacity = section.rows * section.cols;
        const filled = countFilled(state.current);

        activeTitleEl.textContent = section.name;
        activeCopyEl.textContent = section.copy;
        activeCountEl.textContent = `${filled}/${capacity}`;
        gridEl.innerHTML = "";
        gridEl.style.gridTemplateColumns = `repeat(${section.cols}, minmax(0, 1fr))`;

        const aisleAfter = Math.floor(section.cols / 2) - 1;

        state.current.forEach((occupied, index) => {
          const seat = document.createElement("button");
          const changed = occupied !== state.baseline[index];
          const row = Math.floor(index / section.cols);
          const col = index % section.cols;

          seat.type = "button";
          seat.className = "seat-demo-seat";
          seat.setAttribute("aria-pressed", occupied ? "true" : "false");
          seat.setAttribute("aria-label", `${section.shortName} row ${row + 1}, seat ${col + 1}`);

          if (occupied) seat.classList.add("is-occupied");
          if (changed) seat.classList.add("is-changed");
          if (col === aisleAfter) seat.style.marginRight = "0.9rem";

          seat.addEventListener("click", () => {
            state.current[index] = !state.current[index];
            renderActiveSection();
            updateSummary();
          });

          gridEl.appendChild(seat);
        });

        sectionButtons.forEach((button) => {
          button.classList.toggle("is-active", button.getAttribute("data-seat-demo-section") === section.id);
        });
      };

      sectionButtons.forEach((button) => {
        button.addEventListener("click", () => {
          activeSectionId = button.getAttribute("data-seat-demo-section") || activeSectionId;
          renderActiveSection();
          updateSummary();
        });
      });

      resetButton.addEventListener("click", () => {
        sections.forEach((section) => {
          sectionState[section.id].current = [...sectionState[section.id].baseline];
        });
        renderActiveSection();
        updateSummary();
      });

      renderActiveSection();
      updateSummary();
    })();
  </script>
