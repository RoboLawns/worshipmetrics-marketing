---
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.worshipmetrics.com";
const SITE_URL = "https://worshipmetrics.com";
const OG_IMAGE = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main/homepage/new%20images/Church%20Digital%20Signage.jpg";

const faqItems = [
  {
    question: "Is WorshipMetrics digital signage really free?",
    answer: "Yes. WorshipMetrics includes a free church digital signage option so churches can start managing screens without monthly signage fees.",
  },
  {
    question: "What kinds of church screens can it be used for?",
    answer: "Churches can use WorshipMetrics for lobby displays, welcome screens, announcement slides, countdown screens, and other in-building communication use cases.",
  },
  {
    question: "Do we need special signage hardware to start?",
    answer: "No. Many churches can start with their existing displays and workflow, then expand into more connected hardware options later if they want.",
  },
  {
    question: "Why offer church digital signage for free?",
    answer: "Because it solves a common weekly problem for churches and creates a simple entry point into the broader WorshipMetrics platform.",
  },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "Free Church Digital Signage by WorshipMetrics",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: `${SITE_URL}/free-church-digital-signage`,
    image: OG_IMAGE,
    description: "Free church digital signage with no monthly signage fee. Manage welcome screens, lobby displays, and church announcements from one system.",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
      availability: "https://schema.org/InStock",
      url: `${APP_URL}/sign-up`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map(({ question, answer }) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: {
        "@type": "Answer",
        text: answer,
      },
    })),
  },
];
---

<Layout
  title="Free Church Digital Signage"
  description="Free church digital signage with no monthly signage fee. Manage welcome screens, lobby displays, and church announcements from one system."
  canonical="/free-church-digital-signage"
  ogImage={OG_IMAGE}
  structuredData={structuredData}
>
  <section class="bg-gradient-to-b from-indigo-50 to-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Free church digital signage</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
        Manage church screens with Free Forever signage.
      </h1>
      <p class="mx-auto mt-6 max-w-3xl text-lg text-slate-600 sm:text-xl">
        No monthly signage fees. No bloated enterprise setup. Just a practical way to manage welcome screens, announcement slides, and lobby displays from one connected system.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={`${APP_URL}/sign-up`} class="rounded-xl bg-indigo-600 px-8 py-3 text-base font-semibold text-white shadow transition hover:bg-indigo-700">
          Get started free
        </a>
        <a href="/discovery-call" class="rounded-xl border border-slate-300 px-8 py-3 text-base font-semibold text-slate-700 transition hover:border-indigo-400 hover:text-indigo-600">
          Book a discovery call
        </a>
      </div>
      <p class="mt-4 text-sm text-slate-500">No monthly fees. Use it as a free entry point into the WorshipMetrics platform.</p>
    </div>
  </section>

  <section class="bg-white px-4 pb-8 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)]">
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src={OG_IMAGE} alt="Free church digital signage in WorshipMetrics" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src="https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main/homepage/Team%20Collaboration%20hero.jpg" alt="Church team managing signage workflows" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Why churches respond to free digital signage</h2>
        <p class="mt-4 text-base text-slate-600 sm:text-lg">Because keeping screens current every week is a real problem, and most churches do not want another subscription just to solve it.</p>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {[
          {
            title: "No monthly signage fee",
            body: "That matters for churches trying to improve communication without adding another recurring software bill.",
          },
          {
            title: "Update screens remotely",
            body: "Push changes without running back to the booth or relying on one office computer in the building.",
          },
          {
            title: "Keep announcements fresh",
            body: "Welcome slides, event reminders, and lobby content work better when your team can actually maintain them.",
          },
          {
            title: "Grow into the platform later",
            body: "Free signage can be the first step into a larger system for operations, attendance, and communication.",
          },
        ].map(({ title, body }) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900">{title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl grid gap-6 lg:grid-cols-3">
      {[
        {
          eyebrow: "For churches with lobby screens",
          title: "Keep the front door current.",
          body: "Welcome screens and announcement displays should reflect what is happening this week, not what someone forgot to change last month.",
        },
        {
          eyebrow: "For small teams",
          title: "Make signage manageable.",
          body: "Church communication breaks down when signage depends on one overworked staff member. A simpler workflow removes that bottleneck.",
        },
        {
          eyebrow: "For long-term growth",
          title: "Use free signage as the entry point.",
          body: "Digital signage can be the easiest first win before moving into attendance tracking, team workflows, and connected hardware later.",
        },
      ].map(({ eyebrow, title, body }) => (
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">{eyebrow}</p>
          <h2 class="mt-3 text-2xl font-bold text-slate-900">{title}</h2>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">{body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Best next step for your church</h2>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {[
          {
            href: `${APP_URL}/sign-up`,
            title: "Start free",
            body: "Best if you want to get your church signage workflow moving without a sales process.",
            cta: "Create free account →",
          },
          {
            href: "/church-digital-signage-software",
            title: "See the full guide",
            body: "Best if you want to understand how free signage fits into a broader church operations system.",
            cta: "Read signage guide →",
          },
          {
            href: "/discovery-call",
            title: "Talk with us",
            body: "Best if you want help deciding whether free signage is enough or if your church should use a broader setup.",
            cta: "Book discovery call →",
          },
        ].map(({ href, title, body, cta }) => (
          <a href={href} class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:bg-indigo-50/20">
            <h3 class="text-lg font-semibold text-slate-900">{title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{body}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-indigo-600">{cta}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">FAQ</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Questions about the free church digital signage offer</h2>
      </div>
      <div class="mt-8 space-y-4">
        {faqItems.map(({ question, answer }) => (
          <details class="rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-sm">
            <summary class="cursor-pointer list-none text-lg font-semibold text-slate-900">{question}</summary>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-indigo-600 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-white">Start using church signage without paying monthly software fees.</h2>
      <p class="mt-4 text-indigo-200">Get the free signage workflow running first, then expand into the rest of WorshipMetrics when your church is ready.</p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={`${APP_URL}/sign-up`} class="rounded-xl bg-white px-8 py-3 text-base font-semibold text-indigo-700 shadow transition hover:bg-indigo-50">Start free</a>
        <a href="/discovery-call" class="text-sm font-semibold text-indigo-200 underline underline-offset-2 transition hover:text-white">Book a discovery call</a>
      </div>
    </div>
  </section>
</Layout>
