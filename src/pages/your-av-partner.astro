---
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.worshipmetrics.com";
const SITE_URL = "https://worshipmetrics.com";
const R2 = "https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main";
const R2NEW = `${R2}/homepage/new%20images`;
const OG_IMAGE = `${R2NEW}/Stream%20Health.jpg`;

const workModes = [
  {
    title: "Local installation",
    subtitle: "For churches within 50 miles",
    body: "We come to you. We assess your space, design your system, install your cameras, configure your production software, set up the Worship Metrics Hub, and train your team. You go live with a complete, cloud-connected production environment — not just equipment.",
    href: "/discovery-call",
    cta: "Book a free site assessment",
  },
  {
    title: "Remote onboarding",
    subtitle: "For churches everywhere",
    body: "Already have cameras and a production setup? We onboard you onto the Worship Metrics platform remotely — configuring your AV monitoring, connecting your PTZ cameras, integrating OBS or vMix, and training your team via video call. Your system gets smarter without anyone stepping foot in your building.",
    href: "/discovery-call",
    cta: "Start remote onboarding",
  },
];

const installAreas = [
  {
    title: "Cameras",
    body: "PTZ cameras positioned and configured for your worship space — pulpit, congregation wide shot, worship band, choir. Every camera connected to the Worship Metrics Hub for remote control from anywhere in the world.",
  },
  {
    title: "Production",
    body: "Switcher setup, OBS or vMix configuration, scene presets built around your service order. Your AV volunteer walks in Sunday and everything is ready — not starting from scratch.",
  },
  {
    title: "Displays & Signage",
    body: "Lobby screens, overflow displays, nursery feeds. All connected to the Worship Metrics cloud so your team updates every screen from their phone.",
  },
  {
    title: "The Hub",
    body: "The Worship Metrics Hub is installed in your AV closet and connected to everything. From that moment forward your stream is monitored, your attendance is automatic, your cameras are remotely controllable, and your production is cloud-managed.",
  },
  {
    title: "Training",
    body: "We don't hand off and disappear. We train your AV volunteers, your communications team, and your pastoral staff on exactly how to use what we've built — and we're available when questions come up.",
  },
];

const afterInstall = [
  "Stream health monitored 24/7 — your team gets alerted before your congregation notices a problem",
  "Automatic attendance captured every week — no clipboards, no spreadsheets",
  "Remote PTZ camera control — reposition cameras from your phone, from anywhere",
  "Remote OBS and vMix control — a staff member can manage production without being in the building",
  "Digital signage updated from anywhere — push announcements mid-service from your phone",
  "Luminos AI — walk into Monday already knowing who needs follow-up and what changed this week",
  "Video automatically uploaded — sermon clips ready for social before the last car leaves the parking lot",
];

const remoteOnboarding = [
  "Worship Metrics Hub shipped to your door — plug in and connect",
  "Remote configuration session — we configure your Hub, connect your cameras, set up AV monitoring",
  "OBS or vMix integration — scene presets, stream configuration, remote control enabled",
  "Platform setup — attendance tracking, signage URLs, Luminos AI, Worship Clips",
  "Team training via video call — your volunteers know exactly what to do Sunday morning",
  "Ongoing support — we're available when things come up",
];

const projectSteps = [
  {
    title: "Week 1 — Discovery",
    body: "Free site assessment. We walk your space, understand your service style, review your current setup, and ask the questions most AV companies skip — how many volunteers do you have, what does your Sunday morning actually look like, what's broken right now that nobody talks about.",
  },
  {
    title: "Week 2–3 — Design & Proposal",
    body: "We design a system around your actual needs — not the most expensive option, not the cheapest. A proposal with clear line items, clear outcomes, and a clear timeline.",
  },
  {
    title: "Installation day",
    body: "Cameras mounted. Cables run. Switcher configured. Hub installed. OBS or vMix built out. Signage connected. Everything tested before we leave.",
  },
  {
    title: "Training day",
    body: "We come back — or stay — to train your team. Not a manual handoff. A real session with your actual volunteers running your actual service order.",
  },
  {
    title: "Ongoing",
    body: "You're on the Worship Metrics platform. We're monitoring. You're covered.",
  },
];

const investmentTiers = [
  {
    size: "Starter",
    included: "1–2 PTZ cameras, Hub, OBS setup, training",
    range: "$8,000–$15,000",
  },
  {
    size: "Mid-size",
    included: "3–4 cameras, switcher, displays, Hub, full training",
    range: "$20,000–$40,000",
  },
  {
    size: "Full production",
    included: "Complete camera system, production booth, overflow screens, Hub, multi-volunteer training",
    range: "$40,000–$80,000+",
  },
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "WorshipMetrics AV Partner Services",
  provider: {
    "@type": "Organization",
    name: "WorshipMetrics",
    url: SITE_URL,
  },
  serviceType: "Church AV installation, remote onboarding, and cloud-connected production support",
  areaServed: "United States",
  url: `${SITE_URL}/your-av-partner`,
  image: OG_IMAGE,
  description: "Church AV installation and remote onboarding backed by the WorshipMetrics platform for stream health monitoring, remote production control, attendance automation, and digital signage.",
};
---

<Layout
  title="Your AV Partner, Not Just Your AV Installer"
  description="Church AV installation and remote onboarding backed by the WorshipMetrics platform for stream health monitoring, remote production control, attendance automation, and digital signage."
  canonical="/your-av-partner"
  ogImage={OG_IMAGE}
  structuredData={structuredData}
>
  <section class="bg-slate-900 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-400">Church AV services</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        Your AV partner.<br />
        Not just your AV installer.
      </h1>
      <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-slate-300 sm:text-xl">
        Most AV companies hand you a remote and wish you luck. We hand you a remote, a cloud platform, and a team that's with you every Sunday — whether we installed your system or someone else did.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/discovery-call" class="rounded-xl bg-indigo-600 px-8 py-3 text-base font-semibold text-white shadow transition hover:bg-indigo-500">
          Book a free discovery call
        </a>
        <a href="/tech-manager" class="rounded-xl border border-indigo-400 px-8 py-3 text-base font-semibold text-white transition hover:border-white">
          See Tech Manager
        </a>
        <a href={APP_URL} class="rounded-xl border border-indigo-400 px-8 py-3 text-base font-semibold text-white transition hover:border-white">
          Start free on the platform
        </a>
      </div>
    </div>

    <div class="mx-auto mt-16 max-w-6xl grid gap-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)]">
      <div class="overflow-hidden rounded-3xl border border-white/10 bg-white/5 shadow-2xl">
        <img
          src={OG_IMAGE}
          alt="WorshipMetrics AV monitoring dashboard"
          loading="lazy"
          decoding="async"
          class="aspect-[16/10] w-full object-cover"
        />
      </div>
      <div class="grid gap-6">
        <div class="overflow-hidden rounded-3xl border border-white/10 bg-white/5 shadow-2xl">
          <img
            src={`${R2}/tablet/Worship%20Metrics%20Appliance%20Small.jpg`}
            alt="WorshipMetrics Hub hardware"
            loading="lazy"
            decoding="async"
            class="aspect-[16/10] w-full object-cover"
          />
        </div>
        <div class="overflow-hidden rounded-3xl border border-white/10 bg-white/5 shadow-2xl">
          <img
            src={`${R2NEW}/Church%20Digital%20Signage.jpg`}
            alt="Cloud-managed church digital signage"
            loading="lazy"
            decoding="async"
            class="aspect-[16/10] w-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">The difference</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        What makes us different isn't what we install.<br />
        It's what happens after.
      </h2>
    </div>
    <div class="mx-auto mt-10 max-w-4xl space-y-6 text-base leading-relaxed text-slate-600 sm:text-lg">
      <p>
        Every AV integrator can run cable, mount cameras, and configure a switcher. We do all of that. But when we leave your building, we don't actually leave.
      </p>
      <p>
        The Worship Metrics platform stays behind — monitoring your stream health, watching your audio levels, alerting your team when something goes wrong, and giving you remote control over your entire production from anywhere in the world. No other AV company offers that. Not one.
      </p>
      <p class="font-semibold text-slate-900">
        We're not an AV company that built software.
      </p>
      <p class="font-semibold text-slate-900">
        We're a church technology company that also does AV.
      </p>
      <p>
        That distinction matters every single Sunday.
      </p>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Two ways to work with us</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Local installation or remote onboarding.</h2>
      </div>
      <div class="mt-10 grid gap-8 lg:grid-cols-2">
        {workModes.map(({ title, subtitle, body, href, cta }) => (
          <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">{subtitle}</p>
            <h3 class="mt-3 text-2xl font-bold text-slate-900">{title}</h3>
            <p class="mt-4 text-sm leading-relaxed text-slate-600 sm:text-base">{body}</p>
            <a href={href} class="mt-8 inline-block rounded-xl bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow transition hover:bg-indigo-700">
              {cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="grid items-center gap-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
        <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
          <img
            src="https://pub-a4845709a76642e7943bcb8b80677531.r2.dev/main/homepage/1%20Worship%20Technology%20Assistance.jpg"
            alt="Church AV installation and production workflow"
            loading="lazy"
            decoding="async"
            class="aspect-[4/3] w-full object-cover"
          />
        </div>
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">What we install</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
            A complete production environment.<br />
            Not just hardware.
          </h2>
          <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
            Every local installation includes physical AV equipment AND full Worship Metrics platform configuration. You get both in a single engagement.
          </p>
        </div>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {installAreas.map(({ title, body }) => (
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900">{title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-900 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-4xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-300">What happens after install</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">
          This is where we're different from every other AV company.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-slate-300 sm:text-lg">
          After installation day your church has something no other AV integrator leaves behind.
        </p>
      </div>
      <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {afterInstall.map((item) => (
          <div class="rounded-2xl border border-white/10 bg-white/5 p-6 text-sm leading-relaxed text-slate-200 shadow-sm">
            {item}
          </div>
        ))}
      </div>
      <p class="mx-auto mt-8 max-w-4xl text-center text-base leading-relaxed text-slate-300 sm:text-lg">
        No other AV company in the country offers this. We're not doing an install and moving on. We're your ongoing technology partner — and the platform only gets more valuable over time.
      </p>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl grid gap-8 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)]">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Remote onboarding — for churches everywhere</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
          Already have AV equipment?<br />
          We'll make it smarter.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
          You don't need us to install your cameras to get everything the Worship Metrics platform offers. If you have PTZ cameras, a production computer, and a stream — we can connect it all remotely.
        </p>
        <div class="mt-8 rounded-2xl border border-indigo-200 bg-indigo-50 p-6">
          <a href="/discovery-call" class="inline-block rounded-xl bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow transition hover:bg-indigo-700">
            Start remote onboarding — from $499
          </a>
        </div>
      </div>
      <div class="space-y-3">
        {remoteOnboarding.map((item) => (
          <div class="flex items-start gap-3 rounded-xl border border-slate-200 bg-slate-50 p-4">
            <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <p class="text-sm leading-relaxed text-slate-700">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Typical local project</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">No two churches are the same. Here's the general shape of what we do.</h2>
      </div>
      <ol class="relative mt-12 ml-4 space-y-10 border-l border-indigo-200">
        {projectSteps.map(({ title, body }, index) => (
          <li class="pl-8">
            <span class="absolute -left-4 flex h-8 w-8 items-center justify-center rounded-full bg-indigo-600 text-sm font-bold text-white">
              {index + 1}
            </span>
            <h3 class="text-xl font-bold text-slate-900">{title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600 sm:text-base">{body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Investment</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Every project is scoped to your church's needs and budget.</h2>
        <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">Here's a general sense of what to expect.</p>
      </div>
      <div class="mt-10 overflow-hidden rounded-3xl border border-slate-200 shadow-sm">
        <table class="w-full text-sm">
          <thead class="bg-slate-50 text-left">
            <tr>
              <th class="px-6 py-4 font-semibold text-slate-700">Project size</th>
              <th class="px-6 py-4 font-semibold text-slate-700">What's included</th>
              <th class="px-6 py-4 font-semibold text-slate-700">Typical range</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 bg-white">
            {investmentTiers.map(({ size, included, range }) => (
              <tr>
                <td class="px-6 py-4 font-semibold text-slate-900">{size}</td>
                <td class="px-6 py-4 text-slate-600">{included}</td>
                <td class="px-6 py-4 font-medium text-indigo-600">{range}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="mt-6 space-y-2 text-sm text-slate-600">
        <p>All projects include Worship Metrics Pro plan for the first year.</p>
        <p>Remote onboarding starts at $499 plus platform subscription.</p>
        <p>We'll tell you honestly what you need — and what you don't.</p>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">For churches everywhere</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">You don't have to be local to get everything we offer.</h2>
      <p class="mt-6 text-base leading-relaxed text-slate-600 sm:text-lg">
        The Worship Metrics platform is available to any church anywhere. If you already have cameras and a production setup — or if you buy a Hub directly — we onboard you remotely and you get the full benefit of everything we've built.
      </p>
      <p class="mt-4 text-base leading-relaxed text-slate-600 sm:text-lg">
        Churches across the country are using Worship Metrics for automatic attendance, AV monitoring, remote camera control, and digital signage — without ever having us set foot in their building.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={APP_URL} class="rounded-xl bg-indigo-600 px-8 py-3 text-base font-semibold text-white shadow transition hover:bg-indigo-700">Start free</a>
        <a href="/appliance" class="rounded-xl border border-slate-300 px-8 py-3 text-base font-semibold text-slate-700 transition hover:border-indigo-400 hover:text-indigo-600">Buy the Hub</a>
        <a href="/discovery-call" class="rounded-xl border border-slate-300 px-8 py-3 text-base font-semibold text-slate-700 transition hover:border-indigo-400 hover:text-indigo-600">Book remote onboarding</a>
      </div>
    </div>
  </section>

  <section class="bg-indigo-600 px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Ready to find out what's possible?</h2>
      <p class="mt-4 text-lg text-indigo-100">
        Whether you're 10 miles away or 1,000 — start with a free conversation. We'll tell you honestly what would make the biggest difference for your church and exactly where to begin.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row sm:flex-wrap">
        <a href="/discovery-call" class="rounded-xl bg-white px-8 py-3 text-base font-semibold text-indigo-700 shadow transition hover:bg-indigo-50">Book a free discovery call</a>
        <a href="/pilot-program" class="text-sm font-semibold text-white underline underline-offset-4 transition hover:text-indigo-100">Not ready for a quote? Start with a 60-day pilot</a>
        <a href={APP_URL} class="rounded-xl border border-indigo-300 px-8 py-3 text-base font-semibold text-white transition hover:border-white">Start free on the platform</a>
      </div>
    </div>
  </section>
</Layout>
