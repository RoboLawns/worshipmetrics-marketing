---
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.worshipmetrics.com";
const SITE_URL = "https://worshipmetrics.com";
const OG_IMAGE = `${SITE_URL}/legacy-images/seat-counting-hero.jpg`;

const faqItems = [
  {
    question: "Is WorshipMetrics really free for church attendance tracking?",
    answer: "Yes. WorshipMetrics offers a free plan that lets churches start tracking attendance without a credit card, time limit, or required hardware purchase.",
  },
  {
    question: "What can a church do on the free plan?",
    answer: "Churches can start tracking attendance, keep historical data, use basic reporting, and begin building a healthier weekly attendance workflow before upgrading.",
  },
  {
    question: "Do we need hardware to use the free attendance software?",
    answer: "No. Churches can start with phones, tablets, or existing devices. Dedicated hardware is optional if you want more advanced or staffed workflows later.",
  },
  {
    question: "Can we upgrade later if the church grows?",
    answer: "Yes. Churches can start free, then move into paid plans, tablet workflows, or automation options when they are ready.",
  },
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "Free Church Attendance Software by WorshipMetrics",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web, iOS, Android",
    url: `${SITE_URL}/free-church-attendance-software`,
    image: OG_IMAGE,
    description: "Free church attendance software with no credit card required. Track attendance, review trends, and grow into more advanced workflows later.",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
      availability: "https://schema.org/InStock",
      url: `${APP_URL}/sign-up`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map(({ question, answer }) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: {
        "@type": "Answer",
        text: answer,
      },
    })),
  },
];
---

<Layout
  title="Free Church Attendance Software"
  description="Free church attendance software with no credit card required. Track attendance, review trends, and grow into more advanced workflows later."
  canonical="/free-church-attendance-software"
  ogImage={OG_IMAGE}
  structuredData={structuredData}
>
  <section class="bg-gradient-to-b from-indigo-50 to-white px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">Free church attendance software</p>
      <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
        Start tracking church attendance for free.
      </h1>
      <p class="mx-auto mt-6 max-w-3xl text-lg text-slate-600 sm:text-xl">
        No credit card. No hardware required. No awkward trial countdown. Just a clean way to start tracking church attendance and building a healthier weekly reporting rhythm.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={`${APP_URL}/sign-up`} class="rounded-xl bg-indigo-600 px-8 py-3 text-base font-semibold text-white shadow transition hover:bg-indigo-700">
          Start free now
        </a>
        <a href="/discovery-call" class="rounded-xl border border-slate-300 px-8 py-3 text-base font-semibold text-slate-700 transition hover:border-indigo-400 hover:text-indigo-600">
          Book a free onboarding call
        </a>
      </div>
      <p class="mt-4 text-sm text-slate-500">Free forever. Upgrade only if and when your church needs more.</p>
    </div>
  </section>

  <section class="bg-white px-4 pb-8 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)]">
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src={OG_IMAGE} alt="Free church attendance software in WorshipMetrics" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
      <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
        <img src="/legacy-images/attendance-tracking-dashboard.jpg" alt="Attendance dashboard for churches" loading="lazy" decoding="async" class="aspect-[16/10] w-full object-cover" />
      </div>
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">What you get for free</h2>
        <p class="mt-4 text-base text-slate-600 sm:text-lg">Enough to start cleanly, prove value fast, and grow into a better workflow without switching systems later.</p>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {[
          {
            title: "Attendance tracking",
            body: "Start logging church attendance right away instead of waiting to buy hardware or commit to a paid tool.",
          },
          {
            title: "Unlimited users",
            body: "Get pastors, admins, and volunteers into the same system without per-seat pricing pressure.",
          },
          {
            title: "Historical data",
            body: "Keep your records over time so your church can compare patterns and not just this week’s count.",
          },
          {
            title: "Basic reporting",
            body: "Give leadership a more reliable weekly attendance picture without building spreadsheets by hand.",
          },
        ].map(({ title, body }) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-slate-900">{title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl grid gap-6 lg:grid-cols-3">
      {[
        {
          eyebrow: "Why free works",
          title: "Get out of attendance spreadsheet mode.",
          body: "The biggest win for most churches is not automation on day one. It is moving from inconsistent manual tracking into one trusted system.",
        },
        {
          eyebrow: "For smaller churches",
          title: "Start simple without feeling small.",
          body: "You do not need enterprise software to take attendance seriously. You need something simple enough to use every week and strong enough to grow with you.",
        },
        {
          eyebrow: "Upgrade path",
          title: "Grow into tablets, people workflows, and automation later.",
          body: "WorshipMetrics is designed so free users can mature into check-in tablets, guest follow-up, and advanced reporting without replacing the system later.",
        },
      ].map(({ eyebrow, title, body }) => (
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-8">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">{eyebrow}</p>
          <h2 class="mt-3 text-2xl font-bold text-slate-900">{title}</h2>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">{body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-slate-50 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Best next step for your church</h2>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {[
          {
            href: `${APP_URL}/sign-up`,
            title: "Start free",
            body: "Best if you want to start tracking attendance today with no sales process.",
            cta: "Create free account →",
          },
          {
            href: "/platform/attendance",
            title: "See the workflow",
            body: "Best if you want to understand seat templates, online attendance, and what the full system can do.",
            cta: "See attendance page →",
          },
          {
            href: "/discovery-call",
            title: "Talk it through",
            body: "Best if you want help deciding whether free is enough or if your church should start with a bigger setup.",
            cta: "Book discovery call →",
          },
        ].map(({ href, title, body, cta }) => (
          <a href={href} class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:bg-indigo-50/20">
            <h3 class="text-lg font-semibold text-slate-900">{title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{body}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-indigo-600">{cta}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-indigo-600">FAQ</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Questions about the free church attendance software</h2>
      </div>
      <div class="mt-8 space-y-4">
        {faqItems.map(({ question, answer }) => (
          <details class="rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-sm">
            <summary class="cursor-pointer list-none text-lg font-semibold text-slate-900">{question}</summary>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-indigo-600 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-white">Start free and see if WorshipMetrics fits your church.</h2>
      <p class="mt-4 text-indigo-200">You can be tracking attendance today, then decide later whether you want more advanced workflows.</p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={`${APP_URL}/sign-up`} class="rounded-xl bg-white px-8 py-3 text-base font-semibold text-indigo-700 shadow transition hover:bg-indigo-50">Start free</a>
        <a href="/discovery-call" class="text-sm font-semibold text-indigo-200 underline underline-offset-2 transition hover:text-white">Book a free onboarding call</a>
      </div>
    </div>
  </section>
</Layout>
