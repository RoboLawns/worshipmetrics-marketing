---
import { homepageCategoryCounts, homepageIntegrationTiles } from "../../data/integrations";
---

<style>
  .band-wrap {
    background: var(--color-bg-page);
    color: var(--color-text-primary);
  }
  .band-shell {
    max-width: 80rem;
    margin: 0 auto;
    padding: 5rem 1rem;
  }
  .band-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: end;
  }
  .band-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent-gold);
  }
  .band-title {
    margin-top: 0.75rem;
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 4vw, 3.8rem);
    font-weight: 400;
    line-height: 0.96;
    color: var(--color-text-primary);
  }
  .band-title em {
    font-style: italic;
    color: var(--color-accent-gold);
    font-weight: 400;
  }
  .band-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border-strong);
    border-radius: 999px;
    padding: 0.9rem 1.3rem;
    background: transparent;
    color: var(--color-text-primary);
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: 500;
    transition: background 0.18s, border-color 0.18s, transform 0.18s;
  }
  .band-cta:hover {
    background: var(--color-bg-warm);
    border-color: rgba(184, 132, 42, 0.35);
    transform: translateY(-2px);
  }
  .logo-wall {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    border: 1px solid var(--color-border);
    background: var(--color-bg-surface);
  }
  .logo-tile {
    min-height: 120px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0.35rem;
    padding: 1rem;
    text-align: center;
    text-decoration: none;
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-surface);
    transition: background 0.18s, transform 0.18s, box-shadow 0.18s;
  }
  .logo-tile:hover {
    background: var(--color-bg-warm);
    transform: translateY(-2px);
    box-shadow: 0 10px 22px rgba(28, 20, 16, 0.06);
  }
  .logo-brand {
    font-family: var(--font-serif);
    font-size: 1.18rem;
    font-weight: 500;
    color: var(--color-text-primary);
    transition: color 0.18s;
  }
  .logo-image {
    max-height: 36px;
    max-width: 140px;
    width: auto;
    object-fit: contain;
    display: block;
  }
  .logo-tile:hover .logo-brand {
    color: var(--color-accent-gold);
  }
  .logo-meta {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
  }
  .logo-wall > :nth-child(6n) { border-right: none; }
  .count-strip {
    margin-top: 1.25rem;
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    border: 1px solid var(--color-border);
    background: var(--color-bg-surface);
  }
  .count-cell {
    padding: 1rem 1.2rem;
    border-right: 1px solid var(--color-border);
    text-align: center;
  }
  .count-cell:last-child { border-right: none; }
  .count-label {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
  }
  .count-value {
    margin-top: 0.35rem;
    font-family: var(--font-serif);
    font-size: 1.75rem;
    line-height: 1;
    color: var(--color-text-primary);
  }
  .count-value sup {
    color: var(--color-accent-gold);
    font-size: 0.8em;
    top: -0.2em;
    position: relative;
  }
  .band-note {
    margin-top: 1rem;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-secondary);
  }
  @media (max-width: 900px) {
    .band-head { grid-template-columns: 1fr; }
    .logo-wall { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .logo-wall > :nth-child(6n) { border-right: 1px solid var(--color-border); }
    .logo-wall > :nth-child(3n) { border-right: none; }
  }
  @media (max-width: 520px) {
    .band-shell { padding: 4rem 1rem; }
    .logo-wall { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .logo-wall > :nth-child(3n) { border-right: 1px solid var(--color-border); }
    .logo-wall > :nth-child(2n) { border-right: none; }
    .count-strip { grid-template-columns: 1fr; }
    .count-cell { border-right: none; border-bottom: 1px solid var(--color-border); }
    .count-cell:last-child { border-bottom: none; }
  }
</style>

<section class="band-wrap">
  <div class="band-shell">
    <div class="band-head">
      <div>
        <p class="band-eyebrow">Integrations</p>
        <h2 class="band-title">Works with the gear <em>you already own.</em></h2>
      </div>
      <a href="/integrations" class="band-cta">See all 60+ integrations →</a>
    </div>

    <div class="logo-wall">
      {homepageIntegrationTiles.map(({ brand, meta, logoUrl }) => (
        <div class="logo-tile">
          {logoUrl ? <img src={logoUrl} alt={brand} class="logo-image" loading="lazy" decoding="async" /> : <div class="logo-brand">{brand}</div>}
          <div class="logo-meta">{meta}</div>
        </div>
      ))}
    </div>

    <div class="count-strip">
      {homepageCategoryCounts.map(({ label, count }) => (
        <div class="count-cell">
          <div class="count-label">{label}</div>
          <div class="count-value" set:html={count.replace("+", "<sup>+</sup>")}></div>
        </div>
      ))}
    </div>

    <p class="band-note">
      WorshipMetrics works with this ProAV gear through its integration with Central Control&apos;s show automation platform. That means your church can bring role-based workflows into the booth without starting over on hardware.
    </p>
  </div>
</section>
