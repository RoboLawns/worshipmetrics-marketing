---
const APP_URL = "https://app.worshipmetrics.com";
const year = new Date().getFullYear();

const links = {
  Product: [
    { label: "Features", href: "/features" },
    { label: "Pricing",  href: "/pricing"  },
  ],
  Account: [
    { label: "Sign in",  href: `${APP_URL}/sign-in`  },
    { label: "Sign up",  href: `${APP_URL}/sign-up`  },
  ],
  Legal: [
    { label: "Privacy Policy", href: "/privacy" },
    { label: "Terms of Service", href: "/terms" },
  ],
};
---

<footer class="border-t border-slate-200 bg-slate-50">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2 text-base font-bold text-slate-900">
          <svg class="h-6 w-6 text-indigo-600" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <circle cx="16" cy="16" r="16" fill="currentColor" opacity="0.15"/>
            <path d="M8 22 L12 10 L16 18 L20 10 L24 22" stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
          WorshipMetrics
        </a>
        <p class="mt-3 text-sm text-slate-500 leading-relaxed max-w-xs">
          Simple, powerful tools for churches to track attendance, grow community, and stay connected.
        </p>
      </div>

      <!-- Link columns -->
      {Object.entries(links).map(([group, items]) => (
        <div>
          <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-slate-400">{group}</h3>
          <ul class="space-y-2">
            {items.map(({ label, href }) => (
              <li>
                <a href={href} class="text-sm text-slate-600 transition-colors hover:text-indigo-600">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-10 border-t border-slate-200 pt-6 text-center text-xs text-slate-400">
      &copy; {year} WorshipMetrics. All rights reserved.
    </div>
  </div>
</footer>
