---
const APP_URL = "https://app.worshipmetrics.com";
const year = new Date().getFullYear();

const cols = [
  { heading: "Platform", links: [
    { label: "Attendance",       href: "/platform/attendance"  },
    { label: "People & Follow-up",href: "/platform/people"     },
    { label: "Operations",       href: "/platform/operations"  },
    { label: "Luminos AI",       href: "/luminos-ai-assistant" },
    { label: "All Features",     href: "/platform"             },
  ]},
  { heading: "Solutions", links: [
    { label: "Worship Clips",      href: "/solutions/worship-clips"             },
    { label: "Digital Engagement", href: "/solutions/digital-engagement"        },
    { label: "Community Platform", href: "/solutions/church-community-platform" },
    { label: "Outreach Services",  href: "/outreach-services"                   },
    { label: "Pro Services",       href: "/professional-services"               },
  ]},
  { heading: "Hardware", links: [
    { label: "WorshipMetrics Hub",    href: "/appliance" },
    { label: "WorshipMetrics Tablet", href: "/tablet"    },
    { label: "Compare Hardware",      href: "/hardware"  },
  ]},
  { heading: "Company", links: [
    { label: "About",             href: "/about"           },
    { label: "Pricing",           href: "/pricing"         },
    { label: "Contact",           href: "/contact"         },
    { label: "Pilot Program",     href: "/pilot-program"   },
    { label: "Book a call",       href: "/discovery-call"  },
  ]},
  { heading: "Legal", links: [
    { label: "Privacy Policy",   href: "/privacy"  },
    { label: "Terms of Service", href: "/terms"    },
    { label: "Returns Policy",   href: "/returns"  },
  ]},
];
---

<style>
  footer {
    border-top: 1px solid rgba(107,140,255,0.14);
    background: rgba(10,12,18,0.95);
    padding: 3.5rem 1.5rem 2rem;
  }
  .footer-inner {
    max-width: 80rem; margin: 0 auto;
    display: grid;
    grid-template-columns: 1.4fr repeat(5, 1fr);
    gap: 2rem;
  }
  @media (max-width: 1023px) {
    .footer-inner { grid-template-columns: repeat(2, 1fr); }
    .brand-col    { grid-column: 1 / -1; }
  }
  @media (max-width: 639px) {
    .footer-inner { grid-template-columns: 1fr; }
  }
  .brand-col { display: flex; flex-direction: column; gap: 0.75rem; }
  .brand-logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; }
  .brand-logo img { height: 1.75rem; width: 1.75rem; }
  .brand-logo span { font-size: 0.95rem; font-weight: 600; color: #fff; }
  .brand-tagline { font-size: 0.8rem; color: #8a96b3; line-height: 1.55; max-width: 15rem; }
  .brand-btns { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 0.5rem; }
  .col-heading {
    font-size: 0.65rem; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: #6b8cff; margin-bottom: 0.75rem;
  }
  .col-links { display: flex; flex-direction: column; gap: 0.5rem; }
  .col-links a { font-size: 0.8rem; color: #8a96b3; text-decoration: none; transition: color 0.15s; }
  .col-links a:hover { color: #fff; }
  .footer-bottom {
    max-width: 80rem; margin: 2.5rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(107,140,255,0.12);
    display: flex; flex-wrap: wrap; justify-content: space-between;
    gap: 0.5rem;
  }
  .footer-bottom p { font-size: 0.75rem; color: #8a96b3; }
  .footer-bottom a { color: #8a96b3; text-decoration: none; transition: color 0.15s; }
  .footer-bottom a:hover { color: #fff; }
</style>

<footer>
  <div class="footer-inner">
    <!-- Brand -->
    <div class="brand-col">
      <a href="/" class="brand-logo">
        <img src="/logo.png" alt="WorshipMetrics" />
        <span>WorshipMetrics</span>
      </a>
      <p class="brand-tagline">Know who's in the room. Reach who isn't.</p>
      <div class="brand-btns">
        <a href={`${APP_URL}/sign-up`} class="btn-primary" style="justify-content:center;font-size:0.8rem;padding:0.5rem 1rem;">Get started free</a>
        <a href="/discovery-call" class="btn-outline" style="justify-content:center;font-size:0.8rem;padding:0.5rem 1rem;">Book a discovery call</a>
      </div>
    </div>

    <!-- Link columns -->
    {cols.map(({ heading, links }) => (
      <div>
        <p class="col-heading">{heading}</p>
        <div class="col-links">
          {links.map(({ label, href }) => (
            <a href={href}>{label}</a>
          ))}
        </div>
      </div>
    ))}
  </div>

  <div class="footer-bottom">
    <p>&copy; {year} WorshipMetrics. All rights reserved.</p>
    <p>
      <a href="mailto:paul@worshipmetrics.com">paul@worshipmetrics.com</a>
      &nbsp;&middot;&nbsp;
      <a href="tel:4107257500">410-725-7500</a>
    </p>
  </div>
</footer>
