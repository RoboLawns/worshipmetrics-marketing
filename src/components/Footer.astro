---
const APP_URL = "https://app.worshipmetrics.com";
const year = new Date().getFullYear();

const cols = {
  Platform: [
    { label: "Attendance", href: "/platform/attendance" },
    { label: "People & Follow-up", href: "/platform/people" },
    { label: "Operations", href: "/platform/operations" },
    { label: "Luminos AI", href: "/luminos-ai-assistant" },
    { label: "All Features", href: "/platform" },
  ],
  Solutions: [
    { label: "Worship Clips", href: "/solutions/worship-clips" },
    { label: "Digital Engagement", href: "/solutions/digital-engagement" },
    { label: "Community Platform", href: "/solutions/church-community-platform" },
    { label: "Outreach Services", href: "/outreach-services" },
    { label: "Professional Services", href: "/professional-services" },
  ],
  Hardware: [
    { label: "WorshipMetrics Hub", href: "/appliance" },
    { label: "WorshipMetrics Tablet", href: "/tablet" },
    { label: "Compare Hardware", href: "/hardware" },
  ],
  Company: [
    { label: "About", href: "/about" },
    { label: "Pricing", href: "/pricing" },
    { label: "Contact", href: "/contact" },
    { label: "Pilot Program", href: "/pilot-program" },
    { label: "Book a Discovery Call", href: "/discovery-call" },
  ],
  Legal: [
    { label: "Privacy Policy", href: "/privacy" },
    { label: "Terms of Service", href: "/terms" },
    { label: "Returns Policy", href: "/returns" },
  ],
};
---

<footer class="border-t border-slate-200 bg-slate-50">
  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-3 lg:grid-cols-6">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-3 lg:col-span-1">
        <a href="/" class="flex items-center gap-2 text-sm font-bold text-slate-900">
          <svg class="h-6 w-6 text-indigo-600" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <circle cx="16" cy="16" r="16" fill="currentColor" opacity="0.15"/>
            <path d="M8 22 L12 10 L16 18 L20 10 L24 22" stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
          WorshipMetrics
        </a>
        <p class="mt-3 text-xs text-slate-500 leading-relaxed max-w-[180px]">
          Know who's in the room. Reach who isn't.
        </p>
        <div class="mt-4 flex flex-col gap-2">
          <a href={`${APP_URL}/sign-up`} class="rounded-lg bg-indigo-600 px-4 py-2 text-center text-xs font-semibold text-white hover:bg-indigo-700">
            Get started free
          </a>
          <a href="/discovery-call" class="rounded-lg border border-slate-300 px-4 py-2 text-center text-xs font-semibold text-slate-700 hover:border-indigo-400">
            Book a discovery call
          </a>
        </div>
      </div>

      <!-- Link columns -->
      {Object.entries(cols).map(([group, items]) => (
        <div>
          <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-slate-400">{group}</h3>
          <ul class="space-y-2">
            {items.map(({ label, href }) => (
              <li>
                <a href={href} class="text-xs text-slate-600 transition-colors hover:text-indigo-600">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 border-t border-slate-200 pt-6 flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
      <p class="text-xs text-slate-400">&copy; {year} WorshipMetrics. All rights reserved.</p>
      <p class="text-xs text-slate-400">
        <a href="mailto:paul@worshipmetrics.com" class="hover:text-indigo-600">paul@worshipmetrics.com</a>
        &nbsp;·&nbsp;
        <a href="tel:4107257500" class="hover:text-indigo-600">410-725-7500</a>
      </p>
    </div>
  </div>
</footer>
