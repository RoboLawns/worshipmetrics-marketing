---
import { avTeamRoles } from "../data/avTeam";

interface Props {
  currentSlug?: string;
  heading?: string;
  compact?: boolean;
}

const { currentSlug, heading, compact = false } = Astro.props;
---

{heading && <h2 class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">{heading}</h2>}

<div class:list={["mt-8 grid gap-5", compact ? "md:grid-cols-3 xl:grid-cols-4" : "md:grid-cols-2 xl:grid-cols-4"]}>
  {avTeamRoles.map((role, index) => {
    const active = role.slug === currentSlug;
    return (
      <a
        href={`/av-team/${role.slug}`}
        class:list={[
          "group rounded-[1.5rem] border p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md",
          active ? "border-slate-900 bg-slate-900 text-white" : "border-slate-200 bg-white text-slate-900",
        ]}
      >
        <div class="flex items-start justify-between gap-4">
          <span class:list={["text-3xl font-extrabold", active ? "text-white" : "" ]} style={!active ? `color:${role.accentColor}` : undefined}>{index + 1}</span>
          {active && <span class="rounded-full bg-white/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-200">Current role</span>}
        </div>
        <p class:list={["mt-4 text-xs font-semibold uppercase tracking-[0.18em]", active ? "text-slate-300" : ""]} style={!active ? `color:${role.accentColor}` : undefined}>{role.subtitle}</p>
        <h3 class="mt-2 text-xl font-bold">{role.title}</h3>
        <p class:list={["mt-3 text-sm leading-relaxed", active ? "text-slate-300" : "text-slate-600"]}>{role.oneLine}</p>
        <span class:list={["mt-5 inline-block text-sm font-semibold", active ? "text-white" : "text-indigo-600"]}>Learn more →</span>
      </a>
    );
  })}
</div>
