---
const APP_URL = "https://app.worshipmetrics.com";

const platform = [
  { label: "Attendance", href: "/platform/attendance", desc: "Count the room and the stream together" },
  { label: "People", href: "/platform/people", desc: "Guests, follow-up, and member care" },
  { label: "Operations", href: "/platform/operations", desc: "Volunteers, roles, and multi-campus" },
  { label: "Luminos AI", href: "/luminos-ai-assistant", desc: "Weekly ministry summaries" },
];

const solutions = [
  { label: "Worship Clips", href: "/solutions/worship-clips", desc: "Sermons into social content" },
  { label: "Digital Engagement", href: "/solutions/digital-engagement", desc: "Online visitors into known people" },
  { label: "Community Platform", href: "/solutions/church-community-platform", desc: "Discord-based digital campus" },
  { label: "Outreach Services", href: "/outreach-services", desc: "Hands-on digital ministry help" },
];

const hardware = [
  { label: "WorshipMetrics Hub", href: "/appliance", desc: "Auto attendance + signage + production — $499" },
  { label: "WorshipMetrics Tablet", href: "/tablet", desc: "Volunteer-friendly check-in — from $349" },
  { label: "Compare Hardware", href: "/hardware", desc: "Hub vs. Tablet — which fits your church?" },
];
---

<header class="sticky top-0 z-50 w-full border-b border-slate-200 bg-white/95 backdrop-blur-sm">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 text-base font-bold text-slate-900 shrink-0">
      <svg class="h-7 w-7 text-indigo-600" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <circle cx="16" cy="16" r="16" fill="currentColor" opacity="0.15"/>
        <path d="M8 22 L12 10 L16 18 L20 10 L24 22" stroke="currentColor" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
      WorshipMetrics
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-1 text-sm font-medium text-slate-600 lg:flex">
      <!-- Platform dropdown -->
      <li class="group relative">
        <button class="flex items-center gap-1 rounded-lg px-3 py-2 transition-colors hover:bg-slate-50 hover:text-slate-900">
          Platform
          <svg class="h-3.5 w-3.5 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="invisible absolute left-0 top-full mt-1 w-64 rounded-xl border border-slate-100 bg-white p-2 shadow-lg opacity-0 transition-all group-hover:visible group-hover:opacity-100">
          {platform.map(({ label, href, desc }) => (
            <a href={href} class="block rounded-lg px-3 py-2.5 hover:bg-slate-50">
              <div class="text-sm font-semibold text-slate-900">{label}</div>
              <div class="text-xs text-slate-500">{desc}</div>
            </a>
          ))}
        </div>
      </li>

      <!-- Solutions dropdown -->
      <li class="group relative">
        <button class="flex items-center gap-1 rounded-lg px-3 py-2 transition-colors hover:bg-slate-50 hover:text-slate-900">
          Solutions
          <svg class="h-3.5 w-3.5 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="invisible absolute left-0 top-full mt-1 w-72 rounded-xl border border-slate-100 bg-white p-2 shadow-lg opacity-0 transition-all group-hover:visible group-hover:opacity-100">
          {solutions.map(({ label, href, desc }) => (
            <a href={href} class="block rounded-lg px-3 py-2.5 hover:bg-slate-50">
              <div class="text-sm font-semibold text-slate-900">{label}</div>
              <div class="text-xs text-slate-500">{desc}</div>
            </a>
          ))}
        </div>
      </li>

      <!-- Hardware dropdown -->
      <li class="group relative">
        <button class="flex items-center gap-1 rounded-lg px-3 py-2 transition-colors hover:bg-slate-50 hover:text-slate-900">
          Hardware
          <svg class="h-3.5 w-3.5 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="invisible absolute left-0 top-full mt-1 w-72 rounded-xl border border-slate-100 bg-white p-2 shadow-lg opacity-0 transition-all group-hover:visible group-hover:opacity-100">
          {hardware.map(({ label, href, desc }) => (
            <a href={href} class="block rounded-lg px-3 py-2.5 hover:bg-slate-50">
              <div class="text-sm font-semibold text-slate-900">{label}</div>
              <div class="text-xs text-slate-500">{desc}</div>
            </a>
          ))}
        </div>
      </li>

      <li><a href="/pricing" class="rounded-lg px-3 py-2 transition-colors hover:bg-slate-50 hover:text-slate-900">Pricing</a></li>
      <li><a href="/about" class="rounded-lg px-3 py-2 transition-colors hover:bg-slate-50 hover:text-slate-900">About</a></li>
    </ul>

    <!-- CTA buttons -->
    <div class="flex items-center gap-2">
      <a href="/discovery-call" class="hidden text-sm font-medium text-slate-600 transition-colors hover:text-indigo-600 lg:block">
        Book a call
      </a>
      <a href={`${APP_URL}/sign-in`} class="hidden text-sm font-medium text-slate-700 transition-colors hover:text-indigo-600 lg:block">
        Sign in
      </a>
      <a
        href={`${APP_URL}/sign-up`}
        class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-indigo-700"
      >
        Get started free
      </a>
    </div>
  </nav>
</header>
