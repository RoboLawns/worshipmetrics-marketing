---
const APP_URL = "https://app.worshipmetrics.com";

const menus = [
  {
    key: "features",
    label: "Features",
    overview: { href: "/platform", label: "Platform Overview", desc: "See how attendance, people, and operations fit together." },
    items: [
      { href: "/platform/attendance",  label: "Attendance",   desc: "Count in-room and online in one workflow" },
      { href: "/platform/people",      label: "People",       desc: "Guest capture, prayer routing, and member care" },
      { href: "/platform/operations",  label: "Operations",   desc: "Volunteer roles, devices, and multi-campus tools" },
      { href: "/luminos-ai-assistant", label: "Luminos AI",   desc: "Weekly ministry summaries in plain English" },
    ],
  },
  {
    key: "solutions",
    label: "Solutions",
    overview: { href: "/solutions/worship-clips", label: "Solutions Overview", desc: "Tools that extend ministry beyond Sunday morning." },
    items: [
      { href: "/solutions/worship-clips",             label: "Worship Clips",      desc: "Turn services into shareable social content" },
      { href: "/solutions/digital-engagement",        label: "Digital Engagement", desc: "Welcome online visitors and route follow-up" },
      { href: "/solutions/church-community-platform", label: "Community Platform", desc: "Discord-based digital campus with guided setup" },
      { href: "/outreach-services",                   label: "Outreach Services",  desc: "Hands-on livestream engagement help" },
    ],
  },
  {
    key: "hardware",
    label: "Hardware",
    overview: { href: "/hardware", label: "Hardware Overview", desc: "Purpose-built devices for churches." },
    items: [
      { href: "/appliance", label: "WorshipMetrics Hub",    desc: "Auto attendance, signage, and production — $499" },
      { href: "/tablet",    label: "WorshipMetrics Tablet", desc: "Volunteer check-in workflow — from $349" },
    ],
  },
  {
    key: "services",
    label: "Services",
    overview: { href: "/professional-services", label: "Services Overview", desc: "Consulting, training, and workflow design." },
    items: [
      { href: "/professional-services", label: "Professional Services", desc: "Broadcast, workflow, and strategy support" },
      { href: "/outreach-services",     label: "Outreach Services",     desc: "Livestream engagement and follow-up help" },
    ],
  },
];

const simpleLinks = [
  { href: "/pricing", label: "Pricing" },
  { href: "/about",   label: "About"   },
];
---

<style>
  .nav-root {
    position: sticky; top: 0; z-index: 50;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid #e4e8f4;
    box-shadow: 0 1px 4px rgba(15,26,46,0.06);
  }
  .nav-inner {
    max-width: 80rem; margin: 0 auto;
    padding: 0 1.5rem; height: 4rem;
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
  }
  .logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; flex-shrink: 0; }
  .logo img  { height: 2rem; width: 2rem; }
  .logo span { font-size: 1rem; font-weight: 700; color: #0f1a2e; }

  /* Desktop nav */
  .desktop-nav { display: none; align-items: center; gap: 0.1rem; }
  @media (min-width: 1024px) { .desktop-nav { display: flex; } }

  .nav-btn {
    display: flex; align-items: center; gap: 0.2rem;
    padding: 0.4rem 0.7rem; border-radius: 0.5rem;
    font-size: 0.875rem; font-weight: 500; color: #4a5568;
    background: none; border: none; cursor: pointer;
    text-decoration: none; transition: color 0.15s, background 0.15s;
  }
  .nav-btn:hover { color: #4361ee; background: #f0f3fb; }
  .nav-btn svg { width: 0.85rem; height: 0.85rem; opacity: 0.6; transition: transform 0.2s; }

  /* Dropdown */
  .dropdown-wrap { position: relative; }
  .dropdown-wrap::after { content:''; position:absolute; left:0; right:0; top:100%; height:0.6rem; }
  .dropdown {
    position: absolute; left: 0; top: calc(100% + 0.4rem);
    min-width: 44rem; background: #fff;
    border: 1px solid #e4e8f4; border-radius: 1rem;
    padding: 1rem;
    box-shadow: 0 16px 48px rgba(15,26,46,0.12);
    display: none; grid-template-columns: 1.1fr 2fr; gap: 0.75rem;
  }
  .dropdown.narrow { min-width: 28rem; grid-template-columns: 1fr 1fr; }
  .dropdown-wrap:hover .dropdown,
  .dropdown-wrap:focus-within .dropdown { display: grid; }

  .drop-overview {
    background: #f0f3fb; border: 1px solid #c3cdf5;
    border-radius: 0.75rem; padding: 1rem;
    text-decoration: none; display: flex; flex-direction: column; gap: 0.2rem;
    transition: border-color 0.15s, background 0.15s;
  }
  .drop-overview:hover { background: #e6eaf9; border-color: #4361ee; }
  .drop-overview .over-label { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #4361ee; }
  .drop-overview h3 { font-size: 0.9rem; font-weight: 700; color: #0f1a2e; margin: 0.2rem 0 0; }
  .drop-overview p  { font-size: 0.78rem; color: #8494b0; line-height: 1.5; margin: 0; }

  .drop-items { display: flex; flex-direction: column; gap: 0.15rem; }
  .drop-item  {
    display: block; padding: 0.55rem 0.75rem;
    border-radius: 0.5rem; text-decoration: none;
    transition: background 0.15s;
  }
  .drop-item:hover { background: #f0f3fb; }
  .drop-item .il { font-size: 0.875rem; font-weight: 600; color: #0f1a2e; }
  .drop-item .id { font-size: 0.75rem; color: #8494b0; margin-top: 0.05rem; }

  /* CTAs */
  .cta-area { display: none; align-items: center; gap: 0.5rem; }
  @media (min-width: 1024px) { .cta-area { display: flex; } }

  /* Mobile toggle */
  .mobile-toggle {
    display: flex; align-items: center; justify-content: center;
    width: 2.4rem; height: 2.4rem; border-radius: 0.5rem;
    border: 1.5px solid #e4e8f4; background: #f7f8fc;
    color: #0f1a2e; cursor: pointer;
  }
  @media (min-width: 1024px) { .mobile-toggle { display: none; } }

  /* Mobile menu */
  .mobile-menu {
    display: none; flex-direction: column; gap: 0.15rem;
    padding: 1rem 1.5rem 1.5rem;
    border-top: 1px solid #e4e8f4;
    background: #fff;
  }
  .mobile-menu.open { display: flex; }
  @media (min-width: 1024px) { .mobile-menu { display: none !important; } }

  .mob-section { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #4361ee; padding: 0.75rem 0.5rem 0.2rem; }
  .mob-link { display: flex; flex-direction: column; padding: 0.45rem 0.75rem; border-radius: 0.5rem; text-decoration: none; transition: background 0.15s; }
  .mob-link:hover { background: #f0f3fb; }
  .mob-link .ml { font-size: 0.875rem; font-weight: 600; color: #0f1a2e; }
  .mob-link .md { font-size: 0.75rem; color: #8494b0; }
  .mob-ctas { display: flex; flex-direction: column; gap: 0.5rem; padding-top: 0.75rem; border-top: 1px solid #e4e8f4; margin-top: 0.5rem; }
</style>

<header class="nav-root">
  <div class="nav-inner">
    <!-- Logo -->
    <a href="/" class="logo">
      <img src="/logo.png" alt="WorshipMetrics" />
      <span>WorshipMetrics</span>
    </a>

    <!-- Desktop nav -->
    <nav class="desktop-nav" aria-label="Main navigation">
      {menus.map((menu) => (
        <div class="dropdown-wrap">
          <button class="nav-btn" type="button" aria-haspopup="true">
            {menu.label}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class={`dropdown ${menu.key === "hardware" || menu.key === "services" ? "narrow" : ""}`}>
            <a href={menu.overview.href} class="drop-overview">
              <span class="over-label">{menu.label}</span>
              <h3>{menu.overview.label}</h3>
              <p>{menu.overview.desc}</p>
            </a>
            <div class="drop-items">
              {menu.items.map((item) => (
                <a href={item.href} class="drop-item">
                  <div class="il">{item.label}</div>
                  <div class="id">{item.desc}</div>
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
      {simpleLinks.map((l) => (
        <a href={l.href} class="nav-btn">{l.label}</a>
      ))}
    </nav>

    <!-- Desktop CTAs -->
    <div class="cta-area">
      <a href="/discovery-call" class="btn-outline" style="padding:0.45rem 1rem;font-size:0.82rem;">Book a call</a>
      <a href={`${APP_URL}/sign-in`} class="nav-btn">Sign in</a>
      <a href={`${APP_URL}/sign-up`} class="btn-primary" style="padding:0.45rem 1rem;font-size:0.82rem;">Get started free</a>
    </div>

    <!-- Mobile toggle -->
    <button class="mobile-toggle" id="mobile-nav-toggle" aria-label="Toggle navigation" type="button">
      <svg id="icon-menu" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg id="icon-close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true" style="display:none">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu">
    {menus.map((menu) => (
      <div>
        <p class="mob-section">{menu.label}</p>
        <a href={menu.overview.href} class="mob-link">
          <span class="ml">{menu.overview.label}</span>
          <span class="md">{menu.overview.desc}</span>
        </a>
        {menu.items.map((item) => (
          <a href={item.href} class="mob-link">
            <span class="ml">{item.label}</span>
            <span class="md">{item.desc}</span>
          </a>
        ))}
      </div>
    ))}
    {simpleLinks.map((l) => (
      <a href={l.href} class="mob-link"><span class="ml">{l.label}</span></a>
    ))}
    <div class="mob-ctas">
      <a href={`${APP_URL}/sign-up`} class="btn-primary" style="justify-content:center">Get started free</a>
      <a href="/discovery-call" class="btn-outline" style="justify-content:center">Book a discovery call</a>
    </div>
  </div>
</header>

<script>
  const toggle   = document.getElementById("mobile-nav-toggle")!;
  const menu     = document.getElementById("mobile-menu")!;
  const iconMenu  = document.getElementById("icon-menu")!;
  const iconClose = document.getElementById("icon-close")!;
  toggle.addEventListener("click", () => {
    const open = menu.classList.toggle("open");
    iconMenu.style.display  = open ? "none" : "";
    iconClose.style.display = open ? ""     : "none";
  });
</script>
