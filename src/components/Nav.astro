---
const APP_URL = "https://app.worshipmetrics.com";

const navItems = [
  {
    type: "dropdown",
    key: "platform",
    label: "Platform",
    overview: {
      href: "/platform",
      label: "Platform Overview",
      desc: "See how Services, volunteers, booth software, clips, attendance, signage, and Luminos fit together.",
    },
    items: [
      { href: "/services", label: "Services", desc: "Plan the service, assign the team, and run Sunday from one workflow" },
      { href: "/volunteers", label: "Volunteers", desc: "Capabilities, scheduling, communications, and replacement workflows" },
      { href: "/solutions/worship-clips", label: "Worship Clips", desc: "Turn the sermon into ready-to-publish clips without extra editing" },
      { href: "/tech-manager", label: "Tech Manager", desc: "The desktop app that powers the booth and keeps your system mapped" },
      { href: "/platform/attendance", label: "Attendance", desc: "Count in-room and online together without a separate reporting stack" },
      { href: "/signage-display", label: "Digital Signage", desc: "Keep screens current from anywhere with one-screen-free signage" },
      { href: "/luminos-ai-assistant", label: "Luminos AI", desc: "Diagnostics and weekly review with real context from your production system" },
    ],
  },
  {
    type: "dropdown",
    key: "hardware",
    label: "Hardware",
    overview: {
      href: "/hardware",
      label: "Hardware Overview",
      desc: "Purpose-built devices for always-on monitoring, tablets, and church production workflows.",
    },
    items: [
      { href: "/appliance", label: "Worship Metrics Hub", desc: "Always-on hardware for monitoring, automation, and local reliability" },
      { href: "/tablet", label: "Worship Metrics Tablet", desc: "Dedicated volunteer tablet for attendance, check-in, and service-day workflows" },
      { href: "/hardware", label: "Compare Hardware", desc: "See which device fits your campus and team setup" },
    ],
  },
  {
    type: "dropdown",
    key: "resources",
    label: "Resources",
    overview: {
      href: "/kb",
      label: "Resources Overview",
      desc: "Knowledge Base articles, rollout help, and direct support for church teams.",
    },
    items: [
      { href: "/kb", label: "Knowledge Base", desc: "Guides, troubleshooting, comparisons, and setup help for church teams" },
      { href: "/av-club", label: "AV Club", desc: "How churches build volunteer and youth ministry through production roles" },
      { href: "/signal-and-sanctuary", label: "Signal and Sanctuary", desc: "Podcast conversations from the Worship Metrics team" },
      { href: "/professional-services", label: "Professional Services", desc: "Consulting, training, installs, and production support" },
      { href: "/pilot-program", label: "Pilot Program", desc: "Work closely with the team and shape the platform rollout" },
    ],
  },
  {
    type: "link",
    href: "/pricing",
    label: "Pricing",
  },
  {
    type: "dropdown",
    key: "company",
    label: "Company",
    overview: {
      href: "/about",
      label: "About Worship Metrics",
      desc: "Who built it, why it exists, and how to talk with the team.",
    },
    items: [
      { href: "/about", label: "About", desc: "Built by people who believe in the mission and know the booth" },
      { href: "/contact", label: "Contact", desc: "Email, phone, and practical help for questions before you buy" },
      { href: "/discovery-call", label: "Book a Call", desc: "Talk through your current workflow and what fits your church" },
    ],
  },
];

const dropdownMenus = navItems.filter((item) => item.type === "dropdown");
const simpleLinks = navItems.filter((item) => item.type === "link");
---

<style>
  .topbar {
    background: #f0f3fb;
    border-bottom: 1px solid #dde3f5;
    font-size: 0.75rem;
    color: #5a6a8a;
  }
  .topbar-inner {
    max-width: 80rem; margin: 0 auto;
    padding: 0 1.5rem; height: 2rem;
    display: flex; align-items: center; justify-content: flex-end; gap: 1.25rem;
  }
  .topbar a {
    color: #5a6a8a; text-decoration: none; font-weight: 500;
    transition: color 0.15s;
  }
  .topbar a:hover { color: #4361ee; }
  .topbar-sep { color: #c3cdf5; }
  @media (max-width: 1023px) { .topbar { display: none; } }

  .nav-root {
    position: sticky; top: 0; z-index: 50;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid #e4e8f4;
    box-shadow: 0 1px 4px rgba(15,26,46,0.06);
  }
  .nav-inner {
    max-width: 80rem; margin: 0 auto;
    padding: 0 1.5rem; height: 4rem;
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
  }
  .logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; flex-shrink: 0; }
  .logo img  { height: 2rem; width: 2rem; }
  .logo span { font-size: 1rem; font-weight: 700; color: #0f1a2e; }

  .desktop-nav { display: none; align-items: center; gap: 0.1rem; }
  @media (min-width: 1024px) { .desktop-nav { display: flex; } }

  .nav-btn {
    display: flex; align-items: center; gap: 0.2rem;
    padding: 0.4rem 0.7rem; border-radius: 0.5rem;
    font-size: 0.875rem; font-weight: 500; color: #4a5568;
    background: none; border: none; cursor: pointer;
    text-decoration: none; transition: color 0.15s, background 0.15s;
  }
  .nav-btn:hover { color: #4361ee; background: #f0f3fb; }
  .nav-btn svg { width: 0.85rem; height: 0.85rem; opacity: 0.6; transition: transform 0.2s; }

  .dropdown-wrap { position: relative; }
  .dropdown-wrap::after { content: ''; position: absolute; left: 0; right: 0; top: 100%; height: 0.6rem; }
  .dropdown {
    position: absolute; left: 0; top: calc(100% + 0.4rem);
    min-width: 44rem; background: #fff;
    border: 1px solid #e4e8f4; border-radius: 1rem;
    padding: 1rem;
    box-shadow: 0 16px 48px rgba(15,26,46,0.12);
    display: none; grid-template-columns: 1.1fr 2fr; gap: 0.75rem;
  }
  .dropdown.narrow { min-width: 28rem; grid-template-columns: 1fr 1fr; }
  .dropdown-wrap:hover .dropdown,
  .dropdown-wrap:focus-within .dropdown { display: grid; }

  .drop-overview {
    background: #f0f3fb; border: 1px solid #c3cdf5;
    border-radius: 0.75rem; padding: 1rem;
    text-decoration: none; display: flex; flex-direction: column; gap: 0.2rem;
    transition: border-color 0.15s, background 0.15s;
  }
  .drop-overview:hover { background: #e6eaf9; border-color: #4361ee; }
  .drop-overview .over-label { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #4361ee; }
  .drop-overview h3 { font-size: 0.9rem; font-weight: 700; color: #0f1a2e; margin: 0.2rem 0 0; }
  .drop-overview p  { font-size: 0.78rem; color: #8494b0; line-height: 1.5; margin: 0; }

  .drop-items { display: flex; flex-direction: column; gap: 0.15rem; }
  .drop-item  {
    display: block; padding: 0.55rem 0.75rem;
    border-radius: 0.5rem; text-decoration: none;
    transition: background 0.15s;
  }
  .drop-item:hover { background: #f0f3fb; }
  .drop-item .il { font-size: 0.875rem; font-weight: 600; color: #0f1a2e; }
  .drop-item .id { font-size: 0.75rem; color: #8494b0; margin-top: 0.05rem; }

  .cta-area { display: none; align-items: center; gap: 0.5rem; }
  @media (min-width: 1024px) { .cta-area { display: flex; } }

  .mobile-toggle {
    display: flex; align-items: center; justify-content: center;
    width: 2.4rem; height: 2.4rem; border-radius: 0.5rem;
    border: 1.5px solid #e4e8f4; background: #f7f8fc;
    color: #0f1a2e; cursor: pointer;
  }
  @media (min-width: 1024px) { .mobile-toggle { display: none; } }

  .mobile-menu {
    display: none; flex-direction: column;
    padding: 0.75rem 1rem 1.25rem;
    border-top: 1px solid #e4e8f4;
    background: #fff;
    max-height: calc(100dvh - 4rem);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  .mobile-menu.open { display: flex; }
  @media (min-width: 1024px) { .mobile-menu { display: none !important; } }

  .mob-accordion { border-bottom: 1px solid #f0f3fb; }
  .mob-accordion:last-of-type { border-bottom: none; }

  .mob-acc-trigger {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; background: none; border: none; cursor: pointer;
    padding: 0.65rem 0.5rem; text-align: left;
  }
  .mob-acc-trigger-label {
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: #4361ee;
  }
  .mob-acc-chevron {
    width: 1rem; height: 1rem; color: #4361ee; opacity: 0.7;
    transition: transform 0.2s; flex-shrink: 0;
  }
  .mob-accordion.open .mob-acc-chevron { transform: rotate(180deg); }

  .mob-acc-body { display: none; padding-bottom: 0.5rem; }
  .mob-accordion.open .mob-acc-body { display: block; }

  .mob-link {
    display: flex; flex-direction: column; padding: 0.4rem 0.75rem;
    border-radius: 0.5rem; text-decoration: none; transition: background 0.15s;
  }
  .mob-link:hover { background: #f0f3fb; }
  .mob-link .ml { font-size: 0.875rem; font-weight: 600; color: #0f1a2e; }
  .mob-link .md { font-size: 0.75rem; color: #8494b0; }

  .mob-simple { padding: 0.5rem 0 0; }
  .mob-simple-link {
    display: block; padding: 0.5rem 0.75rem; border-radius: 0.5rem;
    text-decoration: none; font-size: 0.875rem; font-weight: 600; color: #0f1a2e;
    transition: background 0.15s;
  }
  .mob-simple-link:hover { background: #f0f3fb; }

  .mob-contact {
    display: flex; flex-wrap: wrap; gap: 0.4rem 1rem;
    padding: 0.6rem 0.75rem 0;
    font-size: 0.78rem;
  }
  .mob-contact a { color: #5a6a8a; text-decoration: none; font-weight: 500; }
  .mob-contact a:hover { color: #4361ee; }

  .mob-ctas { display: flex; flex-direction: column; gap: 0.5rem; padding-top: 0.75rem; border-top: 1px solid #e4e8f4; margin-top: 0.75rem; }
</style>

<div class="topbar">
  <div class="topbar-inner">
    <a href="/about">About</a>
    <span class="topbar-sep">|</span>
    <a href="/pricing">Pricing</a>
    <span class="topbar-sep">|</span>
    <a href="mailto:support@worshipmetrics.com">support@worshipmetrics.com</a>
    <span class="topbar-sep">|</span>
    <a href="tel:+14107257500">(410) 725-7500</a>
  </div>
</div>

<header class="nav-root">
  <div class="nav-inner">
    <a href="/" class="logo">
      <img src="/logo.png" alt="" width="32" height="32" />
      <span>WorshipMetrics</span>
    </a>

    <nav class="desktop-nav" aria-label="Main navigation">
      {navItems.map((item) => (
        item.type === "dropdown" ? (
          <div class="dropdown-wrap">
            <button class="nav-btn" type="button" aria-haspopup="true">
              {item.label}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class={`dropdown ${item.key === "hardware" || item.key === "resources" || item.key === "company" ? "narrow" : ""}`}>
              <a href={item.overview.href} class="drop-overview">
                <span class="over-label">{item.label}</span>
                <h3>{item.overview.label}</h3>
                <p>{item.overview.desc}</p>
              </a>
              <div class="drop-items">
                {item.items.map((entry) => (
                  <a href={entry.href} class="drop-item">
                    <div class="il">{entry.label}</div>
                    <div class="id">{entry.desc}</div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a href={item.href} class="nav-btn">{item.label}</a>
        )
      ))}
    </nav>

    <div class="cta-area">
      <a href={`${APP_URL}/sign-in`} class="nav-btn">Sign in</a>
      <a href={`${APP_URL}/sign-up`} class="btn-primary" style="padding:0.45rem 1rem;font-size:0.82rem;" data-wm-track="cta_click" data-wm-track-label="nav_get_started_free" data-wm-track-location="nav">Get started free</a>
      <a href="/discovery-call" class="btn-outline" style="padding:0.45rem 1rem;font-size:0.82rem;" data-wm-track="cta_click" data-wm-track-label="nav_book_call" data-wm-track-location="nav">Book a call</a>
    </div>

    <button class="mobile-toggle" id="mobile-nav-toggle" aria-label="Toggle navigation" type="button">
      <svg id="icon-menu" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true" style="display:none">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div class="mobile-menu" id="mobile-menu">
    {dropdownMenus.map((menu) => (
      <div class="mob-accordion" data-accordion>
        <button class="mob-acc-trigger" type="button" data-acc-trigger>
          <span class="mob-acc-trigger-label">{menu.label}</span>
          <svg class="mob-acc-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="mob-acc-body">
          <a href={menu.overview.href} class="mob-link">
            <span class="ml">{menu.overview.label}</span>
            <span class="md">{menu.overview.desc}</span>
          </a>
          {menu.items.map((entry) => (
            <a href={entry.href} class="mob-link">
              <span class="ml">{entry.label}</span>
              <span class="md">{entry.desc}</span>
            </a>
          ))}
        </div>
      </div>
    ))}

    <div class="mob-simple">
      {simpleLinks.map((item) => (
        <a href={item.href} class="mob-simple-link">{item.label}</a>
      ))}
    </div>

    <div class="mob-contact">
      <a href="mailto:support@worshipmetrics.com">support@worshipmetrics.com</a>
      <a href="tel:+14107257500">(410) 725-7500</a>
    </div>

    <div class="mob-ctas">
      <a href={`${APP_URL}/sign-in`} class="btn-outline" style="justify-content:center">Sign in</a>
      <a href={`${APP_URL}/sign-up`} class="btn-primary" style="justify-content:center" data-wm-track="cta_click" data-wm-track-label="mobile_nav_get_started_free" data-wm-track-location="mobile_nav">Get started free</a>
      <a href="/discovery-call" class="btn-outline" style="justify-content:center" data-wm-track="cta_click" data-wm-track-label="mobile_nav_book_call" data-wm-track-location="mobile_nav">Book a call</a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-nav-toggle")!;
  const menu = document.getElementById("mobile-menu")!;
  const iconMenu = document.getElementById("icon-menu")!;
  const iconClose = document.getElementById("icon-close")!;

  toggle.addEventListener("click", () => {
    const open = menu.classList.toggle("open");
    iconMenu.style.display = open ? "none" : "";
    iconClose.style.display = open ? "" : "none";

    if (!open) {
      document.querySelectorAll("[data-accordion]").forEach((acc) => acc.classList.remove("open"));
    }
  });

  document.querySelectorAll("[data-acc-trigger]").forEach((trigger) => {
    trigger.addEventListener("click", () => {
      const accordion = trigger.closest("[data-accordion]")!;
      const isOpen = accordion.classList.contains("open");

      document.querySelectorAll("[data-accordion]").forEach((acc) => acc.classList.remove("open"));
      if (!isOpen) accordion.classList.add("open");
    });
  });
</script>
