---
interface Props {
  tier: 'under-500' | 'under-1000' | 'under-2500' | 'under-5000' | 'under-10000' | 'upgrade-roadmap';
}

const { tier } = Astro.props;

const labels: Record<string, string> = {
  'under-500': 'Under $500',
  'under-1000': 'Under $1,000',
  'under-2500': 'Under $2,500',
  'under-5000': 'Under $5,000',
  'under-10000': 'Under $10,000',
  'upgrade-roadmap': 'Upgrade Roadmap',
};

const colorClasses: Record<string, string> = {
  'under-500': 'bg-green-100 text-green-700',
  'under-1000': 'bg-cyan-100 text-cyan-700',
  'under-2500': 'bg-blue-100 text-blue-700',
  'under-5000': 'bg-purple-100 text-purple-700',
  'under-10000': 'bg-rose-100 text-rose-700',
  'upgrade-roadmap': 'bg-slate-100 text-slate-700',
};
---

<span class:list={['inline-flex rounded-full px-3 py-1 text-xs font-semibold', colorClasses[tier]]}>
  {labels[tier]}
</span>
