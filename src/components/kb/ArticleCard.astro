---
import type { CollectionEntry } from 'astro:content';
import CategoryBadge from './CategoryBadge.astro';
import DifficultyBadge from './DifficultyBadge.astro';

interface Props {
  article: CollectionEntry<'articles'>;
  basePath?: string;
}

const { article, basePath = '/kb/articles' } = Astro.props;
const href = `${basePath}/${article.id}`;
---

<article class="group flex h-full flex-col rounded-3xl border border-border bg-surface/80 p-6 shadow-[0_12px_30px_rgba(0,0,0,0.18)] transition hover:-translate-y-0.5 hover:border-accent/40">
  {article.data.coverImage && (
    <a href={href} class="mb-5 overflow-hidden rounded-2xl border border-border bg-bg">
      <img src={article.data.coverImage} alt={article.data.title} class="aspect-[16/9] w-full object-cover transition duration-300 group-hover:scale-[1.02]" loading="lazy" />
    </a>
  )}
  <div class="flex flex-wrap items-center gap-3">
    <CategoryBadge category={article.data.category} />
    <DifficultyBadge difficulty={article.data.difficulty} />
  </div>
  <h3 class="mt-5 font-display text-2xl leading-tight text-white group-hover:text-blue-200">
    <a href={href}>{article.data.title}</a>
  </h3>
  <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-300">{article.data.description}</p>
  <div class="mt-5 flex flex-wrap items-center gap-3 text-xs uppercase tracking-[0.16em] text-muted">
    <span>{article.data.publishedAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
    <span>•</span>
    <span>{article.data.readingTime ?? 6} min read</span>
  </div>
</article>
