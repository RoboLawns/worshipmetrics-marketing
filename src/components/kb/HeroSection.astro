---
import SearchBar from './SearchBar.astro';
---

<section class="kb-grid-bg border-b border-border bg-bg">
  <div class="mx-auto grid max-w-7xl gap-10 px-6 py-20 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)] lg:items-center">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-300">Church AV knowledge base</p>
      <h1 class="mt-4 font-display text-5xl leading-tight text-white sm:text-6xl">The AV Knowledge Base for Church Production Teams</h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-300">Expert guides for streaming, audio, display systems, volunteer operations, and device management — written for the people keeping Sunday running.</p>
      <div class="mt-8">
        <SearchBar />
      </div>
      <div class="mt-6 flex flex-wrap gap-4">
        <a href="/discovery-call" class="rounded-xl bg-accent px-5 py-3 text-sm font-semibold text-white transition hover:bg-blue-500">Talk to the team →</a>
        <a href="/kb/search" class="rounded-xl border border-border px-5 py-3 text-sm font-semibold text-slate-200 transition hover:border-blue-400 hover:text-white">Search all articles</a>
      </div>
    </div>
    <div class="rounded-3xl border border-border bg-surface p-6 shadow-[0_20px_50px_rgba(0,0,0,0.3)]">
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-2xl bg-bg p-5">
          <p class="text-xs uppercase tracking-[0.16em] text-muted">Streaming</p>
          <p class="mt-3 font-display text-2xl text-white">OBS, vMix, encoders, and NDI</p>
        </div>
        <div class="rounded-2xl bg-bg p-5">
          <p class="text-xs uppercase tracking-[0.16em] text-muted">Operations</p>
          <p class="mt-3 font-display text-2xl text-white">Volunteer teams, runsheets, and planning</p>
        </div>
        <div class="rounded-2xl bg-bg p-5 sm:col-span-2">
          <p class="text-xs uppercase tracking-[0.16em] text-muted">Device management</p>
          <p class="mt-3 font-display text-2xl text-white">Cameras, displays, switchers, and campus-wide AV health</p>
        </div>
      </div>
    </div>
  </div>
</section>
