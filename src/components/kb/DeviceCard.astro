---
import DifficultyBadge from './DifficultyBadge.astro';

interface Props {
  title: string;
  description: string;
  brand: string;
  priceRange?: 'under-500' | '500-1500' | '1500-plus';
  href: string;
  difficulty: 'beginner' | 'intermediate' | 'advanced';
}

const { title, description, brand, priceRange, href, difficulty } = Astro.props;

const priceRangeLabels: Record<string, string> = {
  'under-500': 'Under $500',
  '500-1500': '$500–$1,500',
  '1500-plus': '$1,500+',
};
---

<a href={href} class="group rounded-2xl border border-border bg-surface/80 p-6 shadow transition hover:-translate-y-0.5 hover:border-accent/40">
  <div class="flex flex-wrap items-start justify-between gap-2">
    <DifficultyBadge difficulty={difficulty} />
    {priceRange && (
      <span class="rounded-full bg-slate-700/50 px-3 py-1 text-xs text-slate-300">
        {priceRangeLabels[priceRange]}
      </span>
    )}
  </div>
  <p class="mt-3 text-sm text-slate-400">{brand}</p>
  <h3 class="mt-2 font-display text-xl text-white group-hover:text-blue-200">{title}</h3>
  <p class="mt-2 text-sm text-slate-400">{description}</p>
</a>
