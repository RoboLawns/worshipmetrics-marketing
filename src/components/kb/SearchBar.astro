---
interface Props {
  mode?: 'form' | 'pagefind';
  placeholder?: string;
}

const { mode = 'form', placeholder = 'Search church AV articles...' } = Astro.props;
---

{mode === 'form' ? (
  <form action="/kb/search" method="get" class="flex w-full max-w-2xl items-center gap-3 rounded-2xl border border-border bg-surface/90 p-3 shadow-[0_10px_24px_rgba(0,0,0,0.2)]">
    <input
      type="search"
      name="q"
      placeholder={placeholder}
      class="min-w-0 flex-1 bg-transparent px-3 py-2 text-sm text-white outline-none placeholder:text-slate-500"
    />
    <button type="submit" class="rounded-xl bg-accent px-4 py-2 text-sm font-semibold text-white transition hover:bg-blue-500">
      Search
    </button>
  </form>
) : (
  <div class="space-y-4">
    <div class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
      <input
        id="kb-search-input"
        type="search"
        placeholder={placeholder}
        class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-blue-400"
      />
    </div>
    <div class="grid gap-3 sm:grid-cols-3">
      <label class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
        <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Category</span>
        <select id="kb-search-category" class="w-full rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-blue-400">
          <option value="">All categories</option>
          <option value="device-management">Device Management</option>
          <option value="streaming">Streaming</option>
          <option value="video-clipping">Video Clipping</option>
          <option value="audio">Audio</option>
          <option value="display">Display & Presentation</option>
          <option value="operations">Operations</option>
        </select>
      </label>
      <label class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
        <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Difficulty</span>
        <select id="kb-search-difficulty" class="w-full rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-blue-400">
          <option value="">All levels</option>
          <option value="beginner">Beginner</option>
          <option value="intermediate">Intermediate</option>
          <option value="advanced">Advanced</option>
        </select>
      </label>
      <label class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
        <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Sort</span>
        <select id="kb-search-sort" class="w-full rounded-xl border border-slate-200 px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-blue-400">
          <option value="relevance">Best match</option>
          <option value="newest">Newest first</option>
          <option value="oldest">Oldest first</option>
        </select>
      </label>
    </div>
    <p id="kb-search-status" class="text-sm text-slate-500">Type to search all knowledge base articles.</p>
    <div id="kb-search-results" class="grid gap-4"></div>
    <script type="module" is:inline>
      const categoryLabels = {
        'device-management': 'Device Management',
        streaming: 'Streaming',
        'video-clipping': 'Video Clipping',
        audio: 'Audio',
        display: 'Display & Presentation',
        operations: 'Operations',
      };

      const difficultyLabels = {
        beginner: 'Beginner',
        intermediate: 'Intermediate',
        advanced: 'Advanced',
      };

      const input = document.getElementById('kb-search-input');
      const categorySelect = document.getElementById('kb-search-category');
      const difficultySelect = document.getElementById('kb-search-difficulty');
      const sortSelect = document.getElementById('kb-search-sort');
      const status = document.getElementById('kb-search-status');
      const resultsRoot = document.getElementById('kb-search-results');

      if (input instanceof HTMLInputElement && categorySelect instanceof HTMLSelectElement && difficultySelect instanceof HTMLSelectElement && sortSelect instanceof HTMLSelectElement && status && resultsRoot) {
        let pagefind;
        let searchToken = 0;

        const renderEmpty = (message) => {
          resultsRoot.innerHTML = '';
          status.textContent = message;
        };

        const renderResults = (results) => {
          resultsRoot.innerHTML = '';

          for (const result of results) {
            const article = document.createElement('a');
            article.href = result.url;
            article.className = 'block rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-blue-300 hover:bg-blue-50/20';
            article.innerHTML = `
              <div class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">
                <span>${categoryLabels[result.meta.category] || result.meta.category || 'Article'}</span>
                <span>•</span>
                <span>${result.meta.publishedAt || ''}</span>
                <span>•</span>
                <span>${difficultyLabels[result.meta.difficulty] || result.meta.difficulty || ''}</span>
              </div>
              <h3 class="mt-3 text-xl font-semibold text-slate-900">${result.meta.title || result.url}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">${result.excerpt || result.meta.description || ''}</p>
            `;
            resultsRoot.appendChild(article);
          }
        };

        const applyFiltersAndSort = (results) => {
          const selectedCategory = categorySelect.value;
          const selectedDifficulty = difficultySelect.value;
          const sortMode = sortSelect.value;

          let filtered = results.filter((result) => {
            if (selectedCategory && result.meta.category !== selectedCategory) return false;
            if (selectedDifficulty && result.meta.difficulty !== selectedDifficulty) return false;
            return true;
          });

          if (sortMode === 'newest' || sortMode === 'oldest') {
            filtered = filtered.sort((a, b) => {
              const aDate = Date.parse(a.meta.publishedAt || '');
              const bDate = Date.parse(b.meta.publishedAt || '');
              return sortMode === 'newest' ? bDate - aDate : aDate - bDate;
            });
          }

          return filtered;
        };

        const runSearch = async (term) => {
          const currentToken = ++searchToken;

          if (!term.trim()) {
            renderEmpty('Type to search all knowledge base articles.');
            return;
          }

          status.textContent = 'Searching...';

          pagefind ||= await import('/pagefind/pagefind.js');
          const search = await pagefind.search(term, { limit: 12 });
          const hydratedResults = await Promise.all(search.results.map(async (result) => {
            const data = await result.data();
            return {
              url: data.url,
              excerpt: data.excerpt,
              meta: data.meta || {},
              raw: result,
            };
          }));

          if (currentToken !== searchToken) return;

          const processedResults = applyFiltersAndSort(hydratedResults);

          if (!processedResults.length) {
            renderEmpty(`No results for "${term}".`);
            return;
          }

          status.textContent = `${processedResults.length} result${processedResults.length === 1 ? '' : 's'} for "${term}"`;
          renderResults(processedResults);
        };

        const params = new URLSearchParams(window.location.search);
        const initialQuery = params.get('q') || '';
        if (initialQuery) {
          input.value = initialQuery;
          runSearch(initialQuery);
        }

        let debounce;
        input.addEventListener('input', () => {
          window.clearTimeout(debounce);
          debounce = window.setTimeout(() => runSearch(input.value), 180);
        });

        [categorySelect, difficultySelect, sortSelect].forEach((element) => {
          element.addEventListener('change', () => runSearch(input.value));
        });
      }
    </script>
  </div>
)}
